@{
    ViewData["Title"] = "Chọn loại tài khoản";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        background-image: url('https://haycafe.vn/wp-content/uploads/2022/03/Hinh-bat-tay-hop-tac.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        padding: 40px 0;
        position: relative;
    }

    .auth-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.85) 0%, rgba(5, 150, 105, 0.85) 100%);
        z-index: 0;
    }

    .auth-container .container {
        position: relative;
        z-index: 1;
    }

    .auth-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        border: none;
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }

    .auth-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 25px 70px rgba(0, 0, 0, 0.4);
    }

    .auth-card .card-body {
        padding: 40px 35px;
        text-align: center;
    }

    .auth-card.ung-vien {
        border-top: 5px solid #10b981;
    }

    .auth-card.nha-tuyen-dung {
        border-top: 5px solid #10b981;
    }

    .auth-title {
        color: #333;
        font-weight: 700;
        font-size: 24px;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .auth-title.ung-vien {
        color: #10b981;
    }

    .auth-title.nha-tuyen-dung {
        color: #10b981;
    }

    .auth-icon {
        font-size: 28px;
    }

    .user-info {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 30px;
        text-align: center;
    }

    .user-info p {
        margin: 5px 0;
        color: #555;
    }

    .user-info strong {
        color: #333;
    }

    .account-type-form {
        display: block;
        cursor: pointer;
    }

    .account-type-form input[type="radio"] {
        display: none;
    }

    .account-type-form input[type="radio"]:checked ~ .auth-card {
        border: 3px solid #10b981 !important;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.3) !important;
        transform: translateY(-5px);
    }
    
    .auth-card.selected {
        border: 3px solid #10b981 !important;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.3) !important;
        transform: translateY(-5px);
    }

    .btn-submit {
        background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        border: none;
        border-radius: 10px;
        padding: 14px 30px;
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        margin-top: 30px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
        background: linear-gradient(135deg, #059669 0%, #10b981 100%);
    }

    .btn-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

<div class="auth-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="text-center text-white mb-4">
                    <h1 class="mb-3"><i class="bi bi-person-check"></i> Chọn loại tài khoản</h1>
                    <p class="lead">Bạn đang đăng ký với Google. Vui lòng chọn loại tài khoản bạn muốn sử dụng:</p>
                </div>

                @if (ViewBag.Email != null)
                {
                    <div class="user-info mb-4">
                        <p><strong>Email:</strong> @ViewBag.Email</p>
                        @if (ViewBag.Name != null)
                        {
                            <p><strong>Tên:</strong> @ViewBag.Name</p>
                        }
                    </div>
                }

                <form asp-action="ChooseAccountType" method="post" id="chooseAccountForm">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="account-type-form" style="display: block; height: 100%;">
                                <input type="radio" name="loaiTaiKhoan" value="@Unicareer.Models.SD.Role_UngVien" />
                                <div class="card auth-card ung-vien" style="height: 100%;">
                                    <div class="card-body">
                                        <h2 class="auth-title ung-vien">
                                            <i class="bi bi-person-check auth-icon"></i>
                                            Ứng viên tìm việc
                                        </h2>
                                        <p class="text-muted mb-3">Tìm kiếm công việc phù hợp với bạn</p>
                                        <div class="mt-3">
                                            <i class="bi bi-check-circle-fill text-success" style="font-size: 20px; opacity: 0;"></i>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="account-type-form" style="display: block; height: 100%;">
                                <input type="radio" name="loaiTaiKhoan" value="@Unicareer.Models.SD.Role_NhaTuyenDung" />
                                <div class="card auth-card nha-tuyen-dung" style="height: 100%;">
                                    <div class="card-body">
                                        <h2 class="auth-title nha-tuyen-dung">
                                            <i class="bi bi-building auth-icon"></i>
                                            Nhà tuyển dụng
                                        </h2>
                                        <p class="text-muted mb-3">Đăng tin tuyển dụng và tìm ứng viên</p>
                                        <div class="mt-3">
                                            <i class="bi bi-check-circle-fill text-primary" style="font-size: 20px; opacity: 0;"></i>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-submit" id="submitBtn" disabled>
                            <i class="bi bi-check-circle"></i> Xác nhận
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Bật/tắt nút submit và hiển thị icon khi chọn loại tài khoản
        document.querySelectorAll('input[name="loaiTaiKhoan"]').forEach(radio => {
            radio.addEventListener('change', function() {
                document.getElementById('submitBtn').disabled = false;
                
                // Bỏ class selected và ẩn icon check cho tất cả card
                document.querySelectorAll('.auth-card').forEach(card => {
                    card.classList.remove('selected');
                    const icon = card.querySelector('.bi-check-circle-fill');
                    if (icon) {
                        icon.style.opacity = '0';
                    }
                });
                
                // Thêm class selected và hiển thị icon check cho card được chọn
                const selectedCard = this.closest('label').querySelector('.auth-card');
                if (selectedCard) {
                    selectedCard.classList.add('selected');
                    const selectedIcon = selectedCard.querySelector('.bi-check-circle-fill');
                    if (selectedIcon) {
                        selectedIcon.style.opacity = '1';
                    }
                }
            });
        });

        // Thêm sự kiện click cho card để chọn radio
        document.querySelectorAll('.auth-card').forEach(card => {
            card.addEventListener('click', function(e) {
                e.preventDefault();
                const label = this.closest('label');
                const radio = label.querySelector('input[type="radio"]');
                if (radio) {
                    radio.checked = true;
                    radio.dispatchEvent(new Event('change'));
                }
            });
        });
    </script>
}

