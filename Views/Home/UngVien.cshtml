@model List<Unicareer.Models.UngVien>
@{
    ViewData["Title"] = "Danh sách ứng viên";
    var danhSachTinhThanh = ViewBag.DanhSachTinhThanh as List<Unicareer.Models.Province> ?? new List<Unicareer.Models.Province>();
    var danhSachNganhNghe = ViewBag.DanhSachNganhNghe as List<Unicareer.Models.NganhNghe> ?? new List<Unicareer.Models.NganhNghe>();
    var trangThaiOptions = ViewBag.TrangThaiTimViecOptions as List<string> ?? new List<string>();
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
        --secondary-gradient: linear-gradient(135deg, #34d399 0%, #10b981 100%);
        --success-gradient: linear-gradient(135deg, #6ee7b7 0%, #10b981 100%);
        --accent-color: #10b981;
        --accent-dark: #059669;
        --text-primary: #2d3748;
        --text-secondary: #718096;
    }
    
    body {
        background: #f7fafc;
    }
    
    .hero-section {
        background: var(--primary-gradient);
        padding: 80px 0 60px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }
    
    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.3;
    }
    
    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        color: white;
    }
    
    .hero-content h1 {
        font-size: 48px;
        font-weight: 800;
        margin-bottom: 16px;
        text-shadow: 0 2px 20px rgba(0,0,0,0.1);
    }
    
    .hero-content p {
        font-size: 18px;
        opacity: 0.95;
    }
    
    .search-box {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 20px 25px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        position: relative;
        z-index: 1;
        margin-top: 30px;
    }
    
    .search-box .input-group-text {
        border: 2px solid #e2e8f0;
        border-right: 0;
        border-radius: 10px 0 0 10px;
        background: white;
    }
    
    .search-box .form-control {
        border: 2px solid #e2e8f0;
        border-left: 0;
        padding: 14px 20px;
        font-size: 15px;
        border-radius: 0;
    }
    
    .search-box .btn-search {
        background: var(--primary-gradient);
        color: white;
        border: none;
        padding: 14px 20px;
        border-radius: 0 10px 10px 0;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
    
    .search-box .btn-search:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 25px rgba(16, 185, 129, 0.5);
    }
    
    .filter-bar {
        background: white;
        padding: 20px 25px;
        border-radius: 16px;
        margin-bottom: 30px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 1px solid #e2e8f0;
    }
    
    .filter-bar select {
        border: 2px solid #e2e8f0;
        padding: 10px 15px;
        border-radius: 10px;
        font-size: 14px;
        transition: all 0.3s ease;
        cursor: pointer;
        background: white;
    }
    
    .filter-bar select:focus {
        border-color: var(--accent-color);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        outline: none;
    }
    
    .candidate-card {
        background: white;
        border: 2px solid transparent;
        border-radius: 20px;
        padding: 25px 30px;
        margin-bottom: 20px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        display: flex;
        align-items: flex-start;
        gap: 25px;
    }
    
    .candidate-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: var(--primary-gradient);
        opacity: 0.03;
        transition: all 0.4s ease;
    }
    
    .candidate-card:hover::before {
        left: 0;
    }
    
    .candidate-card:hover {
        border-color: var(--accent-color);
        box-shadow: 0 12px 40px rgba(16, 185, 129, 0.15);
        transform: translateY(-4px);
    }
    
    .candidate-avatar {
        width: 120px;
        height: 120px;
        min-width: 120px;
        max-width: 120px;
        min-height: 120px;
        max-height: 120px;
        background: var(--primary-gradient);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 40px;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);
        transition: all 0.3s ease;
        overflow: hidden;
        flex-shrink: 0;
        position: relative;
    }
    
    .candidate-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }
    
    .candidate-card:hover .candidate-avatar {
        transform: scale(1.05);
        box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    }
    
    .candidate-content {
        flex: 1;
        min-width: 0;
    }
    
    .candidate-name {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 12px;
        transition: color 0.3s ease;
    }
    
    .candidate-card:hover .candidate-name {
        color: var(--accent-color);
    }
    
    .candidate-info {
        color: var(--text-secondary);
        font-size: 14px;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .candidate-info i {
        color: var(--accent-color);
        font-size: 16px;
        width: 20px;
    }
    
    .candidate-info span {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    
    .candidate-info-multiline {
        color: var(--text-secondary);
        font-size: 13px;
        margin-bottom: 6px;
        line-height: 1.5;
    }
    
    .candidate-info-multiline-content {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .candidate-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
    }
    
    .candidate-main-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 8px 20px;
        margin-bottom: 12px;
    }
    
    /* Responsive Design */
    @@media (max-width: 768px) {
        .candidate-card {
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 20px;
        }
        
        .candidate-avatar {
            width: 100px;
            height: 100px;
            min-width: 100px;
            max-width: 100px;
            min-height: 100px;
            max-height: 100px;
            font-size: 36px;
        }
        
        .candidate-main-info {
            grid-template-columns: 1fr;
            gap: 8px;
        }
        
        .candidate-content {
            width: 100%;
        }
    }
    
    .badge-item {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(16, 185, 129, 0.1);
        color: var(--accent-color);
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }
    
    .badge-salary {
        background: #e8f8f5;
        color: #27ae60;
    }
    
    .badge-status {
        background: #d1ecf1;
        color: #0c5460;
    }
    
    .badge-specialty {
        background: #fff3cd;
        color: #856404;
    }
    
    .page-title {
        font-size: 32px;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 10px;
    }
    
    .candidate-count {
        background: var(--primary-gradient);
        color: white;
        padding: 4px 14px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
        box-shadow: 0 2px 10px rgba(16, 185, 129, 0.3);
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .candidate-card {
        animation: fadeInUp 0.6s ease backwards;
    }
    
    .candidate-card:nth-child(1) { animation-delay: 0.05s; }
    .candidate-card:nth-child(2) { animation-delay: 0.1s; }
    .candidate-card:nth-child(3) { animation-delay: 0.15s; }
    .candidate-card:nth-child(4) { animation-delay: 0.2s; }
    .candidate-card:nth-child(5) { animation-delay: 0.25s; }
    .candidate-card:nth-child(6) { animation-delay: 0.3s; }
    
    /* Quill Editor Display Styles */
    .quill-content {
        margin-top: 12px;
        padding: 12px 15px;
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 3px solid var(--accent-color);
    }
    
    .quill-content-title {
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 10px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .quill-content-title i {
        color: var(--accent-color);
        font-size: 16px;
    }
    
    .quill-content .ql-editor {
        padding: 0;
        font-size: 13px;
        color: var(--text-secondary);
        line-height: 1.6;
        max-height: 120px;
        overflow: hidden;
        position: relative;
    }
    
    .quill-content .ql-editor::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 30px;
        background: linear-gradient(to bottom, transparent, #f8f9fa);
        pointer-events: none;
    }
    
    .quill-content .ql-editor p {
        margin-bottom: 8px;
    }
    
    .quill-content .ql-editor ul,
    .quill-content .ql-editor ol {
        margin-bottom: 8px;
        padding-left: 20px;
    }
    
    .quill-content .ql-editor li {
        margin-bottom: 4px;
    }
    
    .quill-content .ql-editor strong {
        font-weight: 600;
        color: var(--text-primary);
    }
    
    .quill-content .ql-editor h1,
    .quill-content .ql-editor h2,
    .quill-content .ql-editor h3 {
        font-weight: 600;
        color: var(--text-primary);
        margin-top: 10px;
        margin-bottom: 8px;
    }
    
    .quill-content .ql-editor h1 { font-size: 16px; }
    .quill-content .ql-editor h2 { font-size: 15px; }
    .quill-content .ql-editor h3 { font-size: 14px; }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="container-fluid px-5">
        <div class="hero-content">
            <h1>Khám Phá Ứng Viên Tài Năng</h1>
            <p>Tìm kiếm và kết nối với những ứng viên tiềm năng phù hợp với công ty của bạn</p>
        </div>
        
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <form method="get" action="/Home/UngVien" class="search-box">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" class="form-control" 
                               name="keyword"
                               value="@ViewBag.Keyword"
                               placeholder="Tìm kiếm ứng viên theo tên, vị trí, kỹ năng...">
                        <button class="btn btn-search" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container-fluid px-5">
    <!-- Filter Bar -->
    <form method="get" action="/Home/UngVien" class="filter-bar">
        <input type="hidden" name="keyword" value="@ViewBag.Keyword">
        <div class="row g-3 align-items-center">
            <div class="col-auto">
                <strong style="color: var(--text-primary);">Lọc theo:</strong>
            </div>
            <div class="col-md-3">
                <select class="form-select form-select-sm" name="tinhThanh" id="filterTinhThanh">
                    <option value="">Tỉnh/Thành Phố</option>
                    @foreach (var tinh in danhSachTinhThanh)
                    {
                        <option value="@tinh.FullName" selected="@(ViewBag.TinhThanh == tinh.FullName)">@tinh.FullName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select form-select-sm" name="nganhNghe" id="filterNganhNghe">
                    <option value="">Ngành nghề</option>
                    @foreach (var nganhNghe in danhSachNganhNghe)
                    {
                        <option value="@nganhNghe.TenNganhNghe" selected="@(ViewBag.NganhNghe == nganhNghe.TenNganhNghe)">@nganhNghe.TenNganhNghe</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" name="trangThaiTimViec" id="filterTrangThai">
                    <option value="">Trạng thái</option>
                    @foreach (var trangThai in trangThaiOptions)
                    {
                        <option value="@trangThai" selected="@(ViewBag.TrangThaiTimViec == trangThai)">@trangThai</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" name="mucLuong" id="filterMucLuong">
                    <option value="">Mức lương</option>
                    <option value="Dưới 10 triệu" selected="@(ViewBag.MucLuong == "Dưới 10 triệu")">Dưới 10 triệu</option>
                    <option value="10-15 triệu" selected="@(ViewBag.MucLuong == "10-15 triệu")">10-15 triệu</option>
                    <option value="15-25 triệu" selected="@(ViewBag.MucLuong == "15-25 triệu")">15-25 triệu</option>
                    <option value="Trên 25 triệu" selected="@(ViewBag.MucLuong == "Trên 25 triệu")">Trên 25 triệu</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-sm w-100" style="background: var(--primary-gradient); color: white; border: none; border-radius: 10px; padding: 10px;">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
            </div>
        </div>
    </form>
    
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Unicareer</a></li>
            <li class="breadcrumb-item active" aria-current="page">Ứng viên</li>
        </ol>
    </nav>
    
    <!-- Candidate List -->
    <div class="mb-4">
        <h4 class="page-title">DANH SÁCH ỨNG VIÊN</h4>
        <p class="text-muted" style="font-size: 15px;">Có <span class="candidate-count" id="candidateCount">@Model.Count</span> ứng viên đang tìm việc trên Unicareer</p>
    </div>
    
    <div class="row" id="candidateList">
        @if (Model.Any())
        {
            @foreach (var ungVien in Model)
            {
                <div class="col-12">
                    <div class="candidate-card" onclick="window.location.href='@Url.Action("ChiTietUngVien", "Home", new { id = ungVien.MaUngVien })'">
                        <div class="candidate-avatar">
                            @if (!string.IsNullOrEmpty(ungVien.User?.Avatar))
                            {
                                <img src="@ungVien.User.Avatar" alt="@ungVien.HoTen">
                            }
                            else
                            {
                                @ungVien.HoTen.Substring(0, Math.Min(2, ungVien.HoTen.Length)).ToUpper()
                            }
                        </div>
                        <div class="candidate-content">
                            <h5 class="candidate-name">@ungVien.HoTen</h5>
                            <div class="candidate-main-info">
                                @if (!string.IsNullOrEmpty(ungVien.ViTriMongMuon))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-briefcase"></i>
                                        <span>@ungVien.ViTriMongMuon</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.NoiLamViecMongMuon))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-geo-alt"></i>
                                        <span>@ungVien.NoiLamViecMongMuon</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.Email))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-envelope"></i>
                                        <span>@ungVien.Email</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.SoDienThoai))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-telephone"></i>
                                        <span>@ungVien.SoDienThoai</span>
                                    </div>
                                }
                                @if (ungVien.NgaySinh != default(DateTime) && ungVien.NgaySinh.Year > 1900)
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-calendar"></i>
                                        <span>@ungVien.NgaySinh.ToString("dd/MM/yyyy")</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.GioiTinh))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-gender-ambiguous"></i>
                                        <span>@ungVien.GioiTinh</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.DiaChi))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-house"></i>
                                        <span>@ungVien.DiaChi</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.HocVan))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-mortarboard"></i>
                                        <span>@ungVien.HocVan</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.KinhNghiem))
                                {
                                    <div class="candidate-info">
                                        <i class="bi bi-briefcase-fill"></i>
                                        <span>@ungVien.KinhNghiem</span>
                                    </div>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(ungVien.KyNang))
                            {
                                <div class="candidate-info-multiline">
                                    <div style="display: flex; align-items: flex-start; gap: 8px;">
                                        <i class="bi bi-star" style="color: var(--accent-color); font-size: 16px; width: 20px; flex-shrink: 0; margin-top: 2px;"></i>
                                        <span class="candidate-info-multiline-content">@ungVien.KyNang</span>
                                    </div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(ungVien.MoTaBanThan))
                            {
                                <div class="quill-content" style="margin-top: 12px;">
                                    <div class="quill-content-title">
                                        <i class="bi bi-person-circle"></i>
                                        <span>Mô tả bản thân</span>
                                    </div>
                                    <div class="ql-editor">@Html.Raw(ungVien.MoTaBanThan)</div>
                                </div>
                            }
                            
                            <div class="candidate-badges">
                                @if (ungVien.MucLuongKyVong.HasValue)
                                {
                                    <span class="badge-item badge-salary">@ungVien.MucLuongKyVong.Value.ToString("N0") triệu</span>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.TrangThaiTimViec))
                                {
                                    <span class="badge-item badge-status">@ungVien.TrangThaiTimViec</span>
                                }
                                @if (ungVien.ChuyenNganh != null)
                                {
                                    <span class="badge-item badge-specialty">@ungVien.ChuyenNganh.TenChuyenNganh</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted" style="padding: 60px;">
                <i class="bi bi-people" style="font-size: 4rem; opacity: 0.3;"></i>
                <p class="mt-3" style="font-size: 18px;">Không tìm thấy ứng viên nào phù hợp</p>
                <p class="text-muted">Thử thay đổi các bộ lọc tìm kiếm</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <!-- Quill Editor CSS for displaying content -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    
    <script>
        $(document).ready(function() {
            // Auto submit form when filters change
            $('#filterTinhThanh, #filterNganhNghe, #filterTrangThai, #filterMucLuong').on('change', function() {
                $(this).closest('form').submit();
            });
        });
    </script>
}

