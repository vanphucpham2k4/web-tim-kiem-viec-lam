@model Unicareer.Models.UngVien
@{
    ViewData["Title"] = "Chi tiết ứng viên";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
        --accent-color: #10b981;
        --text-primary: #2d3748;
        --text-secondary: #718096;
    }

    body {
        background: #f7fafc;
    }

    .profile-header {
        background: var(--primary-gradient);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
        position: relative;
        overflow: hidden;
    }

    .profile-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.3;
    }

    .profile-header-content {
        position: relative;
        z-index: 1;
    }

    .profile-avatar {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 48px;
        margin-bottom: 20px;
        border: 4px solid rgba(255, 255, 255, 0.3);
        overflow: hidden;
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    .info-section {
        background: white;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        border: 1px solid #e9ecef;
    }

    .info-section h4 {
        color: var(--text-primary);
        font-weight: 600;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 3px solid var(--accent-color);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-row {
        display: flex;
        padding: 15px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        font-weight: 600;
        color: var(--text-primary);
        width: 200px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-label i {
        color: var(--accent-color);
        width: 20px;
    }

    .info-value {
        flex: 1;
        color: var(--text-secondary);
        word-break: break-word;
    }

    .info-value a {
        color: var(--accent-color);
        text-decoration: none;
    }

    .info-value a:hover {
        text-decoration: underline;
    }

    .badge-custom {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        margin-right: 8px;
        margin-bottom: 8px;
    }

    .badge-salary {
        background: #e8f8f5;
        color: #27ae60;
    }

    .badge-status {
        background: #d1ecf1;
        color: #0c5460;
    }

    .badge-specialty {
        background: #fff3cd;
        color: #856404;
    }

    .content-box {
        background: #f9fafb;
        border-radius: 12px;
        padding: 20px;
        margin-top: 10px;
        border-left: 4px solid var(--accent-color);
        line-height: 1.8;
        color: var(--text-secondary);
    }

    .content-box p {
        margin-bottom: 10px;
    }

    .content-box p:last-child {
        margin-bottom: 0;
    }

    .btn-back {
        background: white;
        color: var(--accent-color);
        border: 2px solid var(--accent-color);
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-back:hover {
        background: var(--accent-color);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

    .link-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent-color);
        text-decoration: none;
        margin-right: 20px;
        margin-bottom: 10px;
        padding: 8px 16px;
        background: #f0fdf4;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .link-item:hover {
        background: var(--accent-color);
        color: white;
        transform: translateY(-2px);
    }
</style>

<div class="container-fluid px-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Unicareer</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("UngVien", "Home")">Ứng viên</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết ứng viên</li>
        </ol>
    </nav>

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-header-content">
            <div class="d-flex align-items-center gap-4">
                <div class="profile-avatar">
                    @if (!string.IsNullOrEmpty(Model.User?.Avatar))
                    {
                        <img src="@Model.User.Avatar" alt="@Model.HoTen">
                    }
                    else
                    {
                        @Model.HoTen.Substring(0, Math.Min(2, Model.HoTen.Length)).ToUpper()
                    }
                </div>
                <div>
                    <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 10px;">@Model.HoTen</h1>
                    @if (!string.IsNullOrEmpty(Model.ViTriMongMuon))
                    {
                        <p style="font-size: 1.2rem; opacity: 0.95; margin-bottom: 15px;">
                            <i class="bi bi-briefcase"></i> @Model.ViTriMongMuon
                        </p>
                    }
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.MucLuongKyVong.HasValue)
                        {
                            <span class="badge-custom badge-salary">
                                <i class="bi bi-cash"></i> @Model.MucLuongKyVong.Value.ToString("N0") triệu VNĐ
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Model.TrangThaiTimViec))
                        {
                            <span class="badge-custom badge-status">
                                <i class="bi bi-info-circle"></i> @Model.TrangThaiTimViec
                            </span>
                        }
                        @if (Model.ChuyenNganh != null)
                        {
                            <span class="badge-custom badge-specialty">
                                <i class="bi bi-book"></i> @Model.ChuyenNganh.TenChuyenNganh
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Thông tin cơ bản -->
            <div class="info-section">
                <h4><i class="bi bi-person"></i> Thông tin cơ bản</h4>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-envelope"></i> Email</div>
                        <div class="info-value">
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.SoDienThoai))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-telephone"></i> Số điện thoại</div>
                        <div class="info-value">
                            <a href="tel:@Model.SoDienThoai">@Model.SoDienThoai</a>
                        </div>
                    </div>
                }
                @if (Model.NgaySinh != default(DateTime) && Model.NgaySinh.Year > 1900)
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-calendar"></i> Ngày sinh</div>
                        <div class="info-value">@Model.NgaySinh.ToString("dd/MM/yyyy")</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.GioiTinh))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-gender-ambiguous"></i> Giới tính</div>
                        <div class="info-value">@Model.GioiTinh</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.DiaChi))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-house"></i> Địa chỉ</div>
                        <div class="info-value">@Model.DiaChi</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.HocVan))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-mortarboard"></i> Học vấn</div>
                        <div class="info-value">@Model.HocVan</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.KinhNghiem))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-briefcase-fill"></i> Kinh nghiệm</div>
                        <div class="info-value">@Model.KinhNghiem</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.KyNang))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-star"></i> Kỹ năng</div>
                        <div class="info-value">@Model.KyNang</div>
                    </div>
                }
            </div>

            <!-- Thông tin nghề nghiệp -->
            <div class="info-section">
                <h4><i class="bi bi-briefcase"></i> Thông tin nghề nghiệp</h4>
                @if (!string.IsNullOrEmpty(Model.ViTriMongMuon))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-briefcase"></i> Vị trí mong muốn</div>
                        <div class="info-value">@Model.ViTriMongMuon</div>
                    </div>
                }
                @if (Model.ChuyenNganh != null)
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-book"></i> Chuyên ngành</div>
                        <div class="info-value">
                            @Model.ChuyenNganh.TenChuyenNganh
                            @if (Model.ChuyenNganh.NganhNghe != null)
                            {
                                <span class="text-muted"> - @Model.ChuyenNganh.NganhNghe.TenNganhNghe</span>
                            }
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.ChuyenNganhKhac))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-bookmark"></i> Chuyên ngành khác</div>
                        <div class="info-value">@Model.ChuyenNganhKhac</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.NoiLamViecMongMuon))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-geo-alt"></i> Nơi làm việc mong muốn</div>
                        <div class="info-value">@Model.NoiLamViecMongMuon</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.TrangThaiTimViec))
                {
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-info-circle"></i> Trạng thái tìm việc</div>
                        <div class="info-value">@Model.TrangThaiTimViec</div>
                    </div>
                }
            </div>

            <!-- CV và hồ sơ -->
            @if (!string.IsNullOrEmpty(Model.MucTieuNgheNghiep) || 
                 !string.IsNullOrEmpty(Model.HocVanChiTiet) || 
                 !string.IsNullOrEmpty(Model.KinhNghiemChiTiet) || 
                 !string.IsNullOrEmpty(Model.KyNangChiTiet) || 
                 !string.IsNullOrEmpty(Model.ChungChi) ||
                 !string.IsNullOrEmpty(Model.CVFile))
            {
                <div class="info-section">
                    <h4><i class="bi bi-file-earmark-person"></i> CV và hồ sơ cá nhân</h4>
                    
                    @if (!string.IsNullOrEmpty(Model.CVFile))
                    {
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-file-earmark-pdf"></i> CV</div>
                            <div class="info-value">
                                <a href="@Model.CVFile" target="_blank" class="link-item">
                                    <i class="bi bi-download"></i> Tải xuống CV
                                </a>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.MucTieuNgheNghiep))
                    {
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-bullseye"></i> Mục tiêu nghề nghiệp</div>
                            <div class="info-value">
                                <div class="content-box">
                                    @Html.Raw(Model.MucTieuNgheNghiep)
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.HocVanChiTiet))
                    {
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-mortarboard"></i> Học vấn (chi tiết)</div>
                            <div class="info-value">
                                <div class="content-box">
                                    @Html.Raw(Model.HocVanChiTiet)
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.KinhNghiemChiTiet))
                    {
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-briefcase-fill"></i> Kinh nghiệm làm việc (chi tiết)</div>
                            <div class="info-value">
                                <div class="content-box">
                                    @Html.Raw(Model.KinhNghiemChiTiet)
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.KyNangChiTiet))
                    {
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-star"></i> Kỹ năng (chi tiết)</div>
                            <div class="info-value">
                                <div class="content-box">
                                    @Html.Raw(Model.KyNangChiTiet)
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ChungChi))
                    {
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-award"></i> Chứng chỉ</div>
                            <div class="info-value">
                                <div class="content-box">
                                    @Html.Raw(Model.ChungChi)
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Portfolio -->
            @if (!string.IsNullOrEmpty(Model.LinkGitHub) || 
                 !string.IsNullOrEmpty(Model.LinkBehance) || 
                 !string.IsNullOrEmpty(Model.LinkPortfolio))
            {
                <div class="info-section">
                    <h4><i class="bi bi-link-45deg"></i> Portfolio / Dự án thực tế</h4>
                    <div class="info-row">
                        <div class="info-label"><i class="bi bi-link-45deg"></i> Liên kết</div>
                        <div class="info-value">
                            @if (!string.IsNullOrEmpty(Model.LinkGitHub))
                            {
                                <a href="@Model.LinkGitHub" target="_blank" class="link-item">
                                    <i class="bi bi-github"></i> GitHub
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.LinkBehance))
                            {
                                <a href="@Model.LinkBehance" target="_blank" class="link-item">
                                    <i class="bi bi-behance"></i> Behance
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.LinkPortfolio))
                            {
                                <a href="@Model.LinkPortfolio" target="_blank" class="link-item">
                                    <i class="bi bi-globe"></i> Portfolio
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Mô tả bản thân -->
            @if (!string.IsNullOrEmpty(Model.MoTaBanThan))
            {
                <div class="info-section">
                    <h4><i class="bi bi-chat-quote"></i> Mô tả bản thân</h4>
                    <div class="content-box">
                        @Html.Raw(Model.MoTaBanThan)
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <!-- Thông tin liên hệ nhanh -->
            <div class="info-section" style="position: sticky; top: 20px;">
                <h4><i class="bi bi-telephone"></i> Liên hệ</h4>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="mb-3">
                        <a href="mailto:@Model.Email" class="btn btn-primary w-100" style="background: var(--primary-gradient); border: none;">
                            <i class="bi bi-envelope"></i> Gửi email
                        </a>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.SoDienThoai))
                {
                    <div class="mb-3">
                        <a href="tel:@Model.SoDienThoai" class="btn btn-success w-100">
                            <i class="bi bi-telephone"></i> Gọi điện
                        </a>
                    </div>
                }
                <div class="mb-3">
                    <a href="@Url.Action("UngVien", "Home")" class="btn-back w-100 text-center">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

