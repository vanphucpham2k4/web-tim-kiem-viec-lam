@model Unicareer.Models.NhaTuyenDung
@using System.Text.Json
@using Microsoft.AspNetCore.Identity
@inject UserManager<Unicareer.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.TenCongTy;
    var danhSachViecLam = ViewBag.DanhSachViecLam as List<Unicareer.Models.TinTuyenDung>;
    var danhSachDanhGia = ViewBag.DanhSachDanhGia as List<Unicareer.Models.DanhGiaCongTy> ?? new List<Unicareer.Models.DanhGiaCongTy>();
    var trustScore = ViewBag.TrustScore as double? ?? 0.0;
    var reviewPage = ViewBag.ReviewPage as int? ?? 1;
    var reviewPageSize = ViewBag.ReviewPageSize as int? ?? 10;
    var totalReviews = ViewBag.TotalReviews as int? ?? 0;
    var totalReviewPages = ViewBag.TotalReviewPages as int? ?? 1;
    var danhSachDaLike = ViewBag.DanhSachDaLike as HashSet<int> ?? new HashSet<int>();
    var currentUserId = ViewBag.CurrentUserId as string;
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
        --secondary-gradient: linear-gradient(135deg, #34d399 0%, #10b981 100%);
        --success-gradient: linear-gradient(135deg, #6ee7b7 0%, #10b981 100%);
        --accent-color: #10b981;
        --accent-dark: #059669;
        --text-primary: #2d3748;
        --text-secondary: #718096;
    }
    
    body {
        background: #f7fafc;
    }
    
    .company-header {
        background: white;
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid #e2e8f0;
    }
    
    .company-logo-large {
        width: 120px;
        height: 120px;
        min-width: 120px;
        max-width: 120px;
        min-height: 120px;
        max-height: 120px;
        background: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: var(--accent-color);
        font-size: 48px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        flex-shrink: 0;
        position: relative;
    }
    
    .company-logo-large img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 24px;
        display: block;
        flex-shrink: 0;
    }
    
    .company-title {
        font-size: 36px;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 12px;
    }
    
    .company-meta {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
        margin-top: 20px;
    }
    
    .meta-item {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-secondary);
        font-size: 15px;
        font-weight: 500;
    }
    
    .meta-item i {
        color: var(--accent-color);
        font-size: 20px;
    }
    
    .company-stats-large {
        display: flex;
        gap: 30px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 2px solid #e2e8f0;
    }
    
    .stat-card {
        flex: 1;
        text-align: center;
        padding: 20px;
        background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
        border-radius: 16px;
        transition: all 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(16, 185, 129, 0.15);
    }
    
    .stat-card .number {
        font-size: 32px;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 8px;
    }
    
    .stat-card .label {
        font-size: 14px;
        color: var(--text-secondary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .section-card {
        background: white;
        border-radius: 20px;
        padding: 35px;
        margin-bottom: 30px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 1px solid #e2e8f0;
    }
    
    .vibe-stat-card {
        padding: 20px;
        border-radius: 12px;
        text-align: center;
        transition: all 0.3s ease;
    }
    
    .vibe-stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }
    
    .section-title {
        font-size: 24px;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .section-title i {
        font-size: 28px;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    
    .company-description {
        color: var(--text-secondary);
        font-size: 15px;
        line-height: 1.8;
    }
    
    .company-description h5 {
        color: var(--text-primary);
        font-weight: 700;
        margin-top: 20px;
        margin-bottom: 12px;
        font-size: 18px;
    }
    
    .company-description ul {
        padding-left: 20px;
    }
    
    .company-description ul li {
        margin-bottom: 8px;
    }
    
    .job-card {
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    
    .job-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: var(--primary-gradient);
        opacity: 0.03;
        transition: all 0.4s ease;
    }
    
    .job-card:hover::before {
        left: 0;
    }
    
    .job-card:hover {
        border-color: var(--accent-color);
        box-shadow: 0 12px 40px rgba(102, 126, 234, 0.15);
        transform: translateY(-4px);
    }
    
    .job-title {
        font-size: 19px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 12px;
        transition: color 0.3s ease;
    }
    
    .job-card:hover .job-title {
        color: var(--accent-color);
    }
    
    .job-meta {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        font-size: 14px;
        color: var(--text-secondary);
        font-weight: 500;
    }
    
    .job-meta span {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    
    .job-meta i {
        color: var(--accent-color);
        font-size: 16px;
    }
    
    .badge-hot {
        background: var(--secondary-gradient);
        color: white;
        padding: 6px 16px;
        border-radius: 25px;
        font-size: 12px;
        font-weight: 700;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        position: absolute;
        top: 20px;
        right: 20px;
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 20px;
    }
    
    .info-item {
        padding: 16px;
        background: #f7fafc;
        border-radius: 12px;
        border-left: 4px solid var(--accent-color);
    }
    
    .info-label {
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }
    
    .info-value {
        font-size: 15px;
        color: var(--text-primary);
        font-weight: 700;
    }
    
    .no-jobs {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-secondary);
    }
    
    .no-jobs i {
        font-size: 64px;
        color: #e2e8f0;
        margin-bottom: 20px;
    }
    
    .breadcrumb {
        background: transparent;
        padding: 15px 0;
        margin: 0;
        font-size: 14px;
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .job-card {
        animation: fadeInUp 0.5s ease backwards;
    }
    
    .job-card:nth-child(1) { animation-delay: 0.05s; }
    .job-card:nth-child(2) { animation-delay: 0.1s; }
    .job-card:nth-child(3) { animation-delay: 0.15s; }
    .job-card:nth-child(4) { animation-delay: 0.2s; }
    .job-card:nth-child(5) { animation-delay: 0.25s; }
    
    /* Pagination Styles */
    .pagination {
        gap: 5px;
    }
    
    .pagination .page-link {
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        color: var(--text-primary);
        padding: 10px 16px;
        font-weight: 500;
        transition: all 0.3s ease;
        min-width: 44px;
        text-align: center;
    }
    
    .pagination .page-link:hover {
        background: var(--primary-gradient);
        color: white;
        border-color: var(--accent-color);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }
    
    .pagination .page-item.active .page-link {
        background: var(--primary-gradient);
        border-color: var(--accent-color);
        color: white;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }
    
    .pagination .page-item.disabled .page-link {
        background: #f7fafc;
        color: #cbd5e0;
        border-color: #e2e8f0;
        cursor: not-allowed;
        opacity: 0.6;
    }
    
    .pagination .page-item.disabled .page-link:hover {
        transform: none;
        box-shadow: none;
    }
    
    @@media (max-width: 576px) {
        .pagination .page-link {
            padding: 8px 12px;
            font-size: 0.9rem;
            min-width: 38px;
        }
    }
</style>

@Html.AntiForgeryToken()

<div class="container-fluid px-5 py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Unicareer</a></li>
            <li class="breadcrumb-item"><a href="/Home/CongTy">Công ty</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenCongTy</li>
        </ol>
    </nav>
    
    <!-- Company Header -->
    <div class="company-header">
        <div class="row align-items-center">
            <div class="col-auto">
                    @if (!string.IsNullOrEmpty(Model.Logo))
                    {
                        <div class="company-logo-large">
                            <img src="@Model.Logo" alt="@Model.TenCongTy">
                        </div>
                    }
                    else
                    {
                        <div class="company-logo-large">
                            @Model.TenCongTy.Substring(0, 1)
                        </div>
                    }
            </div>
            <div class="col">
                <h1 class="company-title">@Model.TenCongTy</h1>
                <div class="company-meta">
                    <div class="meta-item">
                        <i class="bi bi-briefcase-fill"></i>
                        <span>@Model.LinhVuc</span>
                    </div>
                    <div class="meta-item">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span>@Model.TinhThanhPho, @Model.QuanHuyen</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Website))
                    {
                        <div class="meta-item">
                            <i class="bi bi-globe"></i>
                            <a href="@Model.Website" target="_blank" style="color: var(--accent-color); text-decoration: none; font-weight: 600;">
                                Website
                            </a>
                        </div>
                    }
                </div>
                
                <div class="company-stats-large">
                    <div class="stat-card">
                        <div class="number">@ViewBag.SoTinDaDang</div>
                        <div class="label">Vị trí tuyển dụng</div>
                    </div>
                    <div class="stat-card">
                        <div class="number">@ViewBag.SoUngVienNhan</div>
                        <div class="label">Đơn ứng tuyển</div>
                    </div>
                    <div class="stat-card">
                        <div class="number">@ViewBag.SoThangThamGia</div>
                        <div class="label">Tháng trên Unicareer</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <!-- Left Column -->
        <div class="col-lg-8">
            <!-- Company Description -->
            <div class="section-card">
                <h2 class="section-title">
                    <i class="bi bi-info-circle-fill"></i>
                    Giới thiệu về công ty
                </h2>
                <div class="company-description">
                    @Html.Raw(Model.MoTa)
                </div>
            </div>
            
            <!-- Employer Vibe Check -->
            <div class="section-card">
                <h2 class="section-title">
                    <i class="bi bi-star-fill"></i>
                    Employer Vibe Check
                </h2>
                
                <!-- Dashboard tổng quan - Luôn hiển thị -->
                <div class="row mb-4 justify-content-center">
                    <div class="col-md-5 mb-3">
                        <div class="vibe-stat-card" style="background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); border-left: 4px solid #10b981;">
                            <div class="vibe-stat-number" style="font-size: 2.5rem; font-weight: 800; color: #10b981;">
                                @if (totalReviews > 0)
                                {
                                    @trustScore.ToString("0.0")
                                }
                                else
                                {
                                    <span>--</span>
                                }
                            </div>
                            <div class="vibe-stat-label" style="color: #059669; font-weight: 600; margin-top: 5px;">
                                Trust Score / 5.0
                            </div>
                        </div>
                    </div>
                    <div class="col-md-5 mb-3">
                        <div class="vibe-stat-card" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-left: 4px solid #f59e0b;">
                            <div class="vibe-stat-number" style="font-size: 2.5rem; font-weight: 800; color: #f59e0b;">
                                @totalReviews
                            </div>
                            <div class="vibe-stat-label" style="color: #d97706; font-weight: 600; margin-top: 5px;">
                                Đánh giá
                            </div>
                        </div>
                    </div>
                </div>
                
                @if (danhSachDanhGia.Any())
                {
                    <!-- Danh sách Review -->
                    <div class="reviews-section">
                        <h5 class="mb-3" style="font-weight: 700; color: #2d3748;">
                            <i class="bi bi-chat-left-text"></i> Đánh giá từ ứng viên
                        </h5>
                        
                        @foreach (var review in danhSachDanhGia)
                        {
                            var tags = new List<string>();
                            if (!string.IsNullOrEmpty(review.Tags))
                            {
                                try
                                {
                                    tags = JsonSerializer.Deserialize<List<string>>(review.Tags) ?? new List<string>();
                                }
                                catch
                                {
                                    tags = new List<string>();
                                }
                            }
                            
                            var reviewId = ViewBag.ReviewId as int?;
                            var isHighlighted = reviewId.HasValue && review.MaDanhGia == reviewId.Value;
                            var reviewCardStyle = isHighlighted 
                                ? "background: #fff4e6; border-radius: 12px; padding: 20px; border: 3px solid #f59e0b; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);" 
                                : "background: #f9fafb; border-radius: 12px; padding: 20px; border: 1px solid #e5e7eb;";
                            
                            <div id="review-@review.MaDanhGia" class="review-card mb-3" style="@reviewCardStyle">
                                <div class="d-flex align-items-start gap-3 mb-3">
                                    <div class="review-avatar" style="width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, #10b981 0%, #059669 100%); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0;">
                                        @if (review.IsAnDanh)
                                        {
                                            <span>🤖</span>
                                        }
                                        else
                                        {
                                            <span>👤</span>
                                        }
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <strong style="color: #2d3748;">
                                                    @if (review.IsAnDanh)
                                                    {
                                                        <span>Ứng viên ẩn danh</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@(review.User?.HoTen ?? "Ứng viên")</span>
                                                    }
                                                </strong>
                                                <div class="text-muted" style="font-size: 0.85rem;">
                                                    @review.NgayTao.ToString("dd/MM/yyyy")
                                                </div>
                                            </div>
                                            <div class="review-ratings" style="text-align: right;">
                                                <div style="font-size: 0.85rem; color: #6b7280;">
                                                    💰 @review.DiemMinhBachLuong/5 | ⚡ @review.DiemTocDoPhanHoi/5 | 🤝 @review.DiemTonTrongUngVien/5
                                                </div>
                                            </div>
                                        </div>
                                        
                                        @if (tags.Any())
                                        {
                                            <div class="mb-2">
                                                @foreach (var tag in tags)
                                                {
                                                    if (tag.Contains("🚩"))
                                                    {
                                                        <span class="badge bg-danger me-1 mb-1">@tag</span>
                                                    }
                                                    else if (tag.Contains("✅"))
                                                    {
                                                        <span class="badge bg-success me-1 mb-1">@tag</span>
                                                    }
                                                }
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrEmpty(review.NoiDung))
                                        {
                                            <div class="review-content" style="color: #374151; line-height: 1.6;">
                                                @review.NoiDung
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrEmpty(review.PhanHoi))
                                        {
                                            <div class="mt-3 p-3" style="background: #eff6ff; border-radius: 8px; border-left: 3px solid #3b82f6;">
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <i class="bi bi-check-circle-fill text-primary"></i>
                                                    <strong style="color: #1e40af;">Phản hồi từ công ty</strong>
                                                    @if (review.NgayPhanHoi.HasValue)
                                                    {
                                                        <span class="text-muted" style="font-size: 0.85rem;">@review.NgayPhanHoi.Value.ToString("dd/MM/yyyy")</span>
                                                    }
                                                </div>
                                                <div style="color: #1e40af;">
                                                    @review.PhanHoi
                                                </div>
                                            </div>
                                        }
                                        
                                        @{
                                            var isOwner = currentUserId != null && review.UserId == currentUserId;
                                            var hasLiked = currentUserId != null && danhSachDaLike.Contains(review.MaDanhGia);
                                            var canLike = currentUserId != null && !isOwner && !hasLiked;
                                        }
                                        @if (canLike)
                                        {
                                            <div class="mt-2">
                                                <button class="btn btn-sm btn-outline-primary" onclick="tangLuotThich(@review.MaDanhGia)">
                                                    <i class="bi bi-heart"></i> Hữu ích (@review.SoLuotThich)
                                                </button>
                                            </div>
                                        }
                                        else if (hasLiked)
                                        {
                                            <div class="mt-2">
                                                <button class="btn btn-sm btn-primary" disabled>
                                                    <i class="bi bi-heart-fill"></i> Đã thích (@review.SoLuotThich)
                                                </button>
                                            </div>
                                        }
                                        else if (isOwner)
                                        {
                                            <div class="mt-2">
                                                <span class="text-muted" style="font-size: 0.9rem;">
                                                    <i class="bi bi-heart"></i> Hữu ích (@review.SoLuotThich)
                                                </span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mt-2">
                                                <span class="text-muted" style="font-size: 0.9rem;">
                                                    <i class="bi bi-heart"></i> Hữu ích (@review.SoLuotThich)
                                                </span>
                                                <small class="d-block text-muted mt-1">Vui lòng đăng nhập để thích đánh giá</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        
                        <!-- Pagination cho Reviews -->
                        @if (totalReviewPages > 1)
                        {
                            <nav aria-label="Review pagination" class="mt-4">
                                <ul class="pagination justify-content-center flex-wrap">
                                    @if (reviewPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?id=@Model.MaNhaTuyenDung&reviewPage=@(reviewPage - 1)" aria-label="Trước">
                                                <i class="bi bi-chevron-left"></i> Trước
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link" aria-label="Trước">
                                                <i class="bi bi-chevron-left"></i> Trước
                                            </span>
                                        </li>
                                    }
                                    
                                    @{
                                        int startPage = Math.Max(1, reviewPage - 2);
                                        int endPage = Math.Min(totalReviewPages, reviewPage + 2);
                                        
                                        // Hiển thị trang đầu nếu không liền kề
                                        if (startPage > 1)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" href="?id=@Model.MaNhaTuyenDung&reviewPage=1">1</a>
                                            </li>
                                            @if (startPage > 2)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                        }
                                        
                                        // Hiển thị các trang trong khoảng
                                        @for (int i = startPage; i <= endPage; i++)
                                        {
                                            <li class="page-item @(i == reviewPage ? "active" : "")">
                                                <a class="page-link" href="?id=@Model.MaNhaTuyenDung&reviewPage=@i">@i</a>
                                            </li>
                                        }
                                        
                                        // Hiển thị trang cuối nếu không liền kề
                                        if (endPage < totalReviewPages)
                                        {
                                            @if (endPage < totalReviewPages - 1)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">...</span>
                                                </li>
                                            }
                                            <li class="page-item">
                                                <a class="page-link" href="?id=@Model.MaNhaTuyenDung&reviewPage=@totalReviewPages">@totalReviewPages</a>
                                            </li>
                                        }
                                    }
                                    
                                    @if (reviewPage < totalReviewPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?id=@Model.MaNhaTuyenDung&reviewPage=@(reviewPage + 1)" aria-label="Sau">
                                                Sau <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link" aria-label="Sau">
                                                Sau <i class="bi bi-chevron-right"></i>
                                            </span>
                                        </li>
                                    }
                                </ul>
                                <div class="text-center mt-2 text-muted" style="font-size: 0.9rem;">
                                    Trang @reviewPage / @totalReviewPages (@totalReviews đánh giá)
                                </div>
                            </nav>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5" style="color: #9ca3af;">
                        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                        <p class="mt-3">Chưa có đánh giá nào</p>
                    </div>
                }
            </div>
            
            <!-- Jobs -->
            <div class="section-card">
                <h2 class="section-title">
                    <i class="bi bi-briefcase-fill"></i>
                    Các vị trí đang tuyển dụng (@(danhSachViecLam?.Count ?? 0))
                </h2>
                
                @if (danhSachViecLam != null && danhSachViecLam.Any())
                {
                    foreach (var job in danhSachViecLam)
                    {
                        var mucLuongDisplay = job.MucLuongThapNhat == 0 && job.MucLuongCaoNhat == 0 ? "Thỏa thuận" : $"{job.MucLuongThapNhat}-{job.MucLuongCaoNhat} triệu";
                        <a href="/Home/ChiTietViecLam/@job.MaTinTuyenDung" class="text-decoration-none" style="color: inherit;">
                            <div class="job-card">
                                @if (job.SoLuongUngTuyen > 50)
                                {
                                    <span class="badge-hot">Hot</span>
                                }
                                <h5 class="job-title">@job.TenViecLam</h5>
                                <div class="job-meta">
                                    <span><i class="bi bi-cash"></i> @mucLuongDisplay</span>
                                    <span><i class="bi bi-geo-alt"></i> @job.TinhThanhPho</span>
                                    <span><i class="bi bi-clock"></i> @job.LoaiCongViec</span>
                                    <span><i class="bi bi-calendar-check"></i> Hạn nộp: @job.HanNop.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="no-jobs">
                        <i class="bi bi-inbox"></i>
                        <p style="font-size: 16px; margin-top: 15px;">Công ty hiện không có vị trí tuyển dụng nào</p>
                    </div>
                }
            </div>
        </div>
        
        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Contact Info -->
            <div class="section-card">
                <h2 class="section-title" style="font-size: 20px;">
                    <i class="bi bi-telephone-fill"></i>
                    Thông tin liên hệ
                </h2>
                
                <div class="info-grid" style="grid-template-columns: 1fr;">
                    <div class="info-item">
                        <div class="info-label">Người liên hệ</div>
                        <div class="info-value">@Model.NguoiDaiDien</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Chức vụ</div>
                        <div class="info-value">@Model.ChucVu</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Email</div>
                        <div class="info-value" style="word-break: break-all;">@Model.Email</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Số điện thoại</div>
                        <div class="info-value">@Model.SoDienThoai</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Địa chỉ</div>
                        <div class="info-value">@Model.DiaChi</div>
                    </div>
                </div>
            </div>
            
            <!-- Quick Stats -->
            <div class="section-card">
                <h2 class="section-title" style="font-size: 20px;">
                    <i class="bi bi-bar-chart-fill"></i>
                    Thống kê
                </h2>
                
                <div style="margin-top: 20px;">
                    <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: var(--text-secondary); font-weight: 600;">Vị trí tuyển dụng</span>
                            <span style="font-size: 24px; font-weight: 800; color: var(--accent-color);">@ViewBag.SoTinDaDang</span>
                        </div>
                    </div>
                    <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: var(--text-secondary); font-weight: 600;">Đơn ứng tuyển</span>
                            <span style="font-size: 24px; font-weight: 800; color: var(--accent-color);">@ViewBag.SoUngVienNhan</span>
                        </div>
                    </div>
                    <div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: var(--text-secondary); font-weight: 600;">Ngày tham gia</span>
                            <span style="font-size: 16px; font-weight: 700; color: var(--text-primary);">@Model.NgayDangKy.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function tangLuotThich(maDanhGia) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            var formData = new FormData();
            formData.append('maDanhGia', maDanhGia);
            formData.append('__RequestVerificationToken', token);
            
            fetch('/Candidate/DanhGiaCongTy/TangLuotThich?maDanhGia=' + maDanhGia, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Có lỗi xảy ra');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi thích đánh giá');
            });
        }
        
        // Scroll đến đánh giá khi có reviewId trong URL
        $(document).ready(function() {
            var urlParams = new URLSearchParams(window.location.search);
            var reviewId = urlParams.get('reviewId');
            if (reviewId) {
                // Đợi một chút để đảm bảo trang đã load xong
                setTimeout(function() {
                    var reviewElement = document.getElementById('review-' + reviewId);
                    if (reviewElement) {
                        // Scroll đến đánh giá với offset để không bị che bởi header
                        var offset = 100;
                        var elementPosition = reviewElement.getBoundingClientRect().top;
                        var offsetPosition = elementPosition + window.pageYOffset - offset;
                        
                        window.scrollTo({
                            top: offsetPosition,
                            behavior: 'smooth'
                        });
                        
                        // Highlight đánh giá bằng animation
                        reviewElement.style.transition = 'all 0.3s ease';
                        reviewElement.style.animation = 'pulse 2s ease-in-out';
                    }
                }, 500);
            }
        });
    </script>
    
    <style>
        @@keyframes pulse {
            0%, 100% {
                box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
            }
            50% {
                box-shadow: 0 4px 25px rgba(245, 158, 11, 0.6);
            }
        }
    </style>
}

