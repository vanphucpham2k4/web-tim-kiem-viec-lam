@{
    ViewData["Title"] = "Tìm Kiếm Việc Làm";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f5f5f5;
    }
    /* Banner Section */
    .banner-section {
        position: relative;
        height: 400px;
        overflow: hidden;
        background: linear-gradient(135deg, #1e8449, #27ae60);
    }
    .banner-slider {
        position: relative;
        height: 100%;
        width: 100%;
    }
    .banner-slide {
        position: absolute;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .banner-slide.active {
        opacity: 1;
    }
    .banner-content {
        max-width: 1400px;
        padding: 0 20px;
        color: white;
        text-align: center;
        z-index: 2;
    }
    .banner-content h1 {
        font-size: 48px;
        margin-bottom: 20px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    .banner-content p {
        font-size: 20px;
        margin-bottom: 30px;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    }
    .banner-btn {
        padding: 15px 40px;
        background: white;
        color: #27ae60;
        border: none;
        border-radius: 25px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
    .banner-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.3);
    }
    .banner-indicators {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        z-index: 3;
    }
    .indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255,255,255,0.5);
        cursor: pointer;
        transition: all 0.3s;
    }
    .indicator.active {
        background: white;
        width: 30px;
        border-radius: 6px;
    }
    /* Search Section */
    .search-section {
        background: linear-gradient(135deg, #2ecc71, #27ae60);
        padding: 40px 20px;
    }
    .search-container {
        max-width: 1400px;
        margin: 0 auto;
    }
    .search-bar {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .search-input {
        flex: 1;
        min-width: 300px;
        padding: 15px 20px;
        border: 2px solid #fff;
        border-radius: 8px;
        font-size: 16px;
        background: white;
    }
    .search-input::placeholder {
        color: #999;
    }
    .dropdown {
        padding: 15px 20px;
        border: 2px solid #fff;
        border-radius: 8px;
        font-size: 16px;
        background: white;
        cursor: pointer;
        min-width: 180px;
    }
    .search-btn {
        padding: 15px 50px;
        background: #000;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.3s;
    }
    .search-btn:hover {
        background: #333;
    }
    /* Filter Section */
    .filter-section {
        background: white;
        padding: 20px;
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .filter-section select {
        padding: 12px 20px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 15px;
        cursor: pointer;
        background: white;
        color: #666;
        min-width: 150px;
    }
    /* Quick Links */
    .quick-links {
        max-width: 1400px;
        margin: 30px auto;
        padding: 0 20px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        align-items: center;
    }
    .quick-links strong {
        font-size: 16px;
        color: #333;
    }
    .quick-link-btn {
        padding: 10px 20px;
        background: white;
        border: 1px solid #ddd;
        border-radius: 25px;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 14px;
        color: #555;
    }
    .quick-link-btn:hover {
        background: #2ecc71;
        color: white;
        border-color: #2ecc71;
    }
    /* Cities Section */
    .cities-section {
        max-width: 1400px;
        margin: 40px auto;
        padding: 0 20px;
    }
    .cities-section h2 {
        font-size: 28px;
        margin-bottom: 30px;
        color: #333;
    }
    .cities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    .city-card {
        position: relative;
        height: 180px;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
    .city-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.3);
    }
    .city-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .city-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.6) 100%);
        z-index: 1;
    }
    .city-name {
        position: absolute;
        bottom: 20px;
        left: 20px;
        color: white;
        font-size: 24px;
        font-weight: bold;
        z-index: 2;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }
    .view-more-btn {
        display: block;
        margin: 0 auto;
        padding: 15px 60px;
        background: #2ecc71;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.3s;
        text-align: center;
        width: fit-content;
        text-decoration: none;
    }
    .view-more-btn:hover {
        background: #27ae60;
    }
    /* Jobs Section */
    .jobs-section {
        max-width: 1400px;
        margin: 60px auto;
        padding: 0 20px;
    }
    .jobs-section h2 {
        font-size: 28px;
        margin-bottom: 30px;
        color: #333;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .jobs-section h2::before {
        content: '⭐';
        font-size: 32px;
    }
    .jobs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 25px;
        margin-bottom: 30px;
    }
    .job-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: all 0.3s;
        cursor: pointer;
        border: 2px solid transparent;
        position: relative;
        overflow: hidden;
    }
    .job-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: linear-gradient(135deg, #2ecc71, #27ae60);
        transform: scaleY(0);
        transition: transform 0.3s;
    }
    .job-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(46, 204, 113, 0.2);
        border-color: #2ecc71;
    }
    .job-card:hover::before {
        transform: scaleY(1);
    }
    .job-header {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        margin-bottom: 15px;
    }
    .job-company-logo {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        object-fit: cover;
        background: #ffffff;
        border: 1px solid #e0e0e0;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: var(--accent-color);
        font-size: 24px;
    }
    .job-info {
        flex: 1;
    }
    .job-title {
        font-size: 18px;
        font-weight: bold;
        color: #333;
        margin-bottom: 5px;
        line-height: 1.3;
    }
    .job-company {
        font-size: 14px;
        color: #666;
        margin-bottom: 8px;
    }
    .job-location {
        font-size: 13px;
        color: #999;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .job-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 15px;
        margin-bottom: 15px;
    }
    .job-badge {
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 12px;
        font-weight: 600;
    }
    .badge-salary {
        background: #e8f8f5;
        color: #27ae60;
    }
    .badge-type {
        background: #fff3cd;
        color: #856404;
    }
    .badge-level {
        background: #d1ecf1;
        color: #0c5460;
    }
    .badge-urgent {
        background: #f8d7da;
        color: #721c24;
        animation: pulse 2s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }
    .job-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 15px;
        border-top: 1px solid #eee;
    }
    .job-posted {
        font-size: 12px;
        color: #999;
    }
    .job-apply-btn {
        padding: 8px 20px;
        background: linear-gradient(135deg, #2ecc71, #27ae60);
        color: white;
        border: none;
        border-radius: 20px;
        font-size: 14px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
    }
    .job-apply-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(46, 204, 113, 0.4);
    }
    .job-featured {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #f39c12, #e67e22);
        color: white;
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 11px;
        font-weight: bold;
        box-shadow: 0 2px 8px rgba(243, 156, 18, 0.3);
    }
    /* Blog Section */
    .blog-section {
        max-width: 1400px;
        margin: 60px auto;
        padding: 0 20px;
        position: relative;
    }
    .blog-section h2 {
        font-size: 28px;
        margin-bottom: 30px;
        color: #333;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .blog-section h2::before {
        content: '🔥';
        font-size: 32px;
    }
    .blog-container {
        position: relative;
        overflow: hidden;
    }
    .blog-grid {
        display: flex;
        transition: transform 0.5s ease-in-out;
        gap: 25px;
    }
    .blog-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
        flex: 0 0 calc(33.333% - 17px);
        min-width: 300px;
    }
    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    }
    .blog-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(46, 204, 113, 0.8);
        color: white;
        border: none;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        transition: all 0.3s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .blog-nav:hover {
        background: rgba(39, 174, 96, 1);
        transform: translateY(-50%) scale(1.1);
    }
    .blog-nav.prev {
        left: -25px;
    }
    .blog-nav.next {
        right: -25px;
    }
    .blog-indicators {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
    }
    .blog-indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #ddd;
        cursor: pointer;
        transition: all 0.3s;
    }
    .blog-indicator.active {
        background: #2ecc71;
        width: 30px;
        border-radius: 6px;
    }
    .blog-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }
    .blog-content {
        padding: 20px;
    }
    .blog-category {
        display: inline-block;
        padding: 5px 12px;
        background: #e8f8f5;
        color: #27ae60;
        border-radius: 15px;
        font-size: 12px;
        font-weight: bold;
        margin-bottom: 10px;
    }
    .blog-title {
        font-size: 18px;
        font-weight: bold;
        color: #333;
        margin-bottom: 10px;
        line-height: 1.4;
    }
    .blog-excerpt {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
        margin-bottom: 15px;
    }
    .blog-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: #999;
    }
    .blog-date {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .blog-views {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    @@media (max-width: 768px) {
        .search-bar {
            flex-direction: column;
        }
        .search-input, .dropdown, .search-btn {
            width: 100%;
        }
        .cities-grid {
            grid-template-columns: 1fr;
        }
        .jobs-grid {
            grid-template-columns: 1fr;
        }
        .blog-card {
            flex: 0 0 calc(100% - 17px);
        }
        .blog-nav {
            width: 40px;
            height: 40px;
            font-size: 20px;
        }
        .blog-nav.prev {
            left: 10px;
        }
        .blog-nav.next {
            right: 10px;
        }
    }
</style>

<!-- Search Section -->
<div class="search-section">
    <div class="search-container">
        <div class="search-bar">
            <input type="text" class="search-input" id="searchKeyword" placeholder="Tìm kiếm việc làm, chức vụ, kỹ năng, công ty, từ khóa...">
            <select class="dropdown" id="selectTinhThanh">
                <option value="">Tỉnh/Thành Phố</option>
                @{
                    var danhSachTinhThanh = ViewBag.DanhSachTinhThanh as List<Unicareer.Models.Province> ?? new List<Unicareer.Models.Province>();
                }
                @foreach (var tinh in danhSachTinhThanh)
                {
                    <option value="@tinh.Code">@tinh.FullName</option>
                }
            </select>
            <select class="dropdown" id="selectQuanHuyen">
                <option value="">Quận/Huyện</option>
            </select>
            <button class="search-btn">TÌM KIẾM 🔍</button>
        </div>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="search-container" style="width: 100%; display: flex; gap: 15px; flex-wrap: wrap;">
        <select id="filterNganhNghe">
            <option value="">Ngành nghề</option>
            @{
                var danhSachNganhNghe = ViewBag.DanhSachNganhNghe as List<Unicareer.Models.NganhNghe> ?? new List<Unicareer.Models.NganhNghe>();
            }
            @foreach (var nganhNghe in danhSachNganhNghe)
            {
                <option value="@nganhNghe.TenNganhNghe">@nganhNghe.TenNganhNghe</option>
            }
        </select>
        <select id="filterCapBac">
            <option value="">Cấp bậc</option>
            @{
                var danhSachCapBac = ViewBag.DanhSachCapBac as List<string> ?? new List<string>();
            }
            @foreach (var capBac in danhSachCapBac)
            {
                <option value="@capBac">@capBac</option>
            }
        </select>
        <select id="filterKinhNghiem">
            <option value="">Kinh nghiệm</option>
            @{
                var danhSachKinhNghiem = ViewBag.DanhSachKinhNghiem as List<string> ?? new List<string>();
            }
            @foreach (var kinhNghiem in danhSachKinhNghiem)
            {
                <option value="@kinhNghiem">@kinhNghiem</option>
            }
        </select>
        <select id="filterMucLuong">
            <option value="">Mức lương</option>
            <option value="Dưới 10 triệu">Dưới 10 triệu</option>
            <option value="10-15 triệu">10-15 triệu</option>
            <option value="15-25 triệu">15-25 triệu</option>
            <option value="Trên 25 triệu">Trên 25 triệu</option>
        </select>
        <select id="filterLoaiCongViec">
            <option value="">Loại công việc</option>
            @{
                var danhSachLoaiCongViec = ViewBag.DanhSachLoaiCongViec as List<Unicareer.Models.LoaiCongViec> ?? new List<Unicareer.Models.LoaiCongViec>();
            }
            @foreach (var loaiCongViec in danhSachLoaiCongViec)
            {
                <option value="@loaiCongViec.TenLoaiCongViec">@loaiCongViec.TenLoaiCongViec</option>
            }
        </select>
    </div>
</div>

<!-- Quick Links -->
<div class="quick-links">
    <strong>Gợi Ý Tìm Kiếm:</strong>
    @{
        var danhSachGoiYTimKiem = ViewBag.DanhSachGoiYTimKiem as List<Unicareer.Models.GoiYTimKiem> ?? new List<Unicareer.Models.GoiYTimKiem>();
    }
    @foreach (var goiY in danhSachGoiYTimKiem)
    {
        <a href="@goiY.Url" class="quick-link-btn" style="text-decoration: none; display: inline-block;">@goiY.Text</a>
    }
</div>

<!-- Banner Section -->
<div class="banner-section">
    <div class="banner-slider">
        <div class="banner-slide active">
            <div class="banner-content">
                <h1>Tìm Việc Làm Mơ Ước Của Bạn</h1>
                <p>Hơn 10,000+ cơ hội việc làm đang chờ đón bạn</p>
                <button class="banner-btn">Khám Phá Ngay</button>
            </div>
        </div>
        <div class="banner-slide">
            <div class="banner-content">
                <h1>Kết Nối Với Top Nhà Tuyển Dụng</h1>
                <p>Gặp gỡ những công ty hàng đầu tại Việt Nam</p>
                <button class="banner-btn">Xem Công Ty</button>
            </div>
        </div>
        <div class="banner-slide">
            <div class="banner-content">
                <h1>Nâng Cao Kỹ Năng - Thăng Tiến Sự Nghiệp</h1>
                <p>Khóa học miễn phí và tài liệu hữu ích dành cho bạn</p>
                <button class="banner-btn">Học Ngay</button>
            </div>
        </div>
    </div>
    <div class="banner-indicators">
        <div class="indicator active" data-slide="0"></div>
        <div class="indicator" data-slide="1"></div>
        <div class="indicator" data-slide="2"></div>
    </div>
</div>

<!-- Cities Section -->
<div class="cities-section">
    <h2>Bạn Muốn Làm Việc Ở Đâu?</h2>
    <div class="cities-grid">
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1557750255-c76072a7aad1?w=500" alt="Hà Nội">
            <div class="city-name">Hà Nội</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=500" alt="TP Hồ Chí Minh">
            <div class="city-name">TP Hồ Chí Minh</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?w=500" alt="Đà Nẵng">
            <div class="city-name">Đà Nẵng</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1552832230-c0197dd311b5?w=500" alt="Bình Dương">
            <div class="city-name">Bình Dương</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=500" alt="Hải Phòng">
            <div class="city-name">Hải Phòng</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1580837119756-563d608dd119?w=500" alt="Quảng Ninh">
            <div class="city-name">Quảng Ninh</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500" alt="Vũng Tàu">
            <div class="city-name">Vũng Tàu</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=500" alt="Cần Thơ">
            <div class="city-name">Cần Thơ</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1523978591478-c753949ff840?w=500" alt="Bắc Ninh">
            <div class="city-name">Bắc Ninh</div>
        </div>
        <div class="city-card">
            <img src="https://images.unsplash.com/photo-1519046904884-53103b34b206?w=500" alt="Đồng Nai">
            <div class="city-name">Đồng Nai</div>
        </div>
    </div>
    <a href="/Home/TimViec" class="view-more-btn" style="text-decoration: none;">Xem thêm</a>
</div>

<!-- Jobs Section -->
<div class="jobs-section">
    <h2>Các Việc Làm Tốt Nhất</h2>
    <div class="jobs-grid">
        @{
            var danhSachViecLamNoiBat = ViewBag.DanhSachViecLamNoiBat as List<Unicareer.Models.TinTuyenDung> ?? new List<Unicareer.Models.TinTuyenDung>();
        }
        @if (danhSachViecLamNoiBat.Any())
        {
            @foreach (var job in danhSachViecLamNoiBat)
            {
                var mucLuongDisplay = job.MucLuongThapNhat == 0 && job.MucLuongCaoNhat == 0 
                    ? "Thỏa thuận" 
                    : $"{job.MucLuongThapNhat}-{job.MucLuongCaoNhat} triệu";
                var thoiGianDang = DateTime.Now - job.NgayDang;
                var thoiGianDangText = thoiGianDang.TotalHours < 1 
                    ? $"Đăng {(int)thoiGianDang.TotalMinutes} phút trước"
                    : thoiGianDang.TotalDays < 1 
                        ? $"Đăng {(int)thoiGianDang.TotalHours} giờ trước"
                        : $"Đăng {(int)thoiGianDang.TotalDays} ngày trước";
                var isHot = job.SoLuongUngTuyen > 50;
                var isUrgent = job.SoLuongUngTuyen > 100;
                
                <div class="job-card" data-url="/Home/ChiTietViecLam/@job.MaTinTuyenDung" 
                     data-nganh="@job.NganhNghe" 
                     data-capbac="@job.ViTri" 
                     data-mucluong="@mucLuongDisplay" 
                     data-loai="@job.LoaiCongViec" 
                     data-kinhnghiem="@job.KinhNghiem">
                    @if (isHot)
                    {
                        <span class="job-featured">NỔI BẬT</span>
                    }
                    @if (isUrgent)
                    {
                        <span class="job-badge badge-urgent" style="position: absolute; top: 15px; right: 15px;">KHẨN CẤP</span>
                    }
                    <div class="job-header">
                        @{
                            var companyLogos = ViewBag.CompanyLogos as Dictionary<string, string?>;
                            var companyLogo = companyLogos?.ContainsKey(job.CongTy) == true ? companyLogos[job.CongTy] : null;
                        }
                        @if (!string.IsNullOrEmpty(companyLogo))
                        {
                            <img src="@companyLogo" alt="@job.CongTy" class="job-company-logo">
                        }
                        else
                        {
                            <div class="job-company-logo" style="width: 100px; height: 100px; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 16px; display: flex; align-items: center; justify-content: center; color: var(--accent-color); font-weight: bold; font-size: 36px;">
                                @job.CongTy.Substring(0, 1)
                            </div>
                        }
                        <div class="job-info">
                            <h3 class="job-title">@job.TenViecLam</h3>
                            <div class="job-company">@job.CongTy</div>
                            <div class="job-location">📍 @job.TinhThanhPho</div>
                        </div>
                    </div>
                    <div class="job-badges">
                        <span class="job-badge badge-salary">@mucLuongDisplay</span>
                        <span class="job-badge badge-type">@job.LoaiCongViec</span>
                        <span class="job-badge badge-level">@job.ViTri</span>
                    </div>
                    <div class="job-footer">
                        <span class="job-posted">@thoiGianDangText</span>
                        <button class="job-apply-btn">Ứng tuyển ngay</button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted" style="padding: 40px;">
                <p>Hiện chưa có việc làm nào</p>
            </div>
        }
    </div>
    <a href="/Home/TimViec" class="view-more-btn" style="text-decoration: none;">Xem Thêm Việc Làm</a>
</div>

<!-- Candidates Section -->
@if (User.IsInRole(Unicareer.Models.SD.Role_NhaTuyenDung) || User.IsInRole(Unicareer.Models.SD.Role_Admin))
{
    <div class="candidates-section" style="max-width: 1400px; margin: 60px auto; padding: 0 20px;">
        <h2 style="font-size: 28px; margin-bottom: 30px; color: #333; display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 32px;">👥</span>
            Ứng Viên Nổi Bật
        </h2>
        <div class="candidates-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 25px; margin-bottom: 30px;">
            @{
                var danhSachUngVienCongKhai = ViewBag.DanhSachUngVienCongKhai as List<Unicareer.Models.UngVien> ?? new List<Unicareer.Models.UngVien>();
            }
            @if (danhSachUngVienCongKhai.Any())
            {
                @foreach (var ungVien in danhSachUngVienCongKhai)
                {
                    <div class="candidate-card" style="background: white; border-radius: 12px; padding: 25px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); transition: all 0.3s; cursor: pointer; border: 2px solid transparent; position: relative; overflow: hidden;">
                        <div class="candidate-header" style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 15px;">
                            <div class="candidate-avatar" style="width: 60px; height: 60px; border-radius: 50%; background: linear-gradient(135deg, #2ecc71, #27ae60); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 24px; flex-shrink: 0;">
                                @if (!string.IsNullOrEmpty(ungVien.User?.Avatar))
                                {
                                    <img src="@ungVien.User.Avatar" alt="@ungVien.HoTen" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                                }
                                else
                                {
                                    @ungVien.HoTen.Substring(0, Math.Min(2, ungVien.HoTen.Length)).ToUpper()
                                }
                            </div>
                            <div class="candidate-info" style="flex: 1;">
                                <h3 class="candidate-name" style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 5px; line-height: 1.3;">@ungVien.HoTen</h3>
                                @if (!string.IsNullOrEmpty(ungVien.ViTriMongMuon))
                                {
                                    <div class="candidate-position" style="font-size: 14px; color: #666; margin-bottom: 8px;">@ungVien.ViTriMongMuon</div>
                                }
                                @if (!string.IsNullOrEmpty(ungVien.NoiLamViecMongMuon))
                                {
                                    <div class="candidate-location" style="font-size: 13px; color: #999; display: flex; align-items: center; gap: 5px;">📍 @ungVien.NoiLamViecMongMuon</div>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(ungVien.MoTaBanThan))
                        {
                            <div class="candidate-description" style="font-size: 14px; color: #666; line-height: 1.6; margin-bottom: 15px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @ungVien.MoTaBanThan
                            </div>
                        }
                        <div class="candidate-badges" style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 15px;">
                            @if (ungVien.MucLuongKyVong.HasValue)
                            {
                                <span class="candidate-badge" style="padding: 5px 12px; border-radius: 15px; font-size: 12px; font-weight: 600; background: #e8f8f5; color: #27ae60;">
                                    @ungVien.MucLuongKyVong.Value.ToString("N0") triệu
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(ungVien.TrangThaiTimViec))
                            {
                                <span class="candidate-badge" style="padding: 5px 12px; border-radius: 15px; font-size: 12px; font-weight: 600; background: #d1ecf1; color: #0c5460;">
                                    @ungVien.TrangThaiTimViec
                                </span>
                            }
                            @if (ungVien.ChuyenNganh != null)
                            {
                                <span class="candidate-badge" style="padding: 5px 12px; border-radius: 15px; font-size: 12px; font-weight: 600; background: #fff3cd; color: #856404;">
                                    @ungVien.ChuyenNganh.TenChuyenNganh
                                </span>
                            }
                        </div>
                        <div class="candidate-footer" style="display: flex; justify-content: space-between; align-items: center; padding-top: 15px; border-top: 1px solid #eee;">
                            <span class="candidate-posted" style="font-size: 12px; color: #999;">
                                Đăng ký @ungVien.NgayDangKy.ToString("dd/MM/yyyy")
                            </span>
                            <button class="candidate-view-btn" style="padding: 8px 20px; background: linear-gradient(135deg, #2ecc71, #27ae60); color: white; border: none; border-radius: 20px; font-size: 14px; font-weight: bold; cursor: pointer; transition: all 0.3s;">
                                Xem hồ sơ
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted" style="padding: 40px; grid-column: 1 / -1;">
                    <p>Hiện chưa có ứng viên nào đăng hồ sơ công khai</p>
                </div>
            }
        </div>
    </div>
    
    <style>
        .candidate-card {
            position: relative;
        }
        .candidate-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            transform: scaleY(0);
            transition: transform 0.3s;
        }
        .candidate-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(46, 204, 113, 0.2);
            border-color: #2ecc71;
        }
        .candidate-card:hover::before {
            transform: scaleY(1);
        }
        .candidate-view-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(46, 204, 113, 0.4);
        }
        @@media (max-width: 768px) {
            .candidates-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

