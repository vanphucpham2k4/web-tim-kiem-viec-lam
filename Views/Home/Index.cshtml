@{
    ViewData["Title"] = "Unicareer - Nền tảng tìm việc làm cho sinh viên";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --success-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --accent-color: #667eea;
        --accent-dark: #764ba2;
        --text-primary: #2d3748;
        --text-secondary: #718096;
    }
    
    body {
        background: #fff;
    }
    
    /* Hero Section */
    .hero-landing {
        background: var(--primary-gradient);
        padding: 120px 0 100px;
        position: relative;
        overflow: hidden;
        color: white;
    }
    
    .hero-landing::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.3;
    }
    
    .hero-content {
        position: relative;
        z-index: 1;
    }
    
    .hero-landing h1 {
        font-size: 56px;
        font-weight: 800;
        margin-bottom: 24px;
        line-height: 1.2;
        text-shadow: 0 2px 20px rgba(0,0,0,0.1);
    }
    
    .hero-landing p {
        font-size: 20px;
        margin-bottom: 40px;
        opacity: 0.95;
        line-height: 1.6;
    }
    
    .btn-hero {
        padding: 16px 48px;
        font-size: 18px;
        font-weight: 700;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 30px rgba(0,0,0,0.2);
        border: none;
    }
    
    .btn-hero-primary {
        background: white;
        color: var(--accent-color);
    }
    
    .btn-hero-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.3);
        color: var(--accent-dark);
    }
    
    .btn-hero-outline {
        background: transparent;
        color: white;
        border: 3px solid white;
    }
    
    .btn-hero-outline:hover {
        background: white;
        color: var(--accent-color);
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    }
    
    .hero-image {
        position: relative;
        animation: float 6s ease-in-out infinite;
    }
    
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
    
    /* Stats Section */
    .stats-section {
        padding: 80px 0;
        background: #f7fafc;
    }
    
    .stat-card {
        text-align: center;
        padding: 40px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }
    
    .stat-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 12px 40px rgba(102, 126, 234, 0.15);
        border-color: var(--accent-color);
    }
    
    .stat-number {
        font-size: 48px;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 10px;
    }
    
    .stat-label {
        font-size: 18px;
        color: var(--text-secondary);
        font-weight: 600;
    }
    
    /* Features Section */
    .features-section {
        padding: 100px 0;
        background: white;
    }
    
    .section-title {
        text-align: center;
        margin-bottom: 70px;
    }
    
    .section-title h2 {
        font-size: 42px;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 16px;
    }
    
    .section-title p {
        font-size: 18px;
        color: var(--text-secondary);
        max-width: 600px;
        margin: 0 auto;
    }
    
    .feature-card {
        text-align: center;
        padding: 40px 30px;
        border-radius: 20px;
        transition: all 0.3s ease;
        height: 100%;
    }
    
    .feature-card:hover {
        background: #f7fafc;
        transform: translateY(-5px);
    }
    
    .feature-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 24px;
        background: var(--primary-gradient);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        color: white;
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
        transition: all 0.3s ease;
    }
    
    .feature-card:hover .feature-icon {
        transform: scale(1.1) rotate(5deg);
    }
    
    .feature-card h4 {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 16px;
    }
    
    .feature-card p {
        font-size: 16px;
        color: var(--text-secondary);
        line-height: 1.7;
    }
    
    /* How It Works Section */
    .how-it-works {
        padding: 100px 0;
        background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
    }
    
    .step-card {
        text-align: center;
        position: relative;
        padding: 40px 30px;
    }
    
    .step-number {
        width: 70px;
        height: 70px;
        margin: 0 auto 24px;
        background: var(--secondary-gradient);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 800;
        color: white;
        box-shadow: 0 8px 25px rgba(245, 87, 108, 0.3);
        position: relative;
        z-index: 1;
    }
    
    .step-card h4 {
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 12px;
    }
    
    .step-card p {
        font-size: 15px;
        color: var(--text-secondary);
        line-height: 1.7;
    }
    
    /* CTA Section */
    .cta-section {
        padding: 100px 0;
        background: var(--primary-gradient);
        color: white;
        position: relative;
        overflow: hidden;
    }
    
    .cta-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.3;
    }
    
    .cta-content {
        position: relative;
        z-index: 1;
        text-align: center;
    }
    
    .cta-section h2 {
        font-size: 42px;
        font-weight: 800;
        margin-bottom: 20px;
    }
    
    .cta-section p {
        font-size: 20px;
        margin-bottom: 40px;
        opacity: 0.95;
    }
    
    /* Animation */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .animate-fade-in {
        animation: fadeInUp 0.8s ease backwards;
    }
    
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
</style>

<!-- Hero Section -->
<div class="hero-landing">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content">
                <h1 class="animate-fade-in">Tìm Công Việc Mơ Ước Của Bạn</h1>
                <p class="animate-fade-in delay-1">Kết nối sinh viên với hàng nghìn cơ hội việc làm từ các doanh nghiệp hàng đầu. Bắt đầu sự nghiệp của bạn ngay hôm nay!</p>
                <div class="animate-fade-in delay-2">
                    <a href="/Home/TimViec" class="btn btn-hero btn-hero-primary me-3">
                        <i class="bi bi-search me-2"></i>Tìm việc ngay
                    </a>
                    <a href="#features" class="btn btn-hero btn-hero-outline">
                        <i class="bi bi-info-circle me-2"></i>Tìm hiểu thêm
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image animate-fade-in delay-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 400" style="width: 100%; max-width: 500px;">
                        <rect x="50" y="50" width="400" height="300" rx="20" fill="#ffffff" opacity="0.1"/>
                        <rect x="70" y="70" width="360" height="40" rx="10" fill="#ffffff" opacity="0.2"/>
                        <rect x="70" y="130" width="150" height="80" rx="10" fill="#ffffff" opacity="0.15"/>
                        <rect x="240" y="130" width="190" height="80" rx="10" fill="#ffffff" opacity="0.15"/>
                        <rect x="70" y="230" width="360" height="100" rx="10" fill="#ffffff" opacity="0.2"/>
                        <circle cx="100" cy="290" r="20" fill="#ffffff" opacity="0.3"/>
                        <circle cx="400" cy="290" r="30" fill="#ffffff" opacity="0.25"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="stat-card animate-fade-in">
                    <div class="stat-number">1000+</div>
                    <div class="stat-label">Việc làm</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card animate-fade-in delay-1">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Nhà tuyển dụng</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card animate-fade-in delay-2">
                    <div class="stat-number">5000+</div>
                    <div class="stat-label">Ứng viên</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card animate-fade-in delay-3">
                    <div class="stat-number">95%</div>
                    <div class="stat-label">Tỷ lệ thành công</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="features-section" id="features">
    <div class="container">
        <div class="section-title">
            <h2>Tại Sao Chọn Unicareer?</h2>
            <p>Chúng tôi cung cấp những tính năng tốt nhất để giúp bạn tìm được công việc phù hợp</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-search"></i>
                    </div>
                    <h4>Tìm Kiếm Thông Minh</h4>
                    <p>Hệ thống tìm kiếm thông minh giúp bạn dễ dàng tìm được công việc phù hợp với kỹ năng và sở thích.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <h4>Nhà Tuyển Dụng Uy Tín</h4>
                    <p>Kết nối với hàng trăm doanh nghiệp hàng đầu đang tìm kiếm những tài năng trẻ như bạn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h4>Ứng Tuyển Nhanh Chóng</h4>
                    <p>Chỉ cần vài cú click chuột là bạn đã có thể ứng tuyển vào những vị trí công việc yêu thích.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4>An Toàn & Bảo Mật</h4>
                    <p>Thông tin của bạn được bảo mật tuyệt đối với công nghệ mã hóa hiện đại nhất.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-bell"></i>
                    </div>
                    <h4>Thông Báo Tức Thì</h4>
                    <p>Nhận thông báo ngay khi có công việc mới phù hợp hoặc nhà tuyển dụng xem hồ sơ của bạn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-headset"></i>
                    </div>
                    <h4>Hỗ Trợ 24/7</h4>
                    <p>Đội ngũ hỗ trợ của chúng tôi luôn sẵn sàng giúp đỡ bạn mọi lúc, mọi nơi.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- How It Works Section -->
<div class="how-it-works">
    <div class="container">
        <div class="section-title">
            <h2>Cách Hoạt Động</h2>
            <p>Chỉ 3 bước đơn giản để bắt đầu tìm việc làm của bạn</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h4>Tạo Tài Khoản</h4>
                    <p>Đăng ký tài khoản miễn phí và tạo hồ sơ cá nhân để các nhà tuyển dụng có thể tìm thấy bạn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h4>Tìm Kiếm Việc Làm</h4>
                    <p>Duyệt qua hàng nghìn công việc và lọc theo ngành nghề, địa điểm, mức lương phù hợp.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h4>Ứng Tuyển & Nhận Việc</h4>
                    <p>Nộp đơn ứng tuyển trực tuyến và chờ nhà tuyển dụng liên hệ với bạn.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2>Sẵn Sàng Bắt Đầu Sự Nghiệp Của Bạn?</h2>
            <p>Hãy tham gia cùng hàng nghìn sinh viên đã tìm được công việc mơ ước qua Unicareer</p>
            <a href="/Home/TimViec" class="btn btn-hero btn-hero-primary">
                <i class="bi bi-rocket-takeoff me-2"></i>Khám phá ngay
            </a>
        </div>
    </div>
</div>
