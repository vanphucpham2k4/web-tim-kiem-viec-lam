<script>
    // Wait for DOM to be ready
    document.addEventListener('DOMContentLoaded', function() {
    
    // Banner Auto Slider
    let currentSlide = 0;
    const slides = document.querySelectorAll('.banner-slide');
    const indicators = document.querySelectorAll('.indicator');
    
    function showSlide(index) {
        slides.forEach(slide => slide.classList.remove('active'));
        indicators.forEach(indicator => indicator.classList.remove('active'));
        
        slides[index].classList.add('active');
        indicators[index].classList.add('active');
    }
    
    function nextSlide() {
        currentSlide = (currentSlide + 1) % slides.length;
        showSlide(currentSlide);
    }
    
    // Auto slide every 5 seconds
    setInterval(nextSlide, 5000);
    
    // Manual indicator click
    indicators.forEach((indicator, index) => {
        indicator.addEventListener('click', () => {
            currentSlide = index;
            showSlide(currentSlide);
        });
    });
    
    // Add click handlers for city cards - Navigate to TimViec with city filter
    document.querySelectorAll('.city-card').forEach(card => {
        card.addEventListener('click', function() {
            const cityName = this.querySelector('.city-name').textContent;
            // Chuyển đến trang TimViec với query parameter
            window.location.href = `/Home/TimViec?tinhThanh=${encodeURIComponent(cityName)}`;
        });
    });
    
    // Load wards when province is selected
    const selectTinhThanh = document.getElementById('selectTinhThanh');
    const selectQuanHuyen = document.getElementById('selectQuanHuyen');
    
    function loadWardsByProvince(provinceCode) {
        // Reset quận/huyện dropdown
        selectQuanHuyen.innerHTML = '<option value="">Quận/Huyện</option>';
        
        if (provinceCode) {
            // Show loading state
            selectQuanHuyen.disabled = true;
            selectQuanHuyen.innerHTML = '<option value="">Đang tải...</option>';
            
            // Fetch wards from API
            fetch(`/Home/GetWardsByProvince?provinceCode=${encodeURIComponent(provinceCode)}`)
                .then(response => response.json())
                .then(data => {
                    selectQuanHuyen.innerHTML = '<option value="">Quận/Huyện</option>';
                    
                    if (data && data.length > 0) {
                        data.forEach(ward => {
                            const option = document.createElement('option');
                            option.value = ward.code;
                            option.textContent = ward.fullName;
                            selectQuanHuyen.appendChild(option);
                        });
                    } else {
                        selectQuanHuyen.innerHTML = '<option value="">Không có dữ liệu</option>';
                    }
                    
                    selectQuanHuyen.disabled = false;
                })
                .catch(error => {
                    console.error('Error loading wards:', error);
                    selectQuanHuyen.innerHTML = '<option value="">Lỗi tải dữ liệu</option>';
                    selectQuanHuyen.disabled = false;
                });
        } else {
            selectQuanHuyen.disabled = false;
        }
    }
    
    selectTinhThanh.addEventListener('change', function() {
        loadWardsByProvince(this.value);
    });
    
    // Kiểm tra và load quận/huyện nếu tỉnh đã được chọn (khi quay lại bằng back button)
    if (selectTinhThanh && selectTinhThanh.value) {
        loadWardsByProvince(selectTinhThanh.value);
    }
    
    // Function to perform search
    function performSearch() {
        const searchValue = document.getElementById('searchKeyword').value.trim();
        const tinhThanh = selectTinhThanh.value;
        const quanHuyen = selectQuanHuyen.value;
        
        // Build search URL
        let searchUrl = '/Home/TimViec?';
        const params = [];
        
        if (searchValue) {
            params.push(`keyword=${encodeURIComponent(searchValue)}`);
        }
        if (tinhThanh) {
            const tinhName = selectTinhThanh.options[selectTinhThanh.selectedIndex].text;
            params.push(`tinhThanh=${encodeURIComponent(tinhName)}`);
        }
        if (quanHuyen) {
            const quanName = selectQuanHuyen.options[selectQuanHuyen.selectedIndex].text;
            params.push(`quanHuyen=${encodeURIComponent(quanName)}`);
        }
        
        if (params.length > 0 || searchValue) {
            window.location.href = searchUrl + params.join('&');
        } else {
            window.location.href = '/Home/TimViec';
        }
    }
    
    // Search button handler
    document.querySelector('.search-btn').addEventListener('click', function() {
        performSearch();
    });
    
    // Enter key handler for search input
    document.getElementById('searchKeyword').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            performSearch();
        }
    });
    
    // View more button - Now handled by href, no need for click handler
    
    // Blog Carousel
    let currentBlogIndex = 0;
    let blogAutoSlideInterval;
    const blogCards = document.querySelectorAll('.blog-card');
    const blogGrid = document.querySelector('.blog-grid');
    const blogIndicatorsContainer = document.querySelector('.blog-indicators');
    
    function getCardsPerView() {
        return window.innerWidth > 768 ? 3 : 1;
    }
    
    function initBlogCarousel() {
        const cardsPerView = getCardsPerView();
        const totalSlides = Math.ceil(blogCards.length / cardsPerView);
        
        // Clear existing indicators
        blogIndicatorsContainer.innerHTML = '';
        
        // Create indicators
        for (let i = 0; i < totalSlides; i++) {
            const indicator = document.createElement('div');
            indicator.className = 'blog-indicator' + (i === 0 ? ' active' : '');
            indicator.dataset.slide = i;
            blogIndicatorsContainer.appendChild(indicator);
        }
        
        const blogIndicators = document.querySelectorAll('.blog-indicator');
        
        function updateBlogCarousel() {
            if (blogCards.length === 0) return;
            const cardWidth = blogCards[0].offsetWidth + 25; // card width + gap
            const cardsPerView = getCardsPerView();
            const translateX = -currentBlogIndex * cardWidth * cardsPerView;
            blogGrid.style.transform = `translateX(${translateX}px)`;
            
            blogIndicators.forEach((ind, index) => {
                ind.classList.toggle('active', index === currentBlogIndex);
            });
        }
        
        function nextBlogSlide() {
            const totalSlides = Math.ceil(blogCards.length / getCardsPerView());
            currentBlogIndex = (currentBlogIndex + 1) % totalSlides;
            updateBlogCarousel();
        }
        
        function prevBlogSlide() {
            const totalSlides = Math.ceil(blogCards.length / getCardsPerView());
            currentBlogIndex = (currentBlogIndex - 1 + totalSlides) % totalSlides;
            updateBlogCarousel();
        }
        
        // Clear existing interval
        if (blogAutoSlideInterval) {
            clearInterval(blogAutoSlideInterval);
        }
        
        // Auto slide blog every 4 seconds
        blogAutoSlideInterval = setInterval(nextBlogSlide, 4000);
        
        // Manual navigation
        const nextBtn = document.querySelector('.blog-nav.next');
        const prevBtn = document.querySelector('.blog-nav.prev');
        
        // Remove old event listeners by cloning
        const newNextBtn = nextBtn.cloneNode(true);
        const newPrevBtn = prevBtn.cloneNode(true);
        nextBtn.parentNode.replaceChild(newNextBtn, nextBtn);
        prevBtn.parentNode.replaceChild(newPrevBtn, prevBtn);
        
        newNextBtn.addEventListener('click', nextBlogSlide);
        newPrevBtn.addEventListener('click', prevBlogSlide);
        
        // Indicator click
        blogIndicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => {
                currentBlogIndex = index;
                updateBlogCarousel();
            });
        });
        
        // Initial update
        updateBlogCarousel();
    }
    
    // Initialize on page load
    initBlogCarousel();
    
    // Handle window resize
    let resizeTimer;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
            currentBlogIndex = 0; // Reset to first slide
            initBlogCarousel();
        }, 250);
    });
    
    // Blog card click handlers - Navigate to blog detail page
    document.querySelectorAll('.blog-card').forEach(card => {
        card.addEventListener('click', function(e) {
            const url = this.getAttribute('data-url');
            if (url) {
                window.location.href = url;
            }
        });
    });
    
    // Job card click handlers - Navigate to job detail page
    document.querySelectorAll('.job-card').forEach(card => {
        card.addEventListener('click', function(e) {
            // Don't navigate if clicking the apply button
            if (e.target.classList.contains('job-apply-btn')) {
                e.stopPropagation();
                const url = this.getAttribute('data-url');
                if (url) {
                    window.location.href = url;
                }
                return;
            }
            const url = this.getAttribute('data-url');
            if (url) {
                window.location.href = url;
            }
        });
    });
    
    // Job apply button handlers
    document.querySelectorAll('.job-apply-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            const card = this.closest('.job-card');
            const url = card.getAttribute('data-url');
            if (url) {
                window.location.href = url;
            }
        });
    });
    
    // Banner buttons
    document.querySelectorAll('.banner-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            alert('Chuyển đến trang tương ứng...');
        });
    });
    
    // Filter jobs based on dropdown selections
    function filterJobs() {
        const nganhNghe = document.getElementById('filterNganhNghe').value;
        const capBac = document.getElementById('filterCapBac').value;
        const kinhNghiem = document.getElementById('filterKinhNghiem').value;
        const mucLuong = document.getElementById('filterMucLuong').value;
        const loaiCongViec = document.getElementById('filterLoaiCongViec').value;
        
        const jobCards = document.querySelectorAll('.jobs-grid .job-card');
        let visibleCount = 0;
        
        jobCards.forEach(card => {
            const cardNganh = card.getAttribute('data-nganh') || '';
            const cardCapBac = card.getAttribute('data-capbac') || '';
            const cardKinhNghiem = card.getAttribute('data-kinhnghiem') || '';
            const cardMucLuong = card.getAttribute('data-mucluong') || '';
            const cardLoai = card.getAttribute('data-loai') || '';
            
            // Check if job matches all selected filters
            const matchNganh = !nganhNghe || cardNganh === nganhNghe;
            const matchCapBac = !capBac || cardCapBac === capBac;
            const matchKinhNghiem = !kinhNghiem || cardKinhNghiem === kinhNghiem;
            
            // Salary matching - check if selected range matches
            let matchMucLuong = true;
            if (mucLuong && cardMucLuong) {
                // Extract numbers from salary strings (e.g., "15-25 triệu" -> [15, 25])
                const extractNumbers = (str) => {
                    const matches = str.match(/\d+/g);
                    return matches ? matches.map(Number) : [];
                };
                
                const cardNumbers = extractNumbers(cardMucLuong);
                const cardMin = cardNumbers[0] || 0;
                const cardMax = cardNumbers[1] || cardNumbers[0] || 0;
                const cardAvg = (cardMin + cardMax) / 2;
                
                if (mucLuong === 'Dưới 10 triệu') {
                    matchMucLuong = cardMax < 10;
                } else if (mucLuong === '10-15 triệu') {
                    matchMucLuong = cardAvg >= 10 && cardAvg <= 15;
                } else if (mucLuong === '15-25 triệu') {
                    matchMucLuong = cardAvg >= 15 && cardAvg <= 25;
                } else if (mucLuong === 'Trên 25 triệu') {
                    matchMucLuong = cardMin >= 25;
                }
            }
            
            const matchLoai = !loaiCongViec || cardLoai === loaiCongViec;
            
            if (matchNganh && matchCapBac && matchKinhNghiem && matchMucLuong && matchLoai) {
                card.style.display = 'block';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });
    }
    
    // Add event listeners to filter dropdowns
    document.getElementById('filterNganhNghe').addEventListener('change', filterJobs);
    document.getElementById('filterCapBac').addEventListener('change', filterJobs);
    document.getElementById('filterKinhNghiem').addEventListener('change', filterJobs);
    document.getElementById('filterMucLuong').addEventListener('change', filterJobs);
    document.getElementById('filterLoaiCongViec').addEventListener('change', filterJobs);
    
    }); // End DOMContentLoaded
</script>
