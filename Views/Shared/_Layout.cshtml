<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Unicareer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Unicareer.styles.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #ff7b00;
            --primary-hover: #e66d00;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .top-header {
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
            padding: 15px 0;
        }
        
        .logo {
            font-size: 28px;
            font-weight: bold;
            color: #333;
            text-decoration: none;
        }
        
        .logo span.uni {
            color: #333;
        }
        
        .logo span.career {
            color: var(--primary-color);
        }
        
        .main-nav {
            background: #fff;
            padding: 0;
            border-bottom: 1px solid #e0e0e0;
        }
        
        .main-nav .nav-link {
            color: #333;
            font-weight: 500;
            padding: 15px 20px;
            text-transform: uppercase;
            font-size: 14px;
            transition: all 0.3s;
        }
        
        .main-nav .nav-link:hover {
            color: var(--primary-color);
            background: #fff5eb;
        }
        
        .user-actions a {
            color: #333;
            text-decoration: none;
            margin-left: 20px;
            font-size: 14px;
        }
        
        .user-actions a:hover {
            color: var(--primary-color);
        }
        
        .user-dropdown {
            position: relative;
            display: inline-block;
        }
        
        .user-dropdown .dropdown-toggle {
            color: #333;
            text-decoration: none;
            cursor: pointer;
            font-size: 14px;
        }
        
        .user-dropdown .dropdown-toggle:hover {
            color: var(--primary-color);
        }
        
        .user-dropdown .dropdown-toggle::after {
            content: '\25BC';
            font-size: 10px;
            margin-left: 5px;
        }
    </style>
</head>
<body>
    <header>
        <!-- Top Header -->
        <div class="top-header">
            <div class="container-fluid px-5">
                <div class="d-flex justify-content-between align-items-center">
                    <a href="/" class="logo">
                        <span class="uni">Uni</span><span class="career">career</span>
                    </a>
                    <div class="user-actions">
                        <a href="#"><i class="bi bi-building"></i> Quan ly tuyen dung</a>
                        <div class="user-dropdown dropdown">
                            <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Xin chao: Pham Van Phuc
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person"></i> Thong tin tai khoan</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-file-text"></i> CV cua toi</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-heart"></i> Viec lam da luu</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-box-arrow-right"></i> Dang xuat</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Main Navigation -->
        <nav class="navbar navbar-expand-lg main-nav">
            <div class="container-fluid px-5">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">TIM VIEC</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">NHA TRO SINH VIEN</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">THUC TAP</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">CONG TY</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">TUYEN DUNG NHANH</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">CAM NANG NGHE NGHIEP</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="mt-5 py-4 bg-light border-top">
        <div class="container-fluid px-5">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-0">&copy; 2025 - Unicareer - Nen tang tuyen dung sinh vien hang dau Viet Nam</p>
                </div>
                <div class="col-md-6 text-end">
                    <a href="#" class="text-decoration-none me-3">Dieu khoan su dung</a>
                    <a href="#" class="text-decoration-none">Chinh sach bao mat</a>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
