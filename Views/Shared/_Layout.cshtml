<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Unicareer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Unicareer.styles.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #ff7b00;
            --primary-hover: #e66d00;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .top-header {
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
            padding: 15px 0;
        }
        
        .logo {
            display: inline-block;
            text-decoration: none;
        }
        
        .logo img {
            height: 45px;
            width: auto;
        }
        
        .top-header .navbar {
            flex-grow: 0;
        }
        
        .top-header .nav-link {
            color: #333;
            font-weight: 600;
            padding: 10px 25px;
            text-transform: uppercase;
            font-size: 14px;
            transition: all 0.3s;
            border-radius: 8px;
            margin: 0 5px;
        }
        
        .top-header .nav-link:hover {
            color: var(--primary-color);
            background: #fff5eb;
        }
        
        .user-actions a {
            color: #333;
            text-decoration: none;
            margin-left: 20px;
            font-size: 14px;
        }
        
        .user-actions a:hover {
            color: var(--primary-color);
        }
        
        .user-dropdown {
            position: relative;
            display: inline-block;
        }
        
        .user-dropdown .dropdown-toggle {
            color: #333;
            text-decoration: none;
            cursor: pointer;
            font-size: 14px;
        }
        
        .user-dropdown .dropdown-toggle:hover {
            color: var(--primary-color);
        }
        
        .user-dropdown .dropdown-toggle::after {
            content: '\25BC';
            font-size: 10px;
            margin-left: 5px;
        }
    </style>
</head>
<body>
    <header>
        <!-- Top Header with Navigation -->
        <div class="top-header">
            <div class="container-fluid px-5">
                <div class="d-flex justify-content-between align-items-center">
                    <!-- Logo -->
                    <a href="/" class="logo">
                        <img src="~/images/logoUnicareer.png" alt="Unicareer" />
                    </a>
                    
                    <!-- Main Navigation -->
                    <nav class="navbar navbar-expand-lg p-0">
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="mainNav">
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link" href="/Home/TimViec">TÌM VIỆC</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Home/ThucTap">THỰC TẬP</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Home/CongTy">CÔNG TY</a>
                                </li>
                            </ul>
                        </div>
                    </nav>
                    
                    <!-- User Actions -->
                    <div class="user-actions">
                        <a href="#"><i class="bi bi-building"></i> Quản lý tuyển dụng</a>
                        <div class="user-dropdown dropdown">
                            <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Xin chào: Phạm Văn Phúc
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person"></i> Thông tin tài khoản</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-file-text"></i> CV của tôi</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-heart"></i> Việc làm đã lưu</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="mt-5 py-4 bg-light border-top">
        <div class="container-fluid px-5">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-0">&copy; 2025 - Unicareer - Nền tảng tuyển dụng sinh viên hàng đầu Việt Nam</p>
                </div>
                <div class="col-md-6 text-end">
                    <a href="#" class="text-decoration-none me-3">Điều khoản sử dụng</a>
                    <a href="#" class="text-decoration-none">Chính sách bảo mật</a>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
