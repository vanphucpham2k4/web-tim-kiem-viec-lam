@using Microsoft.AspNetCore.Identity
@using Unicareer.Models
@inject SignInManager<ApplicationUser> SignInManager

<footer class="site-footer">
    <div class="footer-container">
        <div class="container-fluid px-5">
            <div class="row footer-content">
                <!-- Column 1: About -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <div class="footer-section">
                        <div class="footer-logo mb-3">
                            <a href="/" class="d-inline-block">
                                <img src="~/images/logoUnicareer.png" alt="Unicareer" class="footer-logo-img">
                            </a>
                        </div>
                        <p class="footer-description">
                            Nền tảng tuyển dụng sinh viên hàng đầu Việt Nam. Kết nối sinh viên với các cơ hội việc làm và thực tập tốt nhất.
                        </p>
                        <div class="footer-social">
                            <a href="#" class="social-link" aria-label="Facebook">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="#" class="social-link" aria-label="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>
                            <a href="#" class="social-link" aria-label="YouTube">
                                <i class="bi bi-youtube"></i>
                            </a>
                            <a href="#" class="social-link" aria-label="Zalo">
                                <i class="bi bi-chat-dots"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Column 2: Quick Links -->
                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <div class="footer-section">
                        <h5 class="footer-title">Dành cho ứng viên</h5>
                        <ul class="footer-links">
                            <li><a href="/Home/TimViec"><i class="bi bi-chevron-right"></i> Tìm việc làm</a></li>
                            <li><a href="/Home/ThucTap"><i class="bi bi-chevron-right"></i> Tìm thực tập</a></li>
                            <li><a href="/Home/UngVien"><i class="bi bi-chevron-right"></i> Ứng viên</a></li>
                            @if (SignInManager.IsSignedIn(User) && User.IsInRole(SD.Role_UngVien))
                            {
                                <li><a asp-area="Candidate" asp-controller="Candidate" asp-action="Index"><i class="bi bi-chevron-right"></i> Quản lý ứng tuyển</a></li>
                                <li><a asp-area="Candidate" asp-controller="Candidate" asp-action="ViecLamDaLuu"><i class="bi bi-chevron-right"></i> Việc đã lưu</a></li>
                            }
                            else
                            {
                                <li><a asp-controller="Account" asp-action="Register"><i class="bi bi-chevron-right"></i> Đăng ký ứng viên</a></li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- Column 3: For Employers -->
                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <div class="footer-section">
                        <h5 class="footer-title">Dành cho nhà tuyển dụng</h5>
                        <ul class="footer-links">
                            <li><a href="/Home/CongTy"><i class="bi bi-chevron-right"></i> Tìm công ty</a></li>
                            @if (SignInManager.IsSignedIn(User) && User.IsInRole(SD.Role_NhaTuyenDung))
                            {
                                <li><a asp-area="Recruiter" asp-controller="Recruiter" asp-action="Index"><i class="bi bi-chevron-right"></i> Quản lý tuyển dụng</a></li>
                                <li><a asp-area="Recruiter" asp-controller="Recruiter" asp-action="DangTinTuyenDung"><i class="bi bi-chevron-right"></i> Đăng tin mới</a></li>
                            }
                            else
                            {
                                <li><a asp-controller="Account" asp-action="Register"><i class="bi bi-chevron-right"></i> Đăng ký nhà tuyển dụng</a></li>
                            }
                            <li><a href="#"><i class="bi bi-chevron-right"></i> Giải pháp tuyển dụng</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right"></i> Bảng giá</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Column 4: Resources -->
                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <div class="footer-section">
                        <h5 class="footer-title">Tài nguyên</h5>
                        <ul class="footer-links">
                            <li><a href="/Home/Blog"><i class="bi bi-chevron-right"></i> Blog việc làm</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right"></i> Hướng dẫn tìm việc</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right"></i> CV mẫu</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right"></i> Câu hỏi thường gặp</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right"></i> Sự kiện</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Column 5: Contact -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <div class="footer-section">
                        <h5 class="footer-title">Liên hệ</h5>
                        <ul class="footer-contact">
                            <li>
                                <i class="bi bi-geo-alt-fill"></i>
                                <span>123 Đường ABC, Quận XYZ, TP. Hồ Chí Minh</span>
                            </li>
                            <li>
                                <i class="bi bi-telephone-fill"></i>
                                <a href="tel:+84123456789">+84 123 456 789</a>
                            </li>
                            <li>
                                <i class="bi bi-envelope-fill"></i>
                                <a href="mailto:contact@unicareer.vn">contact@unicareer.vn</a>
                            </li>
                            <li>
                                <i class="bi bi-clock-fill"></i>
                                <span>Thứ 2 - Thứ 6: 8:00 - 17:30</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Footer Bottom -->
            <div class="footer-bottom">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="footer-copyright mb-0">
                            &copy; @DateTime.Now.Year <strong>Unicareer</strong>. Tất cả quyền được bảo lưu.
                        </p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="footer-legal-links">
                            <a href="#">Điều khoản sử dụng</a>
                            <span class="separator">|</span>
                            <a href="#">Chính sách bảo mật</a>
                            <span class="separator">|</span>
                            <a href="#">Chính sách cookie</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: linear-gradient(135deg, #1e3a2f 0%, #2d4a3e 100%);
        color: #ffffff;
        margin-top: 60px;
        padding: 60px 0 20px;
        position: relative;
        overflow: hidden;
    }

    .site-footer::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #10b981, #34d399, #10b981);
    }

    .footer-container {
        position: relative;
        z-index: 1;
    }

    .footer-content {
        margin-bottom: 40px;
    }

    .footer-section {
        height: 100%;
    }

    .footer-logo-img {
        height: 50px;
        width: auto;
        filter: brightness(0) invert(1);
    }

    .footer-description {
        color: #b0b8c0;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .footer-social {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        color: #ffffff;
        font-size: 18px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .social-link:hover {
        background: #10b981;
        color: #ffffff;
        transform: translateY(-3px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
    }

    .footer-title {
        color: #ffffff;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 20px;
        position: relative;
        padding-bottom: 10px;
    }

    .footer-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 40px;
        height: 3px;
        background: linear-gradient(90deg, #10b981, #34d399);
        border-radius: 2px;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links li {
        margin-bottom: 12px;
    }

    .footer-links a {
        color: #b0b8c0;
        text-decoration: none;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .footer-links a i {
        font-size: 12px;
        color: #10b981;
        transition: transform 0.3s ease;
    }

    .footer-links a:hover {
        color: #10b981;
        padding-left: 5px;
    }

    .footer-links a:hover i {
        transform: translateX(3px);
    }

    .footer-contact {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-contact li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 16px;
        color: #b0b8c0;
        font-size: 14px;
        line-height: 1.6;
    }

    .footer-contact li i {
        color: #10b981;
        font-size: 18px;
        margin-top: 2px;
        flex-shrink: 0;
    }

    .footer-contact li a {
        color: #b0b8c0;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .footer-contact li a:hover {
        color: #10b981;
    }

    .footer-bottom {
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin-top: 20px;
    }

    .footer-copyright {
        color: #b0b8c0;
        font-size: 14px;
    }

    .footer-copyright strong {
        color: #10b981;
    }

    .footer-legal-links {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .footer-legal-links a {
        color: #b0b8c0;
        text-decoration: none;
        font-size: 14px;
        transition: color 0.3s ease;
    }

    .footer-legal-links a:hover {
        color: #10b981;
    }

    .footer-legal-links .separator {
        color: #6b7280;
        margin: 0 4px;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .site-footer {
            padding: 40px 0 20px;
        }

        .footer-content {
            margin-bottom: 30px;
        }

        .footer-section {
            margin-bottom: 30px;
        }

        .footer-bottom {
            text-align: center;
        }

        .footer-legal-links {
            justify-content: center;
            margin-top: 15px;
        }

        .footer-copyright {
            margin-bottom: 15px;
        }
    }
</style>

