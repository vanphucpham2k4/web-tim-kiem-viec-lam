    }

    .map-info {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #ffffff 0%, #f7fafc 100%);
        padding: 12px 18px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        z-index: 1000;
        font-size: 0.9rem;
        font-weight: 600;
        border: 2px solid #e2e8f0;
    }

    .map-info i {
        font-size: 1.2rem;
        margin-right: 5px;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    /* Custom marker popup */
    .leaflet-popup-content-wrapper {
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        border: 2px solid #2545B8;
    }

    .leaflet-popup-content {
        margin: 15px;
        font-size: 0.95rem;
        font-weight: 500;
    }

    /* Marker animation */
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .leaflet-marker-icon.marker-pulse {
        animation: bounce 2s ease-in-out infinite;
    }

    /* Custom marker styling */
    .custom-marker {
        background: transparent;
        border: none;
    }

    .marker-pulse-ring {
        position: absolute;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(37, 69, 184, 0.3);
        animation: ripple 2s ease-out infinite;
        top: 0;
        left: 0;
    }

    @@keyframes ripple {
        0% {
            transform: scale(0.8);
            opacity: 1;
        }
        100% {
            transform: scale(2);
            opacity: 0;
        }
    }

    .marker-pin {
        position: absolute;
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-radius: 50% 50% 50% 0;
        transform: rotate(-45deg);
        top: 5px;
        left: 5px;
        box-shadow: 0 3px 10px rgba(37, 69, 184, 0.4);
    }

    .marker-pin::after {
        content: '';
        position: absolute;
        width: 12px;
        height: 12px;
        background: white;
        border-radius: 50%;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(45deg);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <!-- Quill Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <!-- Quill Editor JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    
    <script>
        var quill;
        
        $(document).ready(function() {
            // Initialize Quill Editor for Mô tả công ty
            quill = new Quill('#editor-container', {
                theme: 'snow',
                modules: {
                    toolbar: [
                        [{ 'header': [1, 2, 3, false] }],
                        ['bold', 'italic', 'underline', 'strike'],
                        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                        [{ 'color': [] }, { 'background': [] }],
                        [{ 'align': [] }],
                        ['link', 'image'],
                        ['clean']
                    ]
                },
                placeholder: 'Viết một vài dòng giới thiệu về công ty, lịch sử phát triển, sứ mệnh, tầm nhìn, sản phẩm/dịch vụ chính...'
            });

            // Update hidden textarea when editor content changes
            quill.on('text-change', function() {
                $('#moTa').val(quill.root.innerHTML);
            });

            // Handle logo file upload
            $('#logoFile').on('change', function(e) {
                var file = e.target.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        var preview = $('#logoPreview');
                        preview.html('<img src="' + e.target.result + '" alt="Logo công ty" />');
                        $('#logo').val(e.target.result); // Store base64 or URL
                    };
                    reader.readAsDataURL(file);
                }
            });

            // Load existing data (if any)
            // loadProfileData();

            // Form submit
            $('#profileForm').on('submit', function(e) {
                e.preventDefault();
                saveProfile();
            });

            // Initialize Map for Company Location
            initCompanyMap();

            // Xử lý khi có hash trong URL để chuyển tab
            const hash = window.location.hash;
            const hasSuccessMessage = @(hasSuccessMessage ? "true" : "false");
            
            // Nếu có hash #baomat hoặc có thông báo thành công, chuyển sang tab bảo mật
            if (hash === '#baomat' || hasSuccessMessage) {
                const baomatTab = document.getElementById('baomat-tab');
                if (baomatTab) {
                    const tab = new bootstrap.Tab(baomatTab);
                    tab.show();
                    if (hasSuccessMessage) {
                        window.location.hash = 'baomat';
                    }
                }
            }
        });

        // Cập nhật hash khi chuyển tab
        document.querySelectorAll('#settingsTabs button[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', function (e) {
                const targetId = e.target.getAttribute('data-bs-target');
                if (targetId === '#baomat') {
                    window.location.hash = 'baomat';
                } else {
                    window.location.hash = '';
                }
            });
        });

        function saveProfile() {
            // Get content from Quill editor
            var moTa = '';
            if (quill) {
                moTa = quill.root.innerHTML;
                $('#moTa').val(moTa);
            }

            // Collect form data
            var formData = {
                tenCongTy: $('#tenCongTy').val(),
                email: $('#email').val(),
                soDienThoai: $('#soDienThoai').val(),
                website: $('#website').val(),
                tinhThanhPho: $('#tinhThanhPho').val(),
                quanHuyen: $('#quanHuyen').val(),
                diaChi: $('#diaChi').val(),
                nguoiDaiDien: $('#nguoiDaiDien').val(),
                chucVu: $('#chucVu').val(),
                soDienThoaiNguoiDaiDien: $('#soDienThoaiNguoiDaiDien').val(),
                logo: $('#logo').val(),
                moTa: moTa,
                latitude: $('#latitude').val(),
                longitude: $('#longitude').val()
            };

            // Validate required fields
            if (!formData.tenCongTy || !formData.email || !formData.soDienThoai || 
                !formData.tinhThanhPho || !formData.diaChi ||
                !formData.nguoiDaiDien || !formData.chucVu || !formData.soDienThoaiNguoiDaiDien) {
                showNotification('Vui lòng điền đầy đủ các trường bắt buộc', 'error');
                return;
            }

            // Validate email format
            var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(formData.email)) {
                showNotification('Email không hợp lệ', 'error');
                return;
            }

            // Here you can add AJAX call to save the data
            console.log('Form data:', formData);
            
            // Show success message
            showNotification('Đã lưu thông tin thành công!', 'success');
        }

        function resetForm() {
            if (confirm('Bạn có chắc muốn hủy? Tất cả thay đổi sẽ không được lưu.')) {
                $('#profileForm')[0].reset();
                if (quill) {
                    quill.setContents([]);
                    $('#moTa').val('');
                }
                $('#logoPreview').html('<span style="color: #cbd5e0;">Chưa có logo</span>');
                $('#logo').val('');
            }
        }

        function showNotification(message, type) {
            var bgColor = type === 'success' ? '#2545B8' : '#e53e3e';
            var notification = $('<div>')
                .css({
                    position: 'fixed',
                    top: '20px',
                    right: '20px',
                    background: bgColor,
                    color: 'white',
                    padding: '15px 25px',
                    borderRadius: '12px',
                    boxShadow: '0 4px 15px rgba(0,0,0,0.2)',
                    zIndex: 9999,
                    fontWeight: '600',
                    animation: 'slideInRight 0.3s ease'
                })
                .text(message)
                .appendTo('body');
            
            setTimeout(function() {
                notification.fadeOut(400, function() {
                    $(this).remove();
                });
            }, 3000);
        }

        // Load profile data (if exists)
        function loadProfileData() {
            // TODO: Load data from server
            // Example:
            // $.ajax({
