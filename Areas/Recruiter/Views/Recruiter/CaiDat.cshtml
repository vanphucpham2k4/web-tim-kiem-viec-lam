                                                        <option value="Phuc Tho">Phúc Thọ</option>
                                                        <option value="Dan Phuong">Đan Phượng</option>
                                                        <option value="Hoai Duc">Hoài Đức</option>
                                                        <option value="Quoc Oai">Quốc Oai</option>
                                                        <option value="Thach That">Thạch Thất</option>
