                                                        <option value="Cat Hai">Cát Hải</option>
                                                        <option value="Bach Long Vi">Bạch Long Vĩ</option>
                                                        <!-- Cần Thơ -->
                                                        <option value="Ninh Kieu">Ninh Kiều</option>
                                                        <option value="O Mon">Ô Môn</option>
                                                        <option value="Binh Thuy">Bình Thủy</option>
                                                        <option value="Cai Rang">Cái Răng</option>
