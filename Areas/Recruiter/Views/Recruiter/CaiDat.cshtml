@model Unicareer.Models.ApplicationUser
@using Microsoft.AspNetCore.Identity
@inject UserManager<Unicareer.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Cài đặt";
    var activeTab = ViewBag.ActiveTab as string ?? "thongtin";
    var roles = await UserManager.GetRolesAsync(Model);
    var roleName = roles.FirstOrDefault() ?? "User";
    var roleDisplay = roleName switch
    {
        "Admin" => "Quản trị viên",
        "NhaTuyenDung" => "Nhà tuyển dụng",
        "UngVien" => "Ứng viên",
        _ => roleName
    };
    var hasSuccessMessage = TempData["ThanhCong"] != null;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="settings-card">
                <div class="settings-header">
                    <h3><i class="bi bi-gear"></i> Cài đặt</h3>
                </div>

                <!-- Tabs Navigation -->
                <ul class="nav nav-tabs settings-tabs" id="settingsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "thongtin" ? "active" : "")" 
                                id="thongtin-tab" 
                                data-bs-toggle="tab" 
                                data-bs-target="#thongtin" 
                                type="button" 
                                role="tab">
                            <i class="bi bi-person"></i> Thông tin tài khoản
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "baomat" ? "active" : "")" 
                                id="baomat-tab" 
                                data-bs-toggle="tab" 
                                data-bs-target="#baomat" 
                                type="button" 
                                role="tab">
                            <i class="bi bi-shield-lock"></i> Bảo mật
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content settings-content" id="settingsTabContent">
                    <!-- Tab 1: Thông tin tài khoản -->
                    <div class="tab-pane fade @(activeTab == "thongtin" ? "show active" : "")" 
                         id="thongtin" 
                         role="tabpanel">
                        <div class="settings-panel">
                            <form id="profileForm">
                                <div class="row">
                                    <div class="col-md-8">
                                        <!-- Thông tin công ty -->
                                        <div class="info-card">
