            //     method: 'GET',
            //     success: function(data) {
            //         $('#tenCongTy').val(data.tenCongTy);
            //         $('#email').val(data.email);
            //         // ... populate other fields
            //         if (data.moTa && quill) {
            //             quill.root.innerHTML = data.moTa;
            //             $('#moTa').val(data.moTa);
            //         }
            //         if (data.logo) {
            //             $('#logoPreview').html('<img src="' + data.logo + '" alt="Logo công ty" />');
            //             $('#logo').val(data.logo);
            //         }
            //         if (data.latitude && data.longitude && companyMap && companyMarker) {
            //             var lat = parseFloat(data.latitude);
            //             var lng = parseFloat(data.longitude);
            //             companyMap.setView([lat, lng], 15);
            //             companyMarker.setLatLng([lat, lng]);
            //             $('#latitude').val(lat.toFixed(6));
            //             $('#longitude').val(lng.toFixed(6));
            //             $('#currentCoords').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
            //         }
            //     }
            // });
        }

        // Map variables
        var companyMap = null;
        var companyMarker = null;

        // Initialize Company Map
        function initCompanyMap() {
            if (typeof L === 'undefined') {
                console.log('Leaflet chưa được load, đợi thêm...');
                setTimeout(initCompanyMap, 500);
                return;
            }

            try {
                var mapLat = parseFloat($('#latitude').val()) || 21.028511;
                var mapLng = parseFloat($('#longitude').val()) || 105.804817;

                // Initialize Leaflet Map
                companyMap = L.map('mapCompany', {
                    preferCanvas: false
                }).setView([mapLat, mapLng], 13);
                
                // Add tile layer
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                    maxZoom: 19
                }).addTo(companyMap);

                // Invalidate size sau khi map được tạo để đảm bảo hiển thị đúng
                setTimeout(function() {
                    if (companyMap) {
                        companyMap.invalidateSize();
                    }
                }, 200);

                // Fix Leaflet default marker icon path
                delete L.Icon.Default.prototype._getIconUrl;
                L.Icon.Default.mergeOptions({
                    iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
                    iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
                    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png'
                });

                // Create custom marker icon with pulse effect
                var customIcon = L.divIcon({
                    className: 'custom-marker',
                    html: '<div class="marker-pulse-ring"></div><div class="marker-pin"></div>',
                    iconSize: [40, 40],
                    iconAnchor: [20, 40],
                    popupAnchor: [0, -40]
                });

                // Create draggable marker
                companyMarker = L.marker([mapLat, mapLng], {
                    draggable: true,
                    icon: customIcon,
                    title: 'Kéo tôi để chọn vị trí công ty'
                }).addTo(companyMap);

                // Add popup to marker
                companyMarker.bindPopup('<strong>📍 Vị trí công ty</strong><br>Kéo marker để điều chỉnh vị trí chính xác').openPopup();

                // Update coordinates when marker is dragged
                companyMarker.on('dragend', function(e) {
                    var lat = e.target.getLatLng().lat;
                    var lng = e.target.getLatLng().lng;
                    $('#latitude').val(lat.toFixed(6));
                    $('#longitude').val(lng.toFixed(6));
                    $('#currentCoords').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                });

                // Update marker when clicking on map
                companyMap.on('click', function(e) {
                    var lat = e.latlng.lat;
                    var lng = e.latlng.lng;
                    
                    companyMarker.setLatLng([lat, lng]);
                    $('#latitude').val(lat.toFixed(6));
                    $('#longitude').val(lng.toFixed(6));
                    $('#currentCoords').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                    
                    // Reverse geocoding để lấy địa chỉ
                    $.ajax({
                        url: 'https://nominatim.openstreetmap.org/reverse',
                        data: {
                            lat: lat,
                            lon: lng,
                            format: 'json',
                            addressdetails: 1
                        },
                        success: function(data) {
                            if (data && data.address) {
                                var address = '';
                                if (data.address.road) address += data.address.road + ', ';
                                if (data.address.suburb || data.address.neighbourhood) address += (data.address.suburb || data.address.neighbourhood) + ', ';
                                if (data.address.city || data.address.town) address += (data.address.city || data.address.town);
                                if (address) {
                                    $('#diaChi').val(address.trim());
                                }
                            }
                        }
                    });
                });

                // Geocoding khi nhập địa chỉ
                var geocodeTimeout;
                $('#diaChi').on('input', function() {
                    clearTimeout(geocodeTimeout);
                    var address = $(this).val();
                    
                    if (address.length > 10) {
                        geocodeTimeout = setTimeout(function() {
                            $.ajax({
                                url: 'https://nominatim.openstreetmap.org/search',
                                data: {
                                    q: address + ', ' + $('#tinhThanhPho').val() + ', Vietnam',
                                    format: 'json',
                                    limit: 1
                                },
                                success: function(data) {
                                    if (data && data.length > 0) {
                                        var lat = parseFloat(data[0].lat);
                                        var lon = parseFloat(data[0].lon);
                                        
                                        companyMap.setView([lat, lon], 16);
                                        companyMarker.setLatLng([lat, lon]);
                                        $('#latitude').val(lat.toFixed(6));
                                        $('#longitude').val(lon.toFixed(6));
                                        $('#currentCoords').text(lat.toFixed(6) + ', ' + lon.toFixed(6));
                                    }
                                }
                            });
                        }, 1000);
                    }
                });

                // Update map when city changes
                $('#tinhThanhPho').on('change', function() {
                    var city = $(this).val();
                    var coordinates = {
                        'Ha Noi': [21.028511, 105.804817],
                        'TP Ho Chi Minh': [10.8231, 106.6297],
                        'Da Nang': [16.0544, 108.2022],
                        'Hai Phong': [20.8449, 106.6881],
                        'Can Tho': [10.0452, 105.7469]
                    };
                    
                    if (coordinates[city] && companyMap) {
                        companyMap.setView(coordinates[city], 13);
                        var lat = coordinates[city][0];
                        var lng = coordinates[city][1];
                        companyMarker.setLatLng([lat, lng]);
                        $('#latitude').val(lat.toFixed(6));
                        $('#longitude').val(lng.toFixed(6));
                        $('#currentCoords').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                    }
                });

            } catch (error) {
                console.error('Lỗi khi khởi tạo map:', error);
            }
        }

        // Invalidate map size when tab is shown
        document.querySelectorAll('#settingsTabs button[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', function (e) {
                const targetId = e.target.getAttribute('data-bs-target');
                if (targetId === '#thongtin' && companyMap) {
                    setTimeout(function() {
                        companyMap.invalidateSize();
                    }, 300);
                }
            });
        });
    </script>
    
    <style>
        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
}

