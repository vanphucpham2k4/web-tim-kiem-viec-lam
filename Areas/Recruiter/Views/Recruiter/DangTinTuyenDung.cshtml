@model Unicareer.Models.TinTuyenDung

@{
    ViewData["Title"] = "Dang tuyen dung";
}

<div class="row">
    <div class="col-12">
        <div class="form-section">
            <form asp-action="DangTinTuyenDung" method="post" enctype="multipart/form-data" id="formDangTin">
                
                <!-- Ten viec lam -->
                <div class="mb-4">
                    <label class="form-label required-label">Ten viec lam</label>
                    <input type="text" class="form-control" name="TenViecLam" required 
                           placeholder="Vi du: Tuyen dung Lap trinh vien Full-stack">
                </div>

                <!-- Mo ta cong viec -->
                <div class="form-section">
                    <h4><i class="bi bi-file-text"></i> Mo ta cong viec</h4>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required-label">Nganh Nghe</label>
                            <select class="form-select" name="NganhNghe" required>
                                <option value="">Chon nganh nghe</option>
                                <option value="Cong nghe thong tin">Cong nghe thong tin</option>
                                <option value="Kinh doanh">Kinh doanh</option>
                                <option value="Ke toan - Tai chinh">Ke toan - Tai chinh</option>
                                <option value="Nhan su">Nhan su</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Thiet ke do hoa">Thiet ke do hoa</option>
                                <option value="Truyen thong - Media">Truyen thong - Media</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nganh nghe chi tiet</label>
                            <select class="form-select" name="NganhNgheChiTiet">
                                <option value="">Chon nganh nghe chi tiet</option>
                                <option value="Web Developer">Web Developer</option>
                                <option value="Mobile Developer">Mobile Developer</option>
                                <option value="Data Analyst">Data Analyst</option>
                                <option value="UI/UX Designer">UI/UX Designer</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required-label">Hinh thuc lam viec</label>
                            <select class="form-select" name="LoaiCongViec" required>
                                <option value="">Chon hinh thuc</option>
                                <option value="Full-time">Full-time</option>
                                <option value="Part-time">Part-time</option>
                                <option value="Internship">Internship</option>
                                <option value="Remote">Remote</option>
                                <option value="Hybrid">Hybrid</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kinh nghiem lam viec</label>
                            <select class="form-select" name="KinhNghiem">
                                <option value="">Chon kinh nghiem</option>
                                <option value="Khong yeu cau">Khong yeu cau</option>
                                <option value="Duoi 1 nam">Duoi 1 nam</option>
                                <option value="1-2 nam">1-2 nam</option>
                                <option value="2-5 nam">2-5 nam</option>
                                <option value="Tren 5 nam">Tren 5 nam</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required-label">Vi tri</label>
                            <select class="form-select" name="ViTri" required>
                                <option value="">Chon vi tri</option>
                                <option value="Nhan vien">Nhan vien</option>
                                <option value="Truong nhom">Truong nhom</option>
                                <option value="Quan ly">Quan ly</option>
                                <option value="Giam doc">Giam doc</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngoai ngu</label>
                            <select class="form-select" name="NgoaiNgu">
                                <option value="">Chon ngoai ngu</option>
                                <option value="Khong yeu cau">Khong yeu cau</option>
                                <option value="Tieng Anh">Tieng Anh</option>
                                <option value="Tieng Nhat">Tieng Nhat</option>
                                <option value="Tieng Han">Tieng Han</option>
                                <option value="Tieng Trung">Tieng Trung</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tu khoa</label>
                            <input type="text" class="form-control" name="TuKhoa" 
                                   placeholder="Chon hoac nhap tu khoa roi nhan enter.">
                            <small class="text-muted">Vi du: ReactJS, NodeJS, .NET Core</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ky nang</label>
                            <input type="text" class="form-control" name="KyNang" 
                                   placeholder="Chon ky nang.">
                            <small class="text-muted">Vi du: Teamwork, Communication, Problem Solving</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label required-label">Mo ta cong viec</label>
                        <textarea class="form-control ckeditor" name="MoTa" rows="5" required></textarea>
                    </div>
                </div>

                <!-- Yeu cau cong viec -->
                <div class="form-section">
                    <h4><i class="bi bi-clipboard-check"></i> Yeu cau cong viec</h4>
                    <div class="mb-3">
                        <textarea class="form-control ckeditor" name="YeuCau" rows="5" required></textarea>
                    </div>
                </div>

                <!-- Quyen loi -->
                <div class="form-section">
                    <h4><i class="bi bi-gift"></i> Quyen loi</h4>
                    
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Muc Luong Thap Nhat (Trieu dong)</label>
                            <input type="number" class="form-control" name="MucLuongThapNhat" min="0" value="0">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Muc Luong Cao Nhat (Trieu dong)</label>
                            <input type="number" class="form-control" name="MucLuongCaoNhat" min="0" value="0">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Thong tin them</label>
                        <textarea class="form-control ckeditor" name="QuyenLoi" rows="4"></textarea>
                        <small class="text-muted">Cac quyen loi khac nhu: bao hiem, thuong, du lich...</small>
                    </div>
                </div>

                <!-- Thong Tin Lien He -->
                <div class="form-section">
                    <h4><i class="bi bi-telephone"></i> Thong Tin Lien He</h4>
                    
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nguoi lien he</label>
                            <input type="text" class="form-control" name="NguoiLienHe" 
                                   placeholder="Nguyen Van A">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label required-label">Email lien he</label>
                            <input type="email" class="form-control" name="EmailLienHe" required
                                   placeholder="tuyendung@company.com">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Dien thoai lien he</label>
                            <input type="tel" class="form-control" name="SDTLienHe" 
                                   placeholder="0312345656">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required-label">Lam viec o Tinh/Thanh pho</label>
                            <select class="form-select" name="TinhThanhPho" id="tinhThanhPho" required>
                                <option value="">Chon tinh/thanh pho</option>
                                <option value="Ha Noi">Ha Noi</option>
                                <option value="TP Ho Chi Minh">TP Ho Chi Minh</option>
                                <option value="Da Nang">Da Nang</option>
                                <option value="Hai Phong">Hai Phong</option>
                                <option value="Can Tho">Can Tho</option>
                                <option value="Binh Duong">Binh Duong</option>
                                <option value="Dong Nai">Dong Nai</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phuong/Xa</label>
                            <select class="form-select" name="PhuongXa" id="phuongXa">
                                <option value="">Chon phuong/xa</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label required-label">Dia chi lam viec</label>
                        <input type="text" class="form-control" name="DiaChiLamViec" required
                               id="diaChiInput" placeholder="123 Nguyen Hue, Quan 1">
                        <small class="text-muted">
                            De tang do tin cay cua dia chi, hay sua vi tri dang tin tren ban do bang cach 
                            <i class="bi bi-geo-alt-fill text-primary"></i> keo den dung vi tri lam viec
                        </small>
                    </div>

                    <!-- Map -->
                    <div id="map"></div>
                </div>

                <!-- Anh van phong/cua hang -->
                <div class="form-section">
                    <h4><i class="bi bi-images"></i> Anh van phong/cua hang</h4>
                    <div class="mb-3">
                        <input type="file" class="form-control" name="AnhVanPhong" 
                               accept="image/*" multiple>
                        <small class="text-muted">Co the chon nhieu anh. Dinh dang: JPG, PNG, GIF</small>
                    </div>
                </div>

                <!-- Han tuyen dung -->
                <div class="form-section">
                    <h4><i class="bi bi-calendar-event"></i> Han tuyen dung</h4>
                    <div class="mb-3">
                        <input type="date" class="form-control" name="HanNop" required
                               min="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <!-- Submit buttons -->
                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary btn-lg px-5">
                        <i class="bi bi-check-circle"></i> Dang tin tuyen dung
                    </button>
                    <button type="button" class="btn btn-secondary btn-lg ms-2 px-5" onclick="window.history.back()">
                        <i class="bi bi-x-circle"></i> Huy
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize CKEditor 5 for all textareas with class ckeditor
            if (typeof ClassicEditor !== 'undefined') {
                $('.ckeditor').each(function() {
                    var textarea = this;
                    ClassicEditor
                        .create(textarea, {
                            toolbar: {
                                items: [
                                    'heading', '|',
                                    'bold', 'italic', 'underline', '|',
                                    'link', '|',
                                    'bulletedList', 'numberedList', '|',
                                    'blockQuote', '|',
                                    'undo', 'redo'
                                ]
                            },
                            language: 'vi'
                        })
                        .catch(error => {
                            console.error('CKEditor initialization error:', error);
                        });
                });
            }

            // Initialize Leaflet Map
            var map = L.map('map').setView([21.028511, 105.804817], 13); // Ha Noi coordinates
            
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
            }).addTo(map);

            var marker = L.marker([21.028511, 105.804817], {
                draggable: true
            }).addTo(map);

            // Update marker position when dragged
            marker.on('dragend', function(e) {
                var position = marker.getLatLng();
                console.log('New position:', position);
                // TODO: Save lat/lng to hidden fields
            });

            // Update map when city changes
            $('#tinhThanhPho').change(function() {
                var city = $(this).val();
                var coordinates = {
                    'Ha Noi': [21.028511, 105.804817],
                    'TP Ho Chi Minh': [10.762622, 106.660172],
                    'Da Nang': [16.047079, 108.206230],
                    'Hai Phong': [20.844892, 106.687973],
                    'Can Tho': [10.045162, 105.746857]
                };
                
                if (coordinates[city]) {
                    map.setView(coordinates[city], 13);
                    marker.setLatLng(coordinates[city]);
                }

                // Update districts based on city
                updateDistricts(city);
            });

            function updateDistricts(city) {
                var districts = {
                    'Ha Noi': ['Ba Dinh', 'Hoan Kiem', 'Dong Da', 'Hai Ba Trung', 'Cau Giay', 'Tay Ho', 'Thanh Xuan', 'Long Bien'],
                    'TP Ho Chi Minh': ['Quan 1', 'Quan 2', 'Quan 3', 'Quan 4', 'Quan 5', 'Quan 7', 'Tan Binh', 'Binh Thanh', 'Phu Nhuan'],
                    'Da Nang': ['Hai Chau', 'Thanh Khe', 'Son Tra', 'Ngu Hanh Son', 'Lien Chieu', 'Cam Le', 'Hoa Vang'],
                    'Hai Phong': ['Hong Bang', 'Ngo Quyen', 'Le Chan', 'Hai An', 'Kien An', 'Do Son'],
                    'Can Tho': ['Ninh Kieu', 'Binh Thuy', 'Cai Rang', 'O Mon', 'Thot Not']
                };

                var $phuongXa = $('#phuongXa');
                $phuongXa.empty();
                $phuongXa.append('<option value="">Chon phuong/xa</option>');

                if (districts[city]) {
                    districts[city].forEach(function(district) {
                        $phuongXa.append('<option value="' + district + '">' + district + '</option>');
                    });
                }
            }

            // Form validation
            $('#formDangTin').submit(function(e) {
                var valid = true;
                
                // Check required fields
                if (!$('input[name="TenViecLam"]').val()) {
                    alert('Vui long nhap ten viec lam!');
                    valid = false;
                }

                if (!valid) {
                    e.preventDefault();
                }
            });
        });
    </script>
}

