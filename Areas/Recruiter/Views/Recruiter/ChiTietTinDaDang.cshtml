                if (editorsInitialized) {
                    // Sync editor data to textarea
                    Object.keys(editors).forEach(function(fieldName) {
                        if (editors[fieldName]) {
                            var textareaId = '';
                            if (fieldName === 'MoTa') textareaId = 'editMoTa';
                            else if (fieldName === 'YeuCau') textareaId = 'editYeuCau';
                            else if (fieldName === 'QuyenLoi') textareaId = 'editQuyenLoi';
                            
                            if (textareaId) {
                                var textarea = document.getElementById(textareaId);
                                if (textarea) {
                                    textarea.value = editors[fieldName].root.innerHTML;
                                }
                            }
                        }
                    });
                }

                // Validate form
                var isValid = true;
                $('.form-control-edit').each(function() {
                    if ($(this).attr('required') && !$(this).val()) {
                        isValid = false;
                        $(this).css('border-color', '#f56565');
                    } else {
                        $(this).css('border-color', '#e2e8f0');
                    }
                });

                // Validate editor
                if (editorsInitialized) {
                    var moTaContent = editors['MoTa'] ? editors['MoTa'].getText().trim() : '';
                    var yeuCauContent = editors['YeuCau'] ? editors['YeuCau'].getText().trim() : '';
                    var quyenLoiContent = editors['QuyenLoi'] ? editors['QuyenLoi'].getText().trim() : '';
                    
                    // Kiểm tra nếu chỉ có thẻ HTML rỗng hoặc chỉ có khoảng trắng
                    if (!moTaContent || moTaContent === '') {
                        isValid = false;
                        $('#editMoTa').closest('.mb-3').find('label').css('color', '#f56565');
                    }
                    if (!yeuCauContent || yeuCauContent === '') {
                        isValid = false;
