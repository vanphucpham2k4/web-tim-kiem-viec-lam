            // Hàm hiển thị thông báo
            window.showNotification = function(message, type) {
                var bgColor = (type === 'success') ? '#48bb78' : '#f56565';
                var notification = $('<div>')
                    .css({
                        position: 'fixed',
                        top: '20px',
                        right: '20px',
                        background: bgColor,
                        color: 'white',
                        padding: '15px 25px',
                        borderRadius: '12px',
                        boxShadow: '0 4px 15px rgba(0,0,0,0.2)',
                        zIndex: 9999,
                        fontWeight: '600',
                        maxWidth: '400px'
                    })
                    .text(message)
                    .appendTo('body');
                
                setTimeout(function() {
                    notification.fadeOut(400, function() {
                        $(this).remove();
                    });
                }, 3000);
            };

            // Initialize Leaflet Map nếu có tọa độ
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <text>
                var mapLat = @Model.Latitude.Value;
                var mapLng = @Model.Longitude.Value;
                var addressText = '@Html.Raw(!string.IsNullOrEmpty(Model.DiaChiLamViec) ? Model.DiaChiLamViec.Replace("'", "\\'").Replace("\"", "\\\"") : "Địa chỉ làm việc")';
                
                // Hàm khởi tạo map
                function initMap() {
                    if (typeof L === 'undefined') {
                        console.log('Leaflet chưa được load, đợi thêm...');
                        setTimeout(initMap, 500);
                        return;
                    }

                    try {
                        // Initialize Leaflet Map
                        var map = L.map('map').setView([mapLat, mapLng], 15);
                        
                        // Add tile layer
                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                            maxZoom: 19
                        }).addTo(map);

                        // Fix Leaflet default marker icon path
                        delete L.Icon.Default.prototype._getIconUrl;
                        L.Icon.Default.mergeOptions({
                            iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
                            iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
                            shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png'
                        });

                        // Create custom marker icon with pulse effect
                        var customIcon = L.divIcon({
                            className: 'custom-marker',
                            html: '<div class="marker-pulse-ring"></div><div class="marker-pin"></div>',
                            iconSize: [40, 40],
                            iconAnchor: [20, 40],
                            popupAnchor: [0, -40]
                        });

                        // Create marker (không draggable vì chỉ xem)
                        var marker = L.marker([mapLat, mapLng], {
                            icon: customIcon,
                            title: 'Vị trí làm việc'
                        }).addTo(map);

                        // Add popup to marker
                        marker.bindPopup('<strong>📍 Vị trí làm việc</strong><br>' + addressText).openPopup();
                    } catch (error) {
                        console.error('Lỗi khi khởi tạo map:', error);
                    }
                }

                // Khởi tạo map sau khi document ready
                initMap();
                </text>
            }
        });

        // Lightbox functionality for image gallery
        $(document).ready(function() {
            // Create lightbox HTML if it doesn't exist
            if ($('#imageLightbox').length === 0) {
                $('body').append(`
                    <div id="imageLightbox" class="lightbox">
                        <div class="lightbox-content">
                            <span class="lightbox-close">&times;</span>
                            <div class="lightbox-nav lightbox-prev">
                                <i class="bi bi-chevron-left"></i>
                            </div>
                            <div class="lightbox-nav lightbox-next">
                                <i class="bi bi-chevron-right"></i>
                            </div>
                            <img id="lightboxImage" src="" alt="Ảnh văn phòng/cửa hàng">
                            <div class="lightbox-counter">
                                <span id="lightboxCurrent">1</span> / <span id="lightboxTotal">1</span>
                            </div>
                        </div>
                    </div>
                `);
            }

            var currentImageIndex = 0;
            var images = [];

            // Initialize images array from gallery
            function initImages() {
                images = [];
                $('.gallery-item').each(function() {
                    var imageSrc = $(this).data('image') || $(this).find('img').attr('src');
                    if (imageSrc) {
                        images.push(imageSrc);
                    }
                });
                $('#lightboxTotal').text(images.length);
            }

            // Open lightbox
            function openLightbox(index) {
                if (images.length === 0) return;
                currentImageIndex = index;
                updateLightboxImage();
                $('#imageLightbox').addClass('active');
                $('body').css('overflow', 'hidden');
            }

            // Close lightbox
            function closeLightbox() {
                $('#imageLightbox').removeClass('active');
                $('body').css('overflow', '');
            }

            // Update lightbox image
            function updateLightboxImage() {
                if (images.length === 0) return;
                var imageSrc = images[currentImageIndex];
                $('#lightboxImage').attr('src', imageSrc);
                $('#lightboxCurrent').text(currentImageIndex + 1);
            }

            // Next image
            function nextImage() {
                if (images.length === 0) return;
                currentImageIndex = (currentImageIndex + 1) % images.length;
                updateLightboxImage();
            }

            // Previous image
            function prevImage() {
                if (images.length === 0) return;
                currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
                updateLightboxImage();
            }

            // Initialize images on page load
            initImages();

            // Click on gallery item to open lightbox
            $(document).on('click', '.gallery-item', function() {
                var imageSrc = $(this).data('image') || $(this).find('img').attr('src');
                if (imageSrc) {
                    initImages(); // Re-initialize in case images changed
                    var index = images.indexOf(imageSrc);
                    if (index !== -1) {
                        openLightbox(index);
                    } else {
                        // If image not found in array, add it and open
                        images = [imageSrc];
                        openLightbox(0);
                    }
                }
            });

            // Close lightbox on close button click
            $(document).on('click', '.lightbox-close', function(e) {
                e.stopPropagation();
                closeLightbox();
            });

            // Close lightbox on background click
            $(document).on('click', '#imageLightbox', function(e) {
                if ($(e.target).is('#imageLightbox')) {
                    closeLightbox();
                }
            });

            // Next image on next button click
            $(document).on('click', '.lightbox-next', function(e) {
                e.stopPropagation();
                nextImage();
            });

            // Previous image on prev button click
            $(document).on('click', '.lightbox-prev', function(e) {
                e.stopPropagation();
                prevImage();
            });

            // Keyboard navigation
            $(document).on('keydown', function(e) {
                if ($('#imageLightbox').hasClass('active')) {
                    if (e.key === 'Escape') {
                        closeLightbox();
                    } else if (e.key === 'ArrowRight') {
                        nextImage();
                    } else if (e.key === 'ArrowLeft') {
                        prevImage();
                    }
                }
            });

            // Prevent lightbox content click from closing
            $(document).on('click', '.lightbox-content', function(e) {
                e.stopPropagation();
            });

            // Touch/swipe support for mobile
            var touchStartX = 0;
            var touchEndX = 0;

            $(document).on('touchstart', '#lightboxImage', function(e) {
                touchStartX = e.originalEvent.touches[0].clientX;
            });

            $(document).on('touchend', '#lightboxImage', function(e) {
                touchEndX = e.originalEvent.changedTouches[0].clientX;
                handleSwipe();
            });

            function handleSwipe() {
                if (touchEndX < touchStartX - 50) {
                    // Swipe left - next image
                    nextImage();
                }
                if (touchEndX > touchStartX + 50) {
                    // Swipe right - previous image
                    prevImage();
                }
            }
        });

        // Xử lý phân trang và bộ lọc cho tab Danh sách ứng tuyển
        var isPaginationClick = false;
        
        // Hàm điều hướng đến trang
        window.goToPage = function(pageNumber) {
            isPaginationClick = true;
            $('#pageNumberInput').val(pageNumber);
            $('#filterForm').submit();
        };
        
        // Khi thay đổi filter, reset về trang 1
        $('#trangThaiFilter').on('change', function() {
            $('#pageNumberInput').val(1);
            $('#filterForm').submit();
        });
        
        // Khi submit form tìm kiếm, reset về trang 1 (chỉ khi không phải là click phân trang)
        $('#filterForm').on('submit', function(e) {
            if (!isPaginationClick) {
                $('#pageNumberInput').val(1);
            }
            isPaginationClick = false; // Reset flag
        });
        
        // Khi nhấn nút tìm kiếm, reset về trang 1
        $('#filterForm button[type="submit"]').on('click', function() {
            isPaginationClick = false;
        });

        // Hàm xem chi tiết đơn ứng tuyển
        window.xemChiTietDonUngTuyen = function(maDon) {
            $.ajax({
                url: '@Url.Action("ChiTietDonUngTuyen", "Recruiter")',
                type: 'GET',
                data: { id: maDon },
                success: function(response) {
                    if (response.success && response.data) {
                        var data = response.data;
                        var modalContent = `
                            <div class="modal fade" id="chiTietDonModal" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title"><i class="bi bi-file-earmark-person"></i> Chi tiết đơn ứng tuyển</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row mb-3">
                                                <div class="col-md-6">
                                                    <p><strong>Mã đơn:</strong> #${data.maTinUngTuyen}</p>
                                                    <p><strong>Họ tên:</strong> ${data.hoTen}</p>
                                                    <p><strong>Email:</strong> <a href="mailto:${data.email}">${data.email}</a></p>
                                                    <p><strong>SĐT:</strong> <a href="tel:${data.soDienThoai}">${data.soDienThoai}</a></p>
                                                </div>
                                                <div class="col-md-6">
                                                    <p><strong>Vị trí ứng tuyển:</strong> ${data.viTriUngTuyen || data.tenViecLam}</p>
                                                    <p><strong>Công ty:</strong> ${data.congTy}</p>
                                                    <p><strong>Ngày ứng tuyển:</strong> ${data.ngayUngTuyen}</p>
                                                    <p><strong>Trạng thái:</strong> <span class="badge bg-primary">${data.trangThaiXuLy}</span></p>
                                                </div>
                                            </div>
                                            ${data.linkCV ? `<p><strong>CV:</strong> <a href="${data.linkCV}" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i> Tải CV</a></p>` : ''}
                                            ${data.ghiChu ? `<div class="mt-3"><strong>Ghi chú:</strong><p class="text-muted">${data.ghiChu}</p></div>` : ''}
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                        
                        // Xóa modal cũ nếu có
                        $('#chiTietDonModal').remove();
                        
                        // Thêm modal mới vào body
                        $('body').append(modalContent);
                        
                        // Hiển thị modal
                        var modal = new bootstrap.Modal(document.getElementById('chiTietDonModal'));
                        modal.show();
                        
                        // Xóa modal khi đóng
                        $('#chiTietDonModal').on('hidden.bs.modal', function() {
                            $(this).remove();
                        });
                    } else {
                        alert('Không thể tải thông tin đơn ứng tuyển: ' + (response.message || 'Có lỗi xảy ra'));
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra khi tải thông tin đơn ứng tuyển!');
                }
            });
        };

        // Hàm mở modal cập nhật trạng thái
        window.capNhatTrangThaiDonUngTuyen = function(maDon) {
            $('#maDonUngTuyen').val(maDon);
            $('#trangThaiMoi').val('');
            $('#ghiChu').val('');
            var modal = new bootstrap.Modal(document.getElementById('trangThaiModal'));
            modal.show();
        };

        // Hàm lưu trạng thái
        window.luuTrangThaiDonUngTuyen = function() {
            var maDon = $('#maDonUngTuyen').val();
            var trangThaiMoi = $('#trangThaiMoi').val();
            var ghiChu = $('#ghiChu').val();
            
            if (!trangThaiMoi) {
                showNotification('Vui lòng chọn trạng thái mới!', 'error');
                return;
            }
            
            // Disable nút để tránh double submit
            var btnLuu = $('button[onclick="luuTrangThaiDonUngTuyen()"]');
            btnLuu.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...');
            
            // Gửi request cập nhật trạng thái lên server
            $.ajax({
                url: '@Url.Action("CapNhatTrangThaiDonUngTuyen", "Recruiter", new { area = "Recruiter" })',
                type: 'POST',
                data: {
                    maDonUngTuyen: maDon,
                    trangThaiMoi: trangThaiMoi,
                    ghiChu: ghiChu || null,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // Hiển thị thông báo thành công
                        showNotification(response.message || 'Cập nhật trạng thái thành công!', 'success');
                        
                        // Đóng modal
                        var modal = bootstrap.Modal.getInstance(document.getElementById('trangThaiModal'));
                        modal.hide();
                        
                        // Lấy URL hiện tại và giữ nguyên các query parameters
                        var currentUrl = new URL(window.location.href);
                        // Đảm bảo có tab parameter để tự động chuyển sang tab "Danh sách ứng tuyển"
                        currentUrl.searchParams.set('tab', 'applications');
                        
                        // Reload trang với URL mới sau 1 giây để người dùng thấy thông báo
                        setTimeout(function() {
                            window.location.href = currentUrl.toString();
                        }, 1000);
                    } else {
                        showNotification(response.message || 'Có lỗi xảy ra khi cập nhật trạng thái!', 'error');
                        btnLuu.prop('disabled', false).html('Lưu thay đổi');
                    }
                },
                error: function(xhr) {
                    var errorMessage = 'Có lỗi xảy ra khi cập nhật trạng thái';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMessage = xhr.responseJSON.message;
                    }
                    showNotification(errorMessage, 'error');
                    btnLuu.prop('disabled', false).html('Lưu thay đổi');
                }
            });
        };
    </script>
}

