            // Nếu có lỗi validation, tự động chuyển sang chế độ chỉnh sửa
            @if (!ViewData.ModelState.IsValid)
            {
                <text>
                // Chuyển sang chế độ chỉnh sửa
                $('#content').removeClass('view-mode').addClass('edit-mode');
                $('#btnEdit').hide();
                $('#btnCancel').show();
                $('#btnSave').show();
                
                // Khởi tạo editor
