                    const selectedProvinceCode = $selectedOption.data('code');
                    // Đọc từ hidden input để tránh HTML encoding issues
                    const selectedWardName = $('#hiddenPhuongXa').val() || '';
                    
                    console.log('Loading wards - Province Code:', selectedProvinceCode, 'Ward Name:', selectedWardName);
                    
                    if (selectedProvinceCode) {
                        loadWardsByProvinceForEdit(selectedProvinceCode, selectedWardName);
                    } else {
                        console.warn('No province code found for selected province');
                    }
                }

                // Thử load ngay lập tức
                setTimeout(loadWardsOnEdit, 100);
                
                // Thử lại sau khi DOM đã render xong
                setTimeout(loadWardsOnEdit, 300);
                
                // Khởi tạo map cho edit mode - đợi một chút để đảm bảo DOM đã render xong
                setTimeout(function() {
                    initEditMap();
                    
                    // Load quận/huyện lần nữa sau khi map đã khởi tạo
                    loadWardsOnEdit();
                }, 600);
            });

            // Nút Hủy thay đổi
            $('#btnCancel').on('click', function() {
                // Khôi phục giá trị ban đầu cho editor
                if (editorsInitialized) {
                    if (editors['MoTa']) {
