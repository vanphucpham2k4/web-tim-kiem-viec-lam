                    initEditors();
                    editorsInitialized = true;
                }
                
                // Load quận/huyện ngay lập tức khi chuyển sang edit mode
                function loadWardsOnValidationError() {
                    const $selectedOption = $('#editTinhThanhPho option:selected');
                    const selectedProvinceCode = $selectedOption.data('code');
                    // Đọc từ hidden input để tránh HTML encoding issues
                    const selectedWardName = $('#hiddenPhuongXa').val() || '';
                    
                    console.log('Loading wards (validation error) - Province Code:', selectedProvinceCode, 'Ward Name:', selectedWardName);
                    
                    if (selectedProvinceCode) {
