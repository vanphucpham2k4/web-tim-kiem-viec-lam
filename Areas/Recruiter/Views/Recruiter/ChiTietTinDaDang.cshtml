    #filterForm .form-select:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    #filterForm .btn-outline-primary {
        border-color: #10b981;
        color: #10b981;
        transition: all 0.3s ease;
    }

    #filterForm .btn-outline-primary:hover {
        background: #10b981;
        color: white;
        transform: translateY(-2px);
    }

    .pagination {
        margin-top: 20px;
    }

    .pagination .page-link {
        color: #10b981;
        border-color: #e2e8f0;
        padding: 10px 15px;
        transition: all 0.3s ease;
    }

    .pagination .page-link:hover {
        background: #10b981;
        color: white;
        border-color: #10b981;
        transform: translateY(-2px);
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-color: #10b981;
        color: white;
    }

    .pagination .page-item.disabled .page-link {
        color: #a0aec0;
        background: #f7fafc;
        border-color: #e2e8f0;
        cursor: not-allowed;
    }
</style>

<!-- Hidden element for success message -->
@if (TempData["ThanhCong"] != null)
{
    <div id="successMessage" style="display: none;">@TempData["ThanhCong"]</div>
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-file-earmark-text"></i> Chi tiết tin tuyển dụng</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Recruiter")">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("TinDaDang", "Recruiter")">Tin đã đăng</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
        <a href="@Url.Action("TinDaDang", "Recruiter")" class="back-button">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<!-- Thông tin cơ bản -->
<div class="row mb-4">
    <div class="col-12">
        <div class="info-card">
            <h5><i class="bi bi-info-circle"></i> Thông tin cơ bản</h5>
            <div class="row">
                <div class="col-md-6">
                    <div class="info-item">
                        <span class="info-label">Mã tin:</span>
                        <span class="info-value"><strong>#@Model.MaTinTuyenDung</strong></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Tên việc làm:</span>
                        <span class="info-value"><strong>@Model.TenViecLam</strong></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Công ty:</span>
                        <span class="info-value">@Model.CongTy</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Ngành nghề:</span>
                        <span class="info-value">@Model.NganhNghe</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Loại công việc:</span>
                        <span class="info-value">
                            <span class="badge-custom badge-primary">@Model.LoaiCongViec</span>
                        </span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-item">
                        <span class="info-label">Vị trí:</span>
                        <span class="info-value">@Model.ViTri</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Kinh nghiệm:</span>
                        <span class="info-value">@Model.KinhNghiem</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Ngày đăng:</span>
                        <span class="info-value">@Model.NgayDang.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Hạn nộp:</span>
                        <span class="info-value">
                            @Model.HanNop.ToString("dd/MM/yyyy")
                            @if (Model.HanNop >= DateTime.Now)
                            {
                                <span class="badge-custom badge-success ms-2">Đang tuyển</span>
                            }
                            else
                            {
                                <span class="badge-custom badge-secondary ms-2">Hết hạn</span>
                            }
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Lượt ứng tuyển:</span>
                        <span class="info-value">
                            @if (Model.SoLuongUngTuyen > 0)
                            {
                                <span class="badge-custom badge-info">@Model.SoLuongUngTuyen</span>
                            }
                            else
                            {
                                <span class="badge-custom badge-secondary">0</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="row">
    <div class="col-12">
        <div class="info-card">
            <ul class="nav nav-tabs" id="detailTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="content-tab" data-bs-toggle="tab" data-bs-target="#content" type="button" role="tab">
                        <i class="bi bi-file-text"></i> Nội dung tin
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="applications-tab" data-bs-toggle="tab" data-bs-target="#applications" type="button" role="tab">
                        <i class="bi bi-people"></i> Danh sách ứng tuyển (@danhSachUngTuyen.Count)
                    </button>
                </li>
            </ul>
            <div class="tab-content" id="detailTabsContent">
                <!-- Tab 1: Nội dung tin -->
                <div class="tab-pane fade show active view-mode" id="content" role="tabpanel">
                    <!-- Edit Controls -->
                    <div class="edit-controls">
                        <button type="button" class="btn-edit" id="btnEdit">
                            <i class="bi bi-pencil"></i> Sửa
                        </button>
                        <button type="button" class="btn-cancel" id="btnCancel" style="display: none;">
                            <i class="bi bi-x-circle"></i> Hủy thay đổi
                        </button>
                        <button type="button" class="btn-save" id="btnSave" style="display: none;">
                            <i class="bi bi-check-circle"></i> Lưu
                        </button>
                    </div>

                    <form id="editForm" method="post" action="@Url.Action("CapNhatTinTuyenDung", "Recruiter", new { id = Model.MaTinTuyenDung })" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaTinTuyenDung" value="@Model.MaTinTuyenDung" />

                        <!-- View Mode Content -->
                        <div class="view-content">
                            <!-- Thong tin co ban -->
                            <div class="content-section">
                                <h4><i class="bi bi-briefcase-fill"></i> Thông tin cơ bản</h4>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <p><strong>Ngành nghề:</strong> @Model.NganhNghe</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        @if (!string.IsNullOrEmpty(Model.NganhNgheChiTiet))
                                        {
                                            <p><strong>Ngành nghề chi tiết:</strong> @Model.NganhNgheChiTiet</p>
                                        }
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <p><strong>Hình thức làm việc:</strong> <span class="badge-custom badge-primary">@Model.LoaiCongViec</span></p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        @if (!string.IsNullOrEmpty(Model.KinhNghiem))
                                        {
                                            <p><strong>Kinh nghiệm:</strong> @Model.KinhNghiem</p>
                                        }
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <p><strong>Vị trí:</strong> @Model.ViTri</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        @if (!string.IsNullOrEmpty(Model.NgoaiNgu))
                                        {
                                            <p><strong>Ngoại ngữ:</strong> @Model.NgoaiNgu</p>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.KyNang))
                                {
                                    <div class="mb-3">
                                        <p><strong>Kỹ năng:</strong> @Model.KyNang</p>
                                    </div>
                                }
                            </div>

                            <div class="content-section">
                                <h4><i class="bi bi-briefcase"></i> Mô tả công việc</h4>
                                <div>@Html.Raw(Model.MoTa ?? "")</div>
                            </div>

                            <div class="content-section">
                                <h4><i class="bi bi-check-circle"></i> Yêu cầu ứng viên</h4>
                                <div>@Html.Raw(Model.YeuCau ?? "")</div>
                            </div>

                            <div class="content-section">
                                <h4><i class="bi bi-gift"></i> Quyền lợi</h4>
                                <div>@Html.Raw(Model.QuyenLoi ?? "")</div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="content-section">
                                        <h4><i class="bi bi-cash-stack"></i> Mức lương</h4>
                                        <p style="font-size: 1.2rem; font-weight: 600; color: #10b981;">
                                            @if (Model.MucLuongThapNhat.HasValue && Model.MucLuongCaoNhat.HasValue)
                                            {
                                                <text>@Model.MucLuongThapNhat.Value.ToString("N0") - @Model.MucLuongCaoNhat.Value.ToString("N0") triệu VNĐ</text>
                                            }
                                            else if (Model.MucLuongThapNhat.HasValue)
                                            {
                                                <text>Từ @Model.MucLuongThapNhat.Value.ToString("N0") triệu VNĐ</text>
                                            }
                                            else
                                            {
                                                <text>Thỏa thuận</text>
                                            }
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="content-section">
                                        <h4><i class="bi bi-geo-alt"></i> Địa điểm làm việc</h4>
                                        <p>
                                            <strong>@Model.DiaChiLamViec</strong><br/>
                                            <span class="text-muted">@Model.PhuongXa, @Model.TinhThanhPho</span>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="content-section">
                                <h4><i class="bi bi-person-lines-fill"></i> Thông tin liên hệ</h4>
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <p><strong>Người liên hệ:</strong> @Model.NguoiLienHe</p>
                                    </div>
                                    <div class="col-md-4">
                                        <p><strong>Email:</strong> <a href="mailto:@Model.EmailLienHe">@Model.EmailLienHe</a></p>
                                    </div>
                                    <div class="col-md-4">
                                        <p><strong>SĐT:</strong> <a href="tel:@Model.SDTLienHe">@Model.SDTLienHe</a></p>
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(Model.DiaChiLamViec))
                                {
                                    <div class="mb-3">
                                        <p><strong>Địa chỉ:</strong> @Model.DiaChiLamViec</p>
                                        @if (!string.IsNullOrEmpty(Model.PhuongXa) || !string.IsNullOrEmpty(Model.TinhThanhPho))
                                        {
                                            <p class="text-muted">@Model.PhuongXa@(!string.IsNullOrEmpty(Model.PhuongXa) && !string.IsNullOrEmpty(Model.TinhThanhPho) ? ", " : "")@Model.TinhThanhPho</p>
                                        }
                                    </div>
                                }

                                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                                {
                                    <!-- Map Container -->
                                    <div class="map-container">
                                        <div id="map"></div>
                                        <div class="map-info">
                                            <i class="bi bi-geo-alt-fill text-danger"></i>
                                            <span id="currentCoords">@Model.Latitude.Value.ToString("F6"), @Model.Longitude.Value.ToString("F6")</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Anh van phong/cua hang -->
                            @if (!string.IsNullOrEmpty(Model.AnhVanPhong))
                            {
                                <div class="content-section">
                                    <h4><i class="bi bi-images"></i> Ảnh văn phòng/cửa hàng</h4>
                                    @{
                                        // Parse ảnh từ string (JSON array hoặc comma-separated)
                                        var anhVanPhongList = new List<string>();
                                        try
                                        {
                                            var anhVanPhongValue = Model.AnhVanPhong?.Trim();
                                            if (string.IsNullOrEmpty(anhVanPhongValue))
                                            {
                                                anhVanPhongList = new List<string>();
                                            }
                                            else
                                            {
                                                // Thử parse JSON array trước (format mới)
                                                if (anhVanPhongValue.StartsWith("["))
                                                {
                                                    try
                                                    {
                                                        var jsonArray = System.Text.Json.JsonSerializer.Deserialize<string[]>(anhVanPhongValue);
                                                        if (jsonArray != null && jsonArray.Length > 0)
                                                        {
                                                            anhVanPhongList = jsonArray.ToList();
                                                        }
                                                    }
                                                    catch
                                                    {
                                                        // Nếu parse JSON thất bại, xử lý như chuỗi thông thường
                                                        anhVanPhongList = anhVanPhongValue
                                                            .Trim('[', ']')
                                                            .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                                            .Select(s => s.Trim().Trim('"', '\'', ' '))
                                                            .Where(s => !string.IsNullOrEmpty(s))
                                                            .ToList();
                                                    }
                                                }
                                                else
                                                {
                                                    // Split bằng dấu phẩy cho chuỗi thông thường (format cũ)
                                                    anhVanPhongList = anhVanPhongValue
                                                        .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                                        .Select(s => s.Trim())
                                                        .Where(s => !string.IsNullOrEmpty(s))
                                                        .ToList();
                                                }
                                            }
                                        }
                                        catch
                                        {
                                            // Nếu có lỗi, thử split đơn giản nhất
                                            try
                                            {
                                                anhVanPhongList = Model.AnhVanPhong?
                                                    .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                                    .Select(s => s.Trim())
                                                    .Where(s => !string.IsNullOrEmpty(s))
                                                    .ToList() ?? new List<string>();
                                            }
                                            catch
                                            {
                                                anhVanPhongList = new List<string>();
                                            }
                                        }
                                    }

                                    @if (anhVanPhongList != null && anhVanPhongList.Count > 0)
                                    {
                                        <div class="image-gallery" id="officeImagesGallery">
                                            @foreach (var imagePath in anhVanPhongList)
                                            {
                                                <div class="gallery-item" data-image="@imagePath">
                                                    <img src="@imagePath" alt="Ảnh văn phòng/cửa hàng" loading="lazy" 
                                                         onerror="this.src='/images/placeholder.png'; this.onerror=null;">
                                                    <div class="gallery-overlay">
                                                        <i class="bi bi-zoom-in"></i>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="empty-gallery">
                                            <i class="bi bi-image"></i>
                                            <p>Chưa có ảnh văn phòng/cửa hàng</p>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.TuKhoa))
                            {
                                <div class="content-section">
                                    <h4><i class="bi bi-tags"></i> Từ khóa</h4>
                                    <div>
                                        @foreach (var keyword in Model.TuKhoa.Split(','))
                                        {
                                            <span class="badge-custom badge-primary me-2">@keyword.Trim()</span>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Han tuyen dung -->
                            <div class="content-section">
                                <h4><i class="bi bi-calendar-event"></i> Hạn tuyển dụng</h4>
                                <p>
                                    <strong>Ngày hết hạn nộp hồ sơ:</strong> @Model.HanNop.ToString("dd/MM/yyyy")
                                    @if (Model.HanNop >= DateTime.Now)
                                    {
                                        <span class="badge-custom badge-success ms-2">Đang tuyển</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-secondary ms-2">Hết hạn</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <!-- Edit Mode Content -->
                        <div class="edit-content">
                            <!-- Ten viec lam -->
                            <div class="form-section">
                                <h4><i class="bi bi-briefcase-fill"></i> Thông tin cơ bản</h4>
                                <div class="mb-4">
                                    <label class="form-label required-label">Tên vị trí tuyển dụng</label>
                                    <input type="text" class="form-control" name="TenViecLam" 
                                           id="editTenViecLam" value="@Model.TenViecLam" required
                                           placeholder="Ví dụ: Senior Full-stack Developer">
                                    <span class="text-danger field-validation-valid" data-valmsg-for="TenViecLam" data-valmsg-replace="true"></span>
                                </div>
                            </div>

                            <!-- Mo ta cong viec -->
                            <div class="form-section">
                                <h4><i class="bi bi-file-text"></i> Mô tả công việc</h4>
                                
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label required-label">Ngành nghề</label>
                                        <select class="form-select" name="NganhNghe" id="editNganhNghe" required>
                                            <option value="">Chọn ngành nghề</option>
                                            @{
                                                var danhSachNganhNghe = ViewBag.DanhSachNganhNghe as List<Unicareer.Models.NganhNghe> ?? new List<Unicareer.Models.NganhNghe>();
                                            }
                                            @foreach (var nganhNghe in danhSachNganhNghe)
                                            {
                                                @if (Model.NganhNghe == nganhNghe.TenNganhNghe)
                                                {
                                                    <option value="@nganhNghe.TenNganhNghe" selected data-ma-nganh-nghe="@nganhNghe.MaNganhNghe">@nganhNghe.TenNganhNghe</option>
                                                }
                                                else
                                                {
                                                    <option value="@nganhNghe.TenNganhNghe" data-ma-nganh-nghe="@nganhNghe.MaNganhNghe">@nganhNghe.TenNganhNghe</option>
                                                }
                                            }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="NganhNghe" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Ngành nghề chi tiết</label>
                                        <select class="form-select" name="NganhNgheChiTiet" id="editNganhNgheChiTiet">
                                            <option value="">Chọn ngành nghề chi tiết</option>
                                            @{
                                                var danhSachChuyenNganh = ViewBag.DanhSachChuyenNganh as List<Unicareer.Models.ChuyenNganh> ?? new List<Unicareer.Models.ChuyenNganh>();
                                                var danhSachNganhNgheForChuyenNganh = ViewBag.DanhSachNganhNghe as List<Unicareer.Models.NganhNghe> ?? new List<Unicareer.Models.NganhNghe>();
                                                var selectedNganhNghe = danhSachNganhNgheForChuyenNganh.FirstOrDefault(n => n.TenNganhNghe == Model.NganhNghe);
                                                var chuyenNganhTheoNganhNghe = selectedNganhNghe != null 
                                                    ? danhSachChuyenNganh.Where(c => c.MaNganhNghe == selectedNganhNghe.MaNganhNghe).ToList()
                                                    : new List<Unicareer.Models.ChuyenNganh>();
                                            }
                                            @foreach (var chuyenNganh in chuyenNganhTheoNganhNghe)
                                            {
                                                @if (Model.NganhNgheChiTiet == chuyenNganh.TenChuyenNganh)
                                                {
                                                    <option value="@chuyenNganh.TenChuyenNganh" selected data-ma-nganh-nghe="@chuyenNganh.MaNganhNghe">@chuyenNganh.TenChuyenNganh</option>
                                                }
                                                else
                                                {
                                                    <option value="@chuyenNganh.TenChuyenNganh" data-ma-nganh-nghe="@chuyenNganh.MaNganhNghe">@chuyenNganh.TenChuyenNganh</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label required-label">Hình thức làm việc</label>
                                        <select class="form-select" name="LoaiCongViec" id="editLoaiCongViec" required>
                                            <option value="">Chọn hình thức</option>
                                            @{
                                                var danhSachLoaiCongViec = ViewBag.DanhSachLoaiCongViec as List<Unicareer.Models.LoaiCongViec> ?? new List<Unicareer.Models.LoaiCongViec>();
                                            }
                                            @foreach (var loaiCongViec in danhSachLoaiCongViec)
                                            {
                                                @if (Model.LoaiCongViec == loaiCongViec.TenLoaiCongViec)
                                                {
                                                    <option value="@loaiCongViec.TenLoaiCongViec" selected>@loaiCongViec.TenLoaiCongViec</option>
                                                }
                                                else
                                                {
                                                    <option value="@loaiCongViec.TenLoaiCongViec">@loaiCongViec.TenLoaiCongViec</option>
                                                }
                                            }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="LoaiCongViec" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Kinh nghiệm làm việc</label>
                                        <select class="form-select" name="KinhNghiem" id="editKinhNghiem">
                                            <option value="">Chọn kinh nghiệm</option>
                                            @foreach (var kn in Unicareer.Models.DropdownOptions.KinhNghiem)
                                            {
                                                @if (Model.KinhNghiem == kn)
                                                {
                                                    <option value="@kn" selected>@kn</option>
                                                }
                                                else
                                                {
                                                    <option value="@kn">@kn</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label required-label">Vị trí</label>
                                        <select class="form-select" name="ViTri" id="editViTri" required>
                                            <option value="">Chọn vị trí</option>
                                            @foreach (var vt in Unicareer.Models.DropdownOptions.ViTri)
                                            {
                                                @if (Model.ViTri == vt)
                                                {
                                                    <option value="@vt" selected>@vt</option>
                                                }
                                                else
                                                {
                                                    <option value="@vt">@vt</option>
                                                }
                                            }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="ViTri" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Ngoại ngữ</label>
                                        <select class="form-select" name="NgoaiNgu" id="editNgoaiNgu">
                                            <option value="">Chọn ngoại ngữ</option>
                                            @foreach (var nn in Unicareer.Models.DropdownOptions.NgoaiNgu)
                                            {
                                                @if (Model.NgoaiNgu == nn)
                                                {
                                                    <option value="@nn" selected>@nn</option>
                                                }
                                                else
                                                {
                                                    <option value="@nn">@nn</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Từ khóa</label>
                                        <input type="text" class="form-control" name="TuKhoa" 
                                               id="editTuKhoa" value="@Model.TuKhoa"
                                               placeholder="Nhập từ khóa liên quan đến công việc">
                                        <small class="text-muted"><i class="bi bi-lightbulb"></i> Ví dụ: ReactJS, NodeJS, .NET Core</small>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Kỹ năng</label>
                                        <input type="text" class="form-control" name="KyNang" 
                                               id="editKyNang" value="@Model.KyNang"
                                               placeholder="Nhập kỹ năng cần thiết">
                                        <small class="text-muted"><i class="bi bi-lightbulb"></i> Ví dụ: Teamwork, Communication, Problem Solving</small>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label required-label">Mô tả công việc chi tiết</label>
                                    <div id="editor-editMoTa" class="editor-container"></div>
                                    <textarea name="MoTa" id="editMoTa" style="display: none;" required>@Html.Raw(Model.MoTa)</textarea>
                                    <span class="text-danger field-validation-valid" data-valmsg-for="MoTa" data-valmsg-replace="true"></span>
                                </div>
                            </div>

                            <!-- Yeu cau cong viec -->
                            <div class="form-section">
                                <h4><i class="bi bi-clipboard-check"></i> Yêu cầu công việc</h4>
                                <div class="mb-3">
                                    <label class="form-label">Các yêu cầu đối với ứng viên</label>
                                    <div id="editor-editYeuCau" class="editor-container"></div>
                                    <textarea name="YeuCau" id="editYeuCau" style="display: none;" required>@Html.Raw(Model.YeuCau)</textarea>
                                    <span class="text-danger field-validation-valid" data-valmsg-for="YeuCau" data-valmsg-replace="true"></span>
                                </div>
                            </div>

                            <!-- Quyen loi -->
                            <div class="form-section">
                                <h4><i class="bi bi-gift"></i> Quyền lợi</h4>
                                
                                <div class="row mb-3">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Mức lương thấp nhất (Triệu đồng)</label>
                                        <input type="number" class="form-control" name="MucLuongThapNhat" 
                                               id="editMucLuongThapNhat" min="0" value="@(Model.MucLuongThapNhat ?? 0)"
                                               placeholder="VD: 10">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Mức lương cao nhất (Triệu đồng)</label>
                                        <input type="number" class="form-control" name="MucLuongCaoNhat" 
                                               id="editMucLuongCaoNhat" min="0" value="@(Model.MucLuongCaoNhat ?? 0)"
                                               placeholder="VD: 20">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Thông tin thêm về quyền lợi</label>
                                    <div id="editor-editQuyenLoi" class="editor-container"></div>
                                    <textarea name="QuyenLoi" id="editQuyenLoi" style="display: none;">@Html.Raw(Model.QuyenLoi)</textarea>
                                    <small class="text-muted"><i class="bi bi-info-circle"></i> Các quyền lợi khác như: bảo hiểm, thưởng, du lịch...</small>
                                </div>
                            </div>

                            <!-- Thong Tin Lien He -->
                            <div class="form-section">
                                <h4><i class="bi bi-telephone"></i> Thông tin liên hệ</h4>
                                
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Người liên hệ</label>
                                        <input type="text" class="form-control" name="NguoiLienHe" 
                                               id="editNguoiLienHe" value="@Model.NguoiLienHe"
                                               placeholder="Nguyễn Văn A">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label required-label">Email liên hệ</label>
                                        <input type="email" class="form-control" name="EmailLienHe" 
                                               id="editEmailLienHe" value="@Model.EmailLienHe" required
                                               placeholder="tuyendung@company.com">
                                        <span class="text-danger field-validation-valid" data-valmsg-for="EmailLienHe" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Điện thoại liên hệ</label>
                                        <input type="tel" class="form-control" name="SDTLienHe" 
                                               id="editSDTLienHe" value="@Model.SDTLienHe"
                                               placeholder="0312345656">
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label required-label">Làm việc tại Tỉnh/Thành phố</label>
                                        <select class="form-select" name="TinhThanhPho" id="editTinhThanhPho" required>
                                            <option value="">Chọn tỉnh/thành phố</option>
                                            @{
                                                var danhSachTinhThanh = ViewBag.DanhSachTinhThanh as List<Unicareer.Models.Province> ?? new List<Unicareer.Models.Province>();
                                            }
                                            @foreach (var tinh in danhSachTinhThanh)
                                            {
                                                @if (Model.TinhThanhPho == tinh.FullName)
                                                {
                                                    <option value="@tinh.FullName" data-code="@tinh.Code" data-fullname="@tinh.FullName" selected>@tinh.FullName</option>
                                                }
                                                else
                                                {
                                                    <option value="@tinh.FullName" data-code="@tinh.Code" data-fullname="@tinh.FullName">@tinh.FullName</option>
                                                }
                                            }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="TinhThanhPho" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Quận/Huyện</label>
                                        <select class="form-select" name="PhuongXa" id="editPhuongXa">
                                            <option value="">Chọn quận/huyện</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label required-label">Địa chỉ làm việc</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" name="DiaChiLamViec" 
                                               id="editDiaChiLamViec" value="@Model.DiaChiLamViec" required
                                               placeholder="123 Nguyễn Huệ, Quận 1">
                                        <button type="button" class="btn btn-outline-primary" id="btnSearchAddressEdit">
                                            <i class="bi bi-search"></i> Tìm trên bản đồ
                                        </button>
                                    </div>
                                    <span class="text-danger field-validation-valid" data-valmsg-for="DiaChiLamViec" data-valmsg-replace="true"></span>
                                    <small class="text-muted">
                                        <i class="bi bi-info-circle"></i> Kéo marker 📍 trên bản đồ để chọn vị trí chính xác hoặc click vào bản đồ
                                    </small>
                                </div>

                                <!-- Hidden fields for coordinates -->
                                <input type="hidden" name="Latitude" id="editLatitude" value="@(Model.Latitude ?? 21.028511)">
                                <input type="hidden" name="Longitude" id="editLongitude" value="@(Model.Longitude ?? 105.804817)">
                                <!-- Hidden field for PhuongXa to avoid HTML encoding issues -->
                                <input type="hidden" id="hiddenPhuongXa" value="@(Model.PhuongXa ?? "")">

                                <!-- Map Container -->
                                <div class="map-container">
                                    <div id="mapEdit"></div>
                                    <div class="map-info">
                                        <i class="bi bi-geo-alt-fill text-danger"></i>
                                        <span id="currentCoordsEdit">@(Model.Latitude?.ToString("F6") ?? "21.028511"), @(Model.Longitude?.ToString("F6") ?? "105.804817")</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Anh van phong/cua hang -->
                            <div class="form-section">
                                <h4><i class="bi bi-images"></i> Ảnh văn phòng/cửa hàng</h4>
                                <div class="mb-3">
                                    <label class="form-label">Tải lên hình ảnh</label>
                                    <input type="file" class="form-control" name="AnhVanPhong" 
                                           id="editAnhVanPhong" accept="image/*" multiple>
                                    <small class="text-muted"><i class="bi bi-info-circle"></i> Có thể chọn nhiều ảnh. Định dạng: JPG, PNG, GIF</small>
                                </div>
                                
                                <!-- Preview Area -->
                                <div id="imagePreviewContainer" class="image-preview-container" style="display: none;">
                                    <!-- Hidden input to store remaining existing images after deletion -->
                                    <input type="hidden" id="remainingExistingImages" name="RemainingExistingImages" value="">
                                    
                                    <!-- Existing Images -->
                                    <div id="existingImagesSection" class="preview-section" style="display: none;">
                                        <div class="preview-section-title">
                                            <i class="bi bi-image"></i> Ảnh hiện có
                                        </div>
                                        <div id="existingImagesGrid" class="preview-images-grid"></div>
                                    </div>
                                    
                                    <!-- New Images Preview -->
                                    <div id="newImagesSection" class="preview-section" style="display: none;">
                                        <div class="preview-section-title">
                                            <i class="bi bi-plus-circle"></i> Ảnh mới đã chọn
                                        </div>
                                        <div id="newImagesGrid" class="preview-images-grid"></div>
                                    </div>
                                    
                                    <!-- No Preview Message -->
                                    <div id="noPreviewMessage" class="no-preview">
                                        <i class="bi bi-image"></i>
                                        <p>Chưa có ảnh để xem trước</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Han tuyen dung -->
                            <div class="form-section">
                                <h4><i class="bi bi-calendar-event"></i> Hạn tuyển dụng</h4>
                                <div class="mb-3">
                                    <label class="form-label required-label">Ngày hết hạn nộp hồ sơ</label>
                                    <input type="date" class="form-control" name="HanNop" 
                                           id="editHanNop" value="@Model.HanNop.ToString("yyyy-MM-dd")" required
                                           min="@DateTime.Now.ToString("yyyy-MM-dd")">
                                    <span class="text-danger field-validation-valid" data-valmsg-for="HanNop" data-valmsg-replace="true"></span>
                                    <small class="text-muted"><i class="bi bi-clock-history"></i> Chọn ngày cuối cùng nhận hồ sơ ứng tuyển</small>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Tab 2: Danh sách ứng tuyển -->
                <div class="tab-pane fade" id="applications" role="tabpanel">
                    @{
                        var danhSachUngTuyenPaged = ViewBag.DanhSachUngTuyen as List<Unicareer.Models.TinUngTuyen> ?? new List<Unicareer.Models.TinUngTuyen>();
                        var pageNumber = ViewBag.PageNumber ?? 1;
                        var pageSize = ViewBag.PageSize ?? 10;
                        var totalCount = ViewBag.TotalCount ?? 0;
                        var totalPages = ViewBag.TotalPages ?? 1;
                        var searchTerm = ViewBag.SearchTerm as string ?? "";
                        var trangThaiFilter = ViewBag.TrangThaiFilter as string ?? "";
                    }
                    
                    <!-- Bộ lọc -->
                    <form method="get" action="@Url.Action("ChiTietTinDaDang", "Recruiter", new { id = Model.MaTinTuyenDung })" id="filterForm">
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="searchInput" name="searchTerm" 
                                           placeholder="Tìm kiếm theo tên, email, SĐT..." value="@searchTerm">
                                    <button class="btn btn-outline-primary" type="submit">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <select class="form-select" id="trangThaiFilter" name="trangThaiFilter">
                                    <option value="">Tất cả trạng thái</option>
                                    @if (trangThaiFilter == "Đang xem xét")
                                    {
                                        <option value="Đang xem xét" selected>Đang xem xét</option>
                                    }
                                    else
                                    {
                                        <option value="Đang xem xét">Đang xem xét</option>
                                    }
                                    @if (trangThaiFilter == "Chờ phỏng vấn")
                                    {
                                        <option value="Chờ phỏng vấn" selected>Chờ phỏng vấn</option>
                                    }
                                    else
                                    {
                                        <option value="Chờ phỏng vấn">Chờ phỏng vấn</option>
                                    }
                                    @if (trangThaiFilter == "Đã phỏng vấn")
                                    {
                                        <option value="Đã phỏng vấn" selected>Đã phỏng vấn</option>
                                    }
                                    else
                                    {
                                        <option value="Đã phỏng vấn">Đã phỏng vấn</option>
                                    }
                                    @if (trangThaiFilter == "Tuyển dụng")
                                    {
                                        <option value="Tuyển dụng" selected>Tuyển dụng</option>
                                    }
                                    else
                                    {
                                        <option value="Tuyển dụng">Tuyển dụng</option>
                                    }
                                    @if (trangThaiFilter == "Từ chối")
                                    {
                                        <option value="Từ chối" selected>Từ chối</option>
                                    }
                                    else
                                    {
                                        <option value="Từ chối">Từ chối</option>
                                    }
                                    @if (trangThaiFilter == "Không phù hợp")
                                    {
                                        <option value="Không phù hợp" selected>Không phù hợp</option>
                                    }
                                    else
                                    {
                                        <option value="Không phù hợp">Không phù hợp</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-5">
                                <div class="d-flex gap-2 align-items-center">
                                    <span class="text-muted">Tổng: <strong>@totalCount</strong> đơn ứng tuyển</span>
                                    @if (ViewBag.TotalDangXemXet != null && (int)ViewBag.TotalDangXemXet > 0)
                                    {
                                        <span class="badge bg-info">Đang xem xét: @ViewBag.TotalDangXemXet</span>
                                    }
                                    @if (ViewBag.TotalChoPhongVan != null && (int)ViewBag.TotalChoPhongVan > 0)
                                    {
                                        <span class="badge bg-warning">Chờ phỏng vấn: @ViewBag.TotalChoPhongVan</span>
                                    }
                                    @if (ViewBag.TotalTuyenDung != null && (int)ViewBag.TotalTuyenDung > 0)
                                    {
                                        <span class="badge bg-success">Tuyển dụng: @ViewBag.TotalTuyenDung</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <input type="hidden" name="pageNumber" id="pageNumberInput" value="@pageNumber" />
                        <input type="hidden" name="tab" value="applications" />
                    </form>

                    @if (danhSachUngTuyenPaged.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-hash"></i> Mã</th>
                                        <th><i class="bi bi-person"></i> Họ tên</th>
                                        <th><i class="bi bi-envelope"></i> Email</th>
                                        <th><i class="bi bi-telephone"></i> SĐT</th>
                                        <th><i class="bi bi-calendar"></i> Ngày ứng tuyển</th>
                                        <th><i class="bi bi-info-circle"></i> Trạng thái</th>
                                        <th><i class="bi bi-gear"></i> Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ungTuyen in danhSachUngTuyenPaged)
                                    {
                                        var trangThaiEnum = Unicareer.Models.Enums.TrangThaiXuLyHelper.FromString(ungTuyen.TrangThaiXuLy);
                                        var trangThaiDisplay = trangThaiEnum.HasValue 
                                            ? Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(trangThaiEnum.Value) 
                                            : ungTuyen.TrangThaiXuLy ?? "Chưa xử lý";
                                        
                                        var trangThaiClass = trangThaiEnum.HasValue switch
                                        {
                                            true when trangThaiEnum.Value == Unicareer.Models.Enums.TrangThaiXuLy.DangXemXet => "badge-secondary",
                                            true when trangThaiEnum.Value == Unicareer.Models.Enums.TrangThaiXuLy.ChoPhongVan => "badge-warning",
                                            true when trangThaiEnum.Value == Unicareer.Models.Enums.TrangThaiXuLy.DaPhongVan => "badge-info",
                                            true when trangThaiEnum.Value == Unicareer.Models.Enums.TrangThaiXuLy.TuyenDung => "badge-success",
                                            true when trangThaiEnum.Value == Unicareer.Models.Enums.TrangThaiXuLy.TuChoi || 
                                                      trangThaiEnum.Value == Unicareer.Models.Enums.TrangThaiXuLy.KhongPhuHop => "badge-danger",
                                            _ => "badge-secondary"
                                        };

                                        <tr>
                                            <td><span class="text-muted">#@ungTuyen.MaTinUngTuyen</span></td>
                                            <td><strong>@ungTuyen.HoTen</strong></td>
                                            <td>@ungTuyen.Email</td>
                                            <td>@ungTuyen.SoDienThoai</td>
                                            <td>@ungTuyen.NgayUngTuyen.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="badge-custom @trangThaiClass">@trangThaiDisplay</span>
                                            </td>
                                            <td>
                                                <button class="btn btn-action btn-view" title="Xem chi tiết" onclick="xemChiTietDonUngTuyen(@ungTuyen.MaTinUngTuyen)">
                                                    <i class="bi bi-eye"></i> Xem
                                                </button>
                                                <button class="btn btn-action btn-success" title="Cập nhật trạng thái" onclick="capNhatTrangThaiDonUngTuyen(@ungTuyen.MaTinUngTuyen)" style="border-color: #48bb78; color: #48bb78;">
                                                    <i class="bi bi-check-circle"></i> Cập nhật
                                                </button>
                                                @if (!string.IsNullOrEmpty(ungTuyen.LinkCV))
                                                {
                                                    <a href="@ungTuyen.LinkCV" target="_blank" class="btn btn-action btn-download" title="Tải CV">
                                                        <i class="bi bi-download"></i> CV
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Phân trang -->
                        @if (totalPages > 1)
                        {
                            <nav aria-label="Phân trang" class="mt-4">
                                <ul class="pagination justify-content-center">
                                    @if (pageNumber > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">
                                                <i class="bi bi-chevron-double-left"></i>
                                            </a>
                                        </li>
                                        <li class="page-item">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(pageNumber - 1))">
                                                <i class="bi bi-chevron-left"></i>
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                                        </li>
                                        <li class="page-item disabled">
                                            <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                                        </li>
                                    }

                                    @{
                                        var startPage = Math.Max(1, pageNumber - 2);
                                        var endPage = Math.Min(totalPages, pageNumber + 2);
                                    }

                                    @if (startPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">1</a>
                                        </li>
                                        @if (startPage > 2)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                    }

                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == pageNumber ? "active" : "")">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@i)">@i</a>
                                        </li>
                                    }

                                    @if (endPage < totalPages)
                                    {
                                        @if (endPage < totalPages - 1)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                        <li class="page-item">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@totalPages)">@totalPages</a>
                                        </li>
                                    }

                                    @if (pageNumber < totalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(pageNumber + 1))">
                                                <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </li>
                                        <li class="page-item">
                                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@totalPages)">
                                                <i class="bi bi-chevron-double-right"></i>
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                                        </li>
                                        <li class="page-item disabled">
                                            <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                                        </li>
                                    }
                                </ul>
                                <div class="text-center text-muted mt-2">
                                    Hiển thị <strong>@((pageNumber - 1) * pageSize + 1)</strong> - 
                                    <strong>@(Math.Min(pageNumber * pageSize, totalCount))</strong> 
                                    trong tổng số <strong>@totalCount</strong> đơn ứng tuyển
                                </div>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox"></i>
                            <h5>Chưa có ứng viên nào ứng tuyển</h5>
                            <p>Tin tuyển dụng này chưa nhận được đơn ứng tuyển nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal cập nhật trạng thái -->
<div class="modal fade" id="trangThaiModal" tabindex="-1" aria-labelledby="trangThaiModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="trangThaiModalLabel">Cập nhật trạng thái</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formCapNhatTrangThai">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="maDonUngTuyen" name="maDonUngTuyen" />
                    <div class="mb-3">
                        <label for="trangThaiMoi" class="form-label">Trạng thái mới</label>
                        <select class="form-select" id="trangThaiMoi" name="trangThaiMoi" required>
                            <option value="">-- Chọn trạng thái --</option>
                            <option value="@Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(Unicareer.Models.Enums.TrangThaiXuLy.DangXemXet)">Đang xem xét</option>
                            <option value="@Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(Unicareer.Models.Enums.TrangThaiXuLy.ChoPhongVan)">Chờ phỏng vấn</option>
                            <option value="@Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(Unicareer.Models.Enums.TrangThaiXuLy.DaPhongVan)">Đã phỏng vấn</option>
                            <option value="@Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(Unicareer.Models.Enums.TrangThaiXuLy.TuyenDung)">Tuyển dụng</option>
                            <option value="@Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(Unicareer.Models.Enums.TrangThaiXuLy.TuChoi)">Từ chối</option>
                            <option value="@Unicareer.Models.Enums.TrangThaiXuLyHelper.ToString(Unicareer.Models.Enums.TrangThaiXuLy.KhongPhuHop)">Không phù hợp</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="ghiChu" class="form-label">Nội dung tin bạn muốn gửi</label>
                        <textarea class="form-control" id="ghiChu" name="ghiChu" rows="4" placeholder="Nhập nội dung tin bạn muốn gửi cho ứng viên (nếu có). Nội dung này sẽ được gửi kèm trong email thông báo."></textarea>
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Nội dung này sẽ được gửi kèm trong email thông báo cho ứng viên. Để trống nếu không cần gửi thêm thông tin.
                        </small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="luuTrangThaiDonUngTuyen()">Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Quill Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <!-- Quill Editor JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        $(document).ready(function() {
            // Tự động chuyển sang tab "Danh sách ứng tuyển" nếu có filter parameters hoặc parameter tab=applications
            var urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('searchTerm') || urlParams.has('trangThaiFilter') || urlParams.has('pageNumber') || urlParams.get('tab') === 'applications') {
                // Chuyển sang tab "Danh sách ứng tuyển"
                var applicationsTab = document.getElementById('applications-tab');
                if (applicationsTab) {
                    var tab = new bootstrap.Tab(applicationsTab);
                    tab.show();
                }
            }

            // Khởi tạo Quill Editor cho các textarea
            let editors = {};
            var editorsInitialized = false;

            var initEditors = function() {
                if (typeof Quill === 'undefined') {
                    console.error('Quill Editor is not loaded. Please check CDN link.');
                    return;
                }

                // Editor configurations
                const editorConfigs = {
                    'MoTa': {
                        containerId: 'editor-editMoTa',
                        textareaId: 'editMoTa',
                        placeholder: 'Nhập mô tả công việc...'
                    },
                    'YeuCau': {
                        containerId: 'editor-editYeuCau',
                        textareaId: 'editYeuCau',
                        placeholder: 'Nhập yêu cầu ứng viên...'
                    },
                    'QuyenLoi': {
                        containerId: 'editor-editQuyenLoi',
                        textareaId: 'editQuyenLoi',
                        placeholder: 'Nhập quyền lợi...'
                    }
                };

                // Initialize all Quill editors
                Object.keys(editorConfigs).forEach(function(fieldName) {
                    var config = editorConfigs[fieldName];
                    var editorContainer = document.getElementById(config.containerId);
                    var textarea = document.getElementById(config.textareaId);
                    
                    if (editorContainer && textarea) {
                        var quill = new Quill(editorContainer, {
                            theme: 'snow',
                            modules: {
                                toolbar: [
                                    [{ 'header': [1, 2, 3, false] }],
                                    ['bold', 'italic', 'underline', 'strike'],
                                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                                    [{ 'color': [] }, { 'background': [] }],
                                    [{ 'align': [] }],
                                    ['link', 'image'],
                                    ['clean']
                                ]
                            },
                            placeholder: config.placeholder
                        });

                        // Load existing content
                        if (textarea.value) {
                            quill.root.innerHTML = textarea.value;
                        }

                        // Update hidden textarea when editor content changes
                        quill.on('text-change', function() {
                            if (textarea) {
                                textarea.value = quill.root.innerHTML;
                            }
                        });

                        editors[fieldName] = quill;
                        console.log('Quill Editor initialized for:', fieldName);
                    }
                });
            };

            // Lưu giá trị ban đầu để có thể hủy
            var originalValues = {
                TenViecLam: $('#editTenViecLam').val() || '',
                NganhNghe: $('#editNganhNghe').val() || '',
                NganhNgheChiTiet: $('#editNganhNgheChiTiet').val() || '',
                LoaiCongViec: $('#editLoaiCongViec').val() || '',
                KinhNghiem: $('#editKinhNghiem').val() || '',
                ViTri: $('#editViTri').val() || '',
                NgoaiNgu: $('#editNgoaiNgu').val() || '',
                KyNang: $('#editKyNang').val() || '',
                MoTa: $('#editMoTa').val() || '',
                YeuCau: $('#editYeuCau').val() || '',
                QuyenLoi: $('#editQuyenLoi').val() || '',
                MucLuongThapNhat: $('#editMucLuongThapNhat').val(),
                MucLuongCaoNhat: $('#editMucLuongCaoNhat').val(),
                DiaChiLamViec: $('#editDiaChiLamViec').val(),
                PhuongXa: $('#editPhuongXa').val(),
                TinhThanhPho: $('#editTinhThanhPho').val(),
                NguoiLienHe: $('#editNguoiLienHe').val(),
                EmailLienHe: $('#editEmailLienHe').val(),
                SDTLienHe: $('#editSDTLienHe').val(),
                TuKhoa: $('#editTuKhoa').val(),
                HanNop: $('#editHanNop').val() || '',
                Latitude: $('#editLatitude').val(),
                Longitude: $('#editLongitude').val()
            };

            // Biến lưu map và marker cho edit mode
            var editMap = null;
            var editMarker = null;
            var editMapInitialized = false;

            // Hàm khởi tạo map cho edit mode
            function initEditMap() {
                if (typeof L === 'undefined') {
                    setTimeout(initEditMap, 500);
                    return;
                }

                // Kiểm tra xem element mapEdit có tồn tại và đã hiển thị chưa
                var mapElement = document.getElementById('mapEdit');
                if (!mapElement) {
                    setTimeout(initEditMap, 300);
                    return;
                }

                // Kiểm tra xem map đã được khởi tạo chưa
                if (mapElement._leaflet_id) {
                    // Map đã được khởi tạo, chỉ cần invalidate size
                    if (editMap) {
                        setTimeout(function() {
                            editMap.invalidateSize();
                        }, 100);
                    }
                    return;
                }

                try {
                    var mapLat = parseFloat($('#editLatitude').val()) || 21.028511;
                    var mapLng = parseFloat($('#editLongitude').val()) || 105.804817;

                    // Initialize Leaflet Map
                    editMap = L.map('mapEdit', {
                        preferCanvas: false
                    }).setView([mapLat, mapLng], 15);
                    
                    // Add tile layer
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                        maxZoom: 19
                    }).addTo(editMap);

                    // Invalidate size sau khi map được tạo để đảm bảo hiển thị đúng
                    setTimeout(function() {
                        if (editMap) {
                            editMap.invalidateSize();
                        }
                    }, 200);

                    // Fix Leaflet default marker icon path
                    delete L.Icon.Default.prototype._getIconUrl;
                    L.Icon.Default.mergeOptions({
                        iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
                        iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
                        shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png'
                    });

                    // Create custom marker icon with pulse effect
                    var customIcon = L.divIcon({
                        className: 'custom-marker',
                        html: '<div class="marker-pulse-ring"></div><div class="marker-pin"></div>',
                        iconSize: [40, 40],
                        iconAnchor: [20, 40],
                        popupAnchor: [0, -40]
                    });

                    // Create draggable marker
                    editMarker = L.marker([mapLat, mapLng], {
                        draggable: true,
                        icon: customIcon,
                        title: 'Kéo tôi để chọn vị trí'
                    }).addTo(editMap);

                    // Add popup to marker
                    editMarker.bindPopup('<strong>📍 Vị trí làm việc</strong><br>Kéo marker để điều chỉnh vị trí chính xác').openPopup();

                    // Function to update coordinates
                    function updateEditCoordinates(lat, lng) {
                        $('#editLatitude').val(lat.toFixed(6));
                        $('#editLongitude').val(lng.toFixed(6));
                        $('#currentCoordsEdit').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                    }

                    // Update marker position when dragged
                    editMarker.on('dragend', function(e) {
                        var position = editMarker.getLatLng();
                        updateEditCoordinates(position.lat, position.lng);
                        editMarker.bindPopup('<strong>✓ Vị trí đã cập nhật</strong><br>Lat: ' + position.lat.toFixed(6) + '<br>Lng: ' + position.lng.toFixed(6)).openPopup();
                    });

                    // Update marker when clicking on map
                    editMap.on('click', function(e) {
                        editMarker.setLatLng(e.latlng);
                        updateEditCoordinates(e.latlng.lat, e.latlng.lng);
                        editMarker.bindPopup('<strong>✓ Vị trí đã cập nhật</strong><br>Lat: ' + e.latlng.lat.toFixed(6) + '<br>Lng: ' + e.latlng.lng.toFixed(6)).openPopup();
                    });

                    // Search address button
                    $('#btnSearchAddressEdit').click(function() {
                        var address = $('#editDiaChiLamViec').val();
                        var city = $('#editTinhThanhPho').val();
                        
                        if (!address) {
                            alert('Vui lòng nhập địa chỉ!');
                            return;
                        }

                        // Simple geocoding using Nominatim
                        var searchQuery = address + (city ? ', ' + city : '') + ', Vietnam';
                        
                        $.ajax({
                            url: 'https://nominatim.openstreetmap.org/search',
                            data: {
                                q: searchQuery,
                                format: 'json',
                                limit: 1
                            },
                            success: function(data) {
                                if (data && data.length > 0) {
                                    var lat = parseFloat(data[0].lat);
                                    var lon = parseFloat(data[0].lon);
                                    
                                    editMap.setView([lat, lon], 16);
                                    editMarker.setLatLng([lat, lon]);
                                    updateEditCoordinates(lat, lon);
                                    
                                    editMarker.bindPopup('<strong>📍 Tìm thấy địa chỉ</strong><br>' + data[0].display_name).openPopup();
                                } else {
                                    alert('Không tìm thấy địa chỉ. Vui lòng thử lại!');
                                }
                            },
                            error: function() {
                                alert('Có lỗi xảy ra khi tìm kiếm địa chỉ!');
                            }
                        });
                    });

                    // Update map when city changes - event handler will be registered outside initEditMap

                    // Allow Enter key to search address
                    $('#editDiaChiLamViec').keypress(function(e) {
                        if (e.which === 13) {
                            e.preventDefault();
                            $('#btnSearchAddressEdit').click();
                        }
                    });

                    // Xử lý khi ngành nghề thay đổi - load chuyên ngành tương ứng
                    $('#editNganhNghe').change(function() {
                        var selectedNganhNghe = $(this).val();
                        var $editNganhNgheChiTiet = $('#editNganhNgheChiTiet');
                        
                        // Reset dropdown chuyên ngành
                        $editNganhNgheChiTiet.html('<option value="">Chọn ngành nghề chi tiết</option>');
                        
                        if (!selectedNganhNghe) {
                            return;
                        }
                        
                        // Lấy mã ngành nghề từ option được chọn
                        var selectedOption = $(this).find('option:selected');
                        var maNganhNghe = selectedOption.data('ma-nganh-nghe');
                        
                        if (!maNganhNghe) {
                            return;
                        }
                        
                        // Load chuyên ngành từ API
                        $.ajax({
                            url: '/Recruiter/Recruiter/LayChuyenNganhTheoNganhNghe',
                            type: 'GET',
                            data: { maNganhNghe: maNganhNghe },
                            success: function(response) {
                                if (response.success && response.data) {
                                    response.data.forEach(function(chuyenNganh) {
                                        var option = $('<option></option>')
                                            .attr('value', chuyenNganh.tenChuyenNganh)
                                            .text(chuyenNganh.tenChuyenNganh);
                                        $editNganhNgheChiTiet.append(option);
                                    });
                                }
                            },
                            error: function() {
                                console.error('Lỗi khi load chuyên ngành');
                            }
                        });
                    });

                    editMapInitialized = true;
                } catch (error) {
                    console.error('Lỗi khi khởi tạo edit map:', error);
                }
            }

            // Function to load wards by province (moved outside initEditMap for reuse)
            function loadWardsByProvinceForEdit(provinceCode, selectedWardName = null) {
                const $editPhuongXa = $('#editPhuongXa');
                
                console.log('loadWardsByProvinceForEdit called with:', { provinceCode, selectedWardName });
                
                // Kiểm tra xem dropdown có tồn tại không
                if ($editPhuongXa.length === 0) {
                    console.error('editPhuongXa dropdown not found');
                    return;
                }
                
                // Reset quận/huyện dropdown
                $editPhuongXa.html('<option value="">Chọn quận/huyện</option>');
                
                if (provinceCode) {
                    // Show loading state
                    $editPhuongXa.prop('disabled', true);
                    $editPhuongXa.html('<option value="">Đang tải...</option>');
                    
                    const apiUrl = `/Recruiter/Recruiter/GetWardsByProvince?provinceCode=${encodeURIComponent(provinceCode)}`;
                    console.log('Fetching wards from:', apiUrl);
                    
                    // Fetch wards from API
                    fetch(apiUrl)
                        .then(response => {
                            console.log('Response status:', response.status);
                            if (!response.ok) {
                                throw new Error(`HTTP error! status: ${response.status}`);
                            }
                            return response.json();
                        })
                        .then(data => {
                            console.log('Wards data received:', data);
                            $editPhuongXa.html('<option value="">Chọn quận/huyện</option>');
                            
                            if (data && data.length > 0) {
                                let foundSelected = false;
                                
                                // Decode HTML entities và normalize selectedWardName
                                let normalizedSelectedWard = '';
                                if (selectedWardName) {
                                    // Decode HTML entities
                                    const tempDiv = document.createElement('div');
                                    tempDiv.innerHTML = selectedWardName;
                                    normalizedSelectedWard = tempDiv.textContent || tempDiv.innerText || '';
                                    // Normalize: trim và lowercase để so sánh
                                    normalizedSelectedWard = normalizedSelectedWard.trim().toLowerCase();
                                    console.log('Normalized selected ward:', normalizedSelectedWard);
                                }
                                
                                data.forEach(ward => {
                                    const option = $('<option></option>')
                                        .attr('value', ward.fullName)
                                        .text(ward.fullName);
                                    
                                    // So sánh với nhiều cách để tìm match
                                    if (selectedWardName && normalizedSelectedWard) {
                                        const normalizedWardName = (ward.fullName || '').trim().toLowerCase();
                                        
                                        // So sánh chính xác (sau khi normalize)
                                        if (normalizedWardName === normalizedSelectedWard) {
                                            option.attr('selected', 'selected');
                                            foundSelected = true;
                                            console.log('Selected ward found (exact match):', ward.fullName);
                                        }
                                        // So sánh linh hoạt (contains)
                                        else if (!foundSelected && normalizedWardName.includes(normalizedSelectedWard)) {
                                            option.attr('selected', 'selected');
                                            foundSelected = true;
                                            console.log('Selected ward found (contains match):', ward.fullName);
                                        }
                                        // So sánh ngược lại (selectedWardName contains wardName)
                                        else if (!foundSelected && normalizedSelectedWard.includes(normalizedWardName)) {
                                            option.attr('selected', 'selected');
                                            foundSelected = true;
                                            console.log('Selected ward found (reverse contains match):', ward.fullName);
                                        }
                                    }
                                    
                                    $editPhuongXa.append(option);
                                });
                                
                                if (selectedWardName && !foundSelected) {
                                    console.warn('Selected ward not found in list:', selectedWardName);
                                    console.log('Available wards (first 5):', data.slice(0, 5).map(w => w.fullName));
                                }
                            } else {
                                $editPhuongXa.html('<option value="">Không có dữ liệu</option>');
                                console.warn('No wards data received');
                            }
                            
                            $editPhuongXa.prop('disabled', false);
                        })
                        .catch(error => {
                            console.error('Error loading wards:', error);
                            $editPhuongXa.html('<option value="">Lỗi tải dữ liệu</option>');
                            $editPhuongXa.prop('disabled', false);
                        });
                } else {
                    console.warn('No province code provided');
                    $editPhuongXa.prop('disabled', false);
                }
            }

            // Event handler for province change - register outside initEditMap
            $(document).on('change', '#editTinhThanhPho', function() {
                var selectedOption = $(this).find('option:selected');
                var cityName = $(this).val();
                var provinceCode = selectedOption.data('code');
                
                // Load wards for selected province
                if (provinceCode) {
                    loadWardsByProvinceForEdit(provinceCode);
                } else {
                    $('#editPhuongXa').html('<option value="">Chọn quận/huyện</option>');
                }
                
                // Update map coordinates if map is initialized
                if (editMap && editMarker) {
                    var coordinates = {
                        'Hà Nội': [21.028511, 105.804817],
                        'Thành phố Hà Nội': [21.028511, 105.804817],
                        'TP Hồ Chí Minh': [10.762622, 106.660172],
                        'Thành phố Hồ Chí Minh': [10.762622, 106.660172],
                        'Đà Nẵng': [16.047079, 108.206230],
                        'Thành phố Đà Nẵng': [16.047079, 108.206230],
                        'Hải Phòng': [20.844892, 106.687973],
                        'Thành phố Hải Phòng': [20.844892, 106.687973],
                        'Cần Thơ': [10.045162, 105.746857],
                        'Thành phố Cần Thơ': [10.045162, 105.746857]
                    };
                    
                    // Try to find matching coordinates
                    var coords = null;
                    for (var key in coordinates) {
                        if (cityName && (cityName.includes(key) || key.includes(cityName))) {
                            coords = coordinates[key];
                            break;
                        }
                    }
                    
                    if (coords) {
                        editMap.setView(coords, 13);
                        editMarker.setLatLng(coords);
                        var lat = coords[0];
                        var lng = coords[1];
                        $('#editLatitude').val(lat.toFixed(6));
                        $('#editLongitude').val(lng.toFixed(6));
                        $('#currentCoordsEdit').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                    }
                }
            });

            // Image Preview Variables
            var existingImages = [];
            var newImageFiles = [];
            var newImagePreviews = [];

            // Load existing images from model
            function loadExistingImages() {
                existingImages = [];
                try {
                    @{
                        // Parse ảnh từ model trong Razor
                        var anhVanPhongListForJS = new List<string>();
                        if (!string.IsNullOrEmpty(Model.AnhVanPhong))
                        {
                            try
                            {
                                var anhVanPhongValue = Model.AnhVanPhong.Trim();
                                if (anhVanPhongValue.StartsWith("["))
                                {
                                    var jsonArray = System.Text.Json.JsonSerializer.Deserialize<string[]>(anhVanPhongValue);
                                    if (jsonArray != null)
                                    {
                                        anhVanPhongListForJS = jsonArray.ToList();
                                    }
                                }
                                else
                                {
                                    anhVanPhongListForJS = anhVanPhongValue
                                        .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                        .Select(s => s.Trim())
                                        .Where(s => !string.IsNullOrEmpty(s))
                                        .ToList();
                                }
                            }
                            catch
                            {
                                anhVanPhongListForJS = Model.AnhVanPhong
                                    .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                    .Select(s => s.Trim())
                                    .Where(s => !string.IsNullOrEmpty(s))
                                    .ToList();
                            }
                        }
                    }
                    
                    @if (anhVanPhongListForJS != null && anhVanPhongListForJS.Count > 0)
                    {
                        <text>
                        existingImages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(anhVanPhongListForJS));
                        </text>
                    }
                    else
                    {
                        <text>
                        existingImages = [];
                        </text>
                    }
                } catch (e) {
                    console.error('Error loading existing images:', e);
                    existingImages = [];
                }
                renderExistingImages();
                // Update hidden input ngay khi load
                updateRemainingImagesInput();
            }

            // Render existing images
            function renderExistingImages() {
                var $grid = $('#existingImagesGrid');
                $grid.empty();
                
                if (existingImages.length > 0) {
                    $('#existingImagesSection').show();
                    existingImages.forEach(function(imagePath, index) {
                        var $item = $('<div class="preview-image-item existing" data-index="' + index + '">' +
                            '<img src="' + imagePath + '" alt="Ảnh hiện có" onerror="this.src=\'/images/placeholder.png\'; this.onerror=null;">' +
                            '<button type="button" class="remove-btn" data-index="' + index + '" title="Xóa ảnh">×</button>' +
                            '<div class="image-label">Ảnh hiện có</div>' +
                            '</div>');
                        $grid.append($item);
                    });
                    
                    // Attach remove handlers for existing images
                    $('.preview-image-item.existing .remove-btn').off('click').on('click', function(e) {
                        e.stopPropagation();
                        e.preventDefault();
                        var index = parseInt($(this).data('index'));
                        removeExistingImage(index);
                    });
                } else {
                    $('#existingImagesSection').hide();
                }
                updatePreviewContainer();
                updateRemainingImagesInput();
            }

            // Remove existing image
            function removeExistingImage(index) {
                if (confirm('Bạn có chắc chắn muốn xóa ảnh này không?')) {
                    // Remove from array
                    existingImages.splice(index, 1);
                    
                    // Re-render existing images
                    renderExistingImages();
                }
            }

            // Update hidden input with remaining existing images
            function updateRemainingImagesInput() {
                var $input = $('#remainingExistingImages');
                if (!$input || $input.length === 0) {
                    // Nếu input không tồn tại, không làm gì (có thể chưa vào edit mode)
                    return;
                }
                
                if (existingImages.length > 0) {
                    // Store as JSON array
                    try {
                        $input.val(JSON.stringify(existingImages));
                    } catch (e) {
                        console.error('Error serializing existing images:', e);
                        $input.val('');
                    }
                } else {
                    // Nếu không còn ảnh nào, set giá trị là empty string để controller biết đã xóa hết
                    $input.val('');
                }
            }

            // Handle file input change
            $('#editAnhVanPhong').on('change', function(e) {
                var files = e.target.files;
                if (!files || files.length === 0) {
                    return;
                }
                
                // Filter only image files
                var imageFiles = Array.from(files).filter(function(file) {
                    return file.type && file.type.startsWith('image/');
                });
                
                if (imageFiles.length === 0) {
                    alert('Vui lòng chọn file ảnh hợp lệ (JPG, PNG, GIF)');
                    return;
                }
                
                // Add new files to array (merge with existing, avoid duplicates)
                var filesToAdd = [];
                imageFiles.forEach(function(file) {
                    // Check if file already exists by name and size
                    var exists = newImageFiles.some(function(existingFile) {
                        return existingFile.name === file.name && existingFile.size === file.size;
                    });
                    if (!exists) {
                        filesToAdd.push(file);
                        newImageFiles.push(file);
                    }
                });
                
                // Read each new file and create preview
                if (filesToAdd.length > 0) {
                    var readCount = 0;
                    var totalToRead = filesToAdd.length;
                    
                    filesToAdd.forEach(function(file) {
                        var reader = new FileReader();
                        reader.onload = function(e) {
                            newImagePreviews.push({
                                file: file,
                                url: e.target.result,
                                index: newImagePreviews.length
                            });
                            readCount++;
                            
                            // Update indices for all previews
                            newImagePreviews.forEach(function(p, i) {
                                p.index = i;
                            });
                            
                            // Render when all files are read
                            if (readCount === totalToRead) {
                                renderNewImages();
                            }
                        };
                        reader.onerror = function() {
                            readCount++;
                            console.error('Error reading file:', file.name);
                            if (readCount === totalToRead) {
                                renderNewImages();
                            }
                        };
                        reader.readAsDataURL(file);
                    });
                } else {
                    // All files already exist, just render
                    renderNewImages();
                }
            });

            // Render new images preview
            function renderNewImages() {
                var $grid = $('#newImagesGrid');
                $grid.empty();
                
                if (newImagePreviews.length > 0) {
                    $('#newImagesSection').show();
                    newImagePreviews.forEach(function(preview, index) {
                        var $item = $('<div class="preview-image-item new" data-index="' + index + '">' +
                            '<img src="' + preview.url + '" alt="Ảnh mới">' +
                            '<button type="button" class="remove-btn" data-index="' + index + '" title="Xóa ảnh">×</button>' +
                            '<div class="image-label">Ảnh mới</div>' +
                            '</div>');
                        $grid.append($item);
                    });
                    
                    // Attach remove handlers
                    $('.preview-image-item.new .remove-btn').off('click').on('click', function(e) {
                        e.stopPropagation();
                        e.preventDefault();
                        var index = parseInt($(this).data('index'));
                        removeNewImage(index);
                    });
                } else {
                    $('#newImagesSection').hide();
                }
                updatePreviewContainer();
            }

            // Remove new image
            function removeNewImage(index) {
                // Remove from arrays
                newImageFiles.splice(index, 1);
                newImagePreviews.splice(index, 1);
                // Update indices
                newImagePreviews.forEach(function(p, i) {
                    p.index = i;
                });
                
                // Update file input
                updateFileInput();
                renderNewImages();
            }

            // Update file input with remaining files
            function updateFileInput() {
                var $input = $('#editAnhVanPhong');
                if ($input.length > 0 && typeof DataTransfer !== 'undefined') {
                    try {
                        var dt = new DataTransfer();
                        newImageFiles.forEach(function(file) {
                            dt.items.add(file);
                        });
                        $input[0].files = dt.files;
                    } catch (e) {
                        // Fallback: reset input and re-select files
                        console.log('DataTransfer not supported, using fallback');
                    }
                }
            }

            // Update preview container visibility
            function updatePreviewContainer() {
                var hasExisting = existingImages.length > 0;
                var hasNew = newImagePreviews.length > 0;
                var hasAny = hasExisting || hasNew;
                
                if (hasAny) {
                    $('#imagePreviewContainer').show().addClass('has-images');
                    $('#noPreviewMessage').hide();
                } else {
                    $('#imagePreviewContainer').show().removeClass('has-images');
                    $('#noPreviewMessage').show();
                }
                
                // Update remaining images input whenever container is updated
                updateRemainingImagesInput();
            }

            // Nút Sửa
            $('#btnEdit').on('click', function() {
