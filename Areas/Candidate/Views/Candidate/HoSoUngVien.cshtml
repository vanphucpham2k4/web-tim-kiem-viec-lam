@model Unicareer.Models.UngVien

@{
    ViewData["Title"] = "Hồ sơ ứng viên";
    var danhSachChuyenNganh = ViewBag.DanhSachChuyenNganh as List<Unicareer.Models.ChuyenNganh> ?? new List<Unicareer.Models.ChuyenNganh>();
    var danhSachNganhNghe = ViewBag.DanhSachNganhNghe as List<Unicareer.Models.NganhNghe> ?? new List<Unicareer.Models.NganhNghe>();
    var danhSachTinhThanh = ViewBag.DanhSachTinhThanh as List<Unicareer.Models.Province> ?? new List<Unicareer.Models.Province>();
    var trangThaiOptions = ViewBag.TrangThaiTimViecOptions as List<string> ?? new List<string>();
}

<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .form-section {
        background: white;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        border: 1px solid #e9ecef;
    }

    .form-section h4 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 3px solid #10b981;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px 16px;
        transition: all 0.3s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    .btn-save {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 12px;
        padding: 15px 40px;
        font-weight: 600;
        font-size: 16px;
        color: white;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
    }

    .file-upload-area {
        border: 2px dashed #cbd5e0;
        border-radius: 12px;
        padding: 40px;
        text-align: center;
        transition: all 0.3s;
        cursor: pointer;
        background: #f9fafb;
    }

    .file-upload-area:hover {
        border-color: #10b981;
        background: #f0fdf4;
    }

    .file-upload-area.dragover {
        border-color: #10b981;
        background: #f0fdf4;
    }

    .cv-preview {
        margin-top: 15px;
        padding: 15px;
        background: #f0fdf4;
        border-radius: 8px;
        border: 1px solid #10b981;
    }

    .cv-preview a {
        color: #059669;
        text-decoration: none;
        font-weight: 600;
    }

    .cv-preview a:hover {
        text-decoration: underline;
    }

    .cv-preview .btn-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border: none;
        color: white;
        font-weight: 600;
        padding: 8px 16px;
        transition: all 0.3s ease;
    }

    .cv-preview .btn-danger:hover {
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 34px;
    }

    .switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 34px;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 26px;
        width: 26px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    input:checked + .slider {
        background-color: #10b981;
    }

    input:checked + .slider:before {
        transform: translateX(26px);
    }

    .alert {
        border-radius: 12px;
        padding: 15px 20px;
        margin-bottom: 20px;
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    /* Quill Editor Styles */
    .ql-container {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        font-size: 14px;
        border-radius: 0 0 8px 8px;
    }

    .ql-toolbar {
        border-radius: 8px 8px 0 0;
        border: 1px solid #e2e8f0;
        background: #f7fafc;
    }

    .ql-container {
        border: 1px solid #e2e8f0;
        border-top: none;
        min-height: 200px;
    }

    .ql-container:focus-within,
    .ql-toolbar:focus-within {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    .editor-container {
        margin-bottom: 10px;
    }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-person-badge"></i> Hồ sơ ứng viên</h1>
            <p>Điền thông tin để tạo hồ sơ chuyên nghiệp và thu hút nhà tuyển dụng</p>
        </div>
        @if (Model != null && Model.MaUngVien > 0)
        {
            <a href="@Url.Action("ThongTinCaNhan", "Candidate", new { area = "Candidate", id = Model.MaUngVien })" 
               class="btn btn-light" style="background: rgba(255,255,255,0.2); border: 2px solid white; color: white; font-weight: 600;">
                <i class="bi bi-eye"></i> Xem hồ sơ công khai
            </a>
        }
    </div>
</div>

<div id="alertContainer"></div>

<!-- Thông báo về thông tin cơ bản -->
<div class="alert alert-info" style="border-radius: 12px; padding: 15px 20px; margin-bottom: 25px; background: #e6fffa; border: 1px solid #10b981; color: #047857;">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Lưu ý:</strong> Thông tin cơ bản (Họ tên, Giới tính, Ngày sinh) được quản lý tại 
    <a href="@Url.Action("CaiDat", "Candidate", new { area = "Candidate" })" style="color: #059669; font-weight: 600; text-decoration: underline;">trang Cài đặt</a>.
    Vui lòng cập nhật thông tin cơ bản tại đó.
</div>

<form id="hoSoForm" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- Thông tin nghề nghiệp -->
    <div class="form-section">
        <h4><i class="bi bi-briefcase"></i> Thông tin nghề nghiệp</h4>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Vị trí mong muốn</label>
                <input type="text" class="form-control" id="viTriMongMuon" name="viTriMongMuon" 
                       value="@Model?.ViTriMongMuon" placeholder="Ví dụ: Full-stack Developer, Marketing Manager...">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Chuyên ngành</label>
                <select class="form-select" id="maChuyenNganh" name="maChuyenNganh">
                    <option value="">Chọn chuyên ngành</option>
                    @foreach (var chuyenNganh in danhSachChuyenNganh)
                    {
                        <option value="@chuyenNganh.MaChuyenNganh" 
                                selected="@(Model?.MaChuyenNganh == chuyenNganh.MaChuyenNganh)">
                            @chuyenNganh.TenChuyenNganh
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Chuyên ngành khác (nếu không có trong danh sách)</label>
                <input type="text" class="form-control" id="chuyenNganhKhac" name="chuyenNganhKhac" 
                       value="@Model?.ChuyenNganhKhac" placeholder="Nhập chuyên ngành khác...">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Mức lương kỳ vọng (triệu VNĐ)</label>
                <input type="number" class="form-control" id="mucLuongKyVong" name="mucLuongKyVong" 
                       value="@Model?.MucLuongKyVong" placeholder="Ví dụ: 15" step="0.1" min="0">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Nơi làm việc mong muốn</label>
                <select class="form-select" id="noiLamViecMongMuon" name="noiLamViecMongMuon">
                    <option value="">Chọn tỉnh/thành phố</option>
                    @foreach (var tinh in danhSachTinhThanh)
                    {
                        <option value="@tinh.FullName" 
                                selected="@(Model?.NoiLamViecMongMuon == tinh.FullName)">
                            @tinh.FullName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Trạng thái tìm việc</label>
                <select class="form-select" id="trangThaiTimViec" name="trangThaiTimViec">
                    <option value="">Chọn trạng thái</option>
                    @foreach (var trangThai in trangThaiOptions)
                    {
                        <option value="@trangThai" selected="@(Model?.TrangThaiTimViec == trangThai)">
                            @trangThai
                        </option>
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- CV và hồ sơ -->
    <div class="form-section">
        <h4><i class="bi bi-file-earmark-person"></i> CV và hồ sơ cá nhân</h4>
        
        <div class="mb-3">
            <label class="form-label">Tải lên CV (PDF, DOC, DOCX - tối đa 10MB)</label>
            <div class="file-upload-area" id="fileUploadArea">
                <i class="bi bi-cloud-upload" style="font-size: 3rem; color: #10b981;"></i>
                <p class="mt-3 mb-2">Kéo thả file vào đây hoặc <strong>click để chọn file</strong></p>
                <p class="text-muted small">Hỗ trợ: PDF, DOC, DOCX (tối đa 10MB)</p>
                <input type="file" class="d-none" id="cvFile" name="cvFile" accept=".pdf,.doc,.docx">
            </div>
            <div id="fileInfo" class="mt-2"></div>
            @if (!string.IsNullOrEmpty(Model?.CVFile))
            {
                <div class="cv-preview" id="currentCvPreview">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-file-earmark-pdf"></i> 
                            <a href="@Model.CVFile" target="_blank">Xem CV hiện tại</a>
                        </div>
                        <button type="button" class="btn btn-sm btn-danger" id="btnXoaCV" style="border-radius: 6px;">
                            <i class="bi bi-trash"></i> Xóa CV
                        </button>
                    </div>
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Mục tiêu nghề nghiệp</label>
            <div id="editor-mucTieuNgheNghiep" class="editor-container"></div>
            <textarea id="mucTieuNgheNghiep" name="mucTieuNgheNghiep" style="display: none;">@Model?.MucTieuNgheNghiep</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Học vấn (chi tiết)</label>
            <div id="editor-hocVanChiTiet" class="editor-container"></div>
            <textarea id="hocVanChiTiet" name="hocVanChiTiet" style="display: none;">@Model?.HocVanChiTiet</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Kinh nghiệm làm việc (chi tiết)</label>
            <div id="editor-kinhNghiemChiTiet" class="editor-container"></div>
            <textarea id="kinhNghiemChiTiet" name="kinhNghiemChiTiet" style="display: none;">@Model?.KinhNghiemChiTiet</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Kỹ năng (chi tiết)</label>
            <div id="editor-kyNangChiTiet" class="editor-container"></div>
            <textarea id="kyNangChiTiet" name="kyNangChiTiet" style="display: none;">@Model?.KyNangChiTiet</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Chứng chỉ</label>
            <div id="editor-chungChi" class="editor-container"></div>
            <textarea id="chungChi" name="chungChi" style="display: none;">@Model?.ChungChi</textarea>
        </div>
    </div>

    <!-- Portfolio -->
    <div class="form-section">
        <h4><i class="bi bi-link-45deg"></i> Portfolio / Dự án thực tế</h4>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Link GitHub</label>
                <input type="url" class="form-control" id="linkGitHub" name="linkGitHub" 
                       value="@Model?.LinkGitHub" placeholder="https://github.com/username">
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Link Behance</label>
                <input type="url" class="form-control" id="linkBehance" name="linkBehance" 
                       value="@Model?.LinkBehance" placeholder="https://behance.net/username">
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Link Portfolio khác</label>
                <input type="url" class="form-control" id="linkPortfolio" name="linkPortfolio" 
                       value="@Model?.LinkPortfolio" placeholder="https://yourportfolio.com">
            </div>
        </div>
    </div>

    <!-- Mô tả bản thân -->
    <div class="form-section">
        <h4><i class="bi bi-chat-quote"></i> Mô tả bản thân</h4>
        <div class="mb-3">
            <label class="form-label">Giới thiệu ngắn gọn về bản thân</label>
            <div id="editor-moTaBanThan" class="editor-container"></div>
            <textarea id="moTaBanThan" name="moTaBanThan" style="display: none;">@Model?.MoTaBanThan</textarea>
            <small class="text-muted">Giúp nhà tuyển dụng hiểu thêm về bạn</small>
        </div>
    </div>

    <!-- Tùy chọn hiển thị -->
    <div class="form-section">
        <h4><i class="bi bi-eye"></i> Tùy chọn hiển thị</h4>
        <div class="d-flex align-items-center gap-3">
            <label class="form-label mb-0">Hiển thị hồ sơ công khai</label>
            <label class="switch">
                <input type="checkbox" id="hienThiCongKhai" name="hienThiCongKhai" 
                       @(Model?.HienThiCongKhai == true ? "checked" : "")>
                <span class="slider"></span>
            </label>
            <small class="text-muted">Chỉ nhà tuyển dụng đã đăng nhập mới xem được hồ sơ của bạn</small>
        </div>
    </div>

    <!-- Nút lưu -->
    <div class="text-center mb-5">
        <button type="submit" class="btn btn-save">
            <i class="bi bi-save"></i> Lưu hồ sơ
        </button>
    </div>
</form>

@section Scripts {
    <!-- Quill Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <!-- Quill Editor JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('hoSoForm');
        const fileUploadArea = document.getElementById('fileUploadArea');
        const cvFileInput = document.getElementById('cvFile');
        const fileInfo = document.getElementById('fileInfo');
        const alertContainer = document.getElementById('alertContainer');

        // Initialize Quill Editors
        let editors = {};
        
        // Editor configurations
        const editorConfigs = {
            'mucTieuNgheNghiep': {
                placeholder: 'Mô tả mục tiêu nghề nghiệp của bạn...'
            },
            'hocVanChiTiet': {
                placeholder: 'Ví dụ: Đại học Bách Khoa Hà Nội - Công nghệ thông tin (2018-2022)\nGPA: 3.5/4.0'
            },
            'kinhNghiemChiTiet': {
                placeholder: 'Ví dụ:\n1. Công ty ABC - Full-stack Developer (2022-2024)\n   - Phát triển ứng dụng web với React và .NET\n   - Quản lý team 3 người\n\n2. Công ty XYZ - Junior Developer (2020-2022)'
            },
            'kyNangChiTiet': {
                placeholder: 'Ví dụ:\n- Lập trình: C#, JavaScript, Python\n- Framework: .NET Core, React, Vue.js\n- Database: SQL Server, MongoDB\n- Tools: Git, Docker, AWS'
            },
            'chungChi': {
                placeholder: 'Ví dụ:\n- AWS Certified Solutions Architect (2023)\n- Google Cloud Professional Developer (2022)'
            },
            'moTaBanThan': {
                placeholder: 'Mô tả tính cách, phong cách làm việc, điểm mạnh của bạn...'
            }
        };

        // Initialize all Quill editors
        Object.keys(editorConfigs).forEach(function(fieldName) {
            var editorContainer = document.getElementById('editor-' + fieldName);
            var textarea = document.getElementById(fieldName);
            
            if (editorContainer && typeof Quill !== 'undefined') {
                var quill = new Quill(editorContainer, {
                    theme: 'snow',
                    modules: {
                        toolbar: [
                            [{ 'header': [1, 2, 3, false] }],
                            ['bold', 'italic', 'underline', 'strike'],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            [{ 'color': [] }, { 'background': [] }],
                            [{ 'align': [] }],
                            ['link', 'image'],
                            ['clean']
                        ]
                    },
                    placeholder: editorConfigs[fieldName].placeholder
                });

                // Load existing content
                if (textarea && textarea.value) {
                    quill.root.innerHTML = textarea.value;
                }

                // Update hidden textarea when editor content changes
                quill.on('text-change', function() {
                    if (textarea) {
                        textarea.value = quill.root.innerHTML;
                    }
                });

                editors[fieldName] = quill;
                console.log('Quill Editor initialized for:', fieldName);
            }
        });

        // File upload area click
        fileUploadArea.addEventListener('click', () => {
            cvFileInput.click();
        });

        // Drag and drop
        fileUploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            fileUploadArea.classList.add('dragover');
        });

        fileUploadArea.addEventListener('dragleave', () => {
            fileUploadArea.classList.remove('dragover');
        });

        fileUploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            fileUploadArea.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                cvFileInput.files = files;
                updateFileInfo(files[0]);
            }
        });

        // File input change
        cvFileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                updateFileInfo(e.target.files[0]);
            }
        });

        function updateFileInfo(file) {
            const fileSize = (file.size / (1024 * 1024)).toFixed(2);
            fileInfo.innerHTML = `
                <div class="alert alert-info">
                    <i class="bi bi-file-earmark"></i> 
                    <strong>${file.name}</strong> (${fileSize} MB)
                </div>
            `;
        }

        // Form submit
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Sync all Quill editors before submit
            Object.keys(editors).forEach(function(fieldName) {
                if (editors[fieldName]) {
                    var textarea = document.getElementById(fieldName);
                    if (textarea) {
                        textarea.value = editors[fieldName].root.innerHTML;
                    }
                }
            });

            const formData = new FormData(form);
            
            // Xử lý checkbox - nếu không checked thì không có trong FormData, cần thêm giá trị false
            const hienThiCongKhaiCheckbox = document.getElementById('hienThiCongKhai');
            if (hienThiCongKhaiCheckbox) {
                // Xóa giá trị cũ nếu có
                formData.delete('hienThiCongKhai');
                // Thêm giá trị mới (true nếu checked, false nếu không)
                formData.append('hienThiCongKhai', hienThiCongKhaiCheckbox.checked ? 'true' : 'false');
            }
            
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';

            try {
                const response = await fetch('@Url.Action("LuuHoSoUngVien", "Candidate", new { area = "Candidate" })', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('success', result.message);
                    // Reload page after 1.5 seconds to show updated data
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showAlert('danger', result.message);
                }
            } catch (error) {
                showAlert('danger', 'Có lỗi xảy ra khi lưu hồ sơ: ' + error.message);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });

        function showAlert(type, message) {
            alertContainer.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            // Auto dismiss after 5 seconds
            setTimeout(() => {
                const alert = alertContainer.querySelector('.alert');
                if (alert) {
                    alert.remove();
                }
            }, 5000);
        }

        // Xóa CV hiện tại
        const btnXoaCV = document.getElementById('btnXoaCV');
        if (btnXoaCV) {
            btnXoaCV.addEventListener('click', async function() {
                if (!confirm('Bạn có chắc chắn muốn xóa CV hiện tại không?')) {
                    return;
                }

                const originalText = btnXoaCV.innerHTML;
                btnXoaCV.disabled = true;
                btnXoaCV.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xóa...';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const response = await fetch('@Url.Action("XoaCV", "Candidate", new { area = "Candidate" })', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: `__RequestVerificationToken=${encodeURIComponent(token)}`
                    });

                    const result = await response.json();

                    if (result.success) {
                        showAlert('success', result.message);
                        const currentCvPreview = document.getElementById('currentCvPreview');
                        if (currentCvPreview) {
                            currentCvPreview.remove();
                        }
                        cvFileInput.value = '';
                        fileInfo.innerHTML = '';
                    } else {
                        showAlert('danger', result.message);
                        btnXoaCV.disabled = false;
                        btnXoaCV.innerHTML = originalText;
                    }
                } catch (error) {
                    showAlert('danger', 'Có lỗi xảy ra khi xóa CV: ' + error.message);
                    btnXoaCV.disabled = false;
                    btnXoaCV.innerHTML = originalText;
                }
            });
        }
    });
    </script>
}

