@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        border: 1px solid #e9ecef;
    }

    .info-card h4 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 3px solid #10b981;
    }
</style>

<div class="page-header">
    <h1><i class="bi bi-person"></i> Thông tin tài khoản</h1>
    <p>Quản lý thông tin cá nhân và cài đặt tài khoản của bạn</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="info-card">
            <h4><i class="bi bi-info-circle"></i> Thông tin cơ bản</h4>
            <p class="text-muted">Tính năng đang được phát triển. Vui lòng quay lại sau!</p>
        </div>
    </div>
</div>
