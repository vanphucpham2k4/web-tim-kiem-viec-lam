@model List<Unicareer.Models.TinTuyenDung>

@{
    ViewData["Title"] = "Việc làm đã lưu";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }

    .card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        transform: translateY(-5px);
    }

    .job-card {
        padding: 25px;
    }

    .job-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 10px;
    }

    .company-name {
        color: #10b981;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .job-info {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }

    .job-info-item {
        display: flex;
        align-items: center;
        gap: 5px;
        color: #718096;
        font-size: 0.9rem;
    }

    .job-info-item i {
        color: #10b981;
    }

    .btn-primary {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 12px;
        padding: 10px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
    }

    .btn-outline-danger {
        border: 2px solid #f56565;
        color: #f56565;
        border-radius: 12px;
        padding: 10px 20px;
        font-weight: 600;
    }

    .btn-outline-danger:hover {
        background: #f56565;
        color: white;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .empty-state i {
        font-size: 4rem;
        margin-bottom: 20px;
        color: #cbd5e0;
    }
</style>

<div class="page-header">
    <h1><i class="bi bi-heart"></i> Việc làm đã lưu</h1>
    <p>Danh sách các công việc bạn đã lưu để xem sau</p>
</div>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var job in Model)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="job-card">
                        <h3 class="job-title">@job.TenViecLam</h3>
                        <div class="company-name">
                            <i class="bi bi-building"></i> @job.CongTy
                        </div>
                        <div class="job-info">
                            <div class="job-info-item">
                                <i class="bi bi-briefcase"></i>
                                <span>@job.LoaiCongViec</span>
                            </div>
                            <div class="job-info-item">
                                <i class="bi bi-geo-alt"></i>
                                <span>@job.TinhThanhPho</span>
                            </div>
                            <div class="job-info-item">
                                <i class="bi bi-cash-coin"></i>
                                <span>@job.MucLuongThapNhat - @job.MucLuongCaoNhat triệu</span>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/Home/ChiTietViecLam/@job.MaTinTuyenDung" class="btn btn-primary">
                                <i class="bi bi-eye"></i> Xem chi tiết
                            </a>
                            <button class="btn btn-outline-danger" onclick="removeSavedJob(@job.MaTinTuyenDung)">
                                <i class="bi bi-heartbreak"></i> Bỏ lưu
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-heart"></i>
            <h4>Chưa có việc làm nào được lưu</h4>
            <p>Hãy tìm kiếm và lưu các công việc bạn quan tâm!</p>
            <a href="/Home/TimViec" class="btn btn-primary mt-3">
                <i class="bi bi-search"></i> Tìm việc ngay
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        function removeSavedJob(jobId) {
            if (confirm('Bạn có chắc chắn muốn bỏ lưu công việc này không?')) {
                // TODO: Implement remove saved job logic
                alert('Tính năng đang được phát triển!');
            }
        }
    </script>
}
