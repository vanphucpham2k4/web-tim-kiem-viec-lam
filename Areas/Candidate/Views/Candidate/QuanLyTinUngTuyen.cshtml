@model List<Unicareer.Models.TinUngTuyen>

@{
    ViewData["Title"] = "Quản lý tin ứng tuyển";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .page-header p {
        opacity: 0.95;
        font-size: 1.1rem;
        margin-bottom: 0;
    }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        gap: 15px;
    }

    .search-filter-group {
        display: flex;
        gap: 15px;
        flex: 1;
    }

    .btn-primary {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
    }

    .form-control, .form-select {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 16px;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    .input-group .btn {
        border-radius: 0 10px 10px 0;
        border: 2px solid #e2e8f0;
        border-left: none;
    }

    .input-group .form-control {
        border-radius: 10px 0 0 10px;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        animation: slideUp 0.5s ease forwards;
    }

    .card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        transform: translateY(-5px);
    }

    .table {
        margin-bottom: 0;
    }

    .table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .table thead th {
        border: none;
        color: #2d3748;
        font-weight: 600;
        padding: 18px 15px;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #e2e8f0;
    }

    .table tbody tr:hover {
        background-color: #f7fafc;
        transform: scale(1.01);
    }

    .table tbody td {
        padding: 18px 15px;
        vertical-align: middle;
        border: none;
    }

    .badge {
        padding: 8px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .badge.bg-success {
        background: linear-gradient(135deg, #48bb78 0%, #38a169 100%) !important;
    }

    .badge.bg-secondary {
        background: linear-gradient(135deg, #a0aec0 0%, #718096 100%) !important;
    }

    .badge.bg-primary {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
    }

    .badge.bg-warning {
        background: linear-gradient(135deg, #ed8936 0%, #dd6b20 100%) !important;
    }

    .badge.bg-info {
        background: linear-gradient(135deg, #4299e1 0%, #3182ce 100%) !important;
    }

    .badge.bg-danger {
        background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%) !important;
    }

    .btn-sm {
        padding: 8px 12px;
        border-radius: 8px;
        transition: all 0.3s ease;
        margin: 0 2px;
    }

    .btn-outline-primary {
        border: 2px solid #10b981;
        color: #10b981;
    }

    .btn-outline-primary:hover {
        background: #10b981;
        color: white;
        transform: translateY(-2px);
    }

    .stats-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border: 2px solid #e2e8f0;
        animation: slideUp 0.5s ease forwards;
        opacity: 0;
    }

    .stats-card:nth-child(1) { animation-delay: 0.1s; }
    .stats-card:nth-child(2) { animation-delay: 0.2s; }
    .stats-card:nth-child(3) { animation-delay: 0.3s; }
    .stats-card:nth-child(4) { animation-delay: 0.4s; }

    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .stats-card .card-title {
        font-size: 0.9rem;
        color: #718096;
        margin-bottom: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stats-card h2 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0;
    }

    .stats-card.primary {
        border-left: 5px solid #10b981;
    }

    .stats-card.success {
        border-left: 5px solid #48bb78;
    }

    .stats-card.secondary {
        border-left: 5px solid #a0aec0;
    }

    .stats-card.info {
        border-left: 5px solid #4299e1;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .table-responsive {
        border-radius: 12px;
        overflow: hidden;
    }

    @@media (max-width: 768px) {
        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .search-filter-group {
            flex-direction: column;
        }
    }
</style>

<div class="page-header">
    <h1><i class="bi bi-clipboard-check"></i> Quản lý tin ứng tuyển</h1>
    <p>Xem và theo dõi tất cả các tin ứng tuyển của bạn</p>
</div>

<div class="action-bar">
    <div class="search-filter-group">
        <div class="input-group" style="max-width: 350px;">
            <input type="text" class="form-control" id="timKiemInput" placeholder="Tìm kiếm theo vị trí...">
            <button class="btn btn-outline-secondary" type="button">
                <i class="bi bi-search"></i>
            </button>
        </div>
        <select class="form-select" id="locTrangThai" style="max-width: 200px;">
            <option value="">Tất cả trạng thái</option>
            <option value="Dang xem xet">Đang xem xét</option>
            <option value="Cho phong van">Chờ phỏng vấn</option>
            <option value="Da phong van">Đã phỏng vấn</option>
            <option value="Tuyen dung">Tuyển dụng</option>
            <option value="Tu choi">Từ chối</option>
        </select>
    </div>
    <div>
        <a href="/Home/TimViec" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm việc làm mới
        </a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th><i class="bi bi-hash"></i> Mã</th>
                                <th><i class="bi bi-briefcase"></i> Vị trí ứng tuyển</th>
                                <th><i class="bi bi-building"></i> Công ty</th>
                                <th><i class="bi bi-calendar-plus"></i> Ngày ứng tuyển</th>
                                <th><i class="bi bi-toggle-on"></i> Trạng thái</th>
                                <th><i class="bi bi-gear"></i> Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tin in Model)
                            {
                                var badgeClass = tin.TrangThaiXuLy switch
                                {
                                    "Dang xem xet" => "bg-warning",
                                    "Cho phong van" => "bg-info",
                                    "Da phong van" => "bg-primary",
                                    "Tuyen dung" => "bg-success",
                                    "Tu choi" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                                
                                <tr>
                                    <td><span class="text-muted">#@tin.MaTinUngTuyen</span></td>
                                    <td>
                                        <strong style="color: #2d3748; font-size: 1rem;">@tin.ViTriUngTuyen</strong>
                                    </td>
                                    <td>@tin.CongTy</td>
                                    <td>@tin.NgayUngTuyen.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @badgeClass">@tin.TrangThaiXuLy</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("ChiTietTinUngTuyen", "Candidate", new { id = tin.MaTinUngTuyen })" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-3 mb-3">
        <div class="stats-card primary">
            <h6 class="card-title">
                <i class="bi bi-clipboard-check"></i> Tổng tin ứng tuyển
            </h6>
            <h2 class="text-primary">@Model.Count</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card success">
            <h6 class="card-title">
                <i class="bi bi-check-circle"></i> Đang xem xét
            </h6>
            <h2 class="text-success">@Model.Count(t => t.TrangThaiXuLy == "Dang xem xet")</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card info">
            <h6 class="card-title">
                <i class="bi bi-calendar-event"></i> Chờ phỏng vấn
            </h6>
            <h2 class="text-info">@Model.Count(t => t.TrangThaiXuLy == "Cho phong van")</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card secondary">
            <h6 class="card-title">
                <i class="bi bi-x-circle"></i> Từ chối
            </h6>
            <h2 class="text-secondary">@Model.Count(t => t.TrangThaiXuLy == "Tu choi")</h2>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Search and filter functionality
            function filterTable() {
                var searchText = $('#timKiemInput').val().toLowerCase();
                var filterStatus = $('#locTrangThai').val();
                
                $('table tbody tr').each(function() {
                    var row = $(this);
                    var position = row.find('td:eq(1) strong').text().toLowerCase();
                    var status = row.find('td:eq(4) .badge').text().trim();
                    
                    var showRow = true;
                    
                    // Filter by search text
                    if (searchText && !position.includes(searchText)) {
                        showRow = false;
                    }
                    
                    // Filter by status
                    if (filterStatus && status !== filterStatus) {
                        showRow = false;
                    }
                    
                    if (showRow) {
                        row.show();
                        row.css('opacity', '0');
                        setTimeout(function() {
                            row.animate({ opacity: 1 }, 300);
                        }, 50);
                    } else {
                        row.hide();
                    }
                });
            }
            
            // Bind events
            $('#timKiemInput').on('keyup', filterTable);
            $('#locTrangThai').on('change', filterTable);
            
            // Add hover effect for stats cards
            $('.stats-card').hover(
                function() {
                    $(this).find('h2').css('transform', 'scale(1.1)').css('transition', 'all 0.3s ease');
                },
                function() {
                    $(this).find('h2').css('transform', 'scale(1)');
                }
            );
            
            // Animate numbers on load
            $('.stats-card h2').each(function() {
                var $this = $(this);
                var countTo = parseInt($this.text());
                
                $({ countNum: 0 }).animate({
                    countNum: countTo
                }, {
                    duration: 1500,
                    easing: 'swing',
                    step: function() {
                        $this.text(Math.floor(this.countNum));
                    },
                    complete: function() {
                        $this.text(this.countNum);
                    }
                });
            });
        });
    </script>
}
