@{
    ViewData["Title"] = "CV của tôi";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        border: 1px solid #e9ecef;
    }

    .info-card h4 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 3px solid #10b981;
    }

    .btn-primary {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
    }
</style>

<div class="page-header">
    <h1><i class="bi bi-file-earmark-person"></i> CV của tôi</h1>
    <p>Quản lý và cập nhật CV của bạn</p>
</div>

<div class="row">
    <div class="col-md-8">
        <!-- CV của tôi -->
        <div class="info-card">
            <h4><i class="bi bi-file-text"></i> CV của tôi</h4>
            <div class="info-section">
                <p class="text-muted mb-3">Tải lên CV để các nhà tuyển dụng có thể xem hồ sơ của bạn.</p>
                <button class="btn btn-primary" disabled>
                    <i class="bi bi-cloud-upload"></i> Tải CV lên
                </button>
            </div>
        </div>

        <!-- CV đã tải lên -->
        <div class="info-card">
            <h4><i class="bi bi-file-earmark-pdf"></i> CV đã tải lên</h4>
            <div class="info-section">
                <div class="empty-state">
                    <i class="bi bi-file-earmark-pdf" style="font-size: 3rem; color: #cbd5e0;"></i>
                    <p class="text-muted mt-3">Chưa có CV nào được tải lên.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Thông tin hữu ích -->
        <div class="info-card">
            <h4><i class="bi bi-lightbulb"></i> Mẹo</h4>
            <div class="info-section">
                <p><strong>CV chất lượng:</strong> Đảm bảo CV của bạn được định dạng đẹp, không có lỗi chính tả và cập nhật thông tin mới nhất.</p>
                <p class="mt-3"><strong>Định dạng:</strong> Hỗ trợ file PDF, DOC, DOCX. Kích thước tối đa 5MB.</p>
                <p class="mt-3"><strong>Bảo mật:</strong> CV của bạn chỉ được nhà tuyển dụng xem khi bạn ứng tuyển vào vị trí của họ.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .info-section {
        padding: 10px 0;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
    }

    .info-section p {
        line-height: 1.7;
        margin-bottom: 0;
    }
</style>
