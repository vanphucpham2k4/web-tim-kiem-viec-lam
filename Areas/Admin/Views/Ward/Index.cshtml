@model Unicareer.Models.ViewModels.WardManagementViewModel

@{
    ViewData["Title"] = "Quản lý Quận/Huyện";
}

<style>
    .ward-management-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(37, 69, 184, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .page-header p {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 15px;
        align-items: end;
    }

    .filter-form input,
    .filter-form select {
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        width: 100%;
    }

    .filter-form input:focus,
    .filter-form select:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .btn-filter {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-filter:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .table-container {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow-x: auto;
    }

    .ward-table {
        width: 100%;
        border-collapse: collapse;
    }

    .ward-table thead {
        background: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

    .ward-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #2d3748;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .ward-table td {
        padding: 15px;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
    }

    .ward-table tbody tr {
        transition: all 0.2s ease;
    }

    .ward-table tbody tr:hover {
        background: #f8f9fa;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 6px 12px;
        border: none;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-edit {
        background: #f3e8ff;
        color: #6b21a8;
    }

    .btn-edit:hover {
        background: #e9d5ff;
    }

    .btn-delete {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-delete:hover {
        background: #fecaca;
    }

    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .stat-card h3 {
        font-size: 2rem;
        font-weight: 700;
        color: #2545B8;
        margin: 0;
    }

    .stat-card p {
        color: #718096;
        margin: 10px 0 0 0;
        font-size: 0.9rem;
    }

    .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 20px 30px;
    }

    .modal-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        display: block;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .btn-primary {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .no-data {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .no-data i {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .pagination .page-link {
        border: 2px solid #e2e8f0;
        color: #2545B8;
        padding: 10px 16px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .pagination .page-link:hover {
        background: #2545B8;
        color: white;
        border-color: #2545B8;
        transform: translateY(-2px);
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-color: #2545B8;
        color: white;
        box-shadow: 0 4px 15px rgba(37, 69, 184, 0.4);
    }

    .pagination .page-item.disabled .page-link {
        color: #a0aec0;
        border-color: #e2e8f0;
        cursor: not-allowed;
        opacity: 0.5;
    }

    .pagination .page-item.disabled .page-link:hover {
        background: transparent;
        transform: none;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        color: #718096;
        font-size: 0.9rem;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    #timKiemInput {
        padding-right: 40px;
    }
</style>

@Html.AntiForgeryToken()

<div class="ward-management-container">
    <div class="page-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1><i class="bi bi-geo-fill"></i> Quản lý Quận/Huyện</h1>
                <p>Quản lý danh mục quận/huyện trong hệ thống</p>
            </div>
            <button class="btn" style="background: white; color: #2545B8; padding: 12px 30px; border-radius: 10px; font-weight: 600; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: all 0.3s;" data-bs-toggle="modal" data-bs-target="#themWardModal">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </button>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="stats-section">
        <div class="stat-card">
            <h3>@Model.TotalCount</h3>
            <p>Tổng quận/huyện</p>
        </div>
        <div class="stat-card">
            <h3>@Model.Wards.Count</h3>
            <p>Hiển thị trên trang này</p>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
        <form class="filter-form" method="get" action="@Url.Action("Index", "Ward", new { area = "Admin" })" id="searchForm">
            <input type="hidden" name="pageNumber" id="pageNumberInput" value="@Model.PageNumber" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <div>
                <label for="provinceFilter" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Lọc theo tỉnh thành</label>
                <select id="provinceFilter" name="provinceCode" class="form-control">
                    <option value="">-- Tất cả tỉnh thành --</option>
                    @foreach (var province in Model.Provinces)
                    {
                        <option value="@province.Code" selected="@(Model.SelectedProvinceCode == province.Code)">@province.FullName</option>
                    }
                </select>
            </div>
            <div style="position: relative;">
                <label for="timKiemInput" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Tìm kiếm</label>
                <input type="text" id="timKiemInput" name="search" value="@Model.SearchTerm" placeholder="Tìm kiếm theo tên quận/huyện..." />
                <span id="searchLoading" style="position: absolute; right: 15px; top: 40px; display: none; color: #2545B8;">
                    <i class="bi bi-arrow-repeat" style="animation: spin 1s linear infinite;"></i>
                </span>
            </div>
            <div>
                <button type="submit" class="btn-filter">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        @if (Model.Wards.Any())
        {
            <table class="ward-table" id="bangWard">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên</th>
                        <th>Tên đầy đủ</th>
                        <th>Tên EN</th>
                        <th>Tỉnh thành</th>
                        <th>Đơn vị hành chính</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ward in Model.Wards)
                    {
                        <tr data-code="@ward.Code">
                            <td><strong>@ward.Code</strong></td>
                            <td><strong>@ward.Name</strong></td>
                            <td>@(ward.FullName ?? "-")</td>
                            <td>@(ward.NameEn ?? "-")</td>
                            <td>@(ward.Province?.FullName ?? "-")</td>
                            <td>@(ward.AdministrativeUnit?.FullName ?? "-")</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-action btn-edit btn-sua" 
                                            data-code="@ward.Code"
                                            data-name="@ward.Name"
                                            data-nameen="@ward.NameEn"
                                            data-fullname="@ward.FullName"
                                            data-fullnameen="@ward.FullNameEn"
                                            data-codename="@ward.CodeName"
                                            data-provincecode="@ward.ProvinceCode"
                                            data-administrativeunitid="@ward.AdministrativeUnitId"
                                            title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn-action btn-delete btn-xoa" 
                                            data-code="@ward.Code" 
                                            title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Phân trang">
                    <ul class="pagination">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber - 1))">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                            </li>
                        }

                        @{
                            int startPage = Math.Max(1, Model.PageNumber - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@i)">@i</a>
                            </li>
                        }

                        @if (endPage < Model.TotalPages)
                        {
                            @if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">@Model.TotalPages</a>
                            </li>
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber + 1))">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                            </li>
                        }
                    </ul>
                    <div class="pagination-info">
                        Hiển thị <strong>@((Model.PageNumber - 1) * Model.PageSize + 1)</strong> - 
                        <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</strong> 
                        trong tổng số <strong>@Model.TotalCount</strong> quận/huyện
                    </div>
                </nav>
            }
        }
        else
        {
            <div class="no-data">
                <i class="bi bi-geo"></i>
                <h3>Chưa có quận/huyện nào</h3>
                <p>Hãy thêm quận/huyện mới để bắt đầu</p>
            </div>
        }
    </div>
</div>

<!-- Modal Thêm quận/huyện -->
<div class="modal fade" id="themWardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Thêm quận/huyện mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formThemWard">
                    <div class="form-group">
                        <label for="codeMoi">Mã quận/huyện <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="codeMoi" required placeholder="Nhập mã quận/huyện">
                    </div>
                    <div class="form-group">
                        <label for="nameMoi">Tên quận/huyện <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="nameMoi" required placeholder="Nhập tên quận/huyện">
                    </div>
                    <div class="form-group">
                        <label for="fullNameMoi">Tên đầy đủ</label>
                        <input type="text" class="form-control" id="fullNameMoi" placeholder="Nhập tên đầy đủ (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="nameEnMoi">Tên tiếng Anh</label>
                        <input type="text" class="form-control" id="nameEnMoi" placeholder="Nhập tên tiếng Anh (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="fullNameEnMoi">Tên đầy đủ tiếng Anh</label>
                        <input type="text" class="form-control" id="fullNameEnMoi" placeholder="Nhập tên đầy đủ tiếng Anh (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="codeNameMoi">Mã tên</label>
                        <input type="text" class="form-control" id="codeNameMoi" placeholder="Nhập mã tên (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="provinceCodeMoi">Tỉnh thành</label>
                        <select class="form-control" id="provinceCodeMoi">
                            <option value="">-- Chọn tỉnh thành --</option>
                            @foreach (var province in Model.Provinces)
                            {
                                <option value="@province.Code">@province.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="administrativeUnitIdMoi">Đơn vị hành chính</label>
                        <select class="form-control" id="administrativeUnitIdMoi">
                            <option value="">-- Chọn đơn vị hành chính --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnLuuWard">
                    <i class="bi bi-check-circle me-2"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa quận/huyện -->
<div class="modal fade" id="suaWardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Sửa quận/huyện</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formSuaWard">
                    <input type="hidden" id="codeSua">
                    <div class="form-group">
                        <label for="nameSua">Tên quận/huyện <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="nameSua" required placeholder="Nhập tên quận/huyện">
                    </div>
                    <div class="form-group">
                        <label for="fullNameSua">Tên đầy đủ</label>
                        <input type="text" class="form-control" id="fullNameSua" placeholder="Nhập tên đầy đủ (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="nameEnSua">Tên tiếng Anh</label>
                        <input type="text" class="form-control" id="nameEnSua" placeholder="Nhập tên tiếng Anh (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="fullNameEnSua">Tên đầy đủ tiếng Anh</label>
                        <input type="text" class="form-control" id="fullNameEnSua" placeholder="Nhập tên đầy đủ tiếng Anh (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="codeNameSua">Mã tên</label>
                        <input type="text" class="form-control" id="codeNameSua" placeholder="Nhập mã tên (tùy chọn)">
                    </div>
                    <div class="form-group">
                        <label for="provinceCodeSua">Tỉnh thành</label>
                        <select class="form-control" id="provinceCodeSua">
                            <option value="">-- Chọn tỉnh thành --</option>
                            @foreach (var province in Model.Provinces)
                            {
                                <option value="@province.Code">@province.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="administrativeUnitIdSua">Đơn vị hành chính</label>
                        <select class="form-control" id="administrativeUnitIdSua">
                            <option value="">-- Chọn đơn vị hành chính --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnCapNhatWard">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var isPaginationClick = false;
            
            // Hàm điều hướng đến trang
            window.goToPage = function(pageNumber) {
                isPaginationClick = true;
                $('#pageNumberInput').val(pageNumber);
                $('#searchForm').submit();
            };
            
            // Khi thay đổi filter, reset về trang 1
            $('#provinceFilter').on('change', function() {
                $('#pageNumberInput').val(1);
                $('#searchForm').submit();
            });
            
            // Khi submit form tìm kiếm, reset về trang 1 (chỉ khi không phải là click phân trang)
            $('#searchForm').on('submit', function(e) {
                if (!isPaginationClick) {
                    $('#pageNumberInput').val(1);
                }
                isPaginationClick = false; // Reset flag
            });
            
            // Khi nhấn nút tìm kiếm, reset về trang 1
            $('#searchForm button[type="submit"]').on('click', function() {
                isPaginationClick = false;
            });

            // Load danh sách AdministrativeUnit khi mở modal
            function loadAdministrativeUnits(selectId) {
                $.ajax({
                    url: '@Url.Action("GetAdministrativeUnits", "Ward", new { area = "Admin" })',
                    type: 'GET',
                    success: function(response) {
                        if (response.success) {
                            var select = $('#' + selectId);
                            select.empty();
                            select.append('<option value="">-- Chọn đơn vị hành chính --</option>');
                            response.data.forEach(function(unit) {
                                select.append('<option value="' + unit.id + '">' + unit.fullName + '</option>');
                            });
                        }
                    }
                });
            }

            $('#themWardModal').on('show.bs.modal', function() {
                loadAdministrativeUnits('administrativeUnitIdMoi');
            });

            $('#suaWardModal').on('show.bs.modal', function() {
                loadAdministrativeUnits('administrativeUnitIdSua');
            });

            // Them ward
            $('#btnLuuWard').click(function() {
                var code = $('#codeMoi').val();
                var name = $('#nameMoi').val();
                var nameEn = $('#nameEnMoi').val();
                var fullName = $('#fullNameMoi').val();
                var fullNameEn = $('#fullNameEnMoi').val();
                var codeName = $('#codeNameMoi').val();
                var provinceCode = $('#provinceCodeMoi').val() || null;
                var administrativeUnitId = $('#administrativeUnitIdMoi').val() || null;

                if (!code || !name) {
                    alert('Vui lòng nhập đầy đủ thông tin bắt buộc!');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("Create", "Ward", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        code: code,
                        name: name,
                        nameEn: nameEn,
                        fullName: fullName,
                        fullNameEn: fullNameEn,
                        codeName: codeName,
                        provinceCode: provinceCode,
                        administrativeUnitId: administrativeUnitId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            $('#themWardModal').modal('hide');
                            $('#formThemWard')[0].reset();
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra khi thêm quận/huyện!');
                    }
                });
            });

            // Sua ward
            $(document).on('click', '.btn-sua', function() {
                var code = $(this).data('code');
                var name = $(this).data('name');
                var nameEn = $(this).data('nameen');
                var fullName = $(this).data('fullname');
                var fullNameEn = $(this).data('fullnameen');
                var codeName = $(this).data('codename');
                var provinceCode = $(this).data('provincecode');
                var administrativeUnitId = $(this).data('administrativeunitid');

                $('#codeSua').val(code);
                $('#nameSua').val(name);
                $('#nameEnSua').val(nameEn || '');
                $('#fullNameSua').val(fullName || '');
                $('#fullNameEnSua').val(fullNameEn || '');
                $('#codeNameSua').val(codeName || '');
                $('#provinceCodeSua').val(provinceCode || '');
                
                // Set selected value after options are loaded
                setTimeout(function() {
                    $('#administrativeUnitIdSua').val(administrativeUnitId || '');
                }, 500);

                $('#suaWardModal').modal('show');
            });

            $('#btnCapNhatWard').click(function() {
                var code = $('#codeSua').val();
                var name = $('#nameSua').val();
                var nameEn = $('#nameEnSua').val();
                var fullName = $('#fullNameSua').val();
                var fullNameEn = $('#fullNameEnSua').val();
                var codeName = $('#codeNameSua').val();
                var provinceCode = $('#provinceCodeSua').val() || null;
                var administrativeUnitId = $('#administrativeUnitIdSua').val() || null;

                if (!name) {
                    alert('Vui lòng nhập tên quận/huyện!');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("Edit", "Ward", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        code: code,
                        name: name,
                        nameEn: nameEn,
                        fullName: fullName,
                        fullNameEn: fullNameEn,
                        codeName: codeName,
                        provinceCode: provinceCode,
                        administrativeUnitId: administrativeUnitId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            $('#suaWardModal').modal('hide');
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra khi cập nhật quận/huyện!');
                    }
                });
            });

            // Xoa ward
            $(document).on('click', '.btn-xoa', function() {
                var code = $(this).data('code');
                var row = $(this).closest('tr');
                
                if (confirm('Bạn có chắc chắn muốn xóa quận/huyện này?')) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Ward", new { area = "Admin" })',
                        type: 'POST',
                        data: {
                            code: code,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                alert(response.message);
                                row.fadeOut(300, function() {
                                    $(this).remove();
                                    location.reload();
                                });
                            } else {
                                alert(response.message);
                            }
                        },
                        error: function() {
                            alert('Có lỗi xảy ra khi xóa quận/huyện!');
                        }
                    });
                }
            });
        });
    </script>
}

