@model Unicareer.Models.ViewModels.AdminLoginViewModel

@{
    ViewData["Title"] = "Cổng Quản Trị Hệ Thống";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Unicareer Security</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --admin-primary: #0f172a; /* Dark Navy */
            --admin-secondary: #1e293b; /* Slate */
            --admin-accent: #3b82f6; /* Blue */
            --admin-danger: #ef4444; /* Red */
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            height: 100vh;
            overflow: hidden;
        }

        .login-wrapper {
            height: 100vh;
            width: 100%;
            display: flex;
        }

        /* KHU VỰC HÌNH ẢNH (BÊN TRÁI) */
        .login-sidebar {
            flex: 1; /* Chiếm phần không gian còn lại */
            background: var(--admin-primary);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
            overflow: hidden;
        }

            /* Lớp phủ hình ảnh abstract */
            .login-sidebar::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=2070&auto=format&fit=crop') no-repeat center center/cover;
                opacity: 0.15;
                z-index: 0;
            }

        .sidebar-content {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .sidebar-logo {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 20px;
            letter-spacing: -1px;
        }

        .sidebar-text {
            font-size: 1.1rem;
            color: #94a3b8;
            max-width: 400px;
        }

        /* KHU VỰC FORM (BÊN PHẢI) - ĐÃ ĐIỀU CHỈNH ĐỘ RỘNG */
        .login-main {
            width: 700px; /* <-- ĐÃ TĂNG TỪ 500px LÊN 700px */
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 80px; /* Tăng padding ngang một chút cho cân đối */
            box-shadow: -10px 0 20px rgba(0,0,0,0.05);
            position: relative;
        }

        .admin-badge {
            display: inline-flex;
            align-items: center;
            background-color: #fee2e2;
            color: #991b1b;
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 25px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .admin-badge i {
                margin-right: 6px;
            }

        .login-title {
            font-weight: 700;
            color: var(--admin-primary);
            font-size: 32px; /* Tăng kích thước font tiêu đề một chút */
            margin-bottom: 10px;
        }

        .login-subtitle {
            color: #64748b;
            margin-bottom: 30px;
            font-size: 16px;
        }

        /* Form Styling */
        .form-floating > .form-control {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            height: 55px;
        }

            .form-floating > .form-control:focus {
                border-color: var(--admin-accent);
                box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            }

        .form-floating > label {
            color: #94a3b8;
        }

        .btn-submit {
            background: var(--admin-primary);
            color: white;
            height: 55px; /* Nút cao hơn một chút cho phù hợp với form rộng */
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.2s;
            border: none;
            font-size: 18px;
        }

            .btn-submit:hover {
                background: var(--admin-secondary);
                transform: translateY(-1px);
            }

        .system-status {
            position: absolute;
            bottom: 20px;
            left: 80px;
            right: 80px;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            border-top: 1px solid #f1f5f9;
            padding-top: 15px;
        }

        .dot-indicator {
            height: 8px;
            width: 8px;
            background-color: #22c55e;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }

        /* Responsive: Trên màn hình nhỏ, form sẽ chiếm 100% */
        @@media (max-width: 1200px) {
            .login-main {
                width: 500px;
                padding: 0 40px;
            }
        }

        @@media (max-width: 992px) {
            .login-sidebar {
                display: none;
            }

            .login-main {
                width: 100%;
                padding: 40px;
            }

            .system-status {
                left: 40px;
                right: 40px;
            }
        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <div class="login-sidebar">
            <div class="sidebar-content">
                <div class="mb-4">
                    <i class="bi bi-shield-fill-check" style="font-size: 5rem; color: var(--admin-accent);"></i>
                </div>
                <h1 class="sidebar-logo">Unicareer Admin</h1>
                <p class="sidebar-text">
                    Hệ thống quản lý dữ liệu tập trung.<br>
                    Mọi truy cập đều được giám sát và ghi nhật ký IP.
                </p>
            </div>
        </div>

        <div class="login-main">
            <div>
                <div class="admin-badge">
                    <i class="bi bi-lock-fill"></i> Restricted Area
                </div>

                <h2 class="login-title">Xác thực Quản trị viên</h2>
                <p class="login-subtitle">Vui lòng nhập thông tin xác thực cấp cao để truy cập hệ thống.</p>

                <div class="alert alert-warning d-flex align-items-center mb-4" role="alert" style="font-size: 14px;">
                    <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                    <div>
                        <strong>Cảnh báo bảo mật:</strong> Khu vực này chỉ dành cho nhân sự được ủy quyền. Phiên làm việc sẽ tự động kết thúc sau 30 phút.
                    </div>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 14px;"></div>
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="form-floating mb-4">
                        <input asp-for="Email" class="form-control" id="floatingInput" placeholder="name@example.com" autocomplete="off">
                        <label for="floatingInput">Email Quản trị (admin@unicareer.com)</label>
                        <span asp-validation-for="Email" class="text-danger" style="font-size: 13px;"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="MatKhau" type="password" class="form-control" id="floatingPassword" placeholder="Password">
                        <label for="floatingPassword">Mật khẩu bảo mật</label>
                        <span asp-validation-for="MatKhau" class="text-danger" style="font-size: 13px;"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="GhiNho" class="form-check-input" type="checkbox" id="rememberCheck" style="transform: scale(1.2);">
                            <label class="form-check-label text-secondary ms-2" for="rememberCheck" style="font-size: 15px;">
                                Ghi nhớ phiên đăng nhập này
                            </label>
                        </div>
                        <a href="#" class="text-decoration-none fw-bold" style="font-size: 15px; color: var(--admin-accent);">Cần hỗ trợ?</a>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-submit">
                            TRUY CẬP HỆ THỐNG <i class="bi bi-arrow-right-circle-fill ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>

            <div class="system-status">
                <span class="dot-indicator"></span> System Status: <strong>Operational</strong> &bull; Encrypted Connection (TLS 1.3) <br>
                IP Address Logged. Unauthorized access is prohibited.
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>