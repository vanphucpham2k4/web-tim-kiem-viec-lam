                    </div>
                    <div class="alert alert-warning" style="margin-top: 15px;">
                        <i class="bi bi-exclamation-triangle"></i> <strong>Lưu ý:</strong> Gán role mới sẽ thay thế tất cả role hiện tại của người dùng.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Gán Role</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Assign Role Modal -->
<div class="modal fade" id="bulkAssignRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-badge"></i> Gán Role Hàng Loạt</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="BulkAssignRole" method="post" id="bulkAssignRoleForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label>Số lượng người dùng đã chọn</label>
                        <input type="text" id="bulkModalUserCount" class="form-control" readonly style="background-color: #f7fafc;" />
                        <input type="hidden" name="userIds" id="bulkModalUserIds" />
                    </div>
                    <div class="form-group">
                        <label for="bulkRoleName">Role <span style="color: red;">*</span></label>
                        <select name="roleName" id="bulkRoleName" class="form-control" required>
                            <option value="">-- Chọn role --</option>
                            @foreach (var role in Model.AvailableRoles)
                            {
                                var roleDisplay = role switch
                                {
                                    "Admin" => "Quản trị viên",
                                    "NhaTuyenDung" => "Nhà tuyển dụng",
                                    "UngVien" => "Ứng viên",
                                    _ => role
                                };
                                <option value="@role">@roleDisplay</option>
                            }
                        </select>
                    </div>
                    <div class="alert alert-warning" style="margin-top: 15px;">
                        <i class="bi bi-exclamation-triangle"></i> <strong>Lưu ý:</strong> Gán role mới sẽ thay thế tất cả role hiện tại của các người dùng đã chọn. Tài khoản quản trị viên chính sẽ được bỏ qua.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Gán Role</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showAssignRoleModal(userId, userEmail, currentRoles) {
            document.getElementById('modalUserId').value = userId;
            document.getElementById('modalUserEmail').value = userEmail;
            document.getElementById('roleName').value = '';
            
            const modal = new bootstrap.Modal(document.getElementById('assignRoleModal'));
            modal.show();
        }

        function showBulkAssignRoleModal() {
            const checkboxes = document.querySelectorAll('.user-checkbox:checked');
            const userIds = Array.from(checkboxes).map(cb => cb.value);
            
            if (userIds.length === 0) {
                alert('Vui lòng chọn ít nhất một người dùng!');
                return;
            }
            
            document.getElementById('bulkModalUserIds').value = userIds.join(',');
            document.getElementById('bulkModalUserCount').value = userIds.length + ' người dùng';
            document.getElementById('bulkRoleName').value = '';
            
            const modal = new bootstrap.Modal(document.getElementById('bulkAssignRoleModal'));
            modal.show();
        }

        function handleRowClick(event, userId) {
            // Kiểm tra nếu click vào các phần tử không nên trigger navigation
            if (event.target.closest('.no-click') || 
                event.target.closest('button') || 
                event.target.closest('a') || 
                event.target.closest('form') ||
                event.target.closest('input[type="checkbox"]')) {
                return;
            }
            
            // Chuyển đến trang chi tiết
            const baseUrl = '@Url.Action("UserDetails", "AdminUser")';
            window.location.href = baseUrl + '?userId=' + encodeURIComponent(userId);
        }

        // Dropdown management
        function toggleDropdown(event) {
            event.stopPropagation();
            const dropdown = document.getElementById('selectAllDropdown');
            dropdown.classList.toggle('show');
        }

        // Đóng dropdown khi click ra ngoài
        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('selectAllDropdown');
            const selectAllDropdown = document.querySelector('.select-all-dropdown');
            if (!selectAllDropdown.contains(event.target)) {
                dropdown.classList.remove('show');
            }
        });

        // Selection management
        let allSelected = false;

        function toggleSelectAll() {
            allSelected = !allSelected;
            const checkboxes = document.querySelectorAll('.user-checkbox:not(:disabled)');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            checkboxes.forEach(checkbox => {
                checkbox.checked = allSelected;
            });
            
            // Highlight/bỏ highlight các hàng (chỉ hàng không disabled)
            document.querySelectorAll('tbody tr').forEach(row => {
                const checkbox = row.querySelector('.user-checkbox');
                if (checkbox && !checkbox.disabled) {
                    if (allSelected) {
                        row.classList.add('selected');
                    } else {
                        row.classList.remove('selected');
                    }
                }
            });
            
            if (allSelected) {
                selectAllIcon.className = 'bi bi-check-square';
            } else {
                selectAllIcon.className = 'bi bi-square';
            }
            
            updateSelection();
        }

        function selectAllUsers() {
            const checkboxes = document.querySelectorAll('.user-checkbox:not(:disabled)');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            checkboxes.forEach(checkbox => {
                checkbox.checked = true;
            });
            
            selectAllIcon.className = 'bi bi-check-square';
            allSelected = true;
            
            // Highlight tất cả các hàng (trừ admin chính)
            document.querySelectorAll('tbody tr').forEach(row => {
                const checkbox = row.querySelector('.user-checkbox');
                if (checkbox && !checkbox.disabled) {
                    row.classList.add('selected');
                }
            });
            
            updateSelection();
            document.getElementById('selectAllDropdown').classList.remove('show');
        }

        function deselectAllUsers() {
            const checkboxes = document.querySelectorAll('.user-checkbox:not(:disabled)');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            checkboxes.forEach(checkbox => {
                checkbox.checked = false;
            });
            
            selectAllIcon.className = 'bi bi-square';
            allSelected = false;
            
            // Bỏ highlight tất cả các hàng
            document.querySelectorAll('tbody tr').forEach(row => {
                row.classList.remove('selected');
            });
            
            updateSelection();
            document.getElementById('selectAllDropdown').classList.remove('show');
        }

        function selectLockedUsers() {
            const rows = document.querySelectorAll('tbody tr');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            // Bỏ chọn tất cả trước
            document.querySelectorAll('.user-checkbox:not(:disabled)').forEach(cb => cb.checked = false);
            rows.forEach(row => row.classList.remove('selected'));
            
            // Chọn các hàng bị khóa (trừ admin chính)
            rows.forEach(row => {
                const isLocked = row.getAttribute('data-is-locked') === 'true';
                const checkbox = row.querySelector('.user-checkbox');
                if (isLocked && checkbox && !checkbox.disabled) {
                    checkbox.checked = true;
                    row.classList.add('selected');
                }
            });
            
            // Cập nhật icon
            const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
            const totalCount = document.querySelectorAll('.user-checkbox:not(:disabled)').length;
            if (checkedCount === totalCount && totalCount > 0) {
                selectAllIcon.className = 'bi bi-check-square';
                allSelected = true;
            } else if (checkedCount > 0) {
                selectAllIcon.className = 'bi bi-dash-square';
                allSelected = false;
            } else {
                selectAllIcon.className = 'bi bi-square';
                allSelected = false;
            }
            
            updateSelection();
            document.getElementById('selectAllDropdown').classList.remove('show');
        }

        function selectActiveUsers() {
            const rows = document.querySelectorAll('tbody tr');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            // Bỏ chọn tất cả trước
            document.querySelectorAll('.user-checkbox:not(:disabled)').forEach(cb => cb.checked = false);
            rows.forEach(row => row.classList.remove('selected'));
            
            // Chọn các hàng hoạt động (trừ admin chính)
            rows.forEach(row => {
                const isActive = row.getAttribute('data-is-active') === 'true';
                const checkbox = row.querySelector('.user-checkbox');
                if (isActive && checkbox && !checkbox.disabled) {
                    checkbox.checked = true;
                    row.classList.add('selected');
                }
            });
            
            // Cập nhật icon
            const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
            const totalCount = document.querySelectorAll('.user-checkbox:not(:disabled)').length;
            if (checkedCount === totalCount && totalCount > 0) {
                selectAllIcon.className = 'bi bi-check-square';
                allSelected = true;
            } else if (checkedCount > 0) {
                selectAllIcon.className = 'bi bi-dash-square';
                allSelected = false;
            } else {
                selectAllIcon.className = 'bi bi-square';
                allSelected = false;
            }
            
            updateSelection();
            document.getElementById('selectAllDropdown').classList.remove('show');
        }

        function selectEmailConfirmedUsers() {
            const rows = document.querySelectorAll('tbody tr');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            // Bỏ chọn tất cả trước
            document.querySelectorAll('.user-checkbox:not(:disabled)').forEach(cb => cb.checked = false);
            rows.forEach(row => row.classList.remove('selected'));
            
            // Chọn các hàng đã xác nhận email (trừ admin chính)
            rows.forEach(row => {
                const emailConfirmed = row.getAttribute('data-email-confirmed') === 'true';
                const checkbox = row.querySelector('.user-checkbox');
                if (emailConfirmed && checkbox && !checkbox.disabled) {
                    checkbox.checked = true;
                    row.classList.add('selected');
                }
            });
            
            // Cập nhật icon
            const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
            const totalCount = document.querySelectorAll('.user-checkbox:not(:disabled)').length;
            if (checkedCount === totalCount && totalCount > 0) {
                selectAllIcon.className = 'bi bi-check-square';
                allSelected = true;
            } else if (checkedCount > 0) {
                selectAllIcon.className = 'bi bi-dash-square';
                allSelected = false;
            } else {
                selectAllIcon.className = 'bi bi-square';
                allSelected = false;
            }
            
            updateSelection();
            document.getElementById('selectAllDropdown').classList.remove('show');
        }

        function selectEmailUnconfirmedUsers() {
            const rows = document.querySelectorAll('tbody tr');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            // Bỏ chọn tất cả trước
            document.querySelectorAll('.user-checkbox:not(:disabled)').forEach(cb => cb.checked = false);
            rows.forEach(row => row.classList.remove('selected'));
            
            // Chọn các hàng chưa xác nhận email (trừ admin chính)
            rows.forEach(row => {
                const emailConfirmed = row.getAttribute('data-email-confirmed') === 'false';
                const checkbox = row.querySelector('.user-checkbox');
                if (emailConfirmed && checkbox && !checkbox.disabled) {
                    checkbox.checked = true;
                    row.classList.add('selected');
                }
            });
            
            // Cập nhật icon
            const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
            const totalCount = document.querySelectorAll('.user-checkbox:not(:disabled)').length;
            if (checkedCount === totalCount && totalCount > 0) {
                selectAllIcon.className = 'bi bi-check-square';
                allSelected = true;
            } else if (checkedCount > 0) {
                selectAllIcon.className = 'bi bi-dash-square';
                allSelected = false;
            } else {
                selectAllIcon.className = 'bi bi-square';
                allSelected = false;
            }
            
            updateSelection();
            document.getElementById('selectAllDropdown').classList.remove('show');
        }

        function updateSelection() {
            const checkboxes = document.querySelectorAll('.user-checkbox:checked');
            const selectedCount = checkboxes.length;
            const selectedCountEl = document.getElementById('selectedCount');
            const bulkToolbar = document.getElementById('bulkActionsToolbar');
            const selectAllIcon = document.getElementById('selectAllIcon');
            
            // Update count
            selectedCountEl.textContent = selectedCount + ' đã chọn';
            
            // Show/hide toolbar
            if (selectedCount > 0) {
                bulkToolbar.classList.add('active');
            } else {
                bulkToolbar.classList.remove('active');
            }
            
            // Update select all icon (only count enabled checkboxes)
            const allCheckboxes = document.querySelectorAll('.user-checkbox:not(:disabled)');
            if (selectedCount === 0) {
                selectAllIcon.className = 'bi bi-square';
                allSelected = false;
            } else if (selectedCount === allCheckboxes.length && allCheckboxes.length > 0) {
                selectAllIcon.className = 'bi bi-check-square';
                allSelected = true;
            } else {
                selectAllIcon.className = 'bi bi-dash-square';
                allSelected = false;
            }
            
            // Update row highlighting
            document.querySelectorAll('tbody tr').forEach(row => {
                const checkbox = row.querySelector('.user-checkbox');
                if (checkbox && checkbox.checked && !checkbox.disabled) {
                    row.classList.add('selected');
                } else {
                    row.classList.remove('selected');
                }
            });
        }

        // Update form with selected user IDs before submit
        const bulkLockForm = document.getElementById('bulkLockForm');
        const bulkUnlockForm = document.getElementById('bulkUnlockForm');
        
        if (bulkLockForm) {
            bulkLockForm.addEventListener('submit', function(e) {
                const checkboxes = document.querySelectorAll('.user-checkbox:checked');
                const userIds = Array.from(checkboxes).map(cb => cb.value);
                const userIdsInput = document.getElementById('bulkLockUserIds');
                if (userIdsInput) {
                    userIdsInput.value = userIds.join(',');
                }
                if (userIds.length === 0) {
                    e.preventDefault();
                    alert('Vui lòng chọn ít nhất một người dùng!');
                    return false;
                }
            });
        }

        if (bulkUnlockForm) {
            bulkUnlockForm.addEventListener('submit', function(e) {
                const checkboxes = document.querySelectorAll('.user-checkbox:checked');
                const userIds = Array.from(checkboxes).map(cb => cb.value);
                const userIdsInput = document.getElementById('bulkUnlockUserIds');
                if (userIdsInput) {
                    userIdsInput.value = userIds.join(',');
                }
                if (userIds.length === 0) {
                    e.preventDefault();
                    alert('Vui lòng chọn ít nhất một người dùng!');
                    return false;
                }
            });
        }

        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}

