@model Unicareer.Models.ViewModels.UserManagementViewModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<style>
    .user-management-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(37, 69, 184, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .page-header p {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 2fr 1fr auto;
        gap: 15px;
        align-items: end;
    }

    .filter-form input,
    .filter-form select {
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .filter-form input:focus,
    .filter-form select:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .btn-filter {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-filter:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .users-table-container {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow-x: auto;
    }

    .users-table {
        width: 100%;
        border-collapse: collapse;
    }

    .users-table thead {
        background: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

    .users-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #2d3748;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .users-table td {
        padding: 15px;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
    }

    .users-table tbody tr {
        transition: all 0.2s ease;
    }

    .users-table tbody tr:hover {
        background: #f8f9fa;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        margin-right: 10px;
    }

    .user-info-cell {
        display: flex;
        align-items: center;
    }

    .user-details {
        display: flex;
        flex-direction: column;
    }

    .user-email {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 3px;
    }

    .user-name {
        font-size: 0.85rem;
        color: #718096;
    }

    .role-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-right: 5px;
        margin-bottom: 5px;
    }

    .role-admin {
        background: #fee2e2;
        color: #991b1b;
    }

    .role-nhatuyendung {
        background: #dbeafe;
        color: #1e40af;
    }

    .role-ungvien {
        background: #dcfce7;
        color: #166534;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
    }

    .status-locked {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-unconfirmed {
        background: #fef3c7;
        color: #92400e;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 6px 12px;
        border: none;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-reset-password {
        background: #fef3c7;
        color: #92400e;
    }

    .btn-reset-password:hover {
        background: #fde68a;
    }

    .btn-assign-role {
        background: #dbeafe;
        color: #1e40af;
    }

    .btn-assign-role:hover {
        background: #bfdbfe;
    }

    .btn-lock {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-lock:hover {
        background: #fecaca;
    }

    .btn-unlock {
        background: #dcfce7;
        color: #166534;
    }

    .btn-unlock:hover {
        background: #bbf7d0;
    }

    .btn-details {
        background: #e0e7ff;
        color: #3730a3;
    }

    .btn-details:hover {
        background: #c7d2fe;
    }

    .btn-edit {
        background: #f3e8ff;
        color: #6b21a8;
    }

    .btn-edit:hover {
        background: #e9d5ff;
    }

    .alert {
        border-radius: 10px;
        padding: 15px 20px;
        margin-bottom: 20px;
    }

    .alert-success {
        background: #f0fdf4;
        border: 1px solid #86efac;
        color: #166534;
    }

    .alert-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .no-users {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .no-users i {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .stat-card h3 {
        font-size: 2rem;
        font-weight: 700;
        color: #2545B8;
        margin: 0;
    }

    .stat-card p {
        color: #718096;
        margin: 10px 0 0 0;
        font-size: 0.9rem;
    }

    .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 20px 30px;
    }

    .modal-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        display: block;
    }

    .form-group select {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    @@media (max-width: 768px) {
        .filter-form {
            grid-template-columns: 1fr;
        }

        .users-table {
            font-size: 0.85rem;
        }

        .action-buttons {
            flex-direction: column;
        }

        .page-header > div {
            flex-direction: column !important;
            gap: 20px;
        }

        .page-header .btn {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="user-management-container">
    <div class="page-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1><i class="bi bi-people"></i> Quản lý người dùng</h1>
                <p>Quản lý tất cả người dùng, roles, và quyền truy cập hệ thống</p>
            </div>
            <a asp-action="CreateUser" class="btn" style="background: white; color: #2545B8; padding: 12px 30px; border-radius: 10px; font-weight: 600; text-decoration: none; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: all 0.3s;">
                <i class="bi bi-person-plus"></i> Tạo tài khoản mới
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats Section -->
    <div class="stats-section">
        <div class="stat-card">
            <h3>@Model.Users.Count</h3>
            <p>Tổng số người dùng</p>
        </div>
        <div class="stat-card">
            <h3>@Model.Users.Count(u => u.Roles.Contains("Admin"))</h3>
            <p>Quản trị viên</p>
        </div>
        <div class="stat-card">
            <h3>@Model.Users.Count(u => u.Roles.Contains("NhaTuyenDung"))</h3>
            <p>Nhà tuyển dụng</p>
        </div>
        <div class="stat-card">
            <h3>@Model.Users.Count(u => u.Roles.Contains("UngVien"))</h3>
            <p>Ứng viên</p>
        </div>
        <div class="stat-card">
            <h3>@Model.Users.Count(u => u.IsLockedOut)</h3>
            <p>Tài khoản bị khóa</p>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
        <form method="get" asp-action="UserManagement" class="filter-form">
            <div>
                <label for="searchTerm" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Tìm kiếm</label>
                <input type="text" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Email, tên, số điện thoại..." />
            </div>
            <div>
                <label for="roleFilter" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Lọc theo role</label>
                <select id="roleFilter" name="roleFilter">
                    <option value="">Tất cả roles</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role" selected="@(Model.RoleFilter == role)">@role</option>
                    }
                </select>
            </div>
            <div>
                <button type="submit" class="btn-filter">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.RoleFilter))
                {
                    <a href="@Url.Action("UserManagement")" class="btn btn-secondary" style="margin-top: 10px; display: block; text-align: center; padding: 12px; border-radius: 8px; text-decoration: none; background: #e2e8f0; color: #2d3748;">
                        <i class="bi bi-x-circle"></i> Xóa bộ lọc
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Users Table -->
    <div class="users-table-container">
        @if (Model.Users.Any())
        {
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Role</th>
                        <th>Trạng thái</th>
                        <th>Ngày đăng ký</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="user-info-cell">
                                    <div class="user-avatar">
                                        @if (!string.IsNullOrEmpty(user.HoTen))
                                        {
                                            var nameParts = user.HoTen.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                            if (nameParts.Length >= 2)
                                            {
                                                @($"{nameParts[0][0]}{nameParts[^1][0]}".ToUpper())
                                            }
                                            else if (nameParts.Length == 1)
                                            {
                                                @nameParts[0].Substring(0, Math.Min(2, nameParts[0].Length)).ToUpper()
                                            }
                                            else
                                            {
                                                @user.Email.Substring(0, 2).ToUpper()
                                            }
                                        }
                                        else
                                        {
                                            @user.Email.Substring(0, 2).ToUpper()
                                        }
                                    </div>
                                    <div class="user-details">
                                        <div class="user-email">@user.Email</div>
                                        @if (!string.IsNullOrEmpty(user.HoTen))
                                        {
                                            <div class="user-name">@user.HoTen</div>
                                        }
                                        @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                        {
                                            <div class="user-name">@user.PhoneNumber</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    var roleClass = role switch
                                    {
                                        "Admin" => "role-admin",
                                        "NhaTuyenDung" => "role-nhatuyendung",
                                        "UngVien" => "role-ungvien",
                                        _ => ""
                                    };
                                    var roleDisplay = role switch
                                    {
                                        "Admin" => "Quản trị viên",
                                        "NhaTuyenDung" => "Nhà tuyển dụng",
                                        "UngVien" => "Ứng viên",
                                        _ => role
                                    };
                                    <span class="role-badge @roleClass" title="@role">@roleDisplay</span>
                                }
                            </td>
                            <td>
                                @if (user.IsLockedOut)
                                {
                                    <span class="status-badge status-locked">
                                        <i class="bi bi-lock"></i> Đã khóa
                                    </span>
                                }
                                else if (!user.EmailConfirmed)
                                {
                                    <span class="status-badge status-unconfirmed">
                                        <i class="bi bi-envelope"></i> Chưa xác nhận
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-active">
                                        <i class="bi bi-check-circle"></i> Hoạt động
                                    </span>
                                }
                                @if (user.IsPrimaryAdmin)
                                {
                                    <br />
                                    <small style="color: #991b1b; font-weight: 600;">⚠️ Admin chính</small>
                                }
                            </td>
                            <td>@user.NgayDangKy.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="UserDetails" asp-route-userId="@user.Id" class="btn-action btn-details" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="ResetUserPassword" asp-route-userId="@user.Id" class="btn-action btn-reset-password" title="Reset mật khẩu">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    @if (!user.IsPrimaryAdmin)
                                    {
                                        <button type="button" class="btn-action btn-assign-role" onclick="showAssignRoleModal('@user.Id', '@user.Email', '@string.Join(",", user.Roles)')" title="Gán role">
                                            <i class="bi bi-person-badge"></i>
                                        </button>
                                        @if (user.IsLockedOut)
                                        {
                                            <form asp-action="LockUnlockUser" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn mở khóa tài khoản này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="lockUser" value="false" />
                                                <button type="submit" class="btn-action btn-unlock" title="Mở khóa">
                                                    <i class="bi bi-unlock"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="LockUnlockUser" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn khóa tài khoản này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="lockUser" value="true" />
                                                <button type="submit" class="btn-action btn-lock" title="Khóa tài khoản">
                                                    <i class="bi bi-lock"></i>
                                                </button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-users">
                <i class="bi bi-people"></i>
                <h3>Không tìm thấy người dùng nào</h3>
                <p>Thử thay đổi bộ lọc tìm kiếm</p>
            </div>
        }
    </div>
</div>

<!-- Assign Role Modal -->
<div class="modal fade" id="assignRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-badge"></i> Gán Role</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AssignRole" method="post" id="assignRoleForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label>Người dùng</label>
                        <input type="text" id="modalUserEmail" class="form-control" readonly style="background-color: #f7fafc;" />
                        <input type="hidden" name="userId" id="modalUserId" />
                    </div>
                    <div class="form-group">
                        <label for="roleName">Role <span style="color: red;">*</span></label>
                        <select name="roleName" id="roleName" class="form-control" required>
                            <option value="">-- Chọn role --</option>
                            @foreach (var role in Model.AvailableRoles)
                            {
                                var roleDisplay = role switch
                                {
                                    "Admin" => "Quản trị viên",
                                    "NhaTuyenDung" => "Nhà tuyển dụng",
                                    "UngVien" => "Ứng viên",
                                    _ => role
                                };
                                <option value="@role">@roleDisplay</option>
                            }
                        </select>
                    </div>
                    <div class="alert alert-warning" style="margin-top: 15px;">
                        <i class="bi bi-exclamation-triangle"></i> <strong>Lưu ý:</strong> Gán role mới sẽ thay thế tất cả role hiện tại của người dùng.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Gán Role</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showAssignRoleModal(userId, userEmail, currentRoles) {
            document.getElementById('modalUserId').value = userId;
            document.getElementById('modalUserEmail').value = userEmail;
            document.getElementById('roleName').value = '';
            
            const modal = new bootstrap.Modal(document.getElementById('assignRoleModal'));
            modal.show();
        }

        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}

