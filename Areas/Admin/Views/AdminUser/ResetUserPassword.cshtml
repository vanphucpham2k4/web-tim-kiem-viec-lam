@model Unicareer.Models.ViewModels.ResetUserPasswordViewModel
@{
    ViewData["Title"] = "Reset mật khẩu người dùng";
}

<style>
    .reset-password-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .page-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(37, 69, 184, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2rem;
        margin-bottom: 10px;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .user-info-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        border-left: 4px solid #2545B8;
    }

    .user-info-box h5 {
        color: #2d3748;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .user-info-box p {
        color: #718096;
        margin: 5px 0;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-group label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        display: block;
        font-size: 14px;
    }

    .form-group label .required {
        color: #e53e3e;
        margin-left: 3px;
    }

    .form-group input {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .form-group input:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .form-group .text-danger {
        font-size: 0.85rem;
        margin-top: 5px;
    }

    .info-hint {
        font-size: 12px;
        color: #718096;
        margin-top: 5px;
    }

    .alert {
        border-radius: 10px;
        padding: 15px 20px;
        margin-bottom: 20px;
    }

    .alert-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 25px;
        border-top: 1px solid #e9ecef;
    }

    .btn-save {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border: none;
        padding: 12px 35px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 15px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(37, 69, 184, 0.3);
        cursor: pointer;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
        color: white;
    }

    .btn-cancel {
        background: white;
        color: #2d3748;
        border: 1px solid #e2e8f0;
        padding: 12px 35px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-cancel:hover {
        background: #f7fafc;
        border-color: #cbd5e0;
        color: #2d3748;
    }

    .security-warning {
        background: #fff5f5;
        border: 2px solid #fed7d7;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .security-warning h5 {
        color: #c53030;
        font-weight: 600;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .security-warning p {
        color: #718096;
        margin: 0;
    }
</style>

<div class="reset-password-container">
    <div class="page-header">
        <h1><i class="bi bi-key"></i> Reset mật khẩu</h1>
        <p>Đặt lại mật khẩu cho người dùng</p>
    </div>

    <div class="form-card">
        <div class="user-info-box">
            <h5><i class="bi bi-person"></i> Thông tin người dùng</h5>
            <p><strong>Email:</strong> @Model.UserEmail</p>
            @if (!string.IsNullOrEmpty(Model.UserName))
            {
                <p><strong>Tên:</strong> @Model.UserName</p>
            }
        </div>

        <div class="security-warning">
            <h5>
                <i class="bi bi-shield-exclamation"></i>
                Lưu ý bảo mật
            </h5>
            <p>Bạn đang reset mật khẩu cho người dùng khác. Mật khẩu mới sẽ thay thế hoàn toàn mật khẩu cũ. Người dùng sẽ cần đăng nhập lại với mật khẩu mới.</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="ResetUserPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserEmail" />
            <input type="hidden" asp-for="UserName" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label for="NewPassword">
                    Mật khẩu mới <span class="required">*</span>
                </label>
                <input type="password" id="NewPassword" name="NewPassword" asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới" required />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
                <div class="info-hint">Mật khẩu phải có ít nhất 6 ký tự</div>
            </div>

            <div class="form-group">
                <label for="ConfirmPassword">
                    Xác nhận mật khẩu mới <span class="required">*</span>
                </label>
                <input type="password" id="ConfirmPassword" name="ConfirmPassword" asp-for="ConfirmPassword" class="form-control" placeholder="Xác nhận mật khẩu mới" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="bi bi-check-circle me-2"></i>Reset mật khẩu
                </button>
                <a asp-action="UserManagement" class="btn-cancel">
                    <i class="bi bi-x-circle me-2"></i>Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

