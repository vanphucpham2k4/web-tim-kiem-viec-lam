@model Unicareer.Models.ViewModels.ChuyenNganhAdminViewModel

@{
    ViewData["Title"] = "Quản lý Chuyên ngành";
    var danhSachNganhNghe = Model.DanhSachNganhNghe ?? new List<Unicareer.Models.NganhNghe>();
}

@Html.AntiForgeryToken()

<style>
    .chuyennganh-management-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(37, 69, 184, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .page-header p {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 2fr 1fr auto;
        gap: 15px;
        align-items: end;
    }

    .filter-form input,
    .filter-form select {
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        width: 100%;
    }

    .filter-form input:focus,
    .filter-form select:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .btn-filter {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-filter:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .table-container {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow-x: auto;
    }

    .chuyennganh-table {
        width: 100%;
        border-collapse: collapse;
    }

    .chuyennganh-table thead {
        background: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

    .chuyennganh-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #2d3748;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .chuyennganh-table td {
        padding: 15px;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
    }

    .chuyennganh-table tbody tr {
        transition: all 0.2s ease;
    }

    .chuyennganh-table tbody tr:hover {
        background: #f8f9fa;
    }

    .badge-custom {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-primary-custom {
        background: #dbeafe;
        color: #1e40af;
    }

    .badge-success-custom {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-danger-custom {
        background: #fee2e2;
        color: #991b1b;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 6px 12px;
        border: none;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-edit {
        background: #f3e8ff;
        color: #6b21a8;
    }

    .btn-edit:hover {
        background: #e9d5ff;
    }

    .btn-delete {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-delete:hover {
        background: #fecaca;
    }

    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .stat-card h3 {
        font-size: 2rem;
        font-weight: 700;
        color: #2545B8;
        margin: 0;
    }

    .stat-card p {
        color: #718096;
        margin: 10px 0 0 0;
        font-size: 0.9rem;
    }

    .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 20px 30px;
    }

    .modal-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        display: block;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-check input[type="checkbox"] {
        width: auto;
    }

    .btn-primary {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .no-data {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .no-data i {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .pagination .page-link {
        border: 2px solid #e2e8f0;
        color: #2545B8;
        padding: 10px 16px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .pagination .page-link:hover {
        background: #2545B8;
        color: white;
        border-color: #2545B8;
        transform: translateY(-2px);
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-color: #2545B8;
        color: white;
        box-shadow: 0 4px 15px rgba(37, 69, 184, 0.4);
    }

    .pagination .page-item.disabled .page-link {
        color: #a0aec0;
        border-color: #e2e8f0;
        cursor: not-allowed;
        opacity: 0.5;
    }

    .pagination .page-item.disabled .page-link:hover {
        background: transparent;
        transform: none;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        color: #718096;
        font-size: 0.9rem;
    }

    .chuyennganh-row {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
        position: relative;
    }

    .chuyennganh-row-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .chuyennganh-row-number {
        background: #2545B8;
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .btn-remove-row {
        background: #fee2e2;
        color: #991b1b;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-remove-row:hover {
        background: #fecaca;
    }

    .chuyennganh-row-body {
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
    }

    @@media (max-width: 768px) {
        .filter-form {
            grid-template-columns: 1fr;
        }

        .chuyennganh-table {
            font-size: 0.85rem;
        }

        .action-buttons {
            flex-direction: column;
        }

        .page-header > div {
            flex-direction: column !important;
            gap: 20px;
        }

        .page-header .btn {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="chuyennganh-management-container">
    <div class="page-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1><i class="bi bi-book-fill"></i> Quản lý Chuyên ngành</h1>
                <p>Quản lý danh mục chuyên ngành theo từng ngành nghề</p>
            </div>
            <button class="btn" style="background: white; color: #2545B8; padding: 12px 30px; border-radius: 10px; font-weight: 600; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: all 0.3s;" data-bs-toggle="modal" data-bs-target="#themChuyenNganhModal">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </button>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="stats-section">
        <div class="stat-card">
            <h3>@Model.TotalChuyenNganh</h3>
            <p>Tổng chuyên ngành</p>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
        <form class="filter-form" method="get" action="@Url.Action("ChuyenNganh", "Admin", new { area = "Admin" })" id="searchForm">
            <input type="hidden" name="pageNumber" id="pageNumberInput" value="@Model.PageNumber" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <div>
                <label for="timKiemInput" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Tìm kiếm</label>
                <input type="text" id="timKiemInput" name="searchTerm" value="@Model.SearchTerm" placeholder="Tìm kiếm theo tên chuyên ngành..." />
            </div>
            <div>
                <label for="locNganhNghe" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Lọc theo ngành nghề</label>
                <select id="locNganhNghe" name="maNganhNgheFilter">
                    <option value="">Tất cả ngành nghề</option>
                    @foreach (var nganhNghe in danhSachNganhNghe)
                    {
                        <option value="@nganhNghe.MaNganhNghe" selected="@(Model.MaNganhNgheFilter == nganhNghe.MaNganhNghe)">@nganhNghe.TenNganhNghe</option>
                    }
                </select>
            </div>
            <div>
                <button type="submit" class="btn-filter">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        @if (Model.ChuyenNganhs != null && Model.ChuyenNganhs.Any())
        {
            <table class="chuyennganh-table" id="bangChuyenNganh">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên chuyên ngành</th>
                        <th>Ngành nghề</th>
                        <th>Mô tả</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var chuyenNganh in Model.ChuyenNganhs)
                    {
                        <tr data-ma="@chuyenNganh.MaChuyenNganh" data-nganhnghe="@(chuyenNganh.MaNganhNghe?.ToString() ?? "")">
                            <td><strong>#@chuyenNganh.MaChuyenNganh</strong></td>
                            <td><strong>@chuyenNganh.TenChuyenNganh</strong></td>
                            <td>
                                <span class="badge-custom badge-primary-custom">
                                    @(chuyenNganh.NganhNghe?.TenNganhNghe ?? "N/A")
                                </span>
                            </td>
                            <td>
                                <span class="text-muted">
                                    @(chuyenNganh.MoTa != null && chuyenNganh.MoTa.Length > 60 ? chuyenNganh.MoTa.Substring(0, 60) + "..." : chuyenNganh.MoTa ?? "")
                                </span>
                            </td>
                            <td>@chuyenNganh.NgayTao.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-action btn-edit btn-sua" 
                                            data-ma="@chuyenNganh.MaChuyenNganh"
                                            data-ten="@chuyenNganh.TenChuyenNganh"
                                            data-mota="@chuyenNganh.MoTa"
                                            data-nganhnghe="@chuyenNganh.MaNganhNghe"
                                            title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn-action btn-delete btn-xoa" 
                                            data-ma="@chuyenNganh.MaChuyenNganh" 
                                            title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Phân trang">
                    <ul class="pagination">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber - 1))">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                            </li>
                        }

                        @{
                            int startPage = Math.Max(1, Model.PageNumber - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@i)">@i</a>
                            </li>
                        }

                        @if (endPage < Model.TotalPages)
                        {
                            @if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">@Model.TotalPages</a>
                            </li>
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber + 1))">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                            </li>
                        }
                    </ul>
                    <div class="pagination-info">
                        Hiển thị <strong>@((Model.PageNumber - 1) * Model.PageSize + 1)</strong> - 
                        <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</strong> 
                        trong tổng số <strong>@Model.TotalCount</strong> chuyên ngành
                    </div>
                </nav>
            }
        }
        else
        {
            <div class="no-data">
                <i class="bi bi-book"></i>
                <h3>Chưa có chuyên ngành nào</h3>
                <p>Hãy thêm chuyên ngành mới để bắt đầu</p>
            </div>
        }
    </div>
</div>

<!-- Modal Thêm nhiều chuyên ngành -->
<div class="modal fade" id="themChuyenNganhModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Thêm chuyên ngành mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Bước 1: Chọn ngành nghề -->
                <div id="buocChonNganhNghe">
                    <div class="form-group">
                        <label for="nganhNgheMoi" style="font-size: 1.1rem; font-weight: 600; margin-bottom: 15px;">
                            <i class="bi bi-briefcase me-2"></i>Chọn ngành nghề <span style="color: red;">*</span>
                        </label>
                        <select class="form-control" id="nganhNgheMoi" required style="font-size: 1rem; padding: 15px;">
                            <option value="">-- Chọn ngành nghề --</option>
                            @foreach (var nganhNghe in danhSachNganhNghe)
                            {
                                <option value="@nganhNghe.MaNganhNghe">@nganhNghe.TenNganhNghe</option>
                            }
                        </select>
                    </div>
                    <div style="text-align: center; margin-top: 30px;">
                        <button type="button" class="btn btn-primary" id="btnTiepTucThemChuyenNganh" style="padding: 12px 40px; font-size: 1rem;">
                            <i class="bi bi-arrow-right me-2"></i>Tiếp tục
                        </button>
                    </div>
                </div>

                <!-- Bước 2: Thêm nhiều chuyên ngành -->
                <div id="buocThemChuyenNganh" style="display: none;">
                    <div style="margin-bottom: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px;">
                        <strong id="tenNganhNgheDaChon"></strong>
                        <button type="button" class="btn btn-sm btn-link" id="btnThayDoiNganhNghe" style="float: right; padding: 0;">
                            <i class="bi bi-pencil"></i> Thay đổi
                        </button>
                    </div>
                    
                    <div id="danhSachChuyenNganh">
                        <!-- Các dòng chuyên ngành sẽ được thêm động ở đây -->
                    </div>
                    
                    <div style="margin-top: 20px;">
                        <button type="button" class="btn btn-outline-primary" id="btnThemDongChuyenNganh">
                            <i class="bi bi-plus-circle me-2"></i>Thêm dòng mới
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer" id="modalFooterThemChuyenNganh" style="display: none;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnLuuNhieuChuyenNganh">
                    <i class="bi bi-check-circle me-2"></i>Lưu tất cả
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa chuyên ngành -->
<div class="modal fade" id="suaChuyenNganhModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Sửa chuyên ngành</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formSuaChuyenNganh">
                    <input type="hidden" id="maChuyenNganhSua">
                    <div class="form-group">
                        <label for="nganhNgheSua">Ngành nghề <span style="color: red;">*</span></label>
                        <select class="form-control" id="nganhNgheSua" required>
                            <option value="">-- Chọn ngành nghề --</option>
                            @foreach (var nganhNghe in danhSachNganhNghe)
                            {
                                <option value="@nganhNghe.MaNganhNghe">@nganhNghe.TenNganhNghe</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="tenChuyenNganhSua">Tên chuyên ngành <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="tenChuyenNganhSua" required placeholder="Nhập tên chuyên ngành">
                    </div>
                    <div class="form-group">
                        <label for="moTaSua">Mô tả</label>
                        <textarea class="form-control" id="moTaSua" rows="3" placeholder="Nhập mô tả chuyên ngành (tùy chọn)"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnCapNhatChuyenNganh">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var isPaginationClick = false;
            
            // Hàm điều hướng đến trang
            window.goToPage = function(pageNumber) {
                isPaginationClick = true;
                $('#pageNumberInput').val(pageNumber);
                $('#searchForm').submit();
            };
            
            // Khi thay đổi filter, reset về trang 1
            $('#locNganhNghe').on('change', function() {
                $('#pageNumberInput').val(1);
                $('#searchForm').submit();
            });
            
            // Khi submit form tìm kiếm, reset về trang 1 (chỉ khi không phải là click phân trang)
            $('#searchForm').on('submit', function(e) {
                if (!isPaginationClick) {
                    $('#pageNumberInput').val(1);
                }
                isPaginationClick = false; // Reset flag
            });
            
            // Khi nhấn nút tìm kiếm, reset về trang 1
            $('#searchForm button[type="submit"]').on('click', function() {
                isPaginationClick = false;
            });

            var soThuTuChuyenNganh = 0;

            // Reset modal khi đóng
            $('#themChuyenNganhModal').on('hidden.bs.modal', function() {
                $('#buocChonNganhNghe').show();
                $('#buocThemChuyenNganh').hide();
                $('#modalFooterThemChuyenNganh').hide();
                $('#nganhNgheMoi').val('');
                $('#danhSachChuyenNganh').empty();
                soThuTuChuyenNganh = 0;
            });

            // Bước 1: Tiếp tục sau khi chọn ngành nghề
            $('#btnTiepTucThemChuyenNganh').click(function() {
                var maNganhNghe = $('#nganhNgheMoi').val();
                var tenNganhNghe = $('#nganhNgheMoi option:selected').text();

                if (!maNganhNghe) {
                    showNotification('Vui lòng chọn ngành nghề!', 'error');
                    return;
                }

                $('#tenNganhNgheDaChon').text('Ngành nghề: ' + tenNganhNghe);
                $('#buocChonNganhNghe').hide();
                $('#buocThemChuyenNganh').show();
                $('#modalFooterThemChuyenNganh').show();
                
                // Thêm dòng đầu tiên
                themDongChuyenNganh();
            });

            // Thay đổi ngành nghề
            $('#btnThayDoiNganhNghe').click(function() {
                $('#buocChonNganhNghe').show();
                $('#buocThemChuyenNganh').hide();
                $('#modalFooterThemChuyenNganh').hide();
                $('#danhSachChuyenNganh').empty();
                soThuTuChuyenNganh = 0;
            });

            // Thêm dòng chuyên ngành mới
            $('#btnThemDongChuyenNganh').click(function() {
                themDongChuyenNganh();
            });

            function themDongChuyenNganh() {
                soThuTuChuyenNganh++;
                var html = `
                    <div class="chuyennganh-row" data-index="${soThuTuChuyenNganh}">
                        <div class="chuyennganh-row-header">
                            <div class="chuyennganh-row-number">${soThuTuChuyenNganh}</div>
                            <button type="button" class="btn-remove-row btn-xoa-dong" data-index="${soThuTuChuyenNganh}">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </div>
                        <div class="chuyennganh-row-body">
                            <div class="form-group">
                                <label>Tên chuyên ngành <span style="color: red;">*</span></label>
                                <input type="text" class="form-control ten-chuyennganh" placeholder="Nhập tên chuyên ngành" required>
                            </div>
                            <div class="form-group">
                                <label>Mô tả</label>
                                <textarea class="form-control mo-ta-chuyennganh" rows="2" placeholder="Nhập mô tả (tùy chọn)"></textarea>
                            </div>
                        </div>
                    </div>
                `;
                $('#danhSachChuyenNganh').append(html);
            }

            // Xóa dòng chuyên ngành
            $(document).on('click', '.btn-xoa-dong', function() {
                if ($('.chuyennganh-row').length <= 1) {
                    showNotification('Phải có ít nhất một dòng chuyên ngành!', 'error');
                    return;
                }
                $(this).closest('.chuyennganh-row').fadeOut(300, function() {
                    $(this).remove();
                    capNhatSoThuTu();
                });
            });

            function capNhatSoThuTu() {
                $('.chuyennganh-row').each(function(index) {
                    $(this).find('.chuyennganh-row-number').text(index + 1);
                    $(this).attr('data-index', index + 1);
                    $(this).find('.btn-xoa-dong').attr('data-index', index + 1);
                });
                soThuTuChuyenNganh = $('.chuyennganh-row').length;
            }

            // Lưu nhiều chuyên ngành
            $('#btnLuuNhieuChuyenNganh').click(function() {
                var maNganhNghe = $('#nganhNgheMoi').val();
                var danhSachChuyenNganh = [];

                $('.chuyennganh-row').each(function() {
                    var ten = $(this).find('.ten-chuyennganh').val();
                    var moTa = $(this).find('.mo-ta-chuyennganh').val();

                    if (ten && ten.trim()) {
                        danhSachChuyenNganh.push({
                            TenChuyenNganh: ten.trim(),
                            MoTa: moTa ? moTa.trim() : null
                        });
                    }
                });

                if (danhSachChuyenNganh.length === 0) {
                    showNotification('Vui lòng nhập ít nhất một chuyên ngành!', 'error');
                    return;
                }

                // Kiểm tra các dòng có tên trống
                var coDongTrong = false;
                $('.chuyennganh-row').each(function() {
                    var ten = $(this).find('.ten-chuyennganh').val();
                    if (!ten || !ten.trim()) {
                        coDongTrong = true;
                        return false;
                    }
                });

                if (coDongTrong) {
                    if (!confirm('Có một số dòng chưa nhập tên chuyên ngành. Các dòng này sẽ bị bỏ qua. Bạn có muốn tiếp tục?')) {
                        return;
                    }
                }

                $.ajax({
                    url: '@Url.Action("ThemNhieuChuyenNganh", "Admin", new { area = "Admin" })',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        MaNganhNghe: parseInt(maNganhNghe),
                        DanhSachChuyenNganh: danhSachChuyenNganh
                    }),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            showNotification(response.message, 'success');
                            $('#themChuyenNganhModal').modal('hide');
                            location.reload();
                        } else {
                            showNotification(response.message, 'error');
                        }
                    },
                    error: function() {
                        showNotification('Có lỗi xảy ra khi thêm chuyên ngành!', 'error');
                    }
                });
            });

            // Sua chuyen nganh
            $(document).on('click', '.btn-sua', function() {
                var ma = $(this).data('ma');
                var ten = $(this).data('ten');
                var moTa = $(this).data('mota') || '';
                var nganhNghe = $(this).data('nganhnghe');

                $('#maChuyenNganhSua').val(ma);
                $('#tenChuyenNganhSua').val(ten);
                $('#moTaSua').val(moTa);
                $('#nganhNgheSua').val(nganhNghe);

                $('#suaChuyenNganhModal').modal('show');
            });

            $('#btnCapNhatChuyenNganh').click(function() {
                var ma = $('#maChuyenNganhSua').val();
                var ten = $('#tenChuyenNganhSua').val();
                var moTa = $('#moTaSua').val();
                var maNganhNghe = $('#nganhNgheSua').val();

                if (!ten || !maNganhNghe) {
                    showNotification('Vui lòng nhập đầy đủ thông tin bắt buộc!', 'error');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("CapNhatChuyenNganh", "Admin", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        id: ma,
                        tenChuyenNganh: ten,
                        moTa: moTa,
                        maNganhNghe: maNganhNghe,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            showNotification(response.message, 'success');
                            location.reload();
                        } else {
                            showNotification(response.message, 'error');
                        }
                    },
                    error: function() {
                        showNotification('Có lỗi xảy ra khi cập nhật chuyên ngành!', 'error');
                    }
                });
            });

            // Xoa chuyen nganh
            $(document).on('click', '.btn-xoa', function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn xóa chuyên ngành này?')) {
                    $.ajax({
                        url: '@Url.Action("XoaChuyenNganh", "Admin", new { area = "Admin" })',
                        type: 'POST',
                        data: {
                            id: ma,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                showNotification(response.message, 'success');
                                location.reload();
                            } else {
                                showNotification(response.message, 'error');
                            }
                        },
                        error: function() {
                            showNotification('Có lỗi xảy ra khi xóa chuyên ngành!', 'error');
                        }
                    });
                }
            });
        });

        // Show notification function
        function showNotification(message, type) {
            var bgColor = type === 'success' ? '#48bb78' : type === 'error' ? '#e53e3e' : '#4299e1';
            var notification = $('<div>')
                .css({
                    position: 'fixed',
                    top: '20px',
                    right: '20px',
                    background: bgColor,
                    color: 'white',
                    padding: '15px 25px',
                    borderRadius: '12px',
                    boxShadow: '0 4px 15px rgba(0,0,0,0.2)',
                    zIndex: 9999,
                    fontWeight: '600',
                    animation: 'slideInRight 0.3s ease'
                })
                .text(message)
                .appendTo('body');
            
            setTimeout(function() {
                notification.fadeOut(400, function() {
                    $(this).remove();
                });
            }, 3000);
        }
    </script>

    <style>
        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
}

