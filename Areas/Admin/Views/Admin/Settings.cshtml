@{
    ViewData["Title"] = "Cài đặt";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5>Cài đặt hệ thống</h5>
            </div>
            <div class="card-body">
                <form>
                    <h6 class="mb-3">Cài đặt chung</h6>
                    <div class="mb-3">
                        <label class="form-label">Tên ứng dụng</label>
                        <input type="text" class="form-control" value="Unicareer">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email liên hệ</label>
                        <input type="email" class="form-control" placeholder="contact@unicareer.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="tel" class="form-control" placeholder="+84 xxx xxx xxx">
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Cài đặt bảo mật</h6>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="twoFactorAuth" checked>
                        <label class="form-check-label" for="twoFactorAuth">
                            Bật xác thực hai yếu tố
                        </label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="emailVerification" checked>
                        <label class="form-check-label" for="emailVerification">
                            Yêu cầu xác thực email
                        </label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thời gian hết phiên (phút)</label>
                        <input type="number" class="form-control" value="30">
                    </div>

                    <hr class="my-4">

                    <h6 class="mb-3">Cài đặt email</h6>
                    <div class="mb-3">
                        <label class="form-label">SMTP Server</label>
                        <input type="text" class="form-control" placeholder="smtp.gmail.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">SMTP Port</label>
                        <input type="number" class="form-control" value="587">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">SMTP Username</label>
                        <input type="text" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">SMTP Password</label>
                        <input type="password" class="form-control">
                    </div>

                    <hr class="my-4">

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Lưu cài đặt</button>
                        <button type="reset" class="btn btn-secondary">Reset</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

