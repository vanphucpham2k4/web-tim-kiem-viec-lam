@{
    ViewData["Title"] = "Cài đặt";
}

<div class="page-header-section mb-4">
    <div class="row">
        <div class="col-12">
            <div class="settings-header-card">
                <div class="header-icon">
                    <i class="bi bi-gear-fill"></i>
                </div>
                <div class="header-content">
                    <h3 class="header-title">Cài đặt hệ thống</h3>
                    <p class="header-subtitle">Quản lý cấu hình và tùy chọn của hệ thống Unicareer</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="settings-card">
            <div class="settings-card-header">
                <h5><i class="bi bi-sliders me-2"></i>Cài đặt chung</h5>
            </div>
            <div class="settings-card-body">
                <form>
                    <div class="settings-group">
                        <div class="mb-4">
                            <label class="settings-label">Tên ứng dụng</label>
                            <input type="text" class="form-control settings-input" value="Unicareer">
                            <small class="form-text text-muted">Tên hiển thị của ứng dụng</small>
                        </div>
                        <div class="mb-4">
                            <label class="settings-label">Email liên hệ</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-envelope-fill input-icon"></i>
                                <input type="email" class="form-control settings-input ps-5" placeholder="contact@unicareer.com">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="settings-label">Số điện thoại</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-telephone-fill input-icon"></i>
                                <input type="tel" class="form-control settings-input ps-5" placeholder="+84 xxx xxx xxx">
                            </div>
                        </div>
                    </div>

                    <div class="settings-divider"></div>

                    <div class="settings-section-title">
                        <i class="bi bi-shield-lock-fill"></i>
                        <span>Cài đặt bảo mật</span>
                    </div>
                    <div class="settings-group">
                        <div class="settings-toggle mb-3">
                            <div class="toggle-info">
                                <label class="toggle-label" for="twoFactorAuth">Bật xác thực hai yếu tố</label>
                                <small class="toggle-description">Tăng cường bảo mật với xác thực 2 lớp</small>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input modern-switch" type="checkbox" id="twoFactorAuth" checked>
                            </div>
                        </div>
                        <div class="settings-toggle mb-3">
                            <div class="toggle-info">
                                <label class="toggle-label" for="emailVerification">Yêu cầu xác thực email</label>
                                <small class="toggle-description">Người dùng phải xác thực email trước khi đăng nhập</small>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input modern-switch" type="checkbox" id="emailVerification" checked>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="settings-label">Thời gian hết phiên (phút)</label>
                            <input type="number" class="form-control settings-input" value="30">
                            <small class="form-text text-muted">Thời gian không hoạt động trước khi tự động đăng xuất</small>
                        </div>
                    </div>

                    <div class="settings-divider"></div>

                    <div class="settings-section-title">
                        <i class="bi bi-envelope-at-fill"></i>
                        <span>Cài đặt email</span>
                    </div>
                    <div class="settings-group">
                        <div class="row">
                            <div class="col-md-8 mb-4">
                                <label class="settings-label">SMTP Server</label>
                                <input type="text" class="form-control settings-input" placeholder="smtp.gmail.com">
                            </div>
                            <div class="col-md-4 mb-4">
                                <label class="settings-label">SMTP Port</label>
                                <input type="number" class="form-control settings-input" value="587">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="settings-label">SMTP Username</label>
                            <input type="text" class="form-control settings-input" placeholder="your-email@gmail.com">
                        </div>
                        <div class="mb-4">
                            <label class="settings-label">SMTP Password</label>
                            <input type="password" class="form-control settings-input" placeholder="••••••••">
                        </div>
                    </div>

                    <div class="settings-actions">
                        <button type="submit" class="btn btn-save">
                            <i class="bi bi-check-circle me-2"></i>Lưu cài đặt
                        </button>
                        <button type="reset" class="btn btn-reset">
                            <i class="bi bi-arrow-clockwise me-2"></i>Đặt lại
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="info-card">
            <div class="info-icon">
                <i class="bi bi-info-circle-fill"></i>
            </div>
            <h5 class="info-title">Hướng dẫn</h5>
            <p class="info-text">Cấu hình các thông số hệ thống để tùy chỉnh theo nhu cầu của bạn.</p>
            <ul class="info-list">
                <li><i class="bi bi-check2-circle"></i> Bảo mật dữ liệu người dùng</li>
                <li><i class="bi bi-check2-circle"></i> Tùy chỉnh email thông báo</li>
                <li><i class="bi bi-check2-circle"></i> Quản lý phiên đăng nhập</li>
            </ul>
        </div>
        
        <div class="warning-card mt-4">
            <div class="warning-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h6 class="warning-title">Lưu ý</h6>
            <p class="warning-text">Thay đổi cài đặt có thể ảnh hưởng đến hoạt động của hệ thống. Vui lòng kiểm tra kỹ trước khi lưu.</p>
        </div>
    </div>
</div>

<style>
    /* Page Header */
    .settings-header-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: white;
        box-shadow: 0 8px 24px rgba(102, 126, 234, 0.25);
        display: flex;
        align-items: center;
        gap: 20px;
    }
    
    .settings-header-card .header-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        backdrop-filter: blur(10px);
        animation: rotate 20s linear infinite;
    }
    
    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    .settings-header-card .header-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    
    .settings-header-card .header-subtitle {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    
    /* Settings Card */
    .settings-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .settings-card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 20px 28px;
        border-bottom: 2px solid #dee2e6;
    }
    
    .settings-card-header h5 {
        margin: 0;
        font-weight: 700;
        font-size: 1.25rem;
        color: #212529;
    }
    
    .settings-card-body {
        padding: 32px 28px;
    }
    
    .settings-section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .settings-section-title i {
        color: #667eea;
        font-size: 1.25rem;
    }
    
    .settings-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    .settings-input {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .settings-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .input-icon-wrapper {
        position: relative;
    }
    
    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.1rem;
    }
    
    .settings-divider {
        height: 2px;
        background: linear-gradient(90deg, transparent 0%, #e9ecef 50%, transparent 100%);
        margin: 32px 0;
    }
    
    /* Toggle Switch */
    .settings-toggle {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
        background: #f8f9fa;
        border-radius: 12px;
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
    }
    
    .settings-toggle:hover {
        background: #e9ecef;
        border-color: #667eea;
    }
    
    .toggle-label {
        font-weight: 600;
        color: #212529;
        margin-bottom: 4px;
        cursor: pointer;
    }
    
    .toggle-description {
        color: #6c757d;
        font-size: 0.85rem;
    }
    
    .modern-switch {
        width: 52px;
        height: 28px;
        cursor: pointer;
    }
    
    .modern-switch:checked {
        background-color: #667eea;
        border-color: #667eea;
    }
    
    /* Action Buttons */
    .settings-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 2px solid #e9ecef;
    }
    
    .btn-save {
        flex: 1;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    
    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }
    
    .btn-reset {
        flex: 1;
        background: white;
        color: #6c757d;
        border: 2px solid #dee2e6;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    
    .btn-reset:hover {
        background: #f8f9fa;
        border-color: #adb5bd;
        color: #495057;
    }
    
    /* Info Card */
    .info-card {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        border-radius: 16px;
        padding: 28px;
        color: white;
        box-shadow: 0 8px 24px rgba(79, 172, 254, 0.3);
    }
    
    .info-icon {
        width: 56px;
        height: 56px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        margin-bottom: 20px;
        backdrop-filter: blur(10px);
    }
    
    .info-title {
        font-weight: 700;
        margin-bottom: 12px;
        font-size: 1.4rem;
    }
    
    .info-text {
        font-size: 0.95rem;
        opacity: 0.95;
        margin-bottom: 20px;
    }
    
    .info-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .info-list li {
        padding: 8px 0;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .info-list li i {
        font-size: 1.2rem;
    }
    
    /* Warning Card */
    .warning-card {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        border-radius: 16px;
        padding: 24px;
        color: white;
        box-shadow: 0 8px 24px rgba(250, 112, 154, 0.3);
    }
    
    .warning-icon {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 16px;
        backdrop-filter: blur(10px);
    }
    
    .warning-title {
        font-weight: 700;
        margin-bottom: 10px;
        font-size: 1.15rem;
    }
    
    .warning-text {
        font-size: 0.9rem;
        opacity: 0.95;
        margin: 0;
    }
</style>

