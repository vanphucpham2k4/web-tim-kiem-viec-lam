@model List<Unicareer.Models.NhaTuyenDung>

@{
    ViewData["Title"] = "Quan ly Nha tuyen dung";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <h3>Danh sach Nha tuyen dung</h3>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-3">
        <div class="input-group">
            <input type="text" class="form-control" id="timKiemInput" placeholder="Tim kiem theo ten cong ty, email...">
            <button class="btn btn-outline-secondary" type="button" id="btnTimKiem">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
    <div class="col-md-2">
        <select class="form-select" id="locTinhThanhPho">
            <option value="">Tat ca tinh/TP</option>
            <option value="Ha Noi">Ha Noi</option>
            <option value="TP Ho Chi Minh">TP Ho Chi Minh</option>
            <option value="Da Nang">Da Nang</option>
            <option value="Hai Phong">Hai Phong</option>
            <option value="Can Tho">Can Tho</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" id="locQuanHuyen">
            <option value="">Tat ca quan/huyen</option>
            <option value="Quan 1">Quan 1</option>
            <option value="Quan 3">Quan 3</option>
            <option value="Quan 4">Quan 4</option>
            <option value="Quan 7">Quan 7</option>
            <option value="Tan Binh">Tan Binh</option>
            <option value="Tan Phu">Tan Phu</option>
            <option value="Binh Thanh">Binh Thanh</option>
            <option value="Ba Dinh">Ba Dinh</option>
            <option value="Cau Giay">Cau Giay</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" id="locLinhVuc">
            <option value="">Tat ca linh vuc</option>
            <option value="Cong nghe thong tin">Cong nghe thong tin</option>
            <option value="Thuong mai dien tu">Thuong mai dien tu</option>
            <option value="Vien thong">Vien thong</option>
            <option value="Tu van">Tu van</option>
            <option value="San xuat">San xuat</option>
            <option value="F&B">F&B</option>
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" id="locQuyMo">
            <option value="">Tat ca quy mo</option>
            <option value="500-1000">500-1000 nhan vien</option>
            <option value="1000-5000">1000-5000 nhan vien</option>
            <option value="5000-10000">5000-10000 nhan vien</option>
            <option value="10000+">10000+ nhan vien</option>
        </select>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="bangNhaTuyenDung">
                        <thead class="table-light">
                            <tr>
                                <th>Ma</th>
                                <th>Ten cong ty</th>
                                <th>Nguoi dai dien</th>
                                <th>Email / SDT</th>
                                <th>Tinh/TP</th>
                                <th>Quan/Huyen</th>
                                <th>Linh vuc</th>
                                <th>Quy mo</th>
                                <th>Tin dang</th>
                                <th>UV nhan</th>
                                <th>Thao tac</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ntd in Model)
                            {
                                <tr data-ma="@ntd.MaNhaTuyenDung" data-tinhthanhpho="@ntd.TinhThanhPho" data-quanhuyen="@ntd.QuanHuyen" data-linhvuc="@ntd.LinhVuc" data-quymo="@ntd.QuyMo">
                                    <td>@ntd.MaNhaTuyenDung</td>
                                    <td>
                                        <strong>@ntd.TenCongTy</strong>
                                        <br/>
                                        <small><a href="@ntd.Website" target="_blank" class="text-muted">@ntd.Website</a></small>
                                    </td>
                                    <td>
                                        @ntd.NguoiDaiDien
                                        <br/>
                                        <small class="text-muted">@ntd.ChucVu</small>
                                    </td>
                                    <td>
                                        @ntd.Email<br/>
                                        <small class="text-muted">@ntd.SoDienThoai</small>
                                    </td>
                                    <td><span class="badge border border-primary text-primary">@ntd.TinhThanhPho</span></td>
                                    <td><span class="badge border border-info text-info">@ntd.QuanHuyen</span></td>
                                    <td><span class="badge border border-dark text-dark">@ntd.LinhVuc</span></td>
                                    <td><span class="badge border border-dark text-dark">@ntd.QuyMo</span></td>
                                    <td><span class="badge border border-dark text-dark">@ntd.SoTinDaDang</span></td>
                                    <td><span class="badge border border-dark text-dark">@ntd.SoUngVienNhan</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-dark btn-xem" 
                                                data-ma="@ntd.MaNhaTuyenDung"
                                                data-tencongty="@ntd.TenCongTy"
                                                data-email="@ntd.Email"
                                                data-sdt="@ntd.SoDienThoai"
                                                data-diachi="@ntd.DiaChi"
                                                data-tinhthanhpho="@ntd.TinhThanhPho"
                                                data-quanhuyen="@ntd.QuanHuyen"
                                                data-website="@ntd.Website"
                                                data-nguoidaidien="@ntd.NguoiDaiDien"
                                                data-chucvu="@ntd.ChucVu"
                                                data-linhvuc="@ntd.LinhVuc"
                                                data-quymo="@ntd.QuyMo"
                                                data-mota="@ntd.MoTa"
                                                data-sotindadang="@ntd.SoTinDaDang"
                                                data-soungviennhan="@ntd.SoUngVienNhan"
                                                data-ngaydk="@ntd.NgayDangKy.ToString("dd/MM/yyyy")">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary btn-tin" 
                                                data-ma="@ntd.MaNhaTuyenDung"
                                                data-ten="@ntd.TenCongTy"
                                                title="Xem tin tuyen dung">
                                            <i class="bi bi-newspaper"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-xoa" data-ma="@ntd.MaNhaTuyenDung">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Thong ke -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card border">
            <div class="card-body">
                <h6 class="card-title text-muted mb-2">Tong NTD</h6>
                <h2 class="mb-0">@Model.Count</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border">
            <div class="card-body">
                <h6 class="card-title text-muted mb-2">Tong tin dang</h6>
                <h2 class="mb-0">@Model.Sum(n => n.SoTinDaDang)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border">
            <div class="card-body">
                <h6 class="card-title text-muted mb-2">Tong UV nhan</h6>
                <h2 class="mb-0">@Model.Sum(n => n.SoUngVienNhan)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border">
            <div class="card-body">
                <h6 class="card-title text-muted mb-2">TB tin/NTD</h6>
                <h2 class="mb-0">@((int)Model.Average(n => n.SoTinDaDang))</h2>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xem chi tiet -->
<div class="modal fade" id="xemChiTietModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thong tin Nha tuyen dung</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-primary">Thong tin cong ty</h6>
                        <p><strong>Ten cong ty:</strong> <span id="chiTietTenCongTy"></span></p>
                        <p><strong>Email:</strong> <span id="chiTietEmail"></span></p>
                        <p><strong>So dien thoai:</strong> <span id="chiTietSDT"></span></p>
                        <p><strong>Website:</strong> <a href="#" id="chiTietWebsite" target="_blank"></a></p>
                        <p><strong>Dia chi:</strong> <span id="chiTietDiaChi"></span></p>
                        <p><strong>Tinh/Thanh pho:</strong> <span id="chiTietTinhThanhPho" class="badge border border-primary text-primary"></span></p>
                        <p><strong>Quan/Huyen:</strong> <span id="chiTietQuanHuyen" class="badge border border-info text-info"></span></p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-primary">Nguoi dai dien</h6>
                        <p><strong>Ho ten:</strong> <span id="chiTietNguoiDaiDien"></span></p>
                        <p><strong>Chuc vu:</strong> <span id="chiTietChucVu"></span></p>
                        <p><strong>Linh vuc:</strong> <span id="chiTietLinhVuc"></span></p>
                        <p><strong>Quy mo:</strong> <span id="chiTietQuyMo"></span></p>
                        <p><strong>Ngay dang ky:</strong> <span id="chiTietNgayDK"></span></p>
                    </div>
                </div>
                <hr/>
                <div class="row mt-3">
                    <div class="col-12">
                        <h6 class="text-primary">Gioi thieu</h6>
                        <p id="chiTietMoTa"></p>
                    </div>
                </div>
                <hr/>
                <div class="row">
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h3 id="chiTietSoTin" class="text-primary">0</h3>
                                <p class="mb-0">Tin tuyen dung da dang</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h3 id="chiTietSoUV" class="text-success">0</h3>
                                <p class="mb-0">Ung vien da nhan</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Dong</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tim kiem va loc
            $('#btnTimKiem, #timKiemInput').on('click keyup', function(e) {
                if (e.type === 'keyup' && e.keyCode !== 13) return;
                locDuLieu();
            });

            $('#locTinhThanhPho, #locQuanHuyen, #locLinhVuc, #locQuyMo').on('change', function() {
                locDuLieu();
            });

            function locDuLieu() {
                var tuKhoa = $('#timKiemInput').val().toLowerCase();
                var tinhThanhPho = $('#locTinhThanhPho').val();
                var quanHuyen = $('#locQuanHuyen').val();
                var linhVuc = $('#locLinhVuc').val();
                var quyMo = $('#locQuyMo').val();

                $('#bangNhaTuyenDung tbody tr').each(function() {
                    var row = $(this);
                    var tenCongTy = row.find('td:eq(1)').text().toLowerCase();
                    var email = row.find('td:eq(3)').text().toLowerCase();
                    var tinhThanhPhoRow = row.data('tinhthanhpho');
                    var quanHuyenRow = row.data('quanhuyen');
                    var linhVucRow = row.data('linhvuc');
                    var quyMoRow = row.data('quymo');
                    
                    var khopTuKhoa = tuKhoa === '' || tenCongTy.includes(tuKhoa) || email.includes(tuKhoa);
                    var khopTinhThanhPho = tinhThanhPho === '' || tinhThanhPhoRow === tinhThanhPho;
                    var khopQuanHuyen = quanHuyen === '' || quanHuyenRow === quanHuyen;
                    var khopLinhVuc = linhVuc === '' || linhVucRow.includes(linhVuc);
                    var khopQuyMo = quyMo === '' || quyMoRow.includes(quyMo);
                    
                    if (khopTuKhoa && khopTinhThanhPho && khopQuanHuyen && khopLinhVuc && khopQuyMo) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Xem chi tiet
            $('.btn-xem').click(function() {
                $('#chiTietTenCongTy').text($(this).data('tencongty'));
                $('#chiTietEmail').text($(this).data('email'));
                $('#chiTietSDT').text($(this).data('sdt'));
                $('#chiTietWebsite').attr('href', $(this).data('website')).text($(this).data('website'));
                $('#chiTietDiaChi').text($(this).data('diachi'));
                $('#chiTietTinhThanhPho').text($(this).data('tinhthanhpho'));
                $('#chiTietQuanHuyen').text($(this).data('quanhuyen'));
                $('#chiTietNguoiDaiDien').text($(this).data('nguoidaidien'));
                $('#chiTietChucVu').text($(this).data('chucvu'));
                $('#chiTietLinhVuc').text($(this).data('linhvuc'));
                $('#chiTietQuyMo').text($(this).data('quymo'));
                $('#chiTietMoTa').text($(this).data('mota'));
                $('#chiTietSoTin').text($(this).data('sotindadang'));
                $('#chiTietSoUV').text($(this).data('soungviennhan'));
                $('#chiTietNgayDK').text($(this).data('ngaydk'));

                $('#xemChiTietModal').modal('show');
            });

            // Xem tin tuyen dung
            $('.btn-tin').click(function() {
                var ma = $(this).data('ma');
                var ten = $(this).data('ten');
                alert('Xem cac tin tuyen dung cua ' + ten);
                // Trong thuc te, chuyen den trang tin tuyen dung voi filter theo cong ty
            });

            // Xoa nha tuyen dung
            $('.btn-xoa').click(function() {
                var ma = $(this).data('ma');
                if (confirm('Ban co chac chan muon xoa nha tuyen dung nay?')) {
                    alert('Da xoa nha tuyen dung ma ' + ma);
                    $(this).closest('tr').fadeOut();
                }
            });
        });
    </script>
}

