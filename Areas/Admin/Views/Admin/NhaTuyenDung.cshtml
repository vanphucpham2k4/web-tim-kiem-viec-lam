@model List<Unicareer.Models.NhaTuyenDung>

@{
    ViewData["Title"] = "Quản lý Nhà tuyển dụng";
    
    // Lay du lieu mockdata
    var danhSachTinTuyenDung = ViewBag.DanhSachTinTuyenDung as List<Unicareer.Models.TinTuyenDung> ?? new List<Unicareer.Models.TinTuyenDung>();
    var danhSachTinUngTuyen = ViewBag.DanhSachTinUngTuyen as List<Unicareer.Models.TinUngTuyen> ?? new List<Unicareer.Models.TinUngTuyen>();
}

<div class="page-header-section mb-4">
    <div class="row">
        <div class="col-12">
            <div class="page-header-card">
                <div class="header-icon">
                    <i class="bi bi-building"></i>
                </div>
                <div class="header-content">
                    <h3 class="header-title">Danh sách Nhà tuyển dụng</h3>
                    <p class="header-subtitle">Quản lý và theo dõi các công ty đăng ký trên hệ thống</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="filter-section mb-4">
    <div class="row g-3">
        <div class="col-lg-3 col-md-6">
            <div class="search-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="form-control search-input" id="timKiemInput" placeholder="Tìm kiếm theo tên công ty, email...">
            </div>
        </div>
        <div class="col-lg-2 col-md-6">
            <div class="filter-select-wrapper">
                <i class="bi bi-geo-alt filter-icon"></i>
                <select class="form-select filter-select" id="locTinhThanhPho">
                    <option value="">Tất cả tỉnh/TP</option>
                    <option value="Ha Noi">Hà Nội</option>
                    <option value="TP Ho Chi Minh">TP Hồ Chí Minh</option>
                    <option value="Da Nang">Đà Nẵng</option>
                    <option value="Hai Phong">Hải Phòng</option>
                    <option value="Can Tho">Cần Thơ</option>
                </select>
            </div>
        </div>
        <div class="col-lg-2 col-md-6">
            <div class="filter-select-wrapper">
                <i class="bi bi-map filter-icon"></i>
                <select class="form-select filter-select" id="locQuanHuyen">
                    <option value="">Tất cả quận/huyện</option>
                    <option value="Quan 1">Quận 1</option>
                    <option value="Quan 3">Quận 3</option>
                    <option value="Quan 4">Quận 4</option>
                    <option value="Quan 7">Quận 7</option>
                    <option value="Tan Binh">Tân Bình</option>
                    <option value="Ba Dinh">Ba Đình</option>
                    <option value="Cau Giay">Cầu Giấy</option>
                </select>
            </div>
        </div>
        <div class="col-lg-2 col-md-6">
            <div class="filter-select-wrapper">
                <i class="bi bi-briefcase filter-icon"></i>
                <select class="form-select filter-select" id="locLinhVuc">
                    <option value="">Tất cả lĩnh vực</option>
                    <option value="Cong nghe thong tin">Công nghệ thông tin</option>
                    <option value="Thuong mai dien tu">Thương mại điện tử</option>
                    <option value="Vien thong">Viễn thông</option>
                    <option value="Tu van">Tư vấn</option>
                    <option value="San xuat">Sản xuất</option>
                    <option value="F&B">F&B</option>
                </select>
            </div>
        </div>
        <div class="col-lg-1 col-md-6">
            <button class="btn btn-primary w-100 filter-btn" type="button" id="btnTimKiem">
                <i class="bi bi-funnel-fill"></i>
            </button>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="data-table-card">
            <div class="table-responsive">
                <table class="table table-hover modern-table" id="bangNhaTuyenDung">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Tên công ty</th>
                            <th>Người đại diện</th>
                            <th>Email / SĐT</th>
                            <th>Tỉnh/TP</th>
                            <th>Quận/Huyện</th>
                            <th>Lĩnh vực</th>
                            <th>Tin đăng</th>
                            <th>UV nhận</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ntd in Model)
                        {
                            <tr data-ma="@ntd.MaNhaTuyenDung" data-tinhthanhpho="@ntd.TinhThanhPho" data-quanhuyen="@ntd.QuanHuyen" data-linhvuc="@ntd.LinhVuc">
                                <td>@ntd.MaNhaTuyenDung</td>
                                <td>
                                    <strong>@ntd.TenCongTy</strong>
                                    <br/>
                                    <small><a href="@ntd.Website" target="_blank" class="text-primary"><i class="bi bi-link-45deg"></i> @ntd.Website</a></small>
                                </td>
                                <td>
                                    @ntd.NguoiDaiDien
                                    <br/>
                                    <small class="text-muted">@ntd.ChucVu</small>
                                </td>
                                <td>
                                    <i class="bi bi-envelope"></i> @ntd.Email<br/>
                                    <small class="text-muted"><i class="bi bi-telephone"></i> @ntd.SoDienThoai</small>
                                </td>
                                <td><span class="badge bg-primary">@ntd.TinhThanhPho</span></td>
                                <td><span class="badge bg-info">@ntd.QuanHuyen</span></td>
                                <td><span class="badge bg-secondary">@ntd.LinhVuc</span></td>
                                <td><span class="badge bg-success">@danhSachTinTuyenDung.Count(t => t.CongTy == ntd.TenCongTy)</span></td>
                                <td><span class="badge bg-warning text-dark">@danhSachTinUngTuyen.Count(t => t.CongTy == ntd.TenCongTy)</span></td>
                                <td>
                                    <a href="@Url.Action("ChiTietNhaTuyenDung", "Admin", new { id = ntd.MaNhaTuyenDung })" 
                                       class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger btn-xoa" data-ma="@ntd.MaNhaTuyenDung" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Thống kê -->
<div class="row stats-section mt-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-purple">
            <div class="stat-icon">
                <i class="bi bi-building"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tổng NTD</h6>
                <h3 class="stat-number">@Model.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-blue">
            <div class="stat-icon">
                <i class="bi bi-file-earmark-text"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tổng tin đăng</h6>
                <h3 class="stat-number">@danhSachTinTuyenDung.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-green">
            <div class="stat-icon">
                <i class="bi bi-person-check"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tổng UV nhận</h6>
                <h3 class="stat-number">@danhSachTinUngTuyen.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-orange">
            <div class="stat-icon">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">TB tin/NTD</h6>
                <h3 class="stat-number">@(Model.Count > 0 ? (int)(danhSachTinTuyenDung.Count / (double)Model.Count) : 0)</h3>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xem chi tiet -->
<div class="modal fade" id="xemChiTietModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-building me-2"></i>Thông tin Nhà tuyển dụng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Tab Navigation -->
                <ul class="nav nav-tabs mb-4" id="chiTietTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="thongtin-tab" data-bs-toggle="tab" data-bs-target="#thongtin" type="button" role="tab" aria-controls="thongtin" aria-selected="true">
                            <i class="bi bi-building me-2"></i>Thông tin công ty
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tintuyendung-tab" data-bs-toggle="tab" data-bs-target="#tintuyendung" type="button" role="tab" aria-controls="tintuyendung" aria-selected="false">
                            <i class="bi bi-newspaper me-2"></i>Các tin tuyển dụng
                            <span class="badge bg-primary ms-2" id="badgeSoTin">0</span>
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="chiTietTabContent">
                    <!-- Tab 1: Thông tin công ty -->
                    <div class="tab-pane fade show active" id="thongtin" role="tabpanel" aria-labelledby="thongtin-tab">
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-primary mb-3"><i class="bi bi-building"></i> Thông tin công ty</h6>
                                <p><strong>Tên công ty:</strong> <span id="chiTietTenCongTy"></span></p>
                                <p><strong>Email:</strong> <span id="chiTietEmail"></span></p>
                                <p><strong>Số điện thoại:</strong> <span id="chiTietSDT"></span></p>
                                <p><strong>Website:</strong> <a href="#" id="chiTietWebsite" target="_blank"></a></p>
                                <p><strong>Địa chỉ:</strong> <span id="chiTietDiaChi"></span></p>
                                <p><strong>Tỉnh/Thành phố:</strong> <span id="chiTietTinhThanhPho" class="badge bg-primary"></span></p>
                                <p><strong>Quận/Huyện:</strong> <span id="chiTietQuanHuyen" class="badge bg-info"></span></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-primary mb-3"><i class="bi bi-person-badge"></i> Người đại diện</h6>
                                <p><strong>Họ tên:</strong> <span id="chiTietNguoiDaiDien"></span></p>
                                <p><strong>Chức vụ:</strong> <span id="chiTietChucVu"></span></p>
                                <p><strong>Lĩnh vực:</strong> <span id="chiTietLinhVuc"></span></p>
                                <p><strong>Ngày đăng ký:</strong> <span id="chiTietNgayDK"></span></p>
                            </div>
                        </div>
                        <hr/>
                        <div class="row mt-3">
                            <div class="col-12">
                                <h6 class="text-primary mb-3"><i class="bi bi-info-circle"></i> Giới thiệu</h6>
                                <p id="chiTietMoTa" class="text-muted"></p>
                            </div>
                        </div>
                        <hr/>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="card bg-light border-0">
                                    <div class="card-body text-center">
                                        <h3 id="chiTietSoTin" class="text-primary mb-0">0</h3>
                                        <p class="mb-0 mt-2 small">Tin tuyển dụng đã đăng</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-light border-0">
                                    <div class="card-body text-center">
                                        <h3 id="chiTietSoUV" class="text-success mb-0">0</h3>
                                        <p class="mb-0 mt-2 small">Ứng viên đã nhận</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tab 2: Các tin tuyển dụng -->
                    <div class="tab-pane fade" id="tintuyendung" role="tabpanel" aria-labelledby="tintuyendung-tab">
                        <div id="loadingTinTuyenDung" class="text-center py-5" style="display: none;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Đang tải...</span>
                            </div>
                            <p class="mt-3 text-muted">Đang tải danh sách tin tuyển dụng...</p>
                        </div>
                        <div id="noDataTinTuyenDung" class="text-center py-5" style="display: none;">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                            <p class="mt-3 text-muted">Công ty này chưa đăng tin tuyển dụng nào.</p>
                        </div>
                        <div id="danhSachTinTuyenDung" class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Mã tin</th>
                                        <th>Tên việc làm</th>
                                        <th>Ngành nghề</th>
                                        <th>Loại công việc</th>
                                        <th>Tỉnh/TP</th>
                                        <th>Mức lương</th>
                                        <th>UV ứng tuyển</th>
                                        <th>Ngày đăng</th>
                                        <th>Hạn nộp</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyTinTuyenDung">
                                    <!-- Dữ liệu sẽ được load bằng JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<style>
    .page-header-card {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: white;
        box-shadow: 0 8px 24px rgba(79, 172, 254, 0.25);
        display: flex;
        align-items: center;
        gap: 20px;
    }
    
    .page-header-card .header-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        backdrop-filter: blur(10px);
    }
    
    .page-header-card .header-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    
    .page-header-card .header-subtitle {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    
    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }
    
    .search-wrapper {
        position: relative;
    }
    
    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.1rem;
        z-index: 1;
    }
    
    .search-input {
        padding-left: 45px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        height: 48px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .search-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .filter-select-wrapper {
        position: relative;
    }
    
    .filter-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.05rem;
        z-index: 1;
        pointer-events: none;
    }
    
    .filter-select {
        padding-left: 45px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        height: 48px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .filter-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .filter-btn {
        height: 48px;
        border-radius: 12px;
        font-weight: 600;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }
    
    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
    
    .data-table-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .modern-table {
        margin-bottom: 0;
    }
    
    .modern-table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
    
    .modern-table thead th {
        border: none;
        padding: 18px 16px;
        font-weight: 700;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #495057;
    }
    
    .modern-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f3f5;
    }
    
    .modern-table tbody tr:hover {
        background: linear-gradient(90deg, rgba(79, 172, 254, 0.05) 0%, transparent 100%);
        transform: scale(1.01);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }
    
    .modern-table tbody td {
        padding: 16px;
        vertical-align: middle;
        border: none;
    }
    
    .modern-table .badge {
        padding: 6px 12px;
        font-weight: 600;
        font-size: 0.8rem;
        border-radius: 8px;
    }
    
    .modern-table .btn {
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    
    .modern-table .btn:hover {
        transform: translateY(-2px);
    }
    
    .mini-stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    
    .mini-stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
    }
    
    .mini-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    
    .stat-purple::before {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    
    .stat-blue::before {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    
    .stat-green::before {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    }
    
    .stat-orange::before {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    
    .mini-stat-card .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }
    
    .stat-purple .stat-icon {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    
    .stat-blue .stat-icon {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    
    .stat-green .stat-icon {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    }
    
    .stat-orange .stat-icon {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    
    .stat-info {
        flex: 1;
    }
    
    .stat-label {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .stat-number {
        font-size: 1.75rem;
        font-weight: 700;
        color: #212529;
        margin: 0;
    }

    /* Tab Styles */
    .nav-tabs {
        border-bottom: 2px solid #e9ecef;
    }

    .nav-tabs .nav-link {
        border: none;
        border-bottom: 3px solid transparent;
        color: #6c757d;
        font-weight: 600;
        padding: 12px 24px;
        transition: all 0.3s ease;
    }

    .nav-tabs .nav-link:hover {
        border-bottom-color: #667eea;
        color: #667eea;
    }

    .nav-tabs .nav-link.active {
        color: #667eea;
        border-bottom-color: #667eea;
        background: transparent;
    }

    .nav-tabs .nav-link .badge {
        font-size: 0.75rem;
        padding: 4px 8px;
    }

    #danhSachTinTuyenDung table {
        margin-bottom: 0;
    }

    #danhSachTinTuyenDung thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    #danhSachTinTuyenDung thead th {
        border: none;
        padding: 12px 10px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #495057;
    }

    #danhSachTinTuyenDung tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f3f5;
    }

    #danhSachTinTuyenDung tbody tr:hover {
        background: linear-gradient(90deg, rgba(79, 172, 254, 0.05) 0%, transparent 100%);
    }

    #danhSachTinTuyenDung tbody td {
        padding: 12px 10px;
        vertical-align: middle;
        border: none;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tim kiem va loc
            $('#btnTimKiem, #timKiemInput').on('click keyup', function(e) {
                if (e.type === 'keyup' && e.keyCode !== 13) return;
                locDuLieu();
            });

            $('#locTinhThanhPho, #locQuanHuyen, #locLinhVuc').on('change', function() {
                locDuLieu();
            });

            function locDuLieu() {
                var tuKhoa = $('#timKiemInput').val().toLowerCase();
                var tinhThanhPho = $('#locTinhThanhPho').val();
                var quanHuyen = $('#locQuanHuyen').val();
                var linhVuc = $('#locLinhVuc').val();

                $('#bangNhaTuyenDung tbody tr').each(function() {
                    var row = $(this);
                    var tenCongTy = row.find('td:eq(1)').text().toLowerCase();
                    var email = row.find('td:eq(3)').text().toLowerCase();
                    var tinhThanhPhoRow = row.data('tinhthanhpho');
                    var quanHuyenRow = row.data('quanhuyen');
                    var linhVucRow = row.data('linhvuc');
                    
                    var khopTuKhoa = tuKhoa === '' || tenCongTy.includes(tuKhoa) || email.includes(tuKhoa);
                    var khopTinhThanhPho = tinhThanhPho === '' || tinhThanhPhoRow === tinhThanhPho;
                    var khopQuanHuyen = quanHuyen === '' || quanHuyenRow === quanHuyen;
                    var khopLinhVuc = linhVuc === '' || linhVucRow.includes(linhVuc);
                    
                    if (khopTuKhoa && khopTinhThanhPho && khopQuanHuyen && khopLinhVuc) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            var currentTenCongTy = '';

            // Xem chi tiet
            $('.btn-xem').click(function() {
                var tenCongTy = $(this).data('tencongty');
                currentTenCongTy = tenCongTy;

                $('#chiTietTenCongTy').text(tenCongTy);
                $('#chiTietEmail').text($(this).data('email'));
                $('#chiTietSDT').text($(this).data('sdt'));
                $('#chiTietWebsite').attr('href', $(this).data('website')).text($(this).data('website'));
                $('#chiTietDiaChi').text($(this).data('diachi'));
                $('#chiTietTinhThanhPho').text($(this).data('tinhthanhpho'));
                $('#chiTietQuanHuyen').text($(this).data('quanhuyen'));
                $('#chiTietNguoiDaiDien').text($(this).data('nguoidaidien'));
                $('#chiTietChucVu').text($(this).data('chucvu'));
                $('#chiTietLinhVuc').text($(this).data('linhvuc'));
                $('#chiTietMoTa').text($(this).data('mota'));
                var soTin = $(this).data('sotindadang');
                $('#chiTietSoTin').text(soTin);
                $('#badgeSoTin').text(soTin);
                $('#chiTietSoUV').text($(this).data('soungviennhan'));
                $('#chiTietNgayDK').text($(this).data('ngaydk'));

                // Reset tab về tab đầu tiên
                $('#thongtin-tab').tab('show');
                $('#tbodyTinTuyenDung').empty();
                $('#danhSachTinTuyenDung').hide();
                $('#noDataTinTuyenDung').hide();

                $('#xemChiTietModal').modal('show');
            });

            // Load tin tuyển dụng khi chuyển sang tab
            $('#tintuyendung-tab').on('shown.bs.tab', function() {
                if (currentTenCongTy && $('#tbodyTinTuyenDung').children().length === 0) {
                    loadDanhSachTinTuyenDung(currentTenCongTy);
                }
            });

            var chiTietTinUrl = '@Url.Action("ChiTietTinTuyenDung", "Admin", new { area = "Admin" })';
            var layTinUrl = '@Url.Action("LayDanhSachTinTuyenDungTheoCongTy", "Admin", new { area = "Admin" })';

            function loadDanhSachTinTuyenDung(tenCongTy) {
                $('#loadingTinTuyenDung').show();
                $('#danhSachTinTuyenDung').hide();
                $('#noDataTinTuyenDung').hide();
                $('#tbodyTinTuyenDung').empty();

                $.ajax({
                    url: layTinUrl,
                    type: 'GET',
                    data: { tenCongTy: tenCongTy },
                    success: function(response) {
                        $('#loadingTinTuyenDung').hide();
                        
                        if (response.success && response.data && response.data.length > 0) {
                            var html = '';
                            response.data.forEach(function(tin) {
                                var mucLuong = '';
                                if (tin.mucLuongThapNhat && tin.mucLuongCaoNhat) {
                                    mucLuong = formatCurrency(tin.mucLuongThapNhat) + ' - ' + formatCurrency(tin.mucLuongCaoNhat) + ' triệu';
                                } else if (tin.mucLuongThapNhat) {
                                    mucLuong = 'Từ ' + formatCurrency(tin.mucLuongThapNhat) + ' triệu';
                                } else {
                                    mucLuong = '<span class="text-muted">Thỏa thuận</span>';
                                }

                                var trangThaiBadge = tin.soLuongUngTuyen > 0 
                                    ? '<span class="badge bg-success">Đang tuyển</span>' 
                                    : '<span class="badge bg-secondary">Chưa có UV</span>';

                                html += '<tr>';
                                html += '<td><strong>#' + tin.maTin + '</strong></td>';
                                html += '<td><strong>' + (tin.tenViecLam || 'N/A') + '</strong></td>';
                                html += '<td><span class="badge bg-info">' + (tin.nganhNghe || 'N/A') + '</span></td>';
                                html += '<td><span class="badge bg-secondary">' + (tin.loaiCongViec || 'N/A') + '</span></td>';
                                html += '<td>' + (tin.tinhThanhPho || 'N/A') + '</td>';
                                html += '<td>' + mucLuong + '</td>';
                                html += '<td>' + trangThaiBadge + ' <small class="text-muted">(' + tin.soLuongUngTuyen + ')</small></td>';
                                html += '<td><small>' + tin.ngayDang + '</small></td>';
                                html += '<td><small>' + tin.hanNop + '</small></td>';
                                html += '<td>';
                                html += '<a href="' + chiTietTinUrl + '?id=' + tin.maTin + '" class="btn btn-sm btn-outline-primary" title="Xem chi tiết" target="_blank">';
                                html += '<i class="bi bi-eye"></i>';
                                html += '</a>';
                                html += '</td>';
                                html += '</tr>';
                            });
                            $('#tbodyTinTuyenDung').html(html);
                            $('#danhSachTinTuyenDung').show();
                        } else {
                            $('#noDataTinTuyenDung').show();
                        }
                    },
                    error: function() {
                        $('#loadingTinTuyenDung').hide();
                        $('#noDataTinTuyenDung').show();
                        $('#noDataTinTuyenDung').html('<i class="bi bi-exclamation-triangle" style="font-size: 3rem; color: #f56565;"></i><p class="mt-3 text-danger">Có lỗi xảy ra khi tải dữ liệu!</p>');
                    }
                });
            }

            function formatCurrency(amount) {
                if (amount >= 1000) {
                    return (amount / 1000).toFixed(1) + 'M';
                }
                return amount.toString();
            }

            // Xem tin tuyen dung
            $('.btn-tin').click(function() {
                var ma = $(this).data('ma');
                var ten = $(this).data('ten');
                alert('Xem các tin tuyển dụng của ' + ten);
                // Trong thực tế, chuyển đến trang tin tuyển dụng với filter theo công ty
            });

            // Xoa nha tuyen dung
            $('.btn-xoa').click(function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn xóa nhà tuyển dụng này?')) {
                    alert('Đã xóa nhà tuyển dụng mã ' + ma);
                    $(this).closest('tr').fadeOut();
                }
            });
        });
    </script>
}
