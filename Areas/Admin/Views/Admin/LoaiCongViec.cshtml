@model List<Unicareer.Models.LoaiCongViec>

@{
    ViewData["Title"] = "Quản lý Loại công việc";
}

@Html.AntiForgeryToken()

<style>
    .loaicongviec-management-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(37, 69, 184, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .page-header p {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 2fr auto;
        gap: 15px;
        align-items: end;
    }

    .filter-form input {
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        width: 100%;
    }

    .filter-form input:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .btn-filter {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-filter:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .table-container {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow-x: auto;
    }

    .loaicongviec-table {
        width: 100%;
        border-collapse: collapse;
    }

    .loaicongviec-table thead {
        background: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

    .loaicongviec-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #2d3748;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .loaicongviec-table td {
        padding: 15px;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
    }

    .loaicongviec-table tbody tr {
        transition: all 0.2s ease;
    }

    .loaicongviec-table tbody tr:hover {
        background: #f8f9fa;
    }

    .badge-custom {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-primary-custom {
        background: #dbeafe;
        color: #1e40af;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 6px 12px;
        border: none;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-edit {
        background: #f3e8ff;
        color: #6b21a8;
    }

    .btn-edit:hover {
        background: #e9d5ff;
    }

    .btn-delete {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-delete:hover {
        background: #fecaca;
    }

    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .stat-card h3 {
        font-size: 2rem;
        font-weight: 700;
        color: #2545B8;
        margin: 0;
    }

    .stat-card p {
        color: #718096;
        margin: 10px 0 0 0;
        font-size: 0.9rem;
    }

    .modal-content {
        border-radius: 16px;
        border: none;
    }

    .modal-header {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 20px 30px;
    }

    .modal-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        display: block;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.1);
    }

    .btn-primary {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 69, 184, 0.4);
    }

    .no-data {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .no-data i {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    @@media (max-width: 768px) {
        .filter-form {
            grid-template-columns: 1fr;
        }

        .loaicongviec-table {
            font-size: 0.85rem;
        }

        .action-buttons {
            flex-direction: column;
        }

        .page-header > div {
            flex-direction: column !important;
            gap: 20px;
        }

        .page-header .btn {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="loaicongviec-management-container">
    <div class="page-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1><i class="bi bi-clock-history"></i> Quản lý Loại công việc</h1>
                <p>Quản lý danh mục loại công việc trong hệ thống</p>
            </div>
            <button class="btn" style="background: white; color: #2545B8; padding: 12px 30px; border-radius: 10px; font-weight: 600; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: all 0.3s;" data-bs-toggle="modal" data-bs-target="#themLoaiCongViecModal">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </button>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="stats-section">
        <div class="stat-card">
            <h3>@Model.Count</h3>
            <p>Tổng loại công việc</p>
        </div>
        <div class="stat-card">
            <h3>@Model.Sum(l => l.SoLuongViTri)</h3>
            <p>Tổng vị trí</p>
        </div>
        <div class="stat-card">
            <h3>@(Model.Count > 0 ? ((int)Model.Average(l => l.SoLuongViTri)) : 0)</h3>
            <p>TB vị trí/loại</p>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
        <form class="filter-form" onsubmit="return false;">
            <div>
                <label for="timKiemInput" style="margin-bottom: 8px; display: block; font-weight: 600; color: #2d3748;">Tìm kiếm</label>
                <input type="text" id="timKiemInput" placeholder="Tìm kiếm theo tên loại công việc..." />
            </div>
            <div>
                <button type="button" class="btn-filter" id="btnTimKiem">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        @if (Model.Any())
        {
            <table class="loaicongviec-table" id="bangLoaiCongViec">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên loại CV</th>
                        <th>Mô tả</th>
                        <th>Số lượng vị trí</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loaiCongViec in Model)
                    {
                        <tr data-ma="@loaiCongViec.MaLoaiCongViec">
                            <td><strong>#@loaiCongViec.MaLoaiCongViec</strong></td>
                            <td><strong>@loaiCongViec.TenLoaiCongViec</strong></td>
                            <td>
                                <span class="text-muted">
                                    @(loaiCongViec.MoTa != null && loaiCongViec.MoTa.Length > 60 ? loaiCongViec.MoTa.Substring(0, 60) + "..." : loaiCongViec.MoTa ?? "")
                                </span>
                            </td>
                            <td>
                                <span class="badge-custom badge-primary-custom">@loaiCongViec.SoLuongViTri vị trí</span>
                            </td>
                            <td>@loaiCongViec.NgayTao.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-action btn-edit btn-sua" 
                                            data-ma="@loaiCongViec.MaLoaiCongViec"
                                            data-ten="@loaiCongViec.TenLoaiCongViec"
                                            data-mota="@loaiCongViec.MoTa"
                                            data-soluong="@loaiCongViec.SoLuongViTri"
                                            title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn-action btn-delete btn-xoa" 
                                            data-ma="@loaiCongViec.MaLoaiCongViec" 
                                            title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-data">
                <i class="bi bi-clock-history"></i>
                <h3>Chưa có loại công việc nào</h3>
                <p>Hãy thêm loại công việc mới để bắt đầu</p>
            </div>
        }
    </div>
</div>

<!-- Modal Thêm loại công việc -->
<div class="modal fade" id="themLoaiCongViecModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Thêm loại công việc mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formThemLoaiCongViec">
                    <div class="form-group">
                        <label for="tenLoaiCongViecMoi">Tên loại công việc <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="tenLoaiCongViecMoi" required placeholder="Nhập tên loại công việc">
                    </div>
                    <div class="form-group">
                        <label for="moTaMoi">Mô tả <span style="color: red;">*</span></label>
                        <textarea class="form-control" id="moTaMoi" rows="3" required placeholder="Nhập mô tả loại công việc"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnLuuLoaiCongViec">
                    <i class="bi bi-check-circle me-2"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa loại công việc -->
<div class="modal fade" id="suaLoaiCongViecModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Sửa loại công việc</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formSuaLoaiCongViec">
                    <input type="hidden" id="maLoaiCongViecSua">
                    <div class="form-group">
                        <label for="tenLoaiCongViecSua">Tên loại công việc <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="tenLoaiCongViecSua" required placeholder="Nhập tên loại công việc">
                    </div>
                    <div class="form-group">
                        <label for="moTaSua">Mô tả <span style="color: red;">*</span></label>
                        <textarea class="form-control" id="moTaSua" rows="3" required placeholder="Nhập mô tả loại công việc"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnCapNhatLoaiCongViec">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tim kiem
            $('#btnTimKiem, #timKiemInput').on('click keyup', function(e) {
                if (e.type === 'keyup' && e.keyCode !== 13) return;
                
                var tuKhoa = $('#timKiemInput').val().toLowerCase();
                locDuLieu(tuKhoa);
            });

            function locDuLieu(tuKhoa) {
                $('#bangLoaiCongViec tbody tr').each(function() {
                    var row = $(this);
                    var ten = row.find('td:eq(1)').text().toLowerCase();
                    
                    if (tuKhoa === '' || ten.includes(tuKhoa)) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Them loai cong viec
            $('#btnLuuLoaiCongViec').click(function() {
                var tenLoaiCongViec = $('#tenLoaiCongViecMoi').val();
                var moTa = $('#moTaMoi').val();

                if (!tenLoaiCongViec) {
                    alert('Vui lòng nhập tên loại công việc!');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("ThemLoaiCongViec", "Admin", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        tenLoaiCongViec: tenLoaiCongViec,
                        moTa: moTa,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            $('#themLoaiCongViecModal').modal('hide');
                            $('#formThemLoaiCongViec')[0].reset();
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra khi thêm loại công việc!');
                    }
                });
            });

            // Sua loai cong viec
            $(document).on('click', '.btn-sua', function() {
                var ma = $(this).data('ma');
                var ten = $(this).data('ten');
                var moTa = $(this).data('mota') || '';

                $('#maLoaiCongViecSua').val(ma);
                $('#tenLoaiCongViecSua').val(ten);
                $('#moTaSua').val(moTa);

                $('#suaLoaiCongViecModal').modal('show');
            });

            $('#btnCapNhatLoaiCongViec').click(function() {
                var ma = $('#maLoaiCongViecSua').val();
                var ten = $('#tenLoaiCongViecSua').val();
                var moTa = $('#moTaSua').val();

                if (!ten) {
                    alert('Vui lòng nhập tên loại công việc!');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("CapNhatLoaiCongViec", "Admin", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        id: ma,
                        tenLoaiCongViec: ten,
                        moTa: moTa,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            $('#suaLoaiCongViecModal').modal('hide');
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra khi cập nhật loại công việc!');
                    }
                });
            });

            // Xoa loai cong viec
            $(document).on('click', '.btn-xoa', function() {
                var ma = $(this).data('ma');
                var row = $(this).closest('tr');
                
                if (confirm('Bạn có chắc chắn muốn xóa loại công việc này?')) {
                    $.ajax({
                        url: '@Url.Action("XoaLoaiCongViec", "Admin", new { area = "Admin" })',
                        type: 'POST',
                        data: {
                            id: ma,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                alert(response.message);
                                row.fadeOut(300, function() {
                                    $(this).remove();
                                    location.reload();
                                });
                            } else {
                                alert(response.message);
                            }
                        },
                        error: function() {
                            alert('Có lỗi xảy ra khi xóa loại công việc!');
                        }
                    });
                }
            });
        });
    </script>
}
