@model Unicareer.Models.TinTuyenDung

@{
    ViewData["Title"] = "Chi tiết tin tuyển dụng";
    var danhSachUngTuyen = ViewBag.DanhSachUngTuyen as List<Unicareer.Models.TinUngTuyen> ?? new List<Unicareer.Models.TinUngTuyen>();
}

<style>
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2rem;
        margin-bottom: 10px;
    }

    .page-header .breadcrumb {
        background: rgba(255, 255, 255, 0.2);
        padding: 10px 20px;
        border-radius: 10px;
        margin: 0;
    }

    .page-header .breadcrumb-item a {
        color: white;
        text-decoration: none;
    }

    .page-header .breadcrumb-item.active {
        color: rgba(255, 255, 255, 0.9);
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        margin-bottom: 25px;
    }

    .info-card h5 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-card h5 i {
        color: #667eea;
        font-size: 1.3rem;
    }

    .info-item {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid #f7fafc;
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .info-label {
        font-weight: 600;
        color: #718096;
        min-width: 180px;
        flex-shrink: 0;
    }

    .info-value {
        color: #2d3748;
        flex: 1;
    }

    .badge-custom {
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .badge-success {
        background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
        color: white;
    }

    .badge-secondary {
        background: linear-gradient(135deg, #a0aec0 0%, #718096 100%);
        color: white;
    }

    .badge-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .badge-info {
        background: linear-gradient(135deg, #4299e1 0%, #3182ce 100%);
        color: white;
    }

    /* Tab Styles */
    .nav-tabs {
        border-bottom: 3px solid #e2e8f0;
        margin-bottom: 25px;
    }

    .nav-tabs .nav-link {
        border: none;
        border-bottom: 3px solid transparent;
        color: #718096;
        font-weight: 600;
        padding: 15px 25px;
        transition: all 0.3s ease;
        background: transparent;
    }

    .nav-tabs .nav-link:hover {
        border-bottom-color: #cbd5e0;
        color: #2d3748;
    }

    .nav-tabs .nav-link.active {
        color: #667eea;
        border-bottom-color: #667eea;
        background: transparent;
    }

    .tab-content {
        padding: 20px 0;
    }

    .content-section {
        margin-bottom: 30px;
    }

    .content-section h4 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #e2e8f0;
    }

    .content-section ul {
        padding-left: 20px;
    }

    .content-section li {
        margin-bottom: 10px;
        color: #4a5568;
        line-height: 1.6;
    }

    /* Table Styles */
    .table-responsive {
        border-radius: 12px;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .table thead th {
        border: none;
        color: #2d3748;
        font-weight: 600;
        padding: 18px 15px;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #e2e8f0;
    }

    .table tbody tr:hover {
        background-color: #f7fafc;
        transform: scale(1.01);
    }

    .table tbody td {
        padding: 18px 15px;
        vertical-align: middle;
        border: none;
    }

    .btn-action {
        padding: 6px 12px;
        border-radius: 8px;
        transition: all 0.3s ease;
        margin: 0 2px;
        border: 2px solid;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .btn-view {
        border-color: #4299e1;
        color: #4299e1;
        background: transparent;
    }

    .btn-view:hover {
        background: #4299e1;
        color: white;
        transform: translateY(-2px);
    }

    .btn-download {
        border-color: #48bb78;
        color: #48bb78;
        background: transparent;
    }

    .btn-download:hover {
        background: #48bb78;
        color: white;
        transform: translateY(-2px);
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #a0aec0;
    }

    .empty-state i {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .empty-state h5 {
        color: #718096;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .empty-state p {
        color: #a0aec0;
        margin: 0;
    }

    .back-button {
        background: white;
        border: 2px solid #667eea;
        color: #667eea;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .back-button:hover {
        background: #667eea;
        color: white;
        transform: translateX(-5px);
    }

    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 20px;
    }

    /* Map Styles */
    .map-container {
        position: relative;
        margin-top: 15px;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        border: 2px solid #e2e8f0;
        background: #f7fafc;
    }

    #map {
        height: 400px;
        border-radius: 16px;
    }

    .map-info {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #ffffff 0%, #f7fafc 100%);
        padding: 12px 18px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        z-index: 1000;
        font-size: 0.9rem;
        font-weight: 600;
        border: 2px solid #e2e8f0;
    }

    .map-info i {
        font-size: 1.2rem;
        margin-right: 5px;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    /* Custom marker popup */
    .leaflet-popup-content-wrapper {
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        border: 2px solid #667eea;
    }

    .leaflet-popup-content {
        margin: 15px;
        font-size: 0.95rem;
        font-weight: 500;
    }

    /* Custom marker styling */
    .custom-marker {
        background: none;
        border: none;
    }

    .marker-pin {
        width: 35px;
        height: 35px;
        border-radius: 50% 50% 50% 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: absolute;
        transform: rotate(-45deg);
        left: 50%;
        top: 50%;
        margin: -17.5px 0 0 -17.5px;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.6);
    }

    .marker-pin::after {
        content: '';
        width: 16px;
        height: 16px;
        margin: 9.5px 0 0 9.5px;
        background: #fff;
        position: absolute;
        border-radius: 50%;
    }

    /* Pulse animation */
    .marker-pulse-ring {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: rgba(102, 126, 234, 0.3);
        position: absolute;
        left: 50%;
        top: 50%;
        margin: -25px 0 0 -25px;
        animation: pulsate 1.5s ease-out infinite;
    }

    @@keyframes pulsate {
        0% {
            transform: scale(0.5, 0.5);
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            transform: scale(1.5, 1.5);
            opacity: 0;
        }
    }

    /* Edit Mode Styles */
    .edit-controls {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e2e8f0;
    }

    .btn-edit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 12px 25px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }

    .btn-cancel {
        background: white;
        border: 2px solid #a0aec0;
        color: #718096;
        padding: 12px 25px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-cancel:hover {
        background: #f7fafc;
        border-color: #718096;
        color: #2d3748;
        transform: translateY(-2px);
    }

    .btn-save {
        background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
        border: none;
        color: white;
        padding: 12px 25px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(72, 187, 120, 0.4);
    }

    .edit-mode .view-content {
        display: none;
    }

    .edit-mode .edit-content {
        display: block;
    }

    .view-mode .view-content {
        display: block;
    }

    .view-mode .edit-content {
        display: none;
    }

    .edit-content {
        display: none;
    }

    .form-control-edit, .form-select-edit {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        font-size: 1rem;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .form-control-edit:focus, .form-select-edit:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        outline: none;
    }

    textarea.form-control-edit {
        min-height: 150px;
        resize: vertical;
    }

    .input-group {
        display: flex;
    }

    .input-group .form-control-edit {
        border-radius: 10px 0 0 10px;
        border-right: none;
        flex: 1;
    }

    .input-group .form-control-edit:focus {
        border-right: none;
    }

    .input-group .btn {
        border-radius: 0 10px 10px 0;
        border-left: 2px solid #e2e8f0;
        padding: 12px 20px;
        font-weight: 600;
        white-space: nowrap;
    }

    .input-group .btn-outline-primary {
        border: 2px solid #e2e8f0;
        border-left: 2px solid #e2e8f0;
        color: #667eea;
        background: white;
    }

    .input-group .btn-outline-primary:hover {
        background: #667eea;
        color: white;
        border-color: #667eea;
    }

    .edit-field-group {
        margin-bottom: 20px;
    }

    .edit-field-group label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        display: block;
    }

    .edit-content .form-section {
        background: white;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        border: 1px solid #e9ecef;
        transition: all 0.3s ease;
    }

    .edit-content .form-section:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }

    .edit-content .form-section h4 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 3px solid #667eea;
        display: inline-block;
    }

    .edit-content .form-section h4 i {
        color: #667eea;
        margin-right: 10px;
        font-size: 1.3rem;
    }

    /* CKEditor 5 Styles */
    .ck-editor__editable {
        min-height: 250px;
        border-radius: 0 0 10px 10px;
    }

    .ck.ck-toolbar {
        border-radius: 10px 10px 0 0;
        border: 2px solid #e2e8f0;
        border-bottom: none;
    }

    .ck.ck-editor__main > .ck-editor__editable {
        border: 2px solid #e2e8f0;
        border-top: none;
    }

    .ck.ck-toolbar.ck-toolbar_grouping > .ck-toolbar__items {
        flex-wrap: wrap;
    }

    .edit-content .map-container {
        z-index: 1;
        position: relative;
    }

    #mapEdit {
        height: 500px;
        border-radius: 16px;
        width: 100%;
        z-index: 1;
    }

    .required-label::after {
        content: " *";
        color: #f56565;
    }
</style>

<!-- Hidden element for success message -->
@if (TempData["ThanhCong"] != null)
{
    <div id="successMessage" style="display: none;">@TempData["ThanhCong"]</div>
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-shield-check"></i> Chi tiết tin tuyển dụng</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Admin")">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("TinTuyenDung", "Admin")">Quản lý tin tuyển dụng</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
        <a href="@Url.Action("TinTuyenDung", "Admin")" class="back-button">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<!-- Thông tin cơ bản -->
<div class="row mb-4">
    <div class="col-12">
        <div class="info-card">
            <h5><i class="bi bi-info-circle"></i> Thông tin cơ bản</h5>
            <div class="row">
                <div class="col-md-6">
                    <div class="info-item">
                        <span class="info-label">Mã tin:</span>
                        <span class="info-value"><strong>#@Model.MaTinTuyenDung</strong></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Tên việc làm:</span>
                        <span class="info-value"><strong>@Model.TenViecLam</strong></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Công ty:</span>
                        <span class="info-value">@Model.CongTy</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Ngành nghề:</span>
                        <span class="info-value">@Model.NganhNghe</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.NganhNgheChiTiet))
                    {
                        <div class="info-item">
                            <span class="info-label">Ngành nghề chi tiết:</span>
                            <span class="info-value">@Model.NganhNgheChiTiet</span>
                        </div>
                    }
                    <div class="info-item">
                        <span class="info-label">Loại công việc:</span>
                        <span class="info-value">
                            <span class="badge-custom badge-primary">@Model.LoaiCongViec</span>
                        </span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-item">
                        <span class="info-label">Vị trí:</span>
                        <span class="info-value">@Model.ViTri</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.KinhNghiem))
                    {
                        <div class="info-item">
                            <span class="info-label">Kinh nghiệm:</span>
                            <span class="info-value">@Model.KinhNghiem</span>
                        </div>
                    }
                    <div class="info-item">
                        <span class="info-label">Ngày đăng:</span>
                        <span class="info-value">@Model.NgayDang.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Hạn nộp:</span>
                        <span class="info-value">
                            @Model.HanNop.ToString("dd/MM/yyyy")
                            @if (Model.HanNop >= DateTime.Now)
                            {
                                <span class="badge-custom badge-success ms-2">Đang tuyển</span>
                            }
                            else
                            {
                                <span class="badge-custom badge-secondary ms-2">Hết hạn</span>
                            }
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Lượt ứng tuyển:</span>
                        <span class="info-value">
                            <span class="badge-custom badge-info">@Model.SoLuongUngTuyen</span>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="row">
    <div class="col-12">
        <div class="info-card">
            <ul class="nav nav-tabs" id="detailTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="content-tab" data-bs-toggle="tab" data-bs-target="#content" type="button" role="tab">
                        <i class="bi bi-file-text"></i> Nội dung tin
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="applications-tab" data-bs-toggle="tab" data-bs-target="#applications" type="button" role="tab">
                        <i class="bi bi-people"></i> Danh sách ứng tuyển (@danhSachUngTuyen.Count)
                    </button>
                </li>
            </ul>
            <div class="tab-content" id="detailTabsContent">
                <!-- Tab 1: Nội dung tin -->
                <div class="tab-pane fade show active view-mode" id="content" role="tabpanel">
                    <!-- Edit Controls -->
                    <div class="edit-controls">
                        <button type="button" class="btn-edit" id="btnEdit">
                            <i class="bi bi-pencil"></i> Sửa
                        </button>
                        <button type="button" class="btn-cancel" id="btnCancel" style="display: none;">
                            <i class="bi bi-x-circle"></i> Hủy thay đổi
                        </button>
                        <button type="button" class="btn-save" id="btnSave" style="display: none;">
                            <i class="bi bi-check-circle"></i> Lưu
                        </button>
                    </div>

                    <form id="editForm" method="post" action="@Url.Action("CapNhatTinTuyenDung", "Admin", new { id = Model.MaTinTuyenDung })" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaTinTuyenDung" value="@Model.MaTinTuyenDung" />

                        <!-- View Mode Content -->
                        <div class="view-content">
                            <!-- Thong tin co ban -->
                            <div class="content-section">
                        <h4><i class="bi bi-briefcase-fill"></i> Thông tin cơ bản</h4>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <p><strong>Ngành nghề:</strong> @Model.NganhNghe</p>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.NganhNgheChiTiet))
                            {
                                <div class="col-md-6 mb-3">
                                    <p><strong>Ngành nghề chi tiết:</strong> @Model.NganhNgheChiTiet</p>
                                </div>
                            }
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <p><strong>Hình thức làm việc:</strong> <span class="badge-custom badge-primary">@Model.LoaiCongViec</span></p>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.KinhNghiem))
                            {
                                <div class="col-md-6 mb-3">
                                    <p><strong>Kinh nghiệm:</strong> @Model.KinhNghiem</p>
                                </div>
                            }
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <p><strong>Vị trí:</strong> @Model.ViTri</p>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.NgoaiNgu))
                            {
                                <div class="col-md-6 mb-3">
                                    <p><strong>Ngoại ngữ:</strong> @Model.NgoaiNgu</p>
                                </div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.KyNang))
                        {
                            <div class="mb-3">
                                <p><strong>Kỹ năng:</strong> @Model.KyNang</p>
                            </div>
                        }
                    </div>

                    <div class="content-section">
                        <h4><i class="bi bi-briefcase"></i> Mô tả công việc</h4>
                        <div>@Html.Raw(Model.MoTa ?? "")</div>
                    </div>

                    <div class="content-section">
                        <h4><i class="bi bi-check-circle"></i> Yêu cầu ứng viên</h4>
                        <div>@Html.Raw(Model.YeuCau ?? "")</div>
                    </div>

                    <div class="content-section">
                        <h4><i class="bi bi-gift"></i> Quyền lợi</h4>
                        <div>@Html.Raw(Model.QuyenLoi ?? "")</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="content-section">
                                <h4><i class="bi bi-cash-stack"></i> Mức lương</h4>
                                <p style="font-size: 1.2rem; font-weight: 600; color: #667eea;">
                                    @if (Model.MucLuongThapNhat.HasValue && Model.MucLuongCaoNhat.HasValue)
                                    {
                                        <text>@Model.MucLuongThapNhat.Value.ToString("N0") - @Model.MucLuongCaoNhat.Value.ToString("N0") triệu VNĐ</text>
                                    }
