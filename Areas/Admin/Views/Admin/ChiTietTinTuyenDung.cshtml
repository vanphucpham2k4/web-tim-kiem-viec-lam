                                    <small class="text-muted"><i class="bi bi-clock-history"></i> Chọn ngày cuối cùng nhận hồ sơ ứng tuyển</small>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Tab 2: Danh sách ứng tuyển -->
                <div class="tab-pane fade" id="applications" role="tabpanel">
                    @if (danhSachUngTuyen.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-hash"></i> Mã</th>
                                        <th><i class="bi bi-person"></i> Họ tên</th>
                                        <th><i class="bi bi-envelope"></i> Email</th>
                                        <th><i class="bi bi-telephone"></i> SĐT</th>
                                        <th><i class="bi bi-calendar"></i> Ngày ứng tuyển</th>
                                        <th><i class="bi bi-info-circle"></i> Trạng thái</th>
                                        <th><i class="bi bi-gear"></i> Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ungTuyen in danhSachUngTuyen)
                                    {
                                        var trangThaiClass = ungTuyen.TrangThaiXuLy switch
                                        {
                                            "Cho phong van" => "badge-warning",
                                            "Tuyen dung" => "badge-success",
                                            "Da phong van" => "badge-info",
                                            "Khong phu hop" => "badge-danger",
                                            _ => "badge-secondary"
                                        };

                                        <tr>
                                            <td><span class="text-muted">#@ungTuyen.MaTinUngTuyen</span></td>
                                            <td><strong>@ungTuyen.HoTen</strong></td>
                                            <td>@ungTuyen.Email</td>
                                            <td>@ungTuyen.SoDienThoai</td>
                                            <td>@ungTuyen.NgayUngTuyen.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="badge-custom @trangThaiClass">@ungTuyen.TrangThaiXuLy</span>
                                            </td>
                                            <td>
                                                <button class="btn btn-action btn-view" title="Xem chi tiết">
                                                    <i class="bi bi-eye"></i> Xem
                                                </button>
                                                @if (!string.IsNullOrEmpty(ungTuyen.LinkCV))
                                                {
                                                    <a href="@ungTuyen.LinkCV" target="_blank" class="btn btn-action btn-download" title="Tải CV">
                                                        <i class="bi bi-download"></i> CV
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox"></i>
                            <h5>Chưa có ứng viên nào ứng tuyển</h5>
                            <p>Tin tuyển dụng này chưa nhận được đơn ứng tuyển nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sidebar với thao tác quản lý -->
<div class="row mt-4">
    <div class="col-12">
        <div class="info-card">
            <h5><i class="bi bi-gear"></i> Thao tác quản lý</h5>
            <div class="action-buttons">
                <button class="btn btn-danger w-100 mb-2 btn-khoa" data-ma="@Model.MaTinTuyenDung">
                    <i class="bi bi-lock"></i> Khóa tin
                </button>
                <button class="btn btn-danger w-100 mb-2 btn-xoa" data-ma="@Model.MaTinTuyenDung">
                    <i class="bi bi-trash"></i> Xóa tin
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        $(document).ready(function() {
            // Khóa tin
            $('.btn-khoa').on('click', function() {
                var ma = $(this).data('ma');
                var lyDo = prompt('Nhập lý do khóa tin:');
                if (lyDo) {
                    $.ajax({
                        url: '@Url.Action("KhoaTinTuyenDung", "Admin")',
                        type: 'POST',
                        data: { id: ma, lyDo: lyDo },
                        success: function(response) {
                            if (response.success) {
                                showNotification('Đã khóa tin thành công!', 'success');
                                location.reload();
                            } else {
                                showNotification(response.message || 'Có lỗi xảy ra!', 'error');
                            }
                        },
                        error: function() {
                            showNotification('Có lỗi xảy ra khi khóa tin!', 'error');
                        }
                    });
                }
            });

            // Xóa tin
            $('.btn-xoa').on('click', function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn xóa tin này không?')) {
                    $.ajax({
                        url: '@Url.Action("XoaTinTuyenDung", "Admin")',
                        type: 'POST',
                        data: { id: ma },
                        success: function(response) {
                            if (response.success) {
                                showNotification('Đã xóa tin thành công!', 'success');
                                setTimeout(function() {
                                    window.location.href = '@Url.Action("TinTuyenDung", "Admin")';
                                }, 1000);
                            } else {
                                showNotification(response.message || 'Có lỗi xảy ra!', 'error');
                            }
                        },
                        error: function() {
                            showNotification('Có lỗi xảy ra khi xóa tin!', 'error');
                        }
                    });
                }
            });

            // Hàm hiển thị thông báo
            function showNotification(message, type) {
                var bgColor = type === 'success' ? '#48bb78' : '#f56565';
                var notification = $('<div>')
                    .css({
                        position: 'fixed',
                        top: '20px',
                        right: '20px',
                        background: bgColor,
                        color: 'white',
                        padding: '15px 25px',
                        borderRadius: '12px',
                        boxShadow: '0 4px 15px rgba(0,0,0,0.2)',
                        zIndex: 9999,
                        fontWeight: '600',
                        maxWidth: '400px'
                    })
                    .text(message)
                    .appendTo('body');
                
                setTimeout(function() {
                    notification.fadeOut(400, function() {
                        $(this).remove();
                    });
                }, 3000);
            }

            // Initialize Leaflet Map nếu có tọa độ
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <text>
                var mapLat = @Model.Latitude.Value;
                var mapLng = @Model.Longitude.Value;
                var addressText = '@Html.Raw(!string.IsNullOrEmpty(Model.DiaChiLamViec) ? Model.DiaChiLamViec.Replace("'", "\\'").Replace("\"", "\\\"") : "Địa chỉ làm việc")';
                
                // Hàm khởi tạo map
                function initMap() {
                    if (typeof L === 'undefined') {
                        console.log('Leaflet chưa được load, đợi thêm...');
                        setTimeout(initMap, 500);
                        return;
                    }

                    try {
                        // Initialize Leaflet Map
                        var map = L.map('map').setView([mapLat, mapLng], 15);
                        
                        // Add tile layer
                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                            maxZoom: 19
                        }).addTo(map);

                        // Fix Leaflet default marker icon path
                        delete L.Icon.Default.prototype._getIconUrl;
                        L.Icon.Default.mergeOptions({
                            iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
                            iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
                            shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png'
                        });

                        // Create custom marker icon with pulse effect
                        var customIcon = L.divIcon({
                            className: 'custom-marker',
                            html: '<div class="marker-pulse-ring"></div><div class="marker-pin"></div>',
                            iconSize: [40, 40],
                            iconAnchor: [20, 40],
                            popupAnchor: [0, -40]
                        });

                        // Create marker (không draggable vì chỉ xem)
                        var marker = L.marker([mapLat, mapLng], {
                            icon: customIcon,
                            title: 'Vị trí làm việc'
                        }).addTo(map);

                        // Add popup to marker
                        marker.bindPopup('<strong>📍 Vị trí làm việc</strong><br>' + addressText).openPopup();
                    } catch (error) {
                        console.error('Lỗi khi khởi tạo map:', error);
                    }
                }

                // Khởi tạo map sau khi document ready
                initMap();
                </text>
            }

            // CKEditor 5 và Edit Mode
            let editors = {};
            var editorsInitialized = false;

            var initEditors = function() {
                if (typeof ClassicEditor === 'undefined') {
                    console.error('CKEditor ClassicEditor is not loaded. Please check CDN link.');
                    return;
                }

                // Khởi tạo editor cho Mô tả công việc
                ClassicEditor
                    .create(document.querySelector('#editMoTa'), {
                        toolbar: {
                            items: [
                                'heading', '|',
                                'bold', 'italic', 'underline', '|',
                                'link', 'blockQuote', '|',
                                'bulletedList', 'numberedList', '|',
                                'undo', 'redo'
                            ],
                            shouldNotGroupWhenFull: true
                        },
                        heading: {
                            options: [
                                { model: 'paragraph', title: 'Đoạn văn', class: 'ck-heading_paragraph' },
                                { model: 'heading1', view: 'h1', title: 'Tiêu đề 1', class: 'ck-heading_heading1' },
                                { model: 'heading2', view: 'h2', title: 'Tiêu đề 2', class: 'ck-heading_heading2' },
                                { model: 'heading3', view: 'h3', title: 'Tiêu đề 3', class: 'ck-heading_heading3' }
                            ]
                        },
                        language: 'vi',
                        placeholder: 'Nhập mô tả công việc...'
                    })
                    .then(editor => {
                        editors['MoTa'] = editor;
                        console.log('CKEditor initialized for: MoTa');
                    })
                    .catch(error => {
                        console.error('CKEditor initialization error for MoTa:', error);
                    });

                // Khởi tạo editor cho Yêu cầu ứng viên
                ClassicEditor
                    .create(document.querySelector('#editYeuCau'), {
                        toolbar: {
                            items: [
                                'heading', '|',
                                'bold', 'italic', 'underline', '|',
                                'link', 'blockQuote', '|',
                                'bulletedList', 'numberedList', '|',
                                'undo', 'redo'
                            ],
                            shouldNotGroupWhenFull: true
                        },
                        heading: {
                            options: [
                                { model: 'paragraph', title: 'Đoạn văn', class: 'ck-heading_paragraph' },
                                { model: 'heading1', view: 'h1', title: 'Tiêu đề 1', class: 'ck-heading_heading1' },
                                { model: 'heading2', view: 'h2', title: 'Tiêu đề 2', class: 'ck-heading_heading2' },
                                { model: 'heading3', view: 'h3', title: 'Tiêu đề 3', class: 'ck-heading_heading3' }
                            ]
                        },
                        language: 'vi',
                        placeholder: 'Nhập yêu cầu ứng viên...'
                    })
                    .then(editor => {
                        editors['YeuCau'] = editor;
                        console.log('CKEditor initialized for: YeuCau');
                    })
                    .catch(error => {
                        console.error('CKEditor initialization error for YeuCau:', error);
                    });

                // Khởi tạo editor cho Quyền lợi
                ClassicEditor
                    .create(document.querySelector('#editQuyenLoi'), {
                        toolbar: {
                            items: [
                                'heading', '|',
                                'bold', 'italic', 'underline', '|',
                                'link', 'blockQuote', '|',
                                'bulletedList', 'numberedList', '|',
                                'undo', 'redo'
                            ],
                            shouldNotGroupWhenFull: true
                        },
                        heading: {
                            options: [
                                { model: 'paragraph', title: 'Đoạn văn', class: 'ck-heading_paragraph' },
                                { model: 'heading1', view: 'h1', title: 'Tiêu đề 1', class: 'ck-heading_heading1' },
                                { model: 'heading2', view: 'h2', title: 'Tiêu đề 2', class: 'ck-heading_heading2' },
                                { model: 'heading3', view: 'h3', title: 'Tiêu đề 3', class: 'ck-heading_heading3' }
                            ]
                        },
                        language: 'vi',
                        placeholder: 'Nhập quyền lợi...'
                    })
                    .then(editor => {
                        editors['QuyenLoi'] = editor;
                        console.log('CKEditor initialized for: QuyenLoi');
                    })
                    .catch(error => {
                        console.error('CKEditor initialization error for QuyenLoi:', error);
                    });
            };

            // Lưu giá trị ban đầu để có thể hủy
            var originalValues = {
                TenViecLam: $('#editTenViecLam').val() || '',
                NganhNghe: $('#editNganhNghe').val() || '',
                NganhNgheChiTiet: $('#editNganhNgheChiTiet').val() || '',
                LoaiCongViec: $('#editLoaiCongViec').val() || '',
                KinhNghiem: $('#editKinhNghiem').val() || '',
                ViTri: $('#editViTri').val() || '',
                NgoaiNgu: $('#editNgoaiNgu').val() || '',
                KyNang: $('#editKyNang').val() || '',
                MoTa: $('#editMoTa').val() || '',
                YeuCau: $('#editYeuCau').val() || '',
                QuyenLoi: $('#editQuyenLoi').val() || '',
                MucLuongThapNhat: $('#editMucLuongThapNhat').val(),
                MucLuongCaoNhat: $('#editMucLuongCaoNhat').val(),
                DiaChiLamViec: $('#editDiaChiLamViec').val(),
                PhuongXa: $('#editPhuongXa').val(),
                TinhThanhPho: $('#editTinhThanhPho').val(),
                NguoiLienHe: $('#editNguoiLienHe').val(),
                EmailLienHe: $('#editEmailLienHe').val(),
                SDTLienHe: $('#editSDTLienHe').val(),
                TuKhoa: $('#editTuKhoa').val(),
                HanNop: $('#editHanNop').val() || '',
                Latitude: $('#editLatitude').val(),
                Longitude: $('#editLongitude').val()
            };

            // Biến lưu map và marker cho edit mode
            var editMap = null;
            var editMarker = null;
            var editMapInitialized = false;

            // Hàm khởi tạo map cho edit mode
            function initEditMap() {
                if (typeof L === 'undefined') {
                    setTimeout(initEditMap, 500);
                    return;
                }

                var mapElement = document.getElementById('mapEdit');
                if (!mapElement) {
                    setTimeout(initEditMap, 300);
                    return;
                }

                if (mapElement._leaflet_id) {
                    if (editMap) {
                        setTimeout(function() {
                            editMap.invalidateSize();
                        }, 100);
                    }
                    return;
                }

                try {
                    var mapLat = parseFloat($('#editLatitude').val()) || 21.028511;
                    var mapLng = parseFloat($('#editLongitude').val()) || 105.804817;

                    editMap = L.map('mapEdit', {
                        preferCanvas: false
                    }).setView([mapLat, mapLng], 15);
                    
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                        maxZoom: 19
                    }).addTo(editMap);

                    setTimeout(function() {
                        if (editMap) {
                            editMap.invalidateSize();
                        }
                    }, 200);

                    delete L.Icon.Default.prototype._getIconUrl;
                    L.Icon.Default.mergeOptions({
                        iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
                        iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
                        shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png'
                    });

                    var customIcon = L.divIcon({
                        className: 'custom-marker',
                        html: '<div class="marker-pulse-ring"></div><div class="marker-pin"></div>',
                        iconSize: [40, 40],
                        iconAnchor: [20, 40],
                        popupAnchor: [0, -40]
                    });

                    editMarker = L.marker([mapLat, mapLng], {
                        draggable: true,
                        icon: customIcon,
                        title: 'Kéo tôi để chọn vị trí'
                    }).addTo(editMap);

                    editMarker.bindPopup('<strong>📍 Vị trí làm việc</strong><br>Kéo marker để điều chỉnh vị trí chính xác').openPopup();

                    function updateEditCoordinates(lat, lng) {
                        $('#editLatitude').val(lat.toFixed(6));
                        $('#editLongitude').val(lng.toFixed(6));
                        $('#currentCoordsEdit').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                    }

                    editMarker.on('dragend', function(e) {
                        var position = editMarker.getLatLng();
                        updateEditCoordinates(position.lat, position.lng);
                        editMarker.bindPopup('<strong>✓ Vị trí đã cập nhật</strong><br>Lat: ' + position.lat.toFixed(6) + '<br>Lng: ' + position.lng.toFixed(6)).openPopup();
                    });

                    editMap.on('click', function(e) {
                        editMarker.setLatLng(e.latlng);
                        updateEditCoordinates(e.latlng.lat, e.latlng.lng);
                        editMarker.bindPopup('<strong>✓ Vị trí đã cập nhật</strong><br>Lat: ' + e.latlng.lat.toFixed(6) + '<br>Lng: ' + e.latlng.lng.toFixed(6)).openPopup();
                    });

                    $('#btnSearchAddressEdit').click(function() {
                        var address = $('#editDiaChiLamViec').val();
                        var city = $('#editTinhThanhPho').val();
                        
                        if (!address) {
                            alert('Vui lòng nhập địa chỉ!');
                            return;
                        }

                        var searchQuery = address + (city ? ', ' + city : '') + ', Vietnam';
                        
                        $.ajax({
                            url: 'https://nominatim.openstreetmap.org/search',
                            data: {
                                q: searchQuery,
                                format: 'json',
                                limit: 1
                            },
                            success: function(data) {
                                if (data && data.length > 0) {
                                    var lat = parseFloat(data[0].lat);
                                    var lon = parseFloat(data[0].lon);
                                    
                                    editMap.setView([lat, lon], 16);
                                    editMarker.setLatLng([lat, lon]);
                                    updateEditCoordinates(lat, lon);
                                    
                                    editMarker.bindPopup('<strong>📍 Tìm thấy địa chỉ</strong><br>' + data[0].display_name).openPopup();
                                } else {
                                    alert('Không tìm thấy địa chỉ. Vui lòng thử lại!');
                                }
                            },
                            error: function() {
                                alert('Có lỗi xảy ra khi tìm kiếm địa chỉ!');
                            }
                        });
                    });

                    // Function to load wards by province
                    function loadWardsByProvince(provinceCode, selectedWardName = null) {
                        const $editPhuongXa = $('#editPhuongXa');
                        
                        // Reset quận/huyện dropdown
                        $editPhuongXa.html('<option value="">Chọn quận/huyện</option>');
                        
                        if (provinceCode) {
                            // Show loading state
                            $editPhuongXa.prop('disabled', true);
                            $editPhuongXa.html('<option value="">Đang tải...</option>');
                            
                            // Fetch wards from API
                            fetch(`/Admin/Admin/GetWardsByProvince?provinceCode=${encodeURIComponent(provinceCode)}`)
                                .then(response => response.json())
                                .then(data => {
                                    $editPhuongXa.html('<option value="">Chọn quận/huyện</option>');
                                    
                                    if (data && data.length > 0) {
                                        data.forEach(ward => {
                                            const option = $('<option></option>')
                                                .attr('value', ward.fullName)
                                                .text(ward.fullName);
                                            if (selectedWardName && ward.fullName === selectedWardName) {
                                                option.attr('selected', 'selected');
                                            }
                                            $editPhuongXa.append(option);
                                        });
                                    } else {
                                        $editPhuongXa.html('<option value="">Không có dữ liệu</option>');
                                    }
                                    
                                    $editPhuongXa.prop('disabled', false);
                                })
                                .catch(error => {
                                    console.error('Error loading wards:', error);
                                    $editPhuongXa.html('<option value="">Lỗi tải dữ liệu</option>');
                                    $editPhuongXa.prop('disabled', false);
                                });
                        } else {
                            $editPhuongXa.prop('disabled', false);
                        }
                    }

                    $('#editTinhThanhPho').change(function() {
                        var selectedOption = $(this).find('option:selected');
                        var cityName = $(this).val();
                        var provinceCode = selectedOption.data('code');
                        
                        // Load wards for selected province
                        if (provinceCode) {
                            loadWardsByProvince(provinceCode);
                        } else {
                            $('#editPhuongXa').html('<option value="">Chọn quận/huyện</option>');
                        }
                        
                        // Update map coordinates (simplified - you can enhance this with actual coordinates from database)
                        var coordinates = {
                            'Hà Nội': [21.028511, 105.804817],
                            'Thành phố Hà Nội': [21.028511, 105.804817],
                            'TP Hồ Chí Minh': [10.762622, 106.660172],
                            'Thành phố Hồ Chí Minh': [10.762622, 106.660172],
                            'Đà Nẵng': [16.047079, 108.206230],
                            'Thành phố Đà Nẵng': [16.047079, 108.206230],
                            'Hải Phòng': [20.844892, 106.687973],
                            'Thành phố Hải Phòng': [20.844892, 106.687973],
                            'Cần Thơ': [10.045162, 105.746857],
                            'Thành phố Cần Thơ': [10.045162, 105.746857]
                        };
                        
                        // Try to find matching coordinates
                        var coords = null;
                        for (var key in coordinates) {
                            if (cityName && (cityName.includes(key) || key.includes(cityName))) {
                                coords = coordinates[key];
                                break;
                            }
                        }
                        
                        if (coords && editMap) {
                            editMap.setView(coords, 13);
                            editMarker.setLatLng(coords);
                            updateEditCoordinates(coords[0], coords[1]);
                        }
                    });
                    
                    // Kiểm tra và load quận/huyện nếu tỉnh đã được chọn (khi quay lại bằng back button hoặc edit)
                    const selectedProvinceCode = $('#editTinhThanhPho option:selected').data('code');
                    const selectedWardName = '@Model.PhuongXa';
                    if (selectedProvinceCode) {
                        loadWardsByProvince(selectedProvinceCode, selectedWardName);
                    }

                    $('#editDiaChiLamViec').keypress(function(e) {
                        if (e.which === 13) {
                            e.preventDefault();
                            $('#btnSearchAddressEdit').click();
                        }
                    });

                    editMapInitialized = true;
                } catch (error) {
                    console.error('Lỗi khi khởi tạo edit map:', error);
                }
            }

            // Nút Sửa
            $('#btnEdit').on('click', function() {
                $('#content').removeClass('view-mode').addClass('edit-mode');
                $('#btnEdit').hide();
                $('#btnCancel').show();
                $('#btnSave').show();
                
                if (!editorsInitialized) {
                    initEditors();
                    editorsInitialized = true;
                }

                setTimeout(function() {
                    initEditMap();
                }, 500);
            });

            // Nút Hủy thay đổi
            $('#btnCancel').on('click', function() {
                if (editorsInitialized) {
                    if (editors['MoTa']) {
                        editors['MoTa'].setData(originalValues.MoTa);
                    }
                    if (editors['YeuCau']) {
                        editors['YeuCau'].setData(originalValues.YeuCau);
                    }
                    if (editors['QuyenLoi']) {
                        editors['QuyenLoi'].setData(originalValues.QuyenLoi);
                    }
                } else {
                    $('#editMoTa').val(originalValues.MoTa);
                    $('#editYeuCau').val(originalValues.YeuCau);
                    $('#editQuyenLoi').val(originalValues.QuyenLoi);
                }
                
                $('#editTenViecLam').val(originalValues.TenViecLam);
                $('#editNganhNghe').val(originalValues.NganhNghe);
                $('#editNganhNgheChiTiet').val(originalValues.NganhNgheChiTiet);
                $('#editLoaiCongViec').val(originalValues.LoaiCongViec);
                $('#editKinhNghiem').val(originalValues.KinhNghiem);
                $('#editViTri').val(originalValues.ViTri);
                $('#editNgoaiNgu').val(originalValues.NgoaiNgu);
                $('#editKyNang').val(originalValues.KyNang);
                $('#editMucLuongThapNhat').val(originalValues.MucLuongThapNhat);
                $('#editMucLuongCaoNhat').val(originalValues.MucLuongCaoNhat);
                $('#editDiaChiLamViec').val(originalValues.DiaChiLamViec);
                $('#editPhuongXa').val(originalValues.PhuongXa);
                $('#editTinhThanhPho').val(originalValues.TinhThanhPho);
                $('#editNguoiLienHe').val(originalValues.NguoiLienHe);
                $('#editEmailLienHe').val(originalValues.EmailLienHe);
                $('#editSDTLienHe').val(originalValues.SDTLienHe);
                $('#editTuKhoa').val(originalValues.TuKhoa);
                $('#editHanNop').val(originalValues.HanNop);
                $('#editLatitude').val(originalValues.Latitude);
                $('#editLongitude').val(originalValues.Longitude);

                if (editMapInitialized && editMarker) {
                    var lat = parseFloat(originalValues.Latitude) || 21.028511;
                    var lng = parseFloat(originalValues.Longitude) || 105.804817;
                    editMarker.setLatLng([lat, lng]);
                    editMap.setView([lat, lng], 15);
                    $('#currentCoordsEdit').text(lat.toFixed(6) + ', ' + lng.toFixed(6));
                }

                $('#content').removeClass('edit-mode').addClass('view-mode');
                $('#btnEdit').show();
                $('#btnCancel').hide();
                $('#btnSave').hide();
            });

            // Nút Lưu
            $('#btnSave').on('click', function() {
                if (editorsInitialized) {
                    Object.keys(editors).forEach(function(fieldName) {
                        if (editors[fieldName]) {
                            editors[fieldName].updateSourceElement();
                        }
                    });
                }

                var isValid = true;
                $('.form-control, .form-select').each(function() {
                    if ($(this).attr('required') && !$(this).val()) {
                        isValid = false;
                        $(this).css('border-color', '#f56565');
                    } else {
                        $(this).css('border-color', '#e2e8f0');
                    }
                });

                if (editorsInitialized) {
                    var moTaContent = editors['MoTa'] ? editors['MoTa'].getData().trim() : '';
                    var yeuCauContent = editors['YeuCau'] ? editors['YeuCau'].getData().trim() : '';
                    
                    if (!moTaContent || moTaContent === '' || moTaContent === '<p></p>') {
                        isValid = false;
                    }
                    if (!yeuCauContent || yeuCauContent === '' || yeuCauContent === '<p></p>') {
                        isValid = false;
                    }
                }

                if (!isValid) {
                    alert('Vui lòng điền đầy đủ các trường bắt buộc!');
                    return;
                }

                $('#editForm').submit();
            });

            // Xử lý tab switching
            $('#detailTabs button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                if ($('#content').hasClass('edit-mode')) {
                    $('#btnCancel').click();
                }
            });

            // Nếu có lỗi validation, tự động chuyển sang chế độ chỉnh sửa
            @if (!ViewData.ModelState.IsValid)
            {
                <text>
                $('#content').removeClass('view-mode').addClass('edit-mode');
                $('#btnEdit').hide();
                $('#btnCancel').show();
                $('#btnSave').show();
                
                if (!editorsInitialized) {
                    initEditors();
                    editorsInitialized = true;
                }
                </text>
            }

            // Xử lý khi submit form thành công
            @if (TempData["ThanhCong"] != null)
            {
                <text>
                var successMessageElement = document.getElementById('successMessage');
                if (successMessageElement) {
                    var successMessage = successMessageElement.textContent || successMessageElement.innerText;
                    showNotification(successMessage, 'success');
                }
                </text>
            }
        });
    </script>
    <!-- CKEditor 5 -->
    <script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
}
