                                            @if (Model.KinhNghiem == "2-5 nam") { <option value="2-5 nam" selected>2-5 năm</option> } else { <option value="2-5 nam">2-5 năm</option> }
                                            @if (Model.KinhNghiem == "Tren 5 nam") { <option value="Tren 5 nam" selected>Trên 5 năm</option> } else { <option value="Tren 5 nam">Trên 5 năm</option> }
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
