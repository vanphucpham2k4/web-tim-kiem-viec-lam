                                            @if (Model.ViTri == "Quan ly") { <option value="Quan ly" selected>Quản lý</option> } else { <option value="Quan ly">Quản lý</option> }
                                            @if (Model.ViTri == "Giam doc") { <option value="Giam doc" selected>Giám đốc</option> } else { <option value="Giam doc">Giám đốc</option> }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="ViTri" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Ngoại ngữ</label>
                                        <select class="form-select" name="NgoaiNgu" id="editNgoaiNgu">
                                            <option value="">Chọn ngoại ngữ</option>
                                            @if (Model.NgoaiNgu == "Khong yeu cau") { <option value="Khong yeu cau" selected>Không yêu cầu</option> } else { <option value="Khong yeu cau">Không yêu cầu</option> }
                                            @if (Model.NgoaiNgu == "Tieng Anh") { <option value="Tieng Anh" selected>Tiếng Anh</option> } else { <option value="Tieng Anh">Tiếng Anh</option> }
                                            @if (Model.NgoaiNgu == "Tieng Nhat") { <option value="Tieng Nhat" selected>Tiếng Nhật</option> } else { <option value="Tieng Nhat">Tiếng Nhật</option> }
                                            @if (Model.NgoaiNgu == "Tieng Han") { <option value="Tieng Han" selected>Tiếng Hàn</option> } else { <option value="Tieng Han">Tiếng Hàn</option> }
                                            @if (Model.NgoaiNgu == "Tieng Trung") { <option value="Tieng Trung" selected>Tiếng Trung</option> } else { <option value="Tieng Trung">Tiếng Trung</option> }
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Từ khóa</label>
                                        <input type="text" class="form-control" name="TuKhoa" 
                                               id="editTuKhoa" value="@Model.TuKhoa"
                                               placeholder="Nhập từ khóa liên quan đến công việc">
                                        <small class="text-muted"><i class="bi bi-lightbulb"></i> Ví dụ: ReactJS, NodeJS, .NET Core</small>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Kỹ năng</label>
                                        <input type="text" class="form-control" name="KyNang" 
                                               id="editKyNang" value="@Model.KyNang"
                                               placeholder="Nhập kỹ năng cần thiết">
