                                            @if (Model.NganhNgheChiTiet == "Mobile Developer") { <option value="Mobile Developer" selected>Mobile Developer</option> } else { <option value="Mobile Developer">Mobile Developer</option> }
                                            @if (Model.NganhNgheChiTiet == "Data Analyst") { <option value="Data Analyst" selected>Data Analyst</option> } else { <option value="Data Analyst">Data Analyst</option> }
