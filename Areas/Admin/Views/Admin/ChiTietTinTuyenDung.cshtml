                                            @if (Model.LoaiCongViec == "Part-time") { <option value="Part-time" selected>Part-time</option> } else { <option value="Part-time">Part-time</option> }
                                            @if (Model.LoaiCongViec == "Internship") { <option value="Internship" selected>Internship</option> } else { <option value="Internship">Internship</option> }
                                            @if (Model.LoaiCongViec == "Remote") { <option value="Remote" selected>Remote</option> } else { <option value="Remote">Remote</option> }
                                            @if (Model.LoaiCongViec == "Hybrid") { <option value="Hybrid" selected>Hybrid</option> } else { <option value="Hybrid">Hybrid</option> }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="LoaiCongViec" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
