                                <input type="hidden" name="Longitude" id="editLongitude" value="@(Model.Longitude ?? 105.804817)">

                                <!-- Map Container -->
                                <div class="map-container">
                                    <div id="mapEdit"></div>
                                    <div class="map-info">
                                        <i class="bi bi-geo-alt-fill text-danger"></i>
                                        <span id="currentCoordsEdit">@(Model.Latitude?.ToString("F6") ?? "21.028511"), @(Model.Longitude?.ToString("F6") ?? "105.804817")</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Han tuyen dung -->
                            <div class="form-section">
                                <h4><i class="bi bi-calendar-event"></i> Hạn tuyển dụng</h4>
