                                            @if (Model.NganhNghe == "Truyen thong - Media") { <option value="Truyen thong - Media" selected>Truyền thông - Media</option> } else { <option value="Truyen thong - Media">Truyền thông - Media</option> }
                                        </select>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="NganhNghe" data-valmsg-replace="true"></span>
                                    </div>
