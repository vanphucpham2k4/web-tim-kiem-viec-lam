                                    <span class="text-danger field-validation-valid" data-valmsg-for="MoTa" data-valmsg-replace="true"></span>
                                </div>
                            </div>

                            <!-- Yeu cau cong viec -->
                            <div class="form-section">
                                <h4><i class="bi bi-clipboard-check"></i> Yêu cầu công việc</h4>
                                <div class="mb-3">
                                    <label class="form-label">Các yêu cầu đối với ứng viên</label>
                                    <textarea name="YeuCau" class="form-control ckeditor" rows="5" required
                                              id="editYeuCau" placeholder="Nhập các yêu cầu về học vấn, kinh nghiệm, kỹ năng cần thiết...">@Html.Raw(Model.YeuCau)</textarea>
                                    <span class="text-danger field-validation-valid" data-valmsg-for="YeuCau" data-valmsg-replace="true"></span>
                                </div>
                            </div>

                            <!-- Quyen loi -->
                            <div class="form-section">
                                <h4><i class="bi bi-gift"></i> Quyền lợi</h4>
                                
                                <div class="row mb-3">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Mức lương thấp nhất (Triệu đồng)</label>
                                        <input type="number" class="form-control" name="MucLuongThapNhat" 
                                               id="editMucLuongThapNhat" min="0" value="@(Model.MucLuongThapNhat ?? 0)"
                                               placeholder="VD: 10">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Mức lương cao nhất (Triệu đồng)</label>
                                        <input type="number" class="form-control" name="MucLuongCaoNhat" 
                                               id="editMucLuongCaoNhat" min="0" value="@(Model.MucLuongCaoNhat ?? 0)"
                                               placeholder="VD: 20">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Thông tin thêm về quyền lợi</label>
                                    <textarea class="form-control ckeditor" name="QuyenLoi" rows="4"
                                              id="editQuyenLoi" placeholder="Mô tả các quyền lợi khác như bảo hiểm, thưởng, du lịch...">@Html.Raw(Model.QuyenLoi)</textarea>
                                    <small class="text-muted"><i class="bi bi-info-circle"></i> Các quyền lợi khác như: bảo hiểm, thưởng, du lịch...</small>
                                </div>
                            </div>

                            <!-- Thong Tin Lien He -->
                            <div class="form-section">
                                <h4><i class="bi bi-telephone"></i> Thông tin liên hệ</h4>
                                
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Người liên hệ</label>
                                        <input type="text" class="form-control" name="NguoiLienHe" 
                                               id="editNguoiLienHe" value="@Model.NguoiLienHe"
                                               placeholder="Nguyễn Văn A">
                                    </div>
