@model Unicareer.Models.TinTuyenDung

@{
    ViewData["Title"] = "Chi tiết tin tuyển dụng";
    var danhSachUngTuyen = ViewBag.DanhSachUngTuyen as List<Unicareer.Models.TinUngTuyen> ?? new List<Unicareer.Models.TinUngTuyen>();
}

<style>
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2rem;
        margin-bottom: 10px;
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        margin-bottom: 25px;
    }

    .info-card h5 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
    }

    .info-item {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid #f7fafc;
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .info-label {
        font-weight: 600;
        color: #718096;
        min-width: 180px;
    }

    .info-value {
        color: #2d3748;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .table thead th {
        border: none;
        color: #2d3748;
        font-weight: 600;
        padding: 18px 15px;
    }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-shield-check"></i> Chi tiết tin tuyển dụng</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb" style="background: rgba(255, 255, 255, 0.2); padding: 10px 20px; border-radius: 10px; margin: 0;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Admin")" style="color: white;">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("TinTuyenDung", "Admin")" style="color: white;">Quản lý tin tuyển dụng</a></li>
                    <li class="breadcrumb-item active" style="color: rgba(255, 255, 255, 0.9);">Chi tiết</li>
                </ol>
            </nav>
        </div>
        <a href="@Url.Action("TinTuyenDung", "Admin")" class="btn btn-light">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="info-card">
            <h5><i class="bi bi-briefcase"></i> Thông tin cơ bản</h5>
            <div class="info-item">
                <div class="info-label">Mã tin:</div>
                <div class="info-value">#@Model.MaTinTuyenDung</div>
            </div>
            <div class="info-item">
                <div class="info-label">Tiêu đề:</div>
                <div class="info-value"><strong>@Model.TenViecLam</strong></div>
            </div>
            <div class="info-item">
                <div class="info-label">Công ty:</div>
                <div class="info-value">@Model.CongTy</div>
            </div>
            <div class="info-item">
                <div class="info-label">Vị trí:</div>
                <div class="info-value">@Model.ViTri</div>
            </div>
            <div class="info-item">
                <div class="info-label">Ngành nghề:</div>
                <div class="info-value">@Model.NganhNghe</div>
            </div>
            <div class="info-item">
                <div class="info-label">Loại công việc:</div>
                <div class="info-value"><span class="badge bg-primary">@Model.LoaiCongViec</span></div>
            </div>
            <div class="info-item">
                <div class="info-label">Mức lương:</div>
                <div class="info-value">@Model.MucLuongThapNhat - @Model.MucLuongCaoNhat triệu</div>
            </div>
            <div class="info-item">
                <div class="info-label">Địa điểm:</div>
                <div class="info-value">@Model.TinhThanhPho, @Model.PhuongXa</div>
            </div>
            <div class="info-item">
                <div class="info-label">Ngày đăng:</div>
                <div class="info-value">@Model.NgayDang.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="info-item">
                <div class="info-label">Hạn nộp:</div>
                <div class="info-value">@Model.HanNop.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="info-item">
                <div class="info-label">Số lượng ứng tuyển:</div>
                <div class="info-value"><span class="badge bg-info">@Model.SoLuongUngTuyen</span></div>
            </div>
        </div>

        <div class="info-card">
            <h5><i class="bi bi-file-text"></i> Mô tả công việc</h5>
            <div>@Html.Raw(Model.MoTa?.Replace("\n", "<br/>"))</div>
        </div>

        <div class="info-card">
            <h5><i class="bi bi-list-check"></i> Yêu cầu</h5>
            <div>@Html.Raw(Model.YeuCau?.Replace("\n", "<br/>"))</div>
        </div>

        <div class="info-card">
            <h5><i class="bi bi-gift"></i> Quyền lợi</h5>
            <div>@Html.Raw(Model.QuyenLoi?.Replace("\n", "<br/>"))</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-card">
            <h5><i class="bi bi-gear"></i> Thao tác quản lý</h5>
            <div class="action-buttons">
                <button class="btn btn-success w-100 mb-2 btn-duyet" data-ma="@Model.MaTinTuyenDung">
                    <i class="bi bi-check-circle"></i> Duyệt tin
                </button>
                <button class="btn btn-warning w-100 mb-2 btn-sua" data-ma="@Model.MaTinTuyenDung">
                    <i class="bi bi-pencil"></i> Chỉnh sửa
                </button>
                <button class="btn btn-danger w-100 mb-2 btn-khoa" data-ma="@Model.MaTinTuyenDung">
                    <i class="bi bi-lock"></i> Khóa tin
                </button>
                <button class="btn btn-danger w-100 mb-2 btn-xoa" data-ma="@Model.MaTinTuyenDung">
                    <i class="bi bi-trash"></i> Xóa tin
                </button>
            </div>
        </div>

        <div class="info-card">
            <h5><i class="bi bi-people"></i> Danh sách ứng viên</h5>
            <p class="text-muted">Tổng số: <strong>@danhSachUngTuyen.Count</strong></p>
            @if (danhSachUngTuyen.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Họ tên</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var uv in danhSachUngTuyen.Take(5))
                            {
                                <tr>
                                    <td>@uv.HoTen</td>
                                    <td><span class="badge bg-info">@uv.TrangThaiXuLy</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(uv.LinkCV))
                                        {
                                            <a href="@uv.LinkCV" target="_blank" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (danhSachUngTuyen.Count > 5)
                {
                    <a href="@Url.Action("TinUngTuyen", "Admin")" class="btn btn-outline-primary w-100 mt-2">
                        Xem tất cả (@danhSachUngTuyen.Count)
                    </a>
                }
            }
            else
            {
                <p class="text-muted">Chưa có ứng viên nào ứng tuyển.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Duyệt tin
            $('.btn-duyet').on('click', function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn duyệt tin này không?')) {
                    $.ajax({
                        url: '@Url.Action("DuyetTinTuyenDung", "Admin")',
                        type: 'POST',
                        data: { id: ma },
                        success: function(response) {
                            if (response.success) {
                                alert('Đã duyệt tin thành công!');
                                location.reload();
                            } else {
                                alert(response.message || 'Có lỗi xảy ra!');
                            }
                        }
                    });
                }
            });

            // Khóa tin
            $('.btn-khoa').on('click', function() {
                var ma = $(this).data('ma');
                var lyDo = prompt('Nhập lý do khóa tin:');
                if (lyDo) {
                    $.ajax({
                        url: '@Url.Action("KhoaTinTuyenDung", "Admin")',
                        type: 'POST',
                        data: { id: ma, lyDo: lyDo },
                        success: function(response) {
                            if (response.success) {
                                alert('Đã khóa tin thành công!');
                                location.reload();
                            } else {
                                alert(response.message || 'Có lỗi xảy ra!');
                            }
                        }
                    });
                }
            });

            // Xóa tin
            $('.btn-xoa').on('click', function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn xóa tin này không?')) {
                    $.ajax({
                        url: '@Url.Action("XoaTinTuyenDung", "Admin")',
                        type: 'POST',
                        data: { id: ma },
                        success: function(response) {
                            if (response.success) {
                                alert('Đã xóa tin thành công!');
                                window.location.href = '@Url.Action("TinTuyenDung", "Admin")';
                            } else {
                                alert(response.message || 'Có lỗi xảy ra!');
                            }
                        }
                    });
                }
            });
        });
    </script>
}

