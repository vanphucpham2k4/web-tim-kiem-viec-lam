@model List<dynamic>

@{
    var danhSachTinTuyenDung = Model ?? new List<dynamic>();
}

<div class="info-section">
    <h4><i class="bi bi-file-earmark-text"></i> Các tin đã ứng tuyển <span class="badge bg-primary" id="soLuongTin">@danhSachTinTuyenDung.Count</span></h4>
    
    @if (danhSachTinTuyenDung.Any())
    {
        <div class="card mb-3">
            <div class="card-body">
                <form id="filterFormTinUngTuyen">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" id="filterTimKiemTin" name="search" placeholder="Tìm kiếm theo tên việc làm, công ty...">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" id="filterTrangThai" name="trangThai">
                                <option value="">Tất cả trạng thái</option>
                                <option value="Dang xem xet">Đang xem xét</option>
                                <option value="Cho phong van">Chờ phỏng vấn</option>
                                <option value="Tuyen dung">Tuyển dụng</option>
                                <option value="Tu choi">Từ chối</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" id="filterNganhNghe" name="nganhNghe">
                                <option value="">Tất cả ngành nghề</option>
                                @{
                                    var danhSachNganhNgheAll = ViewBag.DanhSachNganhNgheAll as List<string> ?? 
                                        danhSachTinTuyenDung.Select(t => (string)t.NganhNghe).Distinct().OrderBy(n => n).ToList();
                                }
                                @foreach (var nganhNghe in danhSachNganhNgheAll)
                                {
                                    <option value="@nganhNghe">@nganhNghe</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100" type="submit" id="btnLocTin">
                                <i class="bi bi-funnel-fill"></i> Lọc
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover" id="bangTinTuyenDung">
                <thead>
                    <tr>
                        <th>Mã tin</th>
                        <th>Tên việc làm</th>
                        <th>Công ty</th>
                        <th>Ngành nghề</th>
                        <th>Loại công việc</th>
                        <th>Tỉnh/TP</th>
                        <th>Mức lương</th>
                        <th>Trạng thái</th>
                        <th>Ngày ứng tuyển</th>
                        <th>Ngày đăng</th>
                        <th>Hạn nộp</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tin in danhSachTinTuyenDung)
                    {
                        var trangThaiBadge = "";
                        switch(tin.TrangThaiXuLy)
                        {
                            case "Dang xem xet":
                                trangThaiBadge = "<span class=\"badge bg-warning text-dark\">Đang xem xét</span>";
                                break;
                            case "Cho phong van":
                                trangThaiBadge = "<span class=\"badge bg-info\">Chờ phỏng vấn</span>";
                                break;
                            case "Tuyen dung":
                                trangThaiBadge = "<span class=\"badge bg-success\">Tuyển dụng</span>";
                                break;
                            case "Tu choi":
                                trangThaiBadge = "<span class=\"badge bg-danger\">Từ chối</span>";
                                break;
                            default:
                                trangThaiBadge = $"<span class=\"badge bg-secondary\">{tin.TrangThaiXuLy}</span>";
                                break;
                        }
                        
                        <tr>
                            <td><strong>#@tin.MaTin</strong></td>
                            <td><strong>@tin.TenViecLam</strong></td>
                            <td>@tin.CongTy</td>
                            <td><span class="badge bg-info">@tin.NganhNghe</span></td>
                            <td><span class="badge bg-secondary">@tin.LoaiCongViec</span></td>
                            <td>@tin.TinhThanhPho</td>
                            <td>@tin.MucLuong</td>
                            <td>@Html.Raw(trangThaiBadge)</td>
                            <td><small>@tin.NgayUngTuyen</small></td>
                            <td><small>@tin.NgayDang</small></td>
                            <td><small>@tin.HanNop</small></td>
                            <td>
                                <a href="@Url.Action("ChiTietTinTuyenDung", "Admin", new { area = "Admin", id = tin.MaTin })" 
                                   class="btn btn-sm btn-outline-primary" title="Xem chi tiết" target="_blank">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger btnXoaTinUngTuyen" 
                                        data-ma-tin-ung-tuyen="@tin.MaTinUngTuyen" 
                                        data-ten-viec-lam="@tin.TenViecLam"
                                        title="Xóa tin ứng tuyển">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
            <p class="mt-3 text-muted">Không tìm thấy tin ứng tuyển nào phù hợp.</p>
        </div>
    }
</div>

