@model Unicareer.Models.ViewModels.UngVienManagementViewModel

@{
    ViewData["Title"] = "Quản lý Ứng viên";
}

<div class="container-fluid" id="ungVienContent">
    @Html.Partial("_UngVienContent", Model)
</div>

<style>
    .dashboard-card {
        background: white;
        border-radius: 20px;
        padding: 32px 28px;
        text-align: left;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(37, 69, 184, 0.08);
        position: relative;
        min-height: 180px;
        overflow: hidden;
        animation: fadeInUp 0.6s ease-out;
    }

    .dashboard-card i {
        font-size: 2.5rem;
        color: #2545B8;
        transition: transform 0.3s ease;
    }

    .dashboard-card h5 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 4px;
        color: #2c3e50;
    }

    .dashboard-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(37, 69, 184, 0.15);
    }

    .special-card {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        box-shadow: 0 15px 35px rgba(37, 69, 184, 0.35);
    }

    .special-card .dashboard-card i {
        color: white;
    }

    .special-card:hover {
        box-shadow: 0 25px 45px rgba(37, 69, 184, 0.45);
    }

.hero-title h5 {
        font-size: 2.4rem;
        letter-spacing: 0.5px;
    }

.hero-title p {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.9);
    }

    .icon-large {
        font-size: 3.5rem;
    }

    .stat-value {
        font-size: 2.25rem;
        font-weight: 700;
        color: #172b4d;
    }

    .filter-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
    }

    .filter-card .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #5a5f7d;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .search-wrapper {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1rem;
        z-index: 2;
    }

    .search-input {
        padding-left: 40px;
        border-radius: 12px;
        height: 48px;
        border: 1px solid #e6e9ef;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .search-input:focus {
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.2);
    }

    .filter-select-wrapper {
        position: relative;
    }

    .filter-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1rem;
        color: #667eea;
        pointer-events: none;
    }

    .filter-select {
        width: 100%;
        padding-left: 40px;
        height: 48px;
        border-radius: 12px;
        border: 1px solid #e6e9ef;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .filter-select:focus {
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.2);
    }

    .filter-btn {
        height: 48px;
        border-radius: 12px;
        font-weight: 600;
        background: linear-gradient(135deg, #2545B8 0%, #4B6CE7 100%);
        border: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(37, 69, 184, 0.3);
    }

    .data-table-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
        padding: 0;
        overflow: hidden;
    }

    .modern-table {
        margin-bottom: 0;
    }

    .modern-table thead {
        background: linear-gradient(135deg, #f6f8fb 0%, #e2e8f0 100%);
    }

    .modern-table thead th {
        border: none;
        padding: 18px 14px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #495057;
    }

    .modern-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f3f5;
    }

    .modern-table tbody tr:hover {
        background: linear-gradient(90deg, rgba(37, 69, 184, 0.05) 0%, transparent 100%);
        transform: translateX(4px);
        box-shadow: 0 2px 8px rgba(37, 69, 184, 0.08);
    }

    .modern-table tbody td {
        padding: 18px 14px;
        vertical-align: middle;
        border: none;
    }

    .pagination {
        margin: 0;
        padding: 0;
    }

    .pagination .page-item {
        margin: 0 3px;
    }

    .pagination .page-link {
        color: #2545B8;
        border: 1px solid #e2e8f0;
        padding: 8px 14px;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .pagination .page-link:hover {
        background: rgba(37, 69, 184, 0.08);
        color: #1e3475;
        border-color: #1e3475;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #2545B8 0%, #4B6CE7 100%);
        border-color: #2545B8;
        color: white;
    }

    .pagination .page-item.disabled .page-link {
        color: #cbd5e0;
        cursor: not-allowed;
        background: #f7fafc;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        color: #4c566a;
        font-size: 0.9rem;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 6px 12px;
        border: none;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-view {
        background: #dbeafe;
        color: #1e40af;
    }

    .btn-view:hover {
        background: #bfdbfe;
    }

    .btn-delete {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-delete:hover {
        background: #fecaca;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            function loadContent() {
                var formData = $('#searchForm').serialize();
                var url = '@Url.Action("UngVien", "Admin", new { area = "Admin" })';
                
                $.ajax({
                    url: url,
                    type: 'GET',
                    data: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    beforeSend: function() {
                        $('#ungVienContent').css('opacity', '0.5');
                    },
                    success: function(response) {
                        $('#ungVienContent').html(response);
                        $('#ungVienContent').css('opacity', '1');
                        bindEvents();
                    },
                    error: function() {
                        showNotification('Có lỗi xảy ra khi tải dữ liệu', 'error');
                        $('#ungVienContent').css('opacity', '1');
                    }
                });
            }

            function bindEvents() {
                $('.btn-xoa').off('click').on('click', function() {
                    var ma = $(this).data('ma');
                    if (confirm('Ban co chac chan muon xoa ung vien nay?')) {
                        showNotification('Đã xóa ứng viên mã ' + ma, 'success');
                        $(this).closest('tr').fadeOut();
                    }
                });
            }

            window.goToPage = function(pageNumber) {
                $('#pageNumberInput').val(pageNumber);
                $('#pageNumberInput').data('pagination-click', true);
                loadContent();
            };

            $(document).on('submit', '#searchForm', function(e) {
                e.preventDefault();
                if (!$('#pageNumberInput').data('pagination-click')) {
                    $('#pageNumberInput').val(1);
                }
                $('#pageNumberInput').removeData('pagination-click');
                loadContent();
            });

            $(document).on('click', '.page-link', function() {
                $('#pageNumberInput').data('pagination-click', true);
            });

            $(document).on('change', '#locNganhNghe, #locKinhNghiem', function() {
                $('#pageNumberInput').val(1);
                $('#pageNumberInput').removeData('pagination-click');
                loadContent();
            });

            bindEvents();
        });

        // Show notification function
        function showNotification(message, type) {
            var bgColor = type === 'success' ? '#48bb78' : type === 'error' ? '#e53e3e' : '#4299e1';
            var notification = $('<div>')
                .css({
                    position: 'fixed',
                    top: '20px',
                    right: '20px',
                    background: bgColor,
                    color: 'white',
                    padding: '15px 25px',
                    borderRadius: '12px',
                    boxShadow: '0 4px 15px rgba(0,0,0,0.2)',
                    zIndex: 9999,
                    fontWeight: '600',
                    animation: 'slideInRight 0.3s ease'
                })
                .text(message)
                .appendTo('body');
            
            setTimeout(function() {
                notification.fadeOut(400, function() {
                    $(this).remove();
                });
            }, 3000);
        }
    </script>

    <style>
        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
}

