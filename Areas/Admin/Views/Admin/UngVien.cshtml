@model Unicareer.Models.ViewModels.UngVienManagementViewModel

@{
    ViewData["Title"] = "Quản lý Ứng viên";
}

<div class="container-fluid">
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="dashboard-card special-card">
                <div class="hero-title d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <h5 class="mb-1 text-white">Quản lý ứng viên</h5>
                        <p class="mb-0 text-white-75">Theo dõi hồ sơ ứng tuyển và đánh giá nhanh các chỉ số chính.</p>
                    </div>
                    <i class="bi bi-person-badge icon-large text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="dashboard-card">
                <i class="bi bi-people-fill text-primary"></i>
                <h5 class="mt-3">Tổng ứng viên</h5>
                <p class="stat-value mb-0">@Model.TotalUngVien</p>
            </div>
        </div>
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="dashboard-card">
                <i class="bi bi-file-earmark-check text-success"></i>
                <h5 class="mt-3">Tổng ứng tuyển</h5>
                <p class="stat-value mb-0">@Model.TotalUngTuyen</p>
            </div>
        </div>
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="dashboard-card">
                <i class="bi bi-graph-up-arrow text-warning"></i>
                <h5 class="mt-3">TB ứng tuyển/người</h5>
                <p class="stat-value mb-0">@Model.TrungBinhUngTuyenPerUngVien</p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="filter-card">
                <form id="searchForm" method="get" action="@Url.Action("UngVien", "Admin", new { area = "Admin" })">
                    <input type="hidden" id="pageNumberInput" name="pageNumber" value="@Model.PageNumber" />
                    <div class="row g-3 align-items-end">
                        <div class="col-lg-4 col-md-6">
                            <label class="form-label">Tìm kiếm</label>
                            <div class="search-wrapper">
                                <i class="bi bi-search search-icon"></i>
                                <input type="text" class="form-control search-input" id="timKiemInput" name="search" value="@Model.SearchTerm" placeholder="Họ tên, email, điện thoại...">
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="form-label">Ngành nghề</label>
                            <div class="filter-select-wrapper">
                                <i class="bi bi-briefcase filter-icon"></i>
                                <select class="form-select filter-select" id="locNganhNghe" name="nganhNghe">
                                    <option value="">Tất cả ngành nghề</option>
                                    @foreach (var nganhNghe in Model.DanhSachNganhNghe)
                                    {
                                        if (Model.NganhNgheFilter == nganhNghe.TenNganhNghe)
                                        {
                                            <option value="@nganhNghe.TenNganhNghe" selected>@nganhNghe.TenNganhNghe</option>
                                        }
                                        else
                                        {
                                            <option value="@nganhNghe.TenNganhNghe">@nganhNghe.TenNganhNghe</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="form-label">Kinh nghiệm</label>
                            <div class="filter-select-wrapper">
                                <i class="bi bi-award filter-icon"></i>
                                <select class="form-select filter-select" id="locKinhNghiem" name="kinhNghiem">
                                    <option value="">Tất cả kinh nghiệm</option>
                                    @foreach (var kn in Model.DanhSachKinhNghiem)
                                    {
                                        if (Model.KinhNghiemFilter == kn)
                                        {
                                            <option value="@kn" selected>@kn</option>
                                        }
                                        else
                                        {
                                            <option value="@kn">@kn</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-6">
                            <button class="btn btn-primary w-100 filter-btn" type="submit" id="btnTimKiem">
                                <i class="bi bi-funnel-fill me-1"></i> Lọc
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="data-table-card">
                <div class="table-responsive">
                    <table class="table table-hover modern-table" id="bangUngVien">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Họ tên</th>
                                <th>Email / SĐT</th>
                                <th>Ngày sinh</th>
                                <th>Địa chỉ</th>
                                <th>Số lần ứng tuyển</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var uv in Model.UngViens)
                            {
                                var tuoi = DateTime.Now.Year - uv.NgaySinh.Year;

                                <tr data-ma="@uv.MaUngVien">
                                    <td>@uv.MaUngVien</td>
                                    <td>
                                        <strong>@uv.HoTen</strong>
                                        <br />
                                        <small class="text-muted">@uv.GioiTinh, @tuoi tuoi</small>
                                    </td>
                                    <td>
                                        @uv.Email<br />
                                        <small class="text-muted">@uv.SoDienThoai</small>
                                    </td>
                                    <td>@uv.NgaySinh.ToString("dd/MM/yyyy")</td>
                                    <td>@uv.DiaChi</td>
                                    <td><span class="badge border border-dark text-dark">@uv.SoLanUngTuyen</span></td>
                                    <td>
                                        <a href="@Url.Action("ChiTietUngVien", "Admin", new { area = "Admin", id = uv.MaUngVien })"
                                           class="btn btn-sm btn-outline-dark" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger btn-xoa" data-ma="@uv.MaUngVien">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Phân trang" style="margin-top: 30px;">
                    <ul class="pagination justify-content-center">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber - 1))">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                            </li>
                        }

                        @{
                            int startPage = Math.Max(1, Model.PageNumber - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@i)">@i</a>
                            </li>
                        }

                        @if (endPage < Model.TotalPages)
                        {
                            @if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">@Model.TotalPages</a>
                            </li>
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber + 1))">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                            </li>
                        }
                    </ul>
                    <div class="pagination-info">
                        Hiển thị <strong>@((Model.PageNumber - 1) * Model.PageSize + 1)</strong> -
                        <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</strong>
                        trong tổng số <strong>@Model.TotalCount</strong> ứng viên
                    </div>
                </nav>
            }
        </div>
    </div>
</div>

<style>
    .dashboard-card {
        background: white;
        border-radius: 20px;
        padding: 32px 28px;
        text-align: left;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(37, 69, 184, 0.08);
        position: relative;
        min-height: 180px;
        overflow: hidden;
        animation: fadeInUp 0.6s ease-out;
    }

    .dashboard-card i {
        font-size: 2.5rem;
        color: #2545B8;
        transition: transform 0.3s ease;
    }

    .dashboard-card h5 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 4px;
        color: #2c3e50;
    }

    .dashboard-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(37, 69, 184, 0.15);
    }

    .special-card {
        background: linear-gradient(135deg, #2545B8 0%, #1a3599 100%);
        color: white;
        box-shadow: 0 15px 35px rgba(37, 69, 184, 0.35);
    }

    .special-card .dashboard-card i {
        color: white;
    }

    .special-card:hover {
        box-shadow: 0 25px 45px rgba(37, 69, 184, 0.45);
    }

.hero-title h5 {
        font-size: 2.4rem;
        letter-spacing: 0.5px;
    }

.hero-title p {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.9);
    }

    .icon-large {
        font-size: 3.5rem;
    }

    .stat-value {
        font-size: 2.25rem;
        font-weight: 700;
        color: #172b4d;
    }

    .filter-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
    }

    .filter-card .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #5a5f7d;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .search-wrapper {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1rem;
        z-index: 2;
    }

    .search-input {
        padding-left: 40px;
        border-radius: 12px;
        height: 48px;
        border: 1px solid #e6e9ef;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .search-input:focus {
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.2);
    }

    .filter-select-wrapper {
        position: relative;
    }

    .filter-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1rem;
        color: #667eea;
        pointer-events: none;
    }

    .filter-select {
        width: 100%;
        padding-left: 40px;
        height: 48px;
        border-radius: 12px;
        border: 1px solid #e6e9ef;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .filter-select:focus {
        border-color: #2545B8;
        box-shadow: 0 0 0 3px rgba(37, 69, 184, 0.2);
    }

    .filter-btn {
        height: 48px;
        border-radius: 12px;
        font-weight: 600;
        background: linear-gradient(135deg, #2545B8 0%, #4B6CE7 100%);
        border: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(37, 69, 184, 0.3);
    }

    .data-table-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
        padding: 0;
        overflow: hidden;
    }

    .modern-table {
        margin-bottom: 0;
    }

    .modern-table thead {
        background: linear-gradient(135deg, #f6f8fb 0%, #e2e8f0 100%);
    }

    .modern-table thead th {
        border: none;
        padding: 18px 14px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #495057;
    }

    .modern-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f3f5;
    }

    .modern-table tbody tr:hover {
        background: linear-gradient(90deg, rgba(37, 69, 184, 0.05) 0%, transparent 100%);
        transform: translateX(4px);
        box-shadow: 0 2px 8px rgba(37, 69, 184, 0.08);
    }

    .modern-table tbody td {
        padding: 18px 14px;
        vertical-align: middle;
        border: none;
    }

    .pagination {
        margin: 0;
        padding: 0;
    }

    .pagination .page-item {
        margin: 0 3px;
    }

    .pagination .page-link {
        color: #2545B8;
        border: 1px solid #e2e8f0;
        padding: 8px 14px;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .pagination .page-link:hover {
        background: rgba(37, 69, 184, 0.08);
        color: #1e3475;
        border-color: #1e3475;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #2545B8 0%, #4B6CE7 100%);
        border-color: #2545B8;
        color: white;
    }

    .pagination .page-item.disabled .page-link {
        color: #cbd5e0;
        cursor: not-allowed;
        background: #f7fafc;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        color: #4c566a;
        font-size: 0.9rem;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Hàm chuyển trang
            window.goToPage = function(pageNumber) {
                $('#pageNumberInput').val(pageNumber);
                $('#pageNumberInput').data('pagination-click', true);
                $('#searchForm').submit();
            };

            // Khi submit form tìm kiếm, reset về trang 1
            $('#searchForm').on('submit', function() {
                // Nếu không phải là click phân trang, reset về trang 1
                if (!$('#pageNumberInput').data('pagination-click')) {
                    $('#pageNumberInput').val(1);
                }
                $('#pageNumberInput').removeData('pagination-click');
            });

            // Đánh dấu khi click phân trang
            $(document).on('click', '.page-link', function() {
                $('#pageNumberInput').data('pagination-click', true);
            });

            // Khi thay đổi filter, reset về trang 1 và submit
            $('#locNganhNghe, #locKinhNghiem').on('change', function() {
                $('#pageNumberInput').val(1);
                $('#pageNumberInput').removeData('pagination-click');
                $('#searchForm').submit();
            });

            // Xoa ung vien
            $('.btn-xoa').click(function() {
                var ma = $(this).data('ma');
                if (confirm('Ban co chac chan muon xoa ung vien nay?')) {
                    alert('Da xoa ung vien ma ' + ma);
                    $(this).closest('tr').fadeOut();
                }
            });
        });
    </script>
}

