        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        backdrop-filter: blur(10px);
    }
    
    .page-header-card .header-title {
        font-size: 1.75rem;
        font-weight: 700;
