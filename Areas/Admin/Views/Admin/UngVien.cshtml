        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    
    .mini-stat-card .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }
    
    .stat-purple .stat-icon {
