                            <dd class="col-sm-7"><strong style="color: #f093fb;">2 ngày 5 giờ</strong></dd>
                            
                            <dt class="col-sm-5"><i class="bi bi-people-fill" style="color: #fa709a;"></i> Tổng users:</dt>
                            <dd class="col-sm-7"><strong style="color: #fa709a;">@(tongUngVien + tongNhaTuyenDung)</strong></dd>
                            
                            <dt class="col-sm-5"><i class="bi bi-file-earmark-bar-graph" style="color: #11998e;"></i> Tổng dữ liệu:</dt>
