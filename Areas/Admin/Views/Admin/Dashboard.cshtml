                            @foreach (var nganh in danhSachNganhNghe.OrderByDescending(n => n.SoLuongCongViec))
                            {
                                <div class="category-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-tag-fill" style="color: #667eea;"></i> @nganh.TenNganhNghe</span>
                                        <span class="badge" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">@nganh.SoLuongCongViec</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="modern-data-card">
                    <div class="card-header" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                        <h5 class="mb-0"><i class="bi bi-briefcase"></i> Loại công việc</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <div class="stat-box" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                                    <h3>@danhSachLoaiCongViec.Count</h3>
                                    <small>Tổng loại</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-box" style="background: linear-gradient(135deg, #3494e6 0%, #ec6ead 100%); color: white;">
                                    <h3>@danhSachLoaiCongViec.Sum(l => l.SoLuongViTri)</h3>
                                    <small>Tổng vị trí</small>
                                </div>
                            </div>
                        </div>
                        <hr/>
                        <div style="max-height: 250px; overflow-y: auto;">
                            @foreach (var loai in danhSachLoaiCongViec.OrderByDescending(l => l.SoLuongViTri))
