            </div>
            <div class="card-body">
                <dl class="row">
                            <dt class="col-sm-4">Phien ban:</dt>
                            <dd class="col-sm-8">1.0.0</dd>
                            
                            <dt class="col-sm-4">Server:</dt>
                            <dd class="col-sm-8">.NET 8.0</dd>
                            
                            <dt class="col-sm-4">Database:</dt>
                            <dd class="col-sm-8">SQL Server</dd>
                            
