                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="modern-data-card">
                    <div class="card-header" style="background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%); color: white;">
                        <h5 class="mb-0"><i class="bi bi-activity"></i> Hoạt động gần đây</h5>
                    </div>
                    <div class="card-body">
                        <div class="activity-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-person-plus" style="color: #11998e; font-size: 1.2rem;"></i>
