@using Unicareer.Models

@{
    ViewData["Title"] = "So lieu phan tich";
    
    // Lay du lieu mockdata
    var danhSachUngVien = UngVien.LayDanhSachUngVien();
    var danhSachNhaTuyenDung = NhaTuyenDung.LayDanhSachNhaTuyenDung();
    var danhSachTinTuyenDung = TinTuyenDung.LayDanhSachTinTuyenDung();
    var danhSachTinUngTuyen = TinUngTuyen.LayDanhSachTinUngTuyen();
    var danhSachNganhNghe = NganhNghe.LayDanhSachNganhNghe();
    var danhSachLoaiCongViec = LoaiCongViec.LayDanhSachLoaiCongViec();
    
    // Tinh toan thong ke
    var tongUngVien = danhSachUngVien.Count;
    var tongNhaTuyenDung = danhSachNhaTuyenDung.Count;
    var tongTinTuyenDung = danhSachTinTuyenDung.Count;
    var tongTinUngTuyen = danhSachTinUngTuyen.Count;
    var tongUngTuyenThanhCong = danhSachTinUngTuyen.Count(t => t.TrangThaiXuLy == "Tuyen dung");
    var tiLeThanhCong = tongTinUngTuyen > 0 ? (tongUngTuyenThanhCong * 100.0 / tongTinUngTuyen) : 0;
}

<div class="row mb-4">
    <div class="col-12">
        <h3>So lieu phan tich he thong</h3>
        <p class="text-muted">Cap nhat: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" id="dashboardTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tong-quan-tab" data-bs-toggle="tab" data-bs-target="#tong-quan" type="button">
            <i class="bi bi-speedometer2"></i> Tong quan
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nguoi-dung-tab" data-bs-toggle="tab" data-bs-target="#nguoi-dung" type="button">
            <i class="bi bi-people"></i> Nguoi dung
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tuyen-dung-tab" data-bs-toggle="tab" data-bs-target="#tuyen-dung" type="button">
            <i class="bi bi-file-earmark-text"></i> Tuyen dung
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="danh-muc-tab" data-bs-toggle="tab" data-bs-target="#danh-muc" type="button">
            <i class="bi bi-list-ul"></i> Danh muc
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="he-thong-tab" data-bs-toggle="tab" data-bs-target="#he-thong" type="button">
            <i class="bi bi-gear"></i> He thong
        </button>
    </li>
</ul>

<!-- Tab Content -->
<div class="tab-content" id="dashboardTabContent">
    
    <!-- Tab Tong quan -->
    <div class="tab-pane fade show active" id="tong-quan" role="tabpanel">
        <!-- Cards thong ke tong quan -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0">Ung vien</h6>
                                <h2 class="mt-2 mb-0">@tongUngVien</h2>
                            </div>
                            <div>
                                <i class="bi bi-person-circle" style="font-size: 3rem; opacity: 0.5;"></i>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-light">
                        <small>Dang ky tren he thong</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0">Nha tuyen dung</h6>
                                <h2 class="mt-2 mb-0">@tongNhaTuyenDung</h2>
                            </div>
                            <div>
                                <i class="bi bi-building" style="font-size: 3rem; opacity: 0.5;"></i>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-light">
                        <small>Cong ty dang ky</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0">Tin tuyen dung</h6>
                                <h2 class="mt-2 mb-0">@tongTinTuyenDung</h2>
                            </div>
                            <div>
                                <i class="bi bi-newspaper" style="font-size: 3rem; opacity: 0.5;"></i>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-light">
                        <small>Dang hoat dong</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title mb-0">Tin ung tuyen</h6>
                                <h2 class="mt-2 mb-0">@tongTinUngTuyen</h2>
                            </div>
                            <div>
                                <i class="bi bi-envelope-check" style="font-size: 3rem; opacity: 0.5;"></i>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-light">
                        <small>Da nhan duoc</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thong ke nhanh -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up"></i> Ty le tuyen dung</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tuyen dung thanh cong</span>
                                <strong>@tongUngTuyenThanhCong / @tongTinUngTuyen</strong>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @tiLeThanhCong%" aria-valuenow="@tiLeThanhCong" aria-valuemin="0" aria-valuemax="100">
                                    @tiLeThanhCong.ToString("F1")%
                                </div>
                            </div>
                        </div>
                        <hr/>
                        <div class="row text-center">
                            <div class="col-4">
                                <h4 class="text-success">@danhSachTinUngTuyen.Count(t => t.TrangThaiXuLy == "Tuyen dung")</h4>
                                <small>Tuyen dung</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-warning">@danhSachTinUngTuyen.Count(t => t.TrangThaiXuLy == "Cho phong van")</h4>
                                <small>Cho PV</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-danger">@danhSachTinUngTuyen.Count(t => t.TrangThaiXuLy == "Tu choi")</h4>
                                <small>Tu choi</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-activity"></i> Hoat dong gan day</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            @foreach (var tinUT in danhSachTinUngTuyen.OrderByDescending(t => t.NgayUngTuyen).Take(5))
                            {
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <strong>@tinUT.HoTen</strong> ung tuyen
                                            <small class="text-muted">@tinUT.ViTriUngTuyen</small>
                                        </div>
                                        <small class="text-muted">@tinUT.NgayUngTuyen.ToString("dd/MM HH:mm")</small>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Bieu do duong -->
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Xu huong dang ky nguoi dung</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="userTrendChart" height="250"></canvas>
                    </div>
                </div>
            </div>
    <div class="col-md-6">
        <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Xu huong ung tuyen</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="applicationTrendChart" height="250"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Tab Nguoi dung -->
    <div class="tab-pane fade" id="nguoi-dung" role="tabpanel">
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Thong ke Ung vien</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr>
                                <td>Tong ung vien:</td>
                                <td><strong>@danhSachUngVien.Count</strong></td>
                            </tr>
                            <tr>
                                <td>Ung vien IT:</td>
                                <td><strong>@danhSachUngVien.Count(u => u.NganhNghe == "Cong nghe thong tin")</strong></td>
                            </tr>
                            <tr>
                                <td>Ung vien Kinh doanh:</td>
                                <td><strong>@danhSachUngVien.Count(u => u.NganhNghe == "Kinh doanh")</strong></td>
                            </tr>
                            <tr>
                                <td>TB ung tuyen/nguoi:</td>
                                <td><strong>@((int)danhSachUngVien.Average(u => u.SoLanUngTuyen))</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Thong ke NTD</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr>
                                <td>Tong cong ty:</td>
                                <td><strong>@danhSachNhaTuyenDung.Count</strong></td>
                            </tr>
                            <tr>
                                <td>Cong ty IT:</td>
                                <td><strong>@danhSachNhaTuyenDung.Count(n => n.LinhVuc.Contains("Cong nghe"))</strong></td>
                            </tr>
                            <tr>
                                <td>Tong tin dang:</td>
                                <td><strong>@danhSachNhaTuyenDung.Sum(n => n.SoTinDaDang)</strong></td>
                            </tr>
                            <tr>
                                <td>TB tin/cong ty:</td>
                                <td><strong>@((int)danhSachNhaTuyenDung.Average(n => n.SoTinDaDang))</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Top NTD hoat dong</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            @foreach (var ntd in danhSachNhaTuyenDung.OrderByDescending(n => n.SoTinDaDang).Take(5))
                            {
                                <div class="list-group-item px-0 py-2">
                                    <div class="d-flex justify-content-between">
                                        <small>@ntd.TenCongTy</small>
                                        <span class="badge bg-primary">@ntd.SoTinDaDang tin</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Bieu do duong cho Nguoi dung -->
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Xu huong dang ky nguoi dung theo thang</h5>
            </div>
            <div class="card-body">
                        <canvas id="userRegistrationChart" height="80"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Tab Tuyen dung -->
    <div class="tab-pane fade" id="tuyen-dung" role="tabpanel">
        <!-- Bieu do duong cho Tuyen dung -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Xu huong tuyen dung va ung tuyen theo thang</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="recruitmentTrendChart" height="80"></canvas>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Tin tuyen dung theo nganh</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var tinTheoNganh = danhSachTinTuyenDung.GroupBy(t => t.NganhNghe)
                                .Select(g => new { NganhNghe = g.Key, SoLuong = g.Count() })
                                .OrderByDescending(x => x.SoLuong)
                                .Take(5);
                        }
                        @foreach (var item in tinTheoNganh)
                        {
                            var phanTram = (item.SoLuong * 100.0 / tongTinTuyenDung);
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>@item.NganhNghe</span>
                                    <strong>@item.SoLuong tin</strong>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-info" style="width: @phanTram%">@phanTram.ToString("F0")%</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">Trang thai ung tuyen</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var trangThaiGroups = danhSachTinUngTuyen.GroupBy(t => t.TrangThaiXuLy)
                                .Select(g => new { TrangThai = g.Key, SoLuong = g.Count() })
                                .OrderByDescending(x => x.SoLuong);
                        }
                        @foreach (var item in trangThaiGroups)
                        {
                            var phanTram = (item.SoLuong * 100.0 / tongTinUngTuyen);
                            var colorClass = item.TrangThai switch {
                                "Tuyen dung" => "success",
                                "Tu choi" => "danger",
                                "Cho phong van" => "warning",
                                "Da phong van" => "info",
                                _ => "secondary"
                            };
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>@item.TrangThai</span>
                                    <strong>@item.SoLuong tin</strong>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-@colorClass" style="width: @phanTram%">@phanTram.ToString("F0")%</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Top khu vuc tin tuyen dung</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var topDiaDiem = danhSachTinTuyenDung.GroupBy(t => t.TinhThanhPho)
                                .Select(g => new { TinhThanhPho = g.Key, SoLuong = g.Count() })
                                .OrderByDescending(x => x.SoLuong)
                                .Take(5);
                        }
                        @foreach (var item in topDiaDiem)
                        {
                            var phanTram = (item.SoLuong * 100.0 / tongTinTuyenDung);
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span><i class="bi bi-geo-alt-fill text-primary"></i> @item.TinhThanhPho</span>
                                    <strong>@item.SoLuong tin</strong>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-primary" style="width: @phanTram%">@phanTram.ToString("F0")%</div>
                                </div>
                            </div>
                        }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Top khu vuc ung vien</h5>
                    </div>
                    <div class="card-body">
                        @{
                            var topUngVienTheoKhuVuc = danhSachUngVien.GroupBy(u => u.DiaChi)
                                .Select(g => new { DiaChi = g.Key, SoLuong = g.Count() })
                                .OrderByDescending(x => x.SoLuong)
                                .Take(5);
                        }
                        @foreach (var item in topUngVienTheoKhuVuc)
                        {
                            var phanTram = (item.SoLuong * 100.0 / tongUngVien);
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span><i class="bi bi-geo-alt-fill text-success"></i> @item.DiaChi</span>
                                    <strong>@item.SoLuong UV</strong>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-success" style="width: @phanTram%">@phanTram.ToString("F0")%</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Tin tuyen dung sap het han</h5>
            </div>
            <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                    <thead>
                        <tr>
                                        <th>Tieu de</th>
                                        <th>Cong ty</th>
                                        <th>Dia diem</th>
                                        <th>Han nop</th>
                                        <th>So ngay con lai</th>
                                        <th>So ung tuyen</th>
                        </tr>
                    </thead>
                    <tbody>
                                    @foreach (var tin in danhSachTinTuyenDung.Where(t => (t.HanNop - DateTime.Now).Days <= 7).OrderBy(t => t.HanNop).Take(5))
                                    {
                                        var soNgay = (tin.HanNop - DateTime.Now).Days;
                                        var colorClass = soNgay <= 3 ? "danger" : "warning";
                                        <tr>
                                            <td>@tin.TenViecLam</td>
                                            <td>@tin.CongTy</td>
                                            <td><i class="bi bi-geo-alt"></i> @tin.TinhThanhPho</td>
                                            <td>@tin.HanNop.ToString("dd/MM/yyyy")</td>
                                            <td><span class="badge bg-@colorClass">@soNgay ngay</span></td>
                                            <td><span class="badge bg-info">@tin.SoLuongUngTuyen</span></td>
                        </tr>
                                    }
                    </tbody>
                </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Tab Danh muc -->
    <div class="tab-pane fade" id="danh-muc" role="tabpanel">
        <!-- Bieu do duong cho Danh muc -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Xu huong phat trien danh muc theo thang</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="categoryGrowthChart" height="80"></canvas>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Nganh nghe</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <h3 class="text-primary">@danhSachNganhNghe.Count</h3>
                                    <small>Tong nganh</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <h3 class="text-success">@danhSachNganhNghe.Sum(n => n.SoLuongCongViec)</h3>
                                    <small>Tong CV</small>
                                </div>
                            </div>
                        </div>
                        <hr/>
                        <div style="max-height: 250px; overflow-y: auto;">
                            @foreach (var nganh in danhSachNganhNghe.OrderByDescending(n => n.SoLuongCongViec))
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@nganh.TenNganhNghe</span>
                                    <span class="badge bg-primary">@nganh.SoLuongCongViec</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Loai cong viec</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <h3 class="text-success">@danhSachLoaiCongViec.Count</h3>
                                    <small>Tong loai</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <h3 class="text-info">@danhSachLoaiCongViec.Sum(l => l.SoLuongViTri)</h3>
                                    <small>Tong vi tri</small>
                                </div>
                            </div>
                        </div>
                        <hr/>
                        <div style="max-height: 250px; overflow-y: auto;">
                            @foreach (var loai in danhSachLoaiCongViec.OrderByDescending(l => l.SoLuongViTri))
                            {
