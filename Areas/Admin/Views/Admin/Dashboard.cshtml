                            <dt class="col-sm-5"><i class="bi bi-bookmark-check-fill" style="color: #667eea;"></i> Phiên bản:</dt>
                            <dd class="col-sm-7"><strong style="color: #667eea;">1.0.0</strong></dd>
                            
                            <dt class="col-sm-5"><i class="bi bi-server" style="color: #11998e;"></i> Server:</dt>
                            <dd class="col-sm-7"><strong style="color: #11998e;">.NET 8.0</strong></dd>
                            
