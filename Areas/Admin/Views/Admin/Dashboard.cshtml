                                        <span><i class="bi bi-briefcase-fill" style="color: #11998e;"></i> @loai.TenLoaiCongViec</span>
                                        <span class="badge" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">@loai.SoLuongViTri</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab He thong -->
