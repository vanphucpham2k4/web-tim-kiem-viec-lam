        <!-- Bieu do duong cho He thong -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="chart-card">
                    <div class="card-header" style="background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%); color: white;">
