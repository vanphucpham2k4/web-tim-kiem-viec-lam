@model List<Unicareer.Models.TinUngTuyen>

@{
    ViewData["Title"] = "Quản lý Tin ứng tuyển";
}

<div class="page-header-section mb-4">
    <div class="row">
        <div class="col-12">
            <div class="page-header-card">
                <div class="header-icon">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div class="header-content">
                    <h3 class="header-title">Danh sách Tin ứng tuyển</h3>
                    <p class="header-subtitle">Quản lý và theo dõi các hồ sơ ứng tuyển</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="filter-section mb-4">
    <div class="row g-3">
        <div class="col-lg-6 col-md-6">
            <div class="search-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="form-control search-input" id="timKiemInput" placeholder="Tìm kiếm theo họ tên, email...">
            </div>
        </div>
        <div class="col-lg-4 col-md-4">
            <div class="filter-select-wrapper">
                <i class="bi bi-funnel filter-icon"></i>
                <select class="form-select filter-select" id="locTrangThai">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Dang xem xet">Đang xem xét</option>
                    <option value="Cho phong van">Chờ phỏng vấn</option>
                    <option value="Da phong van">Đã phỏng vấn</option>
                    <option value="Tuyen dung">Tuyển dụng</option>
                    <option value="Tu choi">Từ chối</option>
                </select>
            </div>
        </div>
        <div class="col-lg-2 col-md-2">
            <button class="btn btn-primary w-100 filter-btn" type="button" id="btnTimKiem">
                <i class="bi bi-funnel-fill"></i> Lọc
            </button>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="data-table-card">
            <div class="table-responsive">
                <table class="table table-hover modern-table" id="bangTinUngTuyen">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Họ tên</th>
                            <th>Email / SĐT</th>
                            <th>Vị trí ứng tuyển</th>
                            <th>Công ty</th>
                            <th>Trạng thái</th>
                            <th>Ngày ứng tuyển</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tin in Model)
                        {
                            string badgeClass = tin.TrangThaiXuLy switch
                            {
                                "Tuyen dung" => "bg-success",
                                "Tu choi" => "bg-danger",
                                "Da phong van" => "bg-info",
                                "Cho phong van" => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };

                            <tr data-ma="@tin.MaTinUngTuyen" data-trangthai="@tin.TrangThaiXuLy">
                                <td>@tin.MaTinUngTuyen</td>
                                <td><strong>@tin.HoTen</strong></td>
                                <td>
                                    <i class="bi bi-envelope"></i> @tin.Email<br/>
                                    <small class="text-muted"><i class="bi bi-telephone"></i> @tin.SoDienThoai</small>
                                </td>
                                <td>@tin.ViTriUngTuyen</td>
                                <td>@tin.CongTy</td>
                                <td>
                                    <span class="badge @badgeClass">@tin.TrangThaiXuLy</span>
                                </td>
                                <td>@tin.NgayUngTuyen.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-info btn-xem" 
                                            data-ma="@tin.MaTinUngTuyen"
                                            data-hoten="@tin.HoTen"
                                            data-email="@tin.Email"
                                            data-sdt="@tin.SoDienThoai"
                                            data-vitri="@tin.ViTriUngTuyen"
                                            data-congty="@tin.CongTy"
                                            data-trangthai="@tin.TrangThaiXuLy"
                                            data-linkcv="@tin.LinkCV"
                                            data-ghichu="@tin.GhiChu"
                                            data-ngayut="@tin.NgayUngTuyen.ToString("dd/MM/yyyy HH:mm")"
                                            title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary btn-sua-trangthai" 
                                            data-ma="@tin.MaTinUngTuyen"
                                            data-hoten="@tin.HoTen"
                                            data-trangthai="@tin.TrangThaiXuLy"
                                            title="Cập nhật trạng thái">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary btn-cv" 
                                            data-linkcv="@tin.LinkCV"
                                            title="Xem CV">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger btn-xoa" data-ma="@tin.MaTinUngTuyen" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Thống kê -->
<div class="row stats-section mt-4">
    <div class="col-xl col-md-4 col-sm-6 mb-3">
        <div class="mini-stat-card stat-purple">
            <div class="stat-icon">
                <i class="bi bi-files"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tổng ứng tuyển</h6>
                <h3 class="stat-number">@Model.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6 mb-3">
        <div class="mini-stat-card stat-secondary">
            <div class="stat-icon">
                <i class="bi bi-eye"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Đang xem xét</h6>
                <h3 class="stat-number">@Model.Count(t => t.TrangThaiXuLy == "Dang xem xet")</h3>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6 mb-3">
        <div class="mini-stat-card stat-warning">
            <div class="stat-icon">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Chờ PV</h6>
                <h3 class="stat-number">@Model.Count(t => t.TrangThaiXuLy == "Cho phong van")</h3>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6 mb-3">
        <div class="mini-stat-card stat-info">
            <div class="stat-icon">
                <i class="bi bi-chat-left-dots"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Đã PV</h6>
                <h3 class="stat-number">@Model.Count(t => t.TrangThaiXuLy == "Da phong van")</h3>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6 mb-3">
        <div class="mini-stat-card stat-green">
            <div class="stat-icon">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tuyển dụng</h6>
                <h3 class="stat-number">@Model.Count(t => t.TrangThaiXuLy == "Tuyen dung")</h3>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6 mb-3">
        <div class="mini-stat-card stat-danger">
            <div class="stat-icon">
                <i class="bi bi-x-circle"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Từ chối</h6>
                <h3 class="stat-number">@Model.Count(t => t.TrangThaiXuLy == "Tu choi")</h3>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xem chi tiết -->
<div class="modal fade" id="xemChiTietModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-file-earmark-person me-2"></i>Chi tiết tin ứng tuyển</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Họ tên:</strong> <span id="chiTietHoTen"></span></p>
                        <p><strong>Email:</strong> <span id="chiTietEmail"></span></p>
                        <p><strong>Số điện thoại:</strong> <span id="chiTietSDT"></span></p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Vị trí ứng tuyển:</strong> <span id="chiTietViTri"></span></p>
                        <p><strong>Công ty:</strong> <span id="chiTietCongTy"></span></p>
                        <p><strong>Ngày ứng tuyển:</strong> <span id="chiTietNgayUT"></span></p>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <p><strong>Trạng thái xử lý:</strong> <span id="chiTietTrangThai" class="badge"></span></p>
                        <p><strong>Link CV:</strong> <a href="#" id="chiTietLinkCV" target="_blank" class="text-primary"><i class="bi bi-file-earmark-pdf"></i> Xem CV</a></p>
                        <p><strong>Ghi chú:</strong></p>
                        <p id="chiTietGhiChu" class="text-muted"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cập nhật trạng thái -->
<div class="modal fade" id="suaTrangThaiModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Cập nhật trạng thái xử lý</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formSuaTrangThai">
                    <input type="hidden" id="maTinUngTuyenSua">
                    <p><strong>Ứng viên:</strong> <span id="hoTenSua"></span></p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Trạng thái xử lý</label>
                        <select class="form-select" id="trangThaiSua">
                            <option value="Dang xem xet">Đang xem xét</option>
                            <option value="Cho phong van">Chờ phỏng vấn</option>
                            <option value="Da phong van">Đã phỏng vấn</option>
                            <option value="Tuyen dung">Tuyển dụng</option>
                            <option value="Tu choi">Từ chối</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnCapNhatTrangThai">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .page-header-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: white;
        box-shadow: 0 8px 24px rgba(102, 126, 234, 0.25);
        display: flex;
        align-items: center;
        gap: 20px;
    }
    
    .page-header-card .header-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        backdrop-filter: blur(10px);
    }
    
    .page-header-card .header-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    
    .page-header-card .header-subtitle {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    
    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }
    
    .search-wrapper {
        position: relative;
    }
    
    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.1rem;
        z-index: 1;
    }
    
    .search-input {
        padding-left: 45px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        height: 48px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .search-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .filter-select-wrapper {
        position: relative;
    }
    
    .filter-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.05rem;
        z-index: 1;
        pointer-events: none;
    }
    
    .filter-select {
        padding-left: 45px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        height: 48px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .filter-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .filter-btn {
        height: 48px;
        border-radius: 12px;
        font-weight: 600;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }
    
    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
    
    .data-table-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .modern-table {
        margin-bottom: 0;
    }
    
    .modern-table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
    
    .modern-table thead th {
        border: none;
        padding: 18px 16px;
        font-weight: 700;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #495057;
    }
    
    .modern-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f3f5;
    }
    
    .modern-table tbody tr:hover {
        background: linear-gradient(90deg, rgba(102, 126, 234, 0.05) 0%, transparent 100%);
        transform: scale(1.01);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }
    
    .modern-table tbody td {
        padding: 16px;
        vertical-align: middle;
        border: none;
    }
    
    .modern-table .badge {
        padding: 6px 12px;
        font-weight: 600;
        font-size: 0.8rem;
        border-radius: 8px;
    }
    
    .modern-table .btn {
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    
    .modern-table .btn:hover {
        transform: translateY(-2px);
    }
    
    .mini-stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    
    .mini-stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
    }
    
    .mini-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    
    .stat-purple::before,
    .mini-stat-card .stat-icon {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    
    .stat-secondary::before {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    }
    
    .stat-secondary .stat-icon {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    }
    
    .stat-warning::before {
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    }
    
    .stat-warning .stat-icon {
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    }
    
    .stat-info::before {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    }
    
    .stat-info .stat-icon {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    }
    
    .stat-green::before {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }
    
    .stat-green .stat-icon {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }
    
    .stat-danger::before {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    }
    
    .stat-danger .stat-icon {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    }
    
    .mini-stat-card .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }
    
    .stat-info {
        flex: 1;
    }
    
    .stat-label {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .stat-number {
        font-size: 1.75rem;
        font-weight: 700;
        color: #212529;
        margin: 0;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tim kiem va loc
            $('#btnTimKiem, #timKiemInput').on('click keyup', function(e) {
                if (e.type === 'keyup' && e.keyCode !== 13) return;
                locDuLieu();
            });

            $('#locTrangThai').on('change', function() {
                locDuLieu();
            });

            function locDuLieu() {
                var tuKhoa = $('#timKiemInput').val().toLowerCase();
                var trangThai = $('#locTrangThai').val();

                $('#bangTinUngTuyen tbody tr').each(function() {
                    var row = $(this);
                    var hoTen = row.find('td:eq(1)').text().toLowerCase();
                    var email = row.find('td:eq(2)').text().toLowerCase();
                    var trangThaiRow = row.data('trangthai');
                    
                    var khopTuKhoa = tuKhoa === '' || hoTen.includes(tuKhoa) || email.includes(tuKhoa);
                    var khopTrangThai = trangThai === '' || trangThaiRow === trangThai;
                    
                    if (khopTuKhoa && khopTrangThai) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Xem chi tiet
            $('.btn-xem').click(function() {
                $('#chiTietHoTen').text($(this).data('hoten'));
                $('#chiTietEmail').text($(this).data('email'));
                $('#chiTietSDT').text($(this).data('sdt'));
                $('#chiTietViTri').text($(this).data('vitri'));
                $('#chiTietCongTy').text($(this).data('congty'));
                $('#chiTietNgayUT').text($(this).data('ngayut'));
                $('#chiTietTrangThai').text($(this).data('trangthai'));
                $('#chiTietLinkCV').attr('href', $(this).data('linkcv'));
                $('#chiTietGhiChu').text($(this).data('ghichu'));

                $('#xemChiTietModal').modal('show');
            });

            // Sua trang thai
            $('.btn-sua-trangthai').click(function() {
                var ma = $(this).data('ma');
                var hoTen = $(this).data('hoten');
                var trangThai = $(this).data('trangthai');

                $('#maTinUngTuyenSua').val(ma);
                $('#hoTenSua').text(hoTen);
                $('#trangThaiSua').val(trangThai);

                $('#suaTrangThaiModal').modal('show');
            });

            $('#btnCapNhatTrangThai').click(function() {
                var ma = $('#maTinUngTuyenSua').val();
                var trangThai = $('#trangThaiSua').val();

                alert('Đã cập nhật trạng thái tin ứng tuyển mã ' + ma + ' thành: ' + trangThai);
                $('#suaTrangThaiModal').modal('hide');
                
                // Cap nhat badge trong bang
                var row = $('tr[data-ma="' + ma + '"]');
                row.data('trangthai', trangThai);
                var badge = row.find('td:eq(5) .badge');
                badge.text(trangThai);
                
                // Cap nhat class cua badge
                badge.removeClass();
                badge.addClass('badge');
                if (trangThai === 'Tuyen dung') badge.addClass('bg-success');
                else if (trangThai === 'Tu choi') badge.addClass('bg-danger');
                else if (trangThai === 'Da phong van') badge.addClass('bg-info');
                else if (trangThai === 'Cho phong van') badge.addClass('bg-warning text-dark');
                else badge.addClass('bg-secondary');
            });

            // Xem CV
            $('.btn-cv').click(function() {
                var linkCV = $(this).data('linkcv');
                window.open(linkCV, '_blank');
            });

            // Xoa tin ung tuyen
            $('.btn-xoa').click(function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn xóa tin ứng tuyển này?')) {
                    alert('Đã xóa tin ứng tuyển mã ' + ma);
                    $(this).closest('tr').fadeOut();
                }
            });
        });
    </script>
}
