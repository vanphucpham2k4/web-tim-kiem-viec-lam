@model Unicareer.Models.Blog

@{
    ViewData["Title"] = "Xem trước bài đăng";
    var isPreview = ViewBag.IsPreview as bool? ?? true;
}

<style>
    .preview-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
        background: white;
    }

    .preview-header {
        text-align: center;
        padding: 20px;
        background: #fff5f2;
        border: 2px dashed #ff6b35;
        border-radius: 8px;
        margin-bottom: 30px;
    }

    .preview-header h2 {
        color: #ff6b35;
        margin: 0;
        font-size: 18px;
    }

    .preview-header p {
        color: #666;
        margin: 10px 0 0 0;
        font-size: 14px;
    }

    .blog-preview-title {
        font-size: 36px;
        font-weight: 700;
        color: #333;
        margin-bottom: 20px;
        line-height: 1.3;
    }

    .blog-preview-meta {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #e0e0e0;
        flex-wrap: wrap;
    }

    .blog-preview-meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #666;
        font-size: 14px;
    }

    .blog-preview-meta-item i {
        color: #999;
    }

    .blog-preview-image {
        width: 100%;
        max-height: 500px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 30px;
    }

    .blog-preview-category {
        display: inline-block;
        padding: 6px 12px;
        background: #e3f2fd;
        color: #1976d2;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 15px;
    }

    .blog-preview-content {
        font-size: 18px;
        line-height: 1.8;
        color: #333;
        margin-bottom: 30px;
    }

    .blog-preview-content h1,
    .blog-preview-content h2,
    .blog-preview-content h3,
    .blog-preview-content h4 {
        margin-top: 30px;
        margin-bottom: 15px;
        color: #333;
    }

    .blog-preview-content p {
        margin-bottom: 20px;
    }

    .blog-preview-content img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 20px 0;
    }

    .blog-preview-content ul,
    .blog-preview-content ol {
        margin: 20px 0;
        padding-left: 30px;
    }

    .blog-preview-content li {
        margin-bottom: 10px;
    }

    .blog-preview-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid #e0e0e0;
    }

    .blog-preview-tag {
        padding: 6px 12px;
        background: #f5f5f5;
        color: #666;
        border-radius: 20px;
        font-size: 13px;
    }


    .blog-preview-excerpt {
        font-size: 20px;
        color: #666;
        font-style: italic;
        margin-bottom: 30px;
        padding: 20px;
        background: #f9f9f9;
        border-left: 4px solid #ff6b35;
        border-radius: 4px;
    }
</style>

<div class="preview-container">
    <div class="preview-header">
        <h2>🔍 Chế độ xem trước</h2>
        <p>Đây là cách bài đăng sẽ hiển thị cho người đọc</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.TieuDe))
    {
        <h1 class="blog-preview-title">@Model.TieuDe</h1>
    }

    <div class="blog-preview-meta">
        @if (Model.TheLoaiBlog != null)
        {
            <span class="blog-preview-category" style="background: @(Model.TheLoaiBlog.MauSac ?? "#e3f2fd"); color: @(Model.TheLoaiBlog.MauSac != null ? "white" : "#1976d2");">
                @Model.TheLoaiBlog.TenTheLoai
            </span>
        }
        else if (!string.IsNullOrEmpty(Model.TheLoai))
        {
            <span class="blog-preview-category">@Model.TheLoai</span>
        }

        @if (Model.User != null)
        {
            <div class="blog-preview-meta-item">
                <i class="bi bi-person"></i>
                <span>@(Model.User.HoTen ?? Model.User.UserName ?? Model.User.Email ?? "Admin")</span>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.TacGia))
        {
            <div class="blog-preview-meta-item">
                <i class="bi bi-person"></i>
                <span>@Model.TacGia</span>
            </div>
        }

        <div class="blog-preview-meta-item">
            <i class="bi bi-calendar"></i>
            <span>@Model.NgayDang.ToString("dd/MM/yyyy HH:mm")</span>
        </div>

        @if (Model.LuotXem > 0)
        {
            <div class="blog-preview-meta-item">
                <i class="bi bi-eye"></i>
                <span>@Model.LuotXem.ToString("N0") lượt xem</span>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.HinhAnh))
    {
        <img src="@Model.HinhAnh" alt="@Model.TieuDe" class="blog-preview-image" onerror="this.style.display='none'" />
    }

    @if (!string.IsNullOrEmpty(Model.MoTaNgan))
    {
        <div class="blog-preview-excerpt">
            @Model.MoTaNgan
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.NoiDung))
    {
        <div class="blog-preview-content">
            @Html.Raw(Model.NoiDung)
        </div>
    }
    else
    {
        <div class="blog-preview-content">
            <p style="color: #999; font-style: italic;">Nội dung bài viết sẽ được hiển thị ở đây...</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Tags))
    {
        <div class="blog-preview-tags">
            @{
                var tags = Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries);
            }
            @foreach (var tag in tags)
            {
                <span class="blog-preview-tag">#@tag.Trim()</span>
            }
        </div>
    }
</div>

