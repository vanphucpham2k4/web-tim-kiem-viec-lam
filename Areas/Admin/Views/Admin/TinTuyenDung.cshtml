@model List<Unicareer.Models.TinTuyenDung>

@{
    ViewData["Title"] = "Quản lý Tin tuyển dụng";
}

<div class="page-header-section mb-4">
    <div class="row">
        <div class="col-12">
            <div class="page-header-card">
                <div class="header-icon">
                    <i class="bi bi-newspaper"></i>
                </div>
                <div class="header-content">
                    <h3 class="header-title">Danh sách Tin tuyển dụng</h3>
                    <p class="header-subtitle">Quản lý và theo dõi các tin tuyển dụng trên hệ thống</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="filter-section mb-4">
    <div class="row g-3">
        <div class="col-lg-4 col-md-6">
            <div class="search-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="form-control search-input" id="timKiemInput" placeholder="Tìm kiếm theo tiêu đề, công ty...">
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="filter-select-wrapper">
                <i class="bi bi-briefcase filter-icon"></i>
                <select class="form-select filter-select" id="locNganhNghe">
                    <option value="">Tất cả ngành nghề</option>
                    <option value="Cong nghe thong tin">Công nghệ thông tin</option>
                    <option value="Kinh doanh">Kinh doanh</option>
                    <option value="Ke toan - Tai chinh">Kế toán - Tài chính</option>
                    <option value="Nhan su">Nhân sự</option>
                    <option value="Thiet ke do hoa">Thiết kế đồ họa</option>
                </select>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="filter-select-wrapper">
                <i class="bi bi-clock filter-icon"></i>
                <select class="form-select filter-select" id="locLoaiCongViec">
                    <option value="">Tất cả loại công việc</option>
                    <option value="Full-time">Full-time</option>
                    <option value="Part-time">Part-time</option>
                    <option value="Internship">Internship</option>
                    <option value="Remote">Remote</option>
                </select>
            </div>
        </div>
        <div class="col-lg-2 col-md-6">
            <button class="btn btn-primary w-100 filter-btn" type="button" id="btnTimKiem">
                <i class="bi bi-funnel-fill"></i> Lọc
            </button>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="data-table-card">
            <div class="table-responsive">
                <table class="table table-hover modern-table" id="bangTinTuyenDung">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Tiêu đề</th>
                            <th>Công ty</th>
                            <th>Vị trí</th>
                            <th>Mức lương</th>
                            <th>Địa điểm</th>
                            <th>Loại CV</th>
                            <th>Số ứng tuyển</th>
                            <th>Hạn nộp</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tin in Model)
                        {
                            var soNgayConLai = (tin.HanNop - DateTime.Now).Days;
                            var hanNopClass = soNgayConLai <= 7 ? "text-danger" : (soNgayConLai <= 14 ? "text-warning" : "");
                            
                            <tr data-ma="@tin.MaTinTuyenDung" data-nganh="@tin.NganhNghe" data-loai="@tin.LoaiCongViec">
                                <td>@tin.MaTinTuyenDung</td>
                                <td><strong>@tin.TenViecLam</strong></td>
                                <td>@tin.CongTy</td>
                                <td>@tin.ViTri</td>
                                <td><span class="badge bg-info">@tin.MucLuongThapNhat-@tin.MucLuongCaoNhat tr</span></td>
                                <td><i class="bi bi-geo-alt-fill text-primary"></i> @tin.TinhThanhPho</td>
                                <td><span class="badge bg-primary">@tin.LoaiCongViec</span></td>
                                <td><span class="badge bg-secondary">@tin.SoLuongUngTuyen</span></td>
                                <td class="@hanNopClass">
                                    @tin.HanNop.ToString("dd/MM/yyyy")
                                    <br/>
                                    <small>(@soNgayConLai ngày)</small>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-info btn-xem" data-ma="@tin.MaTinTuyenDung" title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary btn-sua" 
                                            data-ma="@tin.MaTinTuyenDung"
                                            data-tenviec="@tin.TenViecLam"
                                            data-congty="@tin.CongTy"
                                            data-vitri="@tin.ViTri"
                                            data-mucluongthap="@tin.MucLuongThapNhat"
                                            data-mucluongcao="@tin.MucLuongCaoNhat"
                                            data-tinhthanh="@tin.TinhThanhPho"
                                            data-loaicv="@tin.LoaiCongViec"
                                            data-nganhnghe="@tin.NganhNghe"
                                            data-hannop="@tin.HanNop.ToString("yyyy-MM-dd")"
                                            title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger btn-xoa" data-ma="@tin.MaTinTuyenDung" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Thống kê -->
<div class="row stats-section mt-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-purple">
            <div class="stat-icon">
                <i class="bi bi-newspaper"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tổng tin tuyển dụng</h6>
                <h3 class="stat-number">@Model.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-blue">
            <div class="stat-icon">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Tổng ứng tuyển</h6>
                <h3 class="stat-number">@Model.Sum(t => t.SoLuongUngTuyen)</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-green">
            <div class="stat-icon">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">TB ứng tuyển/tin</h6>
                <h3 class="stat-number">@((int)Model.Average(t => t.SoLuongUngTuyen))</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="mini-stat-card stat-orange">
            <div class="stat-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="stat-info">
                <h6 class="stat-label">Sắp hết hạn</h6>
                <h3 class="stat-number">@Model.Count(t => (t.HanNop - DateTime.Now).Days <= 7)</h3>
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa tin tuyển dụng -->
<div class="modal fade" id="suaTinTuyenDungModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Sửa tin tuyển dụng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formSuaTinTuyenDung">
                    <input type="hidden" id="maTinTuyenDungSua">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên việc làm</label>
                            <input type="text" class="form-control" id="tenViecSua" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Công ty</label>
                            <input type="text" class="form-control" id="congTySua" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Vị trí</label>
                            <input type="text" class="form-control" id="viTriSua" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tỉnh/Thành phố</label>
                            <input type="text" class="form-control" id="tinhThanhSua" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mức lương thấp nhất (triệu)</label>
                            <input type="number" class="form-control" id="mucLuongThapSua" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mức lương cao nhất (triệu)</label>
                            <input type="number" class="form-control" id="mucLuongCaoSua" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Loại công việc</label>
                            <select class="form-select" id="loaiCongViecSua">
                                <option value="Full-time">Full-time</option>
                                <option value="Part-time">Part-time</option>
                                <option value="Internship">Internship</option>
                                <option value="Remote">Remote</option>
                                <option value="Hybrid">Hybrid</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Ngành nghề</label>
                            <input type="text" class="form-control" id="nganhNgheSua" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Hạn nộp</label>
                            <input type="date" class="form-control" id="hanNopSua" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnCapNhatTinTuyenDung">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Reuse styles from UngVien.cshtml */
    .page-header-card {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: white;
        box-shadow: 0 8px 24px rgba(240, 147, 251, 0.25);
        display: flex;
        align-items: center;
        gap: 20px;
    }
    
    .page-header-card .header-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        backdrop-filter: blur(10px);
    }
    
    .page-header-card .header-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    
    .page-header-card .header-subtitle {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    
    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }
    
    .search-wrapper {
        position: relative;
    }
    
    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.1rem;
        z-index: 1;
    }
    
    .search-input {
        padding-left: 45px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        height: 48px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .search-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .filter-select-wrapper {
        position: relative;
    }
    
    .filter-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.05rem;
        z-index: 1;
        pointer-events: none;
    }
    
    .filter-select {
        padding-left: 45px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        height: 48px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .filter-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    
    .filter-btn {
        height: 48px;
        border-radius: 12px;
        font-weight: 600;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }
    
    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
    
    .data-table-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .modern-table {
        margin-bottom: 0;
    }
    
    .modern-table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
    
    .modern-table thead th {
        border: none;
        padding: 18px 16px;
        font-weight: 700;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #495057;
    }
    
    .modern-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f3f5;
    }
    
    .modern-table tbody tr:hover {
        background: linear-gradient(90deg, rgba(240, 147, 251, 0.05) 0%, transparent 100%);
        transform: scale(1.01);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }
    
    .modern-table tbody td {
        padding: 16px;
        vertical-align: middle;
        border: none;
    }
    
    .modern-table .badge {
        padding: 6px 12px;
        font-weight: 600;
        font-size: 0.8rem;
        border-radius: 8px;
    }
    
    .modern-table .btn {
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    
    .modern-table .btn:hover {
        transform: translateY(-2px);
    }
    
    .mini-stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    
    .mini-stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
    }
    
    .mini-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    
    .stat-purple::before {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    
    .stat-blue::before {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    
    .stat-green::before {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    }
    
    .stat-orange::before {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    
    .mini-stat-card .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }
    
    .stat-purple .stat-icon {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    
    .stat-blue .stat-icon {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    
    .stat-green .stat-icon {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    }
    
    .stat-orange .stat-icon {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    
    .stat-info {
        flex: 1;
    }
    
    .stat-label {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .stat-number {
        font-size: 1.75rem;
        font-weight: 700;
        color: #212529;
        margin: 0;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tim kiem va loc
            $('#btnTimKiem, #timKiemInput').on('click keyup', function(e) {
                if (e.type === 'keyup' && e.keyCode !== 13) return;
                locDuLieu();
            });

            $('#locNganhNghe, #locLoaiCongViec').on('change', function() {
                locDuLieu();
            });

            function locDuLieu() {
                var tuKhoa = $('#timKiemInput').val().toLowerCase();
                var nganhNghe = $('#locNganhNghe').val();
                var loaiCongViec = $('#locLoaiCongViec').val();

                $('#bangTinTuyenDung tbody tr').each(function() {
                    var row = $(this);
                    var tieuDe = row.find('td:eq(1)').text().toLowerCase();
                    var congTy = row.find('td:eq(2)').text().toLowerCase();
                    var nganhRow = row.data('nganh');
                    var loaiRow = row.data('loai');
                    
                    var khopTuKhoa = tuKhoa === '' || tieuDe.includes(tuKhoa) || congTy.includes(tuKhoa);
                    var khopNganh = nganhNghe === '' || nganhRow === nganhNghe;
                    var khopLoai = loaiCongViec === '' || loaiRow === loaiCongViec;
                    
                    if (khopTuKhoa && khopNganh && khopLoai) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Sua tin tuyen dung
            $('.btn-sua').click(function() {
                var ma = $(this).data('ma');
                var tenViec = $(this).data('tenviec');
                var congTy = $(this).data('congty');
                var viTri = $(this).data('vitri');
                var mucLuongThap = $(this).data('mucluongthap');
                var mucLuongCao = $(this).data('mucluongcao');
                var tinhThanh = $(this).data('tinhthanh');
                var loaiCongViec = $(this).data('loaicv');
                var nganhNghe = $(this).data('nganhnghe');
                var hanNop = $(this).data('hannop');

                $('#maTinTuyenDungSua').val(ma);
                $('#tenViecSua').val(tenViec);
                $('#congTySua').val(congTy);
                $('#viTriSua').val(viTri);
                $('#mucLuongThapSua').val(mucLuongThap);
                $('#mucLuongCaoSua').val(mucLuongCao);
                $('#tinhThanhSua').val(tinhThanh);
                $('#loaiCongViecSua').val(loaiCongViec);
                $('#nganhNgheSua').val(nganhNghe);
                $('#hanNopSua').val(hanNop);

                $('#suaTinTuyenDungModal').modal('show');
            });

            $('#btnCapNhatTinTuyenDung').click(function() {
                var ma = $('#maTinTuyenDungSua').val();
                var tenViec = $('#tenViecSua').val();

                alert('Đã cập nhật tin tuyển dụng mã ' + ma + ': ' + tenViec);
                $('#suaTinTuyenDungModal').modal('hide');
            });

            // Xem chi tiet
            $('.btn-xem').click(function() {
                var ma = $(this).data('ma');
                alert('Xem chi tiết tin tuyển dụng mã ' + ma);
            });

            // Xoa tin tuyen dung
            $('.btn-xoa').click(function() {
                var ma = $(this).data('ma');
                if (confirm('Bạn có chắc chắn muốn xóa tin tuyển dụng này?')) {
                    alert('Đã xóa tin tuyển dụng mã ' + ma);
                    $(this).closest('tr').fadeOut();
                }
            });
        });
    </script>
}
