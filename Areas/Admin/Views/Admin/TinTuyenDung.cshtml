@model Unicareer.Models.ViewModels.TinTuyenDungAdminViewModel

@{
    ViewData["Title"] = "Quản lý Tin tuyển dụng";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .page-header h1 {
        font-weight: 700;
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .page-header p {
        opacity: 0.95;
        font-size: 1.1rem;
        margin-bottom: 0;
    }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        gap: 15px;
        flex-wrap: wrap;
    }

    .search-filter-group {
        display: flex;
        gap: 15px;
        flex: 1;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
    }

    .btn-success {
        background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(72, 187, 120, 0.4);
    }

    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(72, 187, 120, 0.5);
    }

    .btn-danger {
        background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(245, 101, 101, 0.4);
    }

    .btn-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 101, 101, 0.5);
    }

    .form-control, .form-select {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 16px;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        outline: none;
    }

    .input-group .btn {
        border-radius: 0 10px 10px 0;
        border: 2px solid #e2e8f0;
        border-left: none;
    }

    .input-group .form-control {
        border-radius: 10px 0 0 10px;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        animation: slideUp 0.5s ease forwards;
    }

    .card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        transform: translateY(-5px);
    }

    .table {
        margin-bottom: 0;
    }

    .table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .table thead th {
        border: none;
        color: #2d3748;
        font-weight: 600;
        padding: 18px 15px;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #e2e8f0;
    }

    .table tbody tr:hover {
        background-color: #f7fafc;
        transform: scale(1.01);
    }

    .table tbody td {
        padding: 18px 15px;
        vertical-align: middle;
        border: none;
    }

    .badge {
        padding: 8px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .badge.bg-success {
        background: linear-gradient(135deg, #48bb78 0%, #38a169 100%) !important;
    }

    .badge.bg-secondary {
        background: linear-gradient(135deg, #a0aec0 0%, #718096 100%) !important;
    }

    .badge.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }

    .badge.bg-warning {
        background: linear-gradient(135deg, #ed8936 0%, #dd6b20 100%) !important;
    }

    .badge.bg-danger {
        background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%) !important;
    }

    .badge.bg-info {
        background: linear-gradient(135deg, #4299e1 0%, #3182ce 100%) !important;
    }

    .btn-sm {
        padding: 8px 12px;
        border-radius: 8px;
        transition: all 0.3s ease;
        margin: 0 2px;
    }

    .btn-outline-primary {
        border: 2px solid #667eea;
        color: #667eea;
    }

    .btn-outline-primary:hover {
        background: #667eea;
        color: white;
        transform: translateY(-2px);
    }

    .btn-outline-success {
        border: 2px solid #48bb78;
        color: #48bb78;
    }

    .btn-outline-success:hover {
        background: #48bb78;
        color: white;
        transform: translateY(-2px);
    }

    .btn-outline-warning {
        border: 2px solid #ed8936;
        color: #ed8936;
    }

    .btn-outline-warning:hover {
        background: #ed8936;
        color: white;
        transform: translateY(-2px);
    }

    .btn-outline-danger {
        border: 2px solid #f56565;
        color: #f56565;
    }

    .btn-outline-danger:hover {
        background: #f56565;
        color: white;
        transform: translateY(-2px);
    }

    .btn-outline-info {
        border: 2px solid #4299e1;
        color: #4299e1;
    }

    .btn-outline-info:hover {
        background: #4299e1;
        color: white;
        transform: translateY(-2px);
    }

    .stats-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border: 2px solid #e2e8f0;
        animation: slideUp 0.5s ease forwards;
        opacity: 0;
    }

    .stats-card:nth-child(1) { animation-delay: 0.1s; }
    .stats-card:nth-child(2) { animation-delay: 0.2s; }
    .stats-card:nth-child(3) { animation-delay: 0.3s; }
    .stats-card:nth-child(4) { animation-delay: 0.4s; }
    .stats-card:nth-child(5) { animation-delay: 0.5s; }
    .stats-card:nth-child(6) { animation-delay: 0.6s; }

    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .stats-card .card-title {
        font-size: 0.9rem;
        color: #718096;
        margin-bottom: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stats-card h2 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0;
    }

    .stats-card.primary {
        border-left: 5px solid #667eea;
    }

    .stats-card.success {
        border-left: 5px solid #48bb78;
    }

    .stats-card.secondary {
        border-left: 5px solid #a0aec0;
    }

    .stats-card.info {
        border-left: 5px solid #4299e1;
    }

    .stats-card.warning {
        border-left: 5px solid #ed8936;
    }

    .stats-card.danger {
        border-left: 5px solid #f56565;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .table-responsive {
        border-radius: 12px;
        overflow: hidden;
    }

    .action-buttons {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
    }

    .trang-thai-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .pagination .page-link {
        border: 2px solid #e2e8f0;
        color: #667eea;
        padding: 10px 16px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .pagination .page-link:hover {
        background: #667eea;
        color: white;
        border-color: #667eea;
        transform: translateY(-2px);
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: #667eea;
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .pagination .page-item.disabled .page-link {
        color: #a0aec0;
        border-color: #e2e8f0;
        cursor: not-allowed;
        opacity: 0.5;
    }

    .pagination .page-item.disabled .page-link:hover {
        background: transparent;
        transform: none;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        color: #718096;
        font-size: 0.9rem;
    }

    @@media (max-width: 768px) {
        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .search-filter-group {
            flex-direction: column;
        }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<div class="page-header">
    <h1><i class="bi bi-shield-check"></i> Quản lý tin tuyển dụng</h1>
    <p>Quản lý, duyệt và theo dõi tất cả các tin tuyển dụng trên hệ thống</p>
</div>

<form method="get" action="@Url.Action("TinTuyenDung", "Admin")" id="searchForm">
    <div class="action-bar">
        <div class="search-filter-group">
            <div class="input-group" style="max-width: 350px;">
                <input type="text" class="form-control" id="timKiemInput" name="searchTerm" 
                       placeholder="Tìm kiếm theo tiêu đề, công ty..." value="@Model.SearchTerm">
                <button class="btn btn-outline-secondary" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
            <select class="form-select" id="locTrangThai" name="trangThaiFilter" style="max-width: 200px;">
                <option value="">Tất cả trạng thái</option>
                <option value="Dang tuyen" selected="@(Model.TrangThaiFilter == "Dang tuyen")">Đang tuyển</option>
                <option value="Het han" selected="@(Model.TrangThaiFilter == "Het han")">Hết hạn</option>
                <option value="Da dong" selected="@(Model.TrangThaiFilter == "Da dong")">Đã đóng</option>
                <option value="Cho duyet" selected="@(Model.TrangThaiFilter == "Cho duyet")">Chờ duyệt</option>
                <option value="Da duyet" selected="@(Model.TrangThaiFilter == "Da duyet")">Đã duyệt</option>
                <option value="Tu choi" selected="@(Model.TrangThaiFilter == "Tu choi")">Từ chối</option>
                <option value="Bi khoa" selected="@(Model.TrangThaiFilter == "Bi khoa")">Bị khóa</option>
            </select>
            <select class="form-select" id="locNganhNghe" name="nganhNgheFilter" style="max-width: 200px;">
                <option value="">Tất cả ngành nghề</option>
                <option value="Cong nghe thong tin" selected="@(Model.NganhNgheFilter == "Cong nghe thong tin")">Công nghệ thông tin</option>
                <option value="Kinh doanh" selected="@(Model.NganhNgheFilter == "Kinh doanh")">Kinh doanh</option>
                <option value="Ke toan - Tai chinh" selected="@(Model.NganhNgheFilter == "Ke toan - Tai chinh")">Kế toán - Tài chính</option>
                <option value="Nhan su" selected="@(Model.NganhNgheFilter == "Nhan su")">Nhân sự</option>
                <option value="Thiet ke do hoa" selected="@(Model.NganhNgheFilter == "Thiet ke do hoa")">Thiết kế đồ họa</option>
            </select>
            <input type="hidden" name="pageNumber" id="pageNumberInput" value="@Model.PageNumber" />
        </div>
    </div>
</form>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    <input type="checkbox" id="chonTatCa" title="Chọn tất cả">
                                </th>
                                <th><i class="bi bi-hash"></i> Mã</th>
                                <th><i class="bi-briefcase"></i> Tiêu đề</th>
                                <th><i class="bi bi-building"></i> Công ty</th>
                                <th><i class="bi bi-award"></i> Vị trí</th>
                                <th><i class="bi bi-calendar-plus"></i> Ngày đăng</th>
                                <th><i class="bi bi-calendar-x"></i> Hạn nộp</th>
                                <th><i class="bi bi-people"></i> Lượt UT</th>
                                <th><i class="bi bi-toggle-on"></i> Trạng thái</th>
                                <th><i class="bi bi-gear"></i> Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TinTuyenDungs != null && Model.TinTuyenDungs.Any())
                            {
                                @foreach (var tin in Model.TinTuyenDungs)
                                {
                                    var trangThai = tin.HanNop >= DateTime.Now ? "Đang tuyển" : "Hết hạn";
                                    var badgeClass = trangThai == "Đang tuyển" ? "bg-success" : "bg-secondary";
                                    var soNgayConLai = (tin.HanNop - DateTime.Now).Days;
                                    
                                    <tr data-ma="@tin.MaTinTuyenDung" data-nganh="@(tin.NganhNghe ?? "")" data-trangthai="@trangThai">
                                        <td>
                                            <input type="checkbox" class="chonTin" value="@tin.MaTinTuyenDung">
                                        </td>
                                        <td><span class="text-muted">#@tin.MaTinTuyenDung</span></td>
                                        <td>
                                            <strong style="color: #2d3748; font-size: 1rem;">@tin.TenViecLam</strong><br/>
                                            <small class="text-muted"><i class="bi bi-clock"></i> @tin.LoaiCongViec</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark">@tin.CongTy</span>
                                        </td>
                                        <td><span class="badge bg-light text-dark">@tin.ViTri</span></td>
                                        <td>@tin.NgayDang.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            @tin.HanNop.ToString("dd/MM/yyyy")
                                            @if (soNgayConLai >= 0 && soNgayConLai <= 7)
                                            {
                                                <br/><small class="text-danger">(@soNgayConLai ngày)</small>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-primary">@tin.SoLuongUngTuyen</span>
                                        </td>
                                        <td>
                                            <span class="badge @badgeClass">@trangThai</span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <a href="@Url.Action("ChiTietTinTuyenDung", "Admin", new { id = tin.MaTinTuyenDung })" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-danger btn-khoa" data-ma="@tin.MaTinTuyenDung" title="Khóa tin">
                                                    <i class="bi bi-lock"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger btn-xoa" data-ma="@tin.MaTinTuyenDung" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="text-center py-5">
                                        <i class="bi bi-inbox" style="font-size: 3rem; color: #cbd5e0;"></i>
                                        <p class="mt-3 text-muted">Không có tin tuyển dụng nào</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Phân trang">
                        <ul class="pagination">
                            @if (Model.PageNumber > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber - 1))">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                                </li>
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                                </li>
                            }

                            @{
                                int startPage = Math.Max(1, Model.PageNumber - 2);
                                int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                            }

                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(1)">1</a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(@i)">@i</a>
                                </li>
                            }

                            @if (endPage < Model.TotalPages)
                            {
                                @if (endPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">@Model.TotalPages</a>
                                </li>
                            }

                            @if (Model.PageNumber < Model.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(@(Model.PageNumber + 1))">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="javascript:void(0)" onclick="goToPage(@Model.TotalPages)">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                                </li>
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                                </li>
                            }
                        </ul>
                        <div class="pagination-info">
                            Hiển thị <strong>@((Model.PageNumber - 1) * Model.PageSize + 1)</strong> - 
                            <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</strong> 
                            trong tổng số <strong>@Model.TotalCount</strong> tin tuyển dụng
                        </div>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-3 mb-3">
        <div class="stats-card primary">
            <h6 class="card-title">
                <i class="bi bi-file-earmark-text"></i> Tổng tin đăng
            </h6>
            <h2 class="text-primary">@Model.TotalCount</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card success">
            <h6 class="card-title">
                <i class="bi bi-check-circle"></i> Đang tuyển
            </h6>
            <h2 class="text-success">@Model.TotalDangTuyen</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card secondary">
            <h6 class="card-title">
                <i class="bi bi-x-circle"></i> Hết hạn
            </h6>
            <h2 class="text-secondary">@Model.TotalHetHan</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card info">
            <h6 class="card-title">
                <i class="bi bi-person-check"></i> Tổng ứng tuyển
            </h6>
            <h2 class="text-info">@Model.TotalUngTuyen</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card warning">
            <h6 class="card-title">
                <i class="bi bi-exclamation-triangle"></i> Sắp hết hạn
            </h6>
            <h2 class="text-warning">@Model.TotalSapHetHan</h2>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card danger">
            <h6 class="card-title">
                <i class="bi bi-graph-up"></i> TB ứng tuyển/tin
            </h6>
            <h2 class="text-danger">@Model.TrungBinhUngTuyen</h2>
        </div>
    </div>
</div>

<!-- Modal Khóa tin -->
<div class="modal fade" id="khoaTinModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-lock me-2"></i>Khóa tin tuyển dụng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn khóa tin tuyển dụng này không?</p>
                <div class="mb-3">
                    <label class="form-label">Lý do khóa:</label>
                    <textarea class="form-control" id="lyDoKhoa" rows="3" placeholder="Nhập lý do khóa tin..."></textarea>
                </div>
                <input type="hidden" id="maTinKhoa">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="btnXacNhanKhoa">
                    <i class="bi bi-lock me-2"></i>Xác nhận khóa
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var isPaginationClick = false;
            
            // Hàm điều hướng đến trang
            window.goToPage = function(pageNumber) {
                isPaginationClick = true;
                $('#pageNumberInput').val(pageNumber);
                $('#searchForm').submit();
            };
            
            // Khi thay đổi filter, reset về trang 1
            $('#locTrangThai, #locNganhNghe').on('change', function() {
                $('#pageNumberInput').val(1);
                $('#searchForm').submit();
            });
            
            // Khi submit form tìm kiếm, reset về trang 1 (chỉ khi không phải là click phân trang)
            $('#searchForm').on('submit', function(e) {
                if (!isPaginationClick) {
                    $('#pageNumberInput').val(1);
                }
                isPaginationClick = false; // Reset flag
            });
            
            // Khi nhấn nút tìm kiếm, reset về trang 1
            $('#searchForm button[type="submit"]').on('click', function() {
                isPaginationClick = false;
            });
            
            // Chọn tất cả
            $('#chonTatCa').on('change', function() {
                $('.chonTin').prop('checked', $(this).prop('checked'));
            });
            
            // Khóa tin
            $('.btn-khoa').on('click', function(e) {
                e.preventDefault();
                var ma = $(this).data('ma');
                $('#maTinKhoa').val(ma);
                $('#lyDoKhoa').val('');
                $('#khoaTinModal').modal('show');
            });
            
            $('#btnXacNhanKhoa').on('click', function() {
                var ma = $('#maTinKhoa').val();
                var lyDo = $('#lyDoKhoa').val();
                if (!lyDo.trim()) {
                    alert('Vui lòng nhập lý do khóa!');
                    return;
                }
                // Gọi API khóa tin
                $.ajax({
                    url: '@Url.Action("KhoaTinTuyenDung", "Admin")',
                    type: 'POST',
                    data: { id: ma, lyDo: lyDo },
                    success: function(response) {
                        if (response.success) {
                            showNotification('Đã khóa tin tuyển dụng thành công!', 'success');
                            $('#khoaTinModal').modal('hide');
                            location.reload();
                        } else {
                            showNotification(response.message || 'Có lỗi xảy ra!', 'error');
                        }
                    },
                    error: function() {
                        showNotification('Có lỗi xảy ra khi khóa tin!', 'error');
                    }
                });
            });
            
            // Xóa tin
            $('.btn-xoa').on('click', function(e) {
                e.preventDefault();
                var row = $(this).closest('tr');
                var jobTitle = row.find('td:eq(2) strong').text();
                var ma = $(this).data('ma');
                
                if (confirm('Bạn có chắc chắn muốn xóa tin tuyển dụng "' + jobTitle + '" không?')) {
                    $.ajax({
                        url: '@Url.Action("XoaTinTuyenDung", "Admin")',
                        type: 'POST',
                        data: { id: ma },
                        success: function(response) {
                            if (response.success) {
                                row.fadeOut(400, function() {
                                    $(this).remove();
                                    showNotification('Đã xóa tin tuyển dụng thành công!', 'success');
                                });
                            } else {
                                showNotification(response.message || 'Có lỗi xảy ra!', 'error');
                            }
                        },
                        error: function() {
                            showNotification('Có lỗi xảy ra khi xóa tin!', 'error');
                        }
                    });
                }
            });
            
            // Show notification function
            function showNotification(message, type) {
                var bgColor = type === 'success' ? '#48bb78' : '#f56565';
                var notification = $('<div>')
                    .css({
                        position: 'fixed',
                        top: '20px',
                        right: '20px',
                        background: bgColor,
                        color: 'white',
                        padding: '15px 25px',
                        borderRadius: '12px',
                        boxShadow: '0 4px 15px rgba(0,0,0,0.2)',
                        zIndex: 9999,
                        fontWeight: '600'
                    })
                    .text(message)
                    .appendTo('body');
                
                setTimeout(function() {
                    notification.fadeOut(400, function() {
                        $(this).remove();
                    });
                }, 3000);
            }
            
            // Animate numbers on load
            $('.stats-card h2').each(function() {
                var $this = $(this);
                var countTo = parseInt($this.text());
                
                $({ countNum: 0 }).animate({
                    countNum: countTo
                }, {
                    duration: 1500,
                    easing: 'swing',
                    step: function() {
                        $this.text(Math.floor(this.countNum));
                    },
                    complete: function() {
                        $this.text(this.countNum);
                    }
                });
            });
        });
    </script>
}
