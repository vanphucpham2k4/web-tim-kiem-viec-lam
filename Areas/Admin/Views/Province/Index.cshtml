                if (confirm('Bạn có chắc chắn muốn xóa tỉnh thành này?')) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Province", new { area = "Admin" })',
                        type: 'POST',
                        data: {
                            code: code,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                alert(response.message);
                                // Reload với tham số hiện tại
                                var search = $('#timKiemInput').val() || '';
                                var pageNumber = $('#pageNumberInput').val() || '1';
                                var url = '@Url.Action("Index", "Province", new { area = "Admin" })' + 
                                         '?pageNumber=' + pageNumber + 
                                         (search ? '&search=' + encodeURIComponent(search) : '');
                                window.location.href = url;
